        "Jb 28:15",
        "Pr 8:10",
        "Pr 8:19",
        "Pr 16:16",
        "Pr 22:1"
      ],
      "footnoteMarkers": []
    },
    {
      "number": 15,
      "textLength": 67,
      "textPreview": "She is more precious than jewels; nothing you desire can equal her.",
      "crossRefLabels": [
        "Jb 28:18",
        "Pr 8:11",
        "Pr 20:15"
      ],
      "footnoteMarkers": []
    },
    {
      "number": 16,
