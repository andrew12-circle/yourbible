        "Jb 11:19",
        "Ps 3:5",
        "Pr 6:22"
      ],
      "footnoteMarkers": [
        1
      ]
    },
    {
      "number": 25,
      "textLength": 65,
      "textPreview": "Don’t fear sudden danger or the ruin of the wicked when it comes,",
      "crossRefLabels": [
        "Jb 5:21",
        "Ps 91:5",
        "1Pt 3:14"
      ],
      "footnoteMarkers": []
    },
    {
