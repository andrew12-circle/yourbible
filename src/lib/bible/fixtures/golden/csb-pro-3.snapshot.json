      "crossRefLabels": [
        "Gl 6:10"
      ],
      "footnoteMarkers": [
        1
      ]
    },
    {
      "number": 28,
      "textLength": 105,
      "textPreview": "Don’t say to your neighbor, “Go away! Come back later. I’ll give it tomorrow” —w",
