      "crossRefLabels": [
        "Pr 6:14",
        "Pr 14:22"
      ],
      "footnoteMarkers": []
    },
    {
      "number": 30,
      "textLength": 64,
      "textPreview": "Don’t accuse anyone without cause, when he has done you no harm.",
      "crossRefLabels": [
        "Pr 24:28",
        "Rm 12:18"
      ],
      "footnoteMarkers": []
    },
    {
      "number": 31,
