      "textLength": 74,
      "textPreview": "for the Lord will be your confidence and will keep your foot from a snare.",
      "crossRefLabels": [
        "1Sm 2:9"
      ],
      "footnoteMarkers": [
        1
      ]
    },
    {
      "number": 27,
      "textLength": 78,
