er":"e"},{"kind":"crossref","label":"Rv 11:17","book":"Rev","chapter":11,"verse":17,"letter":"f"},{"kind":"text","text":" is perfected in weakness.”"},{"kind":"crossref","label":"Is 40:29–31","book":"Isa","chapter":40,"verse":29,"letter":"g"},{"kind":"crossref","label":"1Co 2:5","book":"1Co","chapter":2,"verse":5,"letter":"h"},{"kind":"crossref","label":"Php 4:13","book":"Php","chapter":4,"verse":13,"letter":"i"}],"crossRefs":[{"label":"Mk 5:30","book":"Mrk","chapter":5,"verse":30},{"label":"Lk 1:35","book":"Luk","chapter":1,"verse":35},{"label":"Lk 6:19","book":"Luk","chapter":6,"verse":19},{"label":"Ac 19:11","book":"Act","chapter":19,"verse":11},{"label":"2Co 13:4","book":"2Co","chapter":13,"verse":4},{"label":"Rv 11:17","book":"Rev","chapter":11,"verse":17},{"label":"Is 40:29–31","book":"Isa","chapter":40,"verse":29},{"label":"1Co 2:5","book":"1Co","chapter":2,"verse":5},{"label":"Php 4:13","book":"Php","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:10","parts":[{"kind":"text","text":"So I take pleasure in weaknesses, insults, hardships, persecutions, and in difficulties, for the sake of Christ. "},{"kind":"crossref","label":"Mt 5:11–12","book":"Mat","chapter":5,"verse":11,"letter":"a"},{"kind":"crossref","label":"Rm 5:3","book":"Rom","chapter":5,"verse":3,"letter":"b"},{"kind":"crossref","label":"2Co 13:4","book":"2Co","chapter":13,"verse":4,"letter":"c"},{"kind":"text","text":" For when I am weak, then I am strong. "},{"kind":"crossref","label":"Eph 6:10","book":"Eph","chapter":6,"verse":10,"letter":"d"}],"crossRefs":[{"label":"Mt 5:11–12","book":"Mat","chapter":5,"verse":11},{"label":"Rm 5:3","book":"Rom","chapter":5,"verse":3},{"label":"2Co 13:4","book":"2Co","chapter":13,"verse":4},{"label":"Eph 6:10","book":"Eph","chapter":6,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:11","parts":[{"kind":"text","text":"I have been a fool; you forced it on me. You ought to have commended me, since I am not in any way inferior to those “super-apostles,” even though I am nothing. "},{"kind":"crossref","label":"Gl 6:3","book":"Gal","chapter":6,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gl 6:3","book":"Gal","chapter":6,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:12","parts":[{"kind":"text","text":"The signs "},{"kind":"crossref","label":"Heb 2:4","book":"Heb","chapter":2,"verse":4,"letter":"a"},{"kind":"text","text":" of an apostle "},{"kind":"crossref","label":"Ac 1:2","book":"Act","chapter":1,"verse":2,"letter":"b"},{"kind":"crossref","label":"Jd 1:17","book":"Jud","chapter":1,"verse":17,"letter":"c"},{"kind":"text","text":" were performed with unfailing endurance among you, including signs and wonders "},{"kind":"crossref","label":"Mk 13:22","book":"Mrk","chapter":13,"verse":22,"letter":"d"},{"kind":"text","text":" and miracles. "},{"kind":"crossref","label":"Ac 19:11","book":"Act","chapter":19,"verse":11,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Heb 2:4","book":"Heb","chapter":2,"verse":4},{"label":"Ac 1:2","book":"Act","chapter":1,"verse":2},{"label":"Jd 1:17","book":"Jud","chapter":1,"verse":17},{"label":"Mk 13:22","book":"Mrk","chapter":13,"verse":22},{"label":"Ac 19:11","book":"Act","chapter":19,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:13","parts":[{"kind":"text","text":"So in what way are you worse off than the other churches, except that I personally did not burden you? Forgive me for this wrong!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:14","parts":[{"kind":"text","text":"Look, I am ready to come to you this third time. Ac 18"},{"kind":"crossref","label":"2Co 2:1","book":"2Co","chapter":2,"verse":1,"letter":"a"},{"kind":"crossref","label":"2Co 13:1","book":"2Co","chapter":13,"verse":1,"letter":"b"},{"kind":"text","text":" I will not burden you, since I am not seeking what is yours, but you. For children ought not save up for their parents, but parents for their children. "}],"crossRefs":[{"label":"2Co 2:1","book":"2Co","chapter":2,"verse":1},{"label":"2Co 13:1","book":"2Co","chapter":13,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:15","parts":[{"kind":"text","text":"I will most gladly spend and be spent for you. "},{"kind":"footnote","marker":1,"text":"Lit for your souls, or for your lives"},{"kind":"crossref","label":"2Co 1:6","book":"2Co","chapter":1,"verse":6,"letter":"a"},{"kind":"crossref","label":"Php 2:17","book":"Php","chapter":2,"verse":17,"letter":"b"},{"kind":"crossref","label":"Col 1:24","book":"Col","chapter":1,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Th 2:8","book":"1Th","chapter":2,"verse":8,"letter":"d"},{"kind":"crossref","label":"2Tm 2:10","book":"2Ti","chapter":2,"verse":10,"letter":"e"},{"kind":"text","text":" If I love you more, am I to be loved less? "}],"crossRefs":[{"label":"2Co 1:6","book":"2Co","chapter":1,"verse":6},{"label":"Php 2:17","book":"Php","chapter":2,"verse":17},{"label":"Col 1:24","book":"Col","chapter":1,"verse":24},{"label":"1Th 2:8","book":"1Th","chapter":2,"verse":8},{"label":"2Tm 2:10","book":"2Ti","chapter":2,"verse":10}],"footnotes":[{"marker":1,"text":"Lit for your souls, or for your lives"}]},{"verseId":"a556c5305ee15c3f-01:2Co:12:16","parts":[{"kind":"text","text":"Now granted, I did not burden "},{"kind":"crossref","label":"1Th 2:7","book":"1Th","chapter":2,"verse":7,"letter":"a"},{"kind":"text","text":" you; yet sly as I am, I took you in by deceit! "},{"kind":"crossref","label":"Ps 10:7","book":"Psa","chapter":10,"verse":7,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Th 2:7","book":"1Th","chapter":2,"verse":7},{"label":"Ps 10:7","book":"Psa","chapter":10,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:17","parts":[{"kind":"text","text":"Did I take advantage of you by any of those I sent you? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:18","parts":[{"kind":"text","text":"I urged Titus "},{"kind":"crossref","label":"Ti 1:4","book":"Tit","chapter":1,"verse":4,"letter":"a"},{"kind":"text","text":" to go, and I sent the brother with him. Titus didn’t take advantage of you, did he? Didn’t we walk in the same spirit "},{"kind":"crossref","label":"Ps 51:12","book":"Psa","chapter":51,"verse":12,"letter":"b"},{"kind":"text","text":" and in the same footsteps?"}],"crossRefs":[{"label":"Ti 1:4","book":"Tit","chapter":1,"verse":4},{"label":"Ps 51:12","book":"Psa","chapter":51,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:19","parts":[{"kind":"text","text":"Have you been thinking all along that we were defending ourselves to you? No, in the sight of God we are speaking in Christ, and everything, dear friends, is for building you up. "},{"kind":"crossref","label":"1Co 14:3–4","book":"1Co","chapter":14,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Co 14:3–4","book":"1Co","chapter":14,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:20","parts":[{"kind":"text","text":"For I fear that perhaps when I come I will not find you to be what I want, and you may not find me to be what you want. Perhaps there will be quarreling, "},{"kind":"crossref","label":"Ti 3:9","book":"Tit","chapter":3,"verse":9,"letter":"a"},{"kind":"text","text":" jealousy, "},{"kind":"crossref","label":"Jms 3:14","book":"Jas","chapter":3,"verse":14,"letter":"b"},{"kind":"text","text":" angry outbursts, selfish ambitions, "},{"kind":"crossref","label":"Rm 2:8","book":"Rom","chapter":2,"verse":8,"letter":"c"},{"kind":"text","text":" slander, "},{"kind":"crossref","label":"1Pt 2:1","book":"1Pe","chapter":2,"verse":1,"letter":"d"},{"kind":"text","text":" gossip, arrogance, and disorder. "},{"kind":"crossref","label":"1Co 14:33","book":"1Co","chapter":14,"verse":33,"letter":"e"},{"kind":"crossref","label":"1Co 14:40","book":"1Co","chapter":14,"verse":40,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ti 3:9","book":"Tit","chapter":3,"verse":9},{"label":"Jms 3:14","book":"Jas","chapter":3,"verse":14},{"label":"Rm 2:8","book":"Rom","chapter":2,"verse":8},{"label":"1Pt 2:1","book":"1Pe","chapter":2,"verse":1},{"label":"1Co 14:33","book":"1Co","chapter":14,"verse":33},{"label":"1Co 14:40","book":"1Co","chapter":14,"verse":40}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:12:21","parts":[{"kind":"text","text":"I fear that when I come my God will again "},{"kind":"footnote","marker":1,"text":"Or come again my God will"},{"kind":"text","text":" humiliate me in your presence, and I will grieve for many who sinned before and have not repented "},{"kind":"crossref","label":"Ac 3:19","book":"Act","chapter":3,"verse":19,"letter":"a"},{"kind":"text","text":" of the moral impurity, sexual immorality, "},{"kind":"crossref","label":"1Th 4:3","book":"1Th","chapter":4,"verse":3,"letter":"b"},{"kind":"text","text":" and sensuality "},{"kind":"crossref","label":"Mk 7:21–22","book":"Mrk","chapter":7,"verse":21,"letter":"c"},{"kind":"text","text":" they practiced."}],"crossRefs":[{"label":"Ac 3:19","book":"Act","chapter":3,"verse":19},{"label":"1Th 4:3","book":"1Th","chapter":4,"verse":3},{"label":"Mk 7:21–22","book":"Mrk","chapter":7,"verse":21}],"footnotes":[{"marker":1,"text":"Or come again my God will"}]}]},"cachedAt":1783279664638}