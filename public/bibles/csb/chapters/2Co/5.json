,"label":"Mt 25:31–46","book":"Mat","chapter":25,"verse":31,"letter":"b"},{"kind":"crossref","label":"Php 1:6","book":"Php","chapter":1,"verse":6,"letter":"c"},{"kind":"crossref","label":"Heb 10:31","book":"Heb","chapter":10,"verse":31,"letter":"d"},{"kind":"text","text":" so that each may be repaid "},{"kind":"crossref","label":"Mt 16:27","book":"Mat","chapter":16,"verse":27,"letter":"e"},{"kind":"text","text":" for what he has done in the body, whether good or evil."}],"crossRefs":[{"label":"Jn 5:22–30","book":"Jhn","chapter":5,"verse":22},{"label":"Mt 25:31–46","book":"Mat","chapter":25,"verse":31},{"label":"Php 1:6","book":"Php","chapter":1,"verse":6},{"label":"Heb 10:31","book":"Heb","chapter":10,"verse":31},{"label":"Mt 16:27","book":"Mat","chapter":16,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:11","parts":[{"kind":"text","text":"Therefore, since we know the fear of the Lord, "},{"kind":"crossref","label":"Ps 147:11","book":"Psa","chapter":147,"verse":11,"letter":"a"},{"kind":"crossref","label":"Pr 1:7","book":"Pro","chapter":1,"verse":7,"letter":"b"},{"kind":"crossref","label":"1Pt 1:17","book":"1Pe","chapter":1,"verse":17,"letter":"c"},{"kind":"crossref","label":"Rv 14:7","book":"Rev","chapter":14,"verse":7,"letter":"d"},{"kind":"text","text":" we try to persuade people. What we are is plain to God, and I hope it is also plain to your consciences. "}],"crossRefs":[{"label":"Ps 147:11","book":"Psa","chapter":147,"verse":11},{"label":"Pr 1:7","book":"Pro","chapter":1,"verse":7},{"label":"1Pt 1:17","book":"1Pe","chapter":1,"verse":17},{"label":"Rv 14:7","book":"Rev","chapter":14,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:12","parts":[{"kind":"text","text":"We are not commending ourselves to you again, but giving you an opportunity to be proud of us, so that you may have a reply for those who take pride in outward appearance rather than in the heart. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:13","parts":[{"kind":"text","text":"For if we are out of our mind, "},{"kind":"crossref","label":"Ac 10:45","book":"Act","chapter":10,"verse":45,"letter":"a"},{"kind":"text","text":" it is for God; if we are in our right mind, "},{"kind":"crossref","label":"1Pt 4:7","book":"1Pe","chapter":4,"verse":7,"letter":"b"},{"kind":"text","text":" it is for you. "}],"crossRefs":[{"label":"Ac 10:45","book":"Act","chapter":10,"verse":45},{"label":"1Pt 4:7","book":"1Pe","chapter":4,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:14","parts":[{"kind":"text","text":"For the love of Christ compels us, since we have reached this conclusion, that one died for all, "},{"kind":"crossref","label":"Jn 11:51","book":"Jhn","chapter":11,"verse":51,"letter":"a"},{"kind":"crossref","label":"2Co 4:10","book":"2Co","chapter":4,"verse":10,"letter":"b"},{"kind":"text","text":" and therefore all died. "}],"crossRefs":[{"label":"Jn 11:51","book":"Jhn","chapter":11,"verse":51},{"label":"2Co 4:10","book":"2Co","chapter":4,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:15","parts":[{"kind":"text","text":"And he died for all "},{"kind":"crossref","label":"Lk 20:38","book":"Luk","chapter":20,"verse":38,"letter":"a"},{"kind":"crossref","label":"Heb 2:9","book":"Heb","chapter":2,"verse":9,"letter":"b"},{"kind":"text","text":" so that those who live should no longer live for themselves, "},{"kind":"crossref","label":"Rm 14:7","book":"Rom","chapter":14,"verse":7,"letter":"c"},{"kind":"text","text":" but for the one "},{"kind":"crossref","label":"Lk 20:38","book":"Luk","chapter":20,"verse":38,"letter":"d"},{"kind":"text","text":" who died for them and was raised."}],"crossRefs":[{"label":"Lk 20:38","book":"Luk","chapter":20,"verse":38},{"label":"Heb 2:9","book":"Heb","chapter":2,"verse":9},{"label":"Rm 14:7","book":"Rom","chapter":14,"verse":7},{"label":"Lk 20:38","book":"Luk","chapter":20,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:16","parts":[{"kind":"text","text":"From now on, then, we do not know anyone from a worldly perspective. "},{"kind":"footnote","marker":1,"text":"Lit anyone according to the flesh"},{"kind":"text","text":" Even if we have known Christ from a worldly perspective, "},{"kind":"footnote","marker":2,"text":"Lit Christ according to the flesh"},{"kind":"text","text":" yet now we no longer know him in this way. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit anyone according to the flesh"},{"marker":2,"text":"Lit Christ according to the flesh"}]},{"verseId":"a556c5305ee15c3f-01:2Co:5:17","parts":[{"kind":"text","text":"Therefore, if anyone is in Christ, he is a new creation; "},{"kind":"crossref","label":"Jn 1:3","book":"Jhn","chapter":1,"verse":3,"letter":"a"},{"kind":"crossref","label":"Rv 3:14","book":"Rev","chapter":3,"verse":14,"letter":"b"},{"kind":"text","text":" the old has passed away, and see, "},{"kind":"crossref","label":"Rm 8:24","book":"Rom","chapter":8,"verse":24,"letter":"c"},{"kind":"text","text":" the new has "},{"kind":"footnote","marker":3,"text":"Other mss read look, all new things have"},{"kind":"text","text":" come! "},{"kind":"crossref","label":"Is 43:19","book":"Isa","chapter":43,"verse":19,"letter":"d"},{"kind":"crossref","label":"Is 65:17","book":"Isa","chapter":65,"verse":17,"letter":"e"},{"kind":"crossref","label":"Rm 6:4","book":"Rom","chapter":6,"verse":4,"letter":"f"},{"kind":"crossref","label":"Eph 4:24","book":"Eph","chapter":4,"verse":24,"letter":"g"},{"kind":"crossref","label":"Rv 21:5","book":"Rev","chapter":21,"verse":5,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 1:3","book":"Jhn","chapter":1,"verse":3},{"label":"Rv 3:14","book":"Rev","chapter":3,"verse":14},{"label":"Rm 8:24","book":"Rom","chapter":8,"verse":24},{"label":"Is 43:19","book":"Isa","chapter":43,"verse":19},{"label":"Is 65:17","book":"Isa","chapter":65,"verse":17},{"label":"Rm 6:4","book":"Rom","chapter":6,"verse":4},{"label":"Eph 4:24","book":"Eph","chapter":4,"verse":24},{"label":"Rv 21:5","book":"Rev","chapter":21,"verse":5}],"footnotes":[{"marker":3,"text":"Other mss read look, all new things have"}]},{"verseId":"a556c5305ee15c3f-01:2Co:5:18","parts":[{"kind":"text","text":"Everything is from God, who has reconciled us to himself through Christ and has given us the ministry of reconciliation. "},{"kind":"crossref","label":"Rm 5:11","book":"Rom","chapter":5,"verse":11,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 5:11","book":"Rom","chapter":5,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:19","parts":[{"kind":"text","text":"That is, in Christ, God was reconciling the world "},{"kind":"crossref","label":"2Pt 2:20","book":"2Pe","chapter":2,"verse":20,"letter":"a"},{"kind":"text","text":" to himself, "},{"kind":"crossref","label":"Ti 2:11","book":"Tit","chapter":2,"verse":11,"letter":"b"},{"kind":"text","text":" not counting their trespasses against them, and he has committed the message of reconciliation to us."}],"crossRefs":[{"label":"2Pt 2:20","book":"2Pe","chapter":2,"verse":20},{"label":"Ti 2:11","book":"Tit","chapter":2,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:20","parts":[{"kind":"text","text":"Therefore, we are ambassadors "},{"kind":"crossref","label":"Eph 6:20","book":"Eph","chapter":6,"verse":20,"letter":"a"},{"kind":"text","text":" for Christ, since God is making his appeal through us. We plead on Christ’s behalf, "},{"kind":"crossref","label":"2Co 12:10","book":"2Co","chapter":12,"verse":10,"letter":"b"},{"kind":"crossref","label":"Php 1:29","book":"Php","chapter":1,"verse":29,"letter":"c"},{"kind":"text","text":" “Be reconciled to God.” "}],"crossRefs":[{"label":"Eph 6:20","book":"Eph","chapter":6,"verse":20},{"label":"2Co 12:10","book":"2Co","chapter":12,"verse":10},{"label":"Php 1:29","book":"Php","chapter":1,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:5:21","parts":[{"kind":"text","text":"He made the one 