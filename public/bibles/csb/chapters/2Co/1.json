crossref","label":"Mt 5:16","book":"Mat","chapter":5,"verse":16,"letter":"e"},{"kind":"crossref","label":"Mt 11:27","book":"Mat","chapter":11,"verse":27,"letter":"f"},{"kind":"crossref","label":"Lk 11:13","book":"Luk","chapter":11,"verse":13,"letter":"g"},{"kind":"crossref","label":"Jn 8:42","book":"Jhn","chapter":8,"verse":42,"letter":"h"},{"kind":"crossref","label":"Eph 5:20","book":"Eph","chapter":5,"verse":20,"letter":"i"},{"kind":"text","text":" and the Lord Jesus Christ."}],"crossRefs":[{"label":"Lk 12:51","book":"Luk","chapter":12,"verse":51},{"label":"Rm 1:7","book":"Rom","chapter":1,"verse":7},{"label":"2Tm 1:2","book":"2Ti","chapter":1,"verse":2},{"label":"3Jn 14","book":"3Jn","chapter":1,"verse":14},{"label":"Mt 5:16","book":"Mat","chapter":5,"verse":16},{"label":"Mt 11:27","book":"Mat","chapter":11,"verse":27},{"label":"Lk 11:13","book":"Luk","chapter":11,"verse":13},{"label":"Jn 8:42","book":"Jhn","chapter":8,"verse":42},{"label":"Eph 5:20","book":"Eph","chapter":5,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:3","parts":[{"kind":"text","text":"Blessed be "},{"kind":"crossref","label":"Mk 14:61","book":"Mrk","chapter":14,"verse":61,"letter":"a"},{"kind":"text","text":" the God and Father of our Lord Jesus Christ, the Father of mercies "},{"kind":"crossref","label":"Heb 10:28","book":"Heb","chapter":10,"verse":28,"letter":"b"},{"kind":"text","text":" and the God of all comfort. "},{"kind":"crossref","label":"Lk 2:25","book":"Luk","chapter":2,"verse":25,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 14:61","book":"Mrk","chapter":14,"verse":61},{"label":"Heb 10:28","book":"Heb","chapter":10,"verse":28},{"label":"Lk 2:25","book":"Luk","chapter":2,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:4","parts":[{"kind":"text","text":"He comforts us in all our affliction, "},{"kind":"footnote","marker":1,"text":"Or trouble, or tribulation, or trials, or oppression"},{"kind":"text","text":" so that we may be able to comfort those who are in any kind of affliction, through the comfort we ourselves receive from God. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or trouble, or tribulation, or trials, or oppression"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:5","parts":[{"kind":"text","text":"For just as the sufferings "},{"kind":"crossref","label":"Gl 5:24","book":"Gal","chapter":5,"verse":24,"letter":"a"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"b"},{"kind":"text","text":" of Christ "},{"kind":"crossref","label":"Rm 8:17","book":"Rom","chapter":8,"verse":17,"letter":"c"},{"kind":"crossref","label":"2Co 4:10","book":"2Co","chapter":4,"verse":10,"letter":"d"},{"kind":"crossref","label":"Gl 6:17","book":"Gal","chapter":6,"verse":17,"letter":"e"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"f"},{"kind":"crossref","label":"Col 1:24","book":"Col","chapter":1,"verse":24,"letter":"g"},{"kind":"text","text":" overflow to us, so also through Christ our comfort overflows. "},{"kind":"crossref","label":"Php 1:29","book":"Php","chapter":1,"verse":29,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gl 5:24","book":"Gal","chapter":5,"verse":24},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10},{"label":"Rm 8:17","book":"Rom","chapter":8,"verse":17},{"label":"2Co 4:10","book":"2Co","chapter":4,"verse":10},{"label":"Gl 6:17","book":"Gal","chapter":6,"verse":17},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10},{"label":"Col 1:24","book":"Col","chapter":1,"verse":24},{"label":"Php 1:29","book":"Php","chapter":1,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:6","parts":[{"kind":"text","text":"If we are afflicted, "},{"kind":"crossref","label":"Heb 11:37","book":"Heb","chapter":11,"verse":37,"letter":"a"},{"kind":"text","text":" it is for your comfort and salvation. If we are comforted, it is for your comfort, which produces in you patient endurance of the same sufferings that we suffer. "},{"kind":"crossref","label":"Php 1:29","book":"Php","chapter":1,"verse":29,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Heb 11:37","book":"Heb","chapter":11,"verse":37},{"label":"Php 1:29","book":"Php","chapter":1,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:7","parts":[{"kind":"text","text":"And our hope "},{"kind":"crossref","label":"1Th 1:3","book":"1Th","chapter":1,"verse":3,"letter":"a"},{"kind":"text","text":" for you is firm, because we know that as you share "},{"kind":"crossref","label":"Phm 17","book":"Phm","chapter":1,"verse":17,"letter":"b"},{"kind":"text","text":" in the sufferings, so you will also share in the comfort."}],"crossRefs":[{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3},{"label":"Phm 17","book":"Phm","chapter":1,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:8","parts":[{"kind":"text","text":"We don’t want you to be unaware, brothers and sisters, of our affliction that took place in Asia. "},{"kind":"crossref","label":"Ac 6:9","book":"Act","chapter":6,"verse":9,"letter":"a"},{"kind":"text","text":" We were completely overwhelmed —beyond our strength "},{"kind":"crossref","label":"Ac 8:10","book":"Act","chapter":8,"verse":10,"letter":"b"},{"kind":"crossref","label":"1Co 15:24","book":"1Co","chapter":15,"verse":24,"letter":"c"},{"kind":"crossref","label":"Eph 1:21","book":"Eph","chapter":1,"verse":21,"letter":"d"},{"kind":"crossref","label":"1Pt 3:22","book":"1Pe","chapter":3,"verse":22,"letter":"e"},{"kind":"text","text":" —so that we even despaired "},{"kind":"crossref","label":"2Co 4:8","book":"2Co","chapter":4,"verse":8,"letter":"f"},{"kind":"text","text":" of life itself. "}],"crossRefs":[{"label":"Ac 6:9","book":"Act","chapter":6,"verse":9},{"label":"Ac 8:10","book":"Act","chapter":8,"verse":10},{"label":"1Co 15:24","book":"1Co","chapter":15,"verse":24},{"label":"Eph 1:21","book":"Eph","chapter":1,"verse":21},{"label":"1Pt 3:22","book":"1Pe","chapter":3,"verse":22},{"label":"2Co 4:8","book":"2Co","chapter":4,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:9","parts":[{"kind":"text","text":"Indeed, we felt that we had received the sentence of death, so that we would not trust in ourselves but in God "},{"kind":"crossref","label":"Ps 25:2","book":"Psa","chapter":25,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 26:1","book":"Psa","chapter":26,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jr 17:5–7","book":"Jer","chapter":17,"verse":5,"letter":"c"},{"kind":"crossref","label":"Lk 18:9","book":"Luk","chapter":18,"verse":9,"letter":"d"},{"kind":"text","text":" who raises "},{"kind":"crossref","label":"Mk 9:27","book":"Mrk","chapter":9,"verse":27,"letter":"e"},{"kind":"crossref","label":"Jn 2:19","book":"Jhn","chapter":2,"verse":19,"letter":"f"},{"kind":"text","text":" the dead. "}],"crossRefs":[{"label":"Ps 25:2","book":"Psa","chapter":25,"verse":2},{"label":"Ps 26:1","book":"Psa","chapter":26,"verse":1},{"label":"Jr 17:5–7","book":"Jer","chapter":17,"verse":5},{"label":"Lk 18:9","book":"Luk","chapter":18,"verse":9},{"label":"Mk 9:27","book":"Mrk","chapter":9,"verse":27},{"label":"Jn 2:19","book":"Jhn","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:10","parts":[{"kind":"text","text":"He has delivered "},{"kind":"crossref","label":"Mt 27:43","book":"Mat","chapter":27,"verse":43,"letter":"a"},{"kind":"text","text":" us from such a terrible death, "},{"kind":"crossref","label":"Mt 10:21","book":"Mat","chapter":10,"verse":21,"letter":"b"},{"kind":"crossref","label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51,"letter":"c"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"d"},{"kind":"text","text":" and he will deliver us. We have put our hope in him that he will deliver us again "}],"crossRefs":[{"label":"Mt 27:43","book":"Mat","chapter":27,"verse":43},{"label":"Mt 10:21","book":"Mat","chapter":10,"verse":21},{"label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:11","parts":[{"kind":"text","text":"while you join in helping us by your prayers. Then many will give thanks on our "},{"kind":"footnote","marker":1,"text":"Other mss read your"},{"kind":"text","text":" behalf for the gift that came to us through the prayers of many."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss read your"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:12","parts":[{"kind":"text","text":"Indeed, this is our boast: The testimony "},{"kind":"crossref","label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6,"letter":"a"},{"kind":"text","text":" of our conscience "},{"kind":"crossref","label":"Heb 13:18","book":"Heb","chapter":13,"verse":18,"letter":"b"},{"kind":"text","text":" is that we have conducted ourselves in the world, and especially toward you, with godly sincerity and purity, not by human wisdom "},{"kind":"crossref","label":"Pr 3:19","book":"Pro","chapter":3,"verse":19,"letter":"c"},{"kind":"crossref","label":"1Co 1:21","book":"1Co","chapter":1,"verse":21,"letter":"d"},{"kind":"text","text":" but by God’s grace. "},{"kind":"crossref","label":"Ac 23:1","book":"Act","chapter":23,"verse":1,"letter":"e"},{"kind":"crossref","label":"2Co 4:2","book":"2Co","chapter":4,"verse":2,"letter":"f"},{"kind":"crossref","label":"2Co 5:12","book":"2Co","chapter":5,"verse":12,"letter":"g"},{"kind":"crossref","label":"1Th 2:10","book":"1Th","chapter":2,"verse":10,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6},{"label":"Heb 13:18","book":"Heb","chapter":13,"verse":18},{"label":"Pr 3:19","book":"Pro","chapter":3,"verse":19},{"label":"1Co 1:21","book":"1Co","chapter":1,"verse":21},{"label":"Ac 23:1","book":"Act","chapter":23,"verse":1},{"label":"2Co 4:2","book":"2Co","chapter":4,"verse":2},{"label":"2Co 5:12","book":"2Co","chapter":5,"verse":12},{"label":"1Th 2:10","book":"1Th","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:13","parts":[{"kind":"text","text":"For we are writing nothing to you other than what you can read and also understand. I hope you will understand completely — "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:14","parts":[{"kind":"text","text":"just as you have partially understood us —that we are your reason for pride, "},{"kind":"crossref","label":"Rm 2:17","book":"Rom","chapter":2,"verse":17,"letter":"a"},{"kind":"crossref","label":"Gl 6:4","book":"Gal","chapter":6,"verse":4,"letter":"b"},{"kind":"text","text":" just as you also are ours "},{"kind":"crossref","label":"2Co 9:3","book":"2Co","chapter":9,"verse":3,"letter":"c"},{"kind":"crossref","label":"Php 2:16","book":"Php","chapter":2,"verse":16,"letter":"d"},{"kind":"crossref","label":"Php 4:1","book":"Php","chapter":4,"verse":1,"letter":"e"},{"kind":"crossref","label":"1Th 2:19–20","book":"1Th","chapter":2,"verse":19,"letter":"f"},{"kind":"text","text":" in the day of our "},{"kind":"footnote","marker":1,"text":"Other mss omit our"},{"kind":"text","text":" Lord Jesus. "},{"kind":"crossref","label":"Php 1:6","book":"Php","chapter":1,"verse":6,"letter":"g"}],"crossRefs":[{"label":"Rm 2:17","book":"Rom","chapter":2,"verse":17},{"label":"Gl 6:4","book":"Gal","chapter":6,"verse":4},{"label":"2Co 9:3","book":"2Co","chapter":9,"verse":3},{"label":"Php 2:16","book":"Php","chapter":2,"verse":16},{"label":"Php 4:1","book":"Php","chapter":4,"verse":1},{"label":"1Th 2:19–20","book":"1Th","chapter":2,"verse":19},{"label":"Php 1:6","book":"Php","chapter":1,"verse":6}],"footnotes":[{"marker":1,"text":"Other mss omit our"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:15","parts":[{"kind":"text","text":"Because of this confidence, I planned to come to you first, "},{"kind":"crossref","label":"Ac 18:1–18","book":"Act","chapter":18,"verse":1,"letter":"a"},{"kind":"crossref","label":"1Co 4:19","book":"1Co","chapter":4,"verse":19,"letter":"b"},{"kind":"text","text":" so that you could have a second benefit, "},{"kind":"footnote","marker":1,"text":"Other mss read a second joy"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 18:1–18","book":"Act","chapter":18,"verse":1},{"label":"1Co 4:19","book":"1Co","chapter":4,"verse":19}],"footnotes":[{"marker":1,"text":"Other mss read a second joy"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:16","parts":[{"kind":"text","text":"and to visit you on my way to Macedonia, "},{"kind":"crossref","label":"Ac 16:9","book":"Act","chapter":16,"verse":9,"letter":"a"},{"kind":"text","text":" and then come to you again from Macedonia and be helped by you "},{"kind":"crossref","label":"Ac 20:38","book":"Act","chapter":20,"verse":38,"letter":"b"},{"kind":"text","text":" on my journey "},{"kind":"crossref","label":"Ac 19:21","book":"Act","chapter":19,"verse":21,"letter":"c"},{"kind":"crossref","label":"1Co 16:5–7","book":"1Co","chapter":16,"verse":5,"letter":"d"},{"kind":"text","text":" to Judea. "},{"kind":"crossref","label":"Lk 1:5","book":"Luk","chapter":1,"verse":5,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 16:9","book":"Act","chapter":16,"verse":9},{"label":"Ac 20:38","book":"Act","chapter":20,"verse":38},{"label":"Ac 19:21","book":"Act","chapter":19,"verse":21},{"label":"1Co 16:5–7","book":"1Co","chapter":16,"verse":5},{"label":"Lk 1:5","book":"Luk","chapter":1,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:17","parts":[{"kind":"text","text":"Now when I planned this, was I of two minds? Or what I plan, do I plan in a purely human "},{"kind":"footnote","marker":2,"text":"Or a worldly, or a fleshly, or a selfish"},{"kind":"crossref","label":"Php 3:3","book":"Php","chapter":3,"verse":3,"letter":"a"},{"kind":"crossref","label":"Col 3:22","book":"Col","chapter":3,"verse":22,"letter":"b"},{"kind":"text","text":" way so that I say “Yes, yes” and “No, no” at the same time? "}],"crossRefs":[{"label":"Php 3:3","book":"Php","chapter":3,"verse":3},{"label":"Col 3:22","book":"Col","chapter":3,"verse":22}],"footnotes":[{"marker":2,"text":"Or a worldly, or a fleshly, or a selfish"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:18","parts":[{"kind":"text","text":"As God is faithful, "},{"kind":"crossref","label":"Nm 23:19","book":"Num","chapter":23,"verse":19,"letter":"a"},{"kind":"text","text":" our message to you is not “Yes and no.” "}],"crossRefs":[{"label":"Nm 23:19","book":"Num","chapter":23,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:19","parts":[{"kind":"text","text":"For the Son of God, "},{"kind":"crossref","label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19,"letter":"a"},{"kind":"crossref","label":"Heb 1:2","book":"Heb","chapter":1,"verse":2,"letter":"b"},{"kind":"text","text":" Jesus Christ, whom we proclaimed among you —Silvanus, "},{"kind":"footnote","marker":3,"text":"Or Silas; Ac 15:22–32; 16:19–40; 17:1–16"},{"kind":"crossref","label":"1Th 1:1","book":"1Th","chapter":1,"verse":1,"letter":"c"},{"kind":"text","text":" Timothy, and I —did not become “Yes and no.” On the contrary, in him it is always “Yes.” "},{"kind":"crossref","label":"Heb 13:8","book":"Heb","chapter":13,"verse":8,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19},{"label":"Heb 1:2","book":"Heb","chapter":1,"verse":2},{"label":"1Th 1:1","book":"1Th","chapter":1,"verse":1},{"label":"Heb 13:8","book":"Heb","chapter":13,"verse":8}],"footnotes":[{"marker":3,"text":"Or Silas; Ac 15:22–32; 16:19–40; 17:1–16"}]},{"verseId":"a556c5305ee15c3f-01:2Co:1:20","parts":[{"kind":"text","text":"For every one of God’s promises "},{"kind":"crossref","label":"Gn 12:7","book":"Gen","chapter":12,"verse":7,"letter":"a"},{"kind":"text","text":" is “Yes” in him. Therefore, through him we also say “Amen” "},{"kind":"crossref","label":"Ps 72:19","book":"Psa","chapter":72,"verse":19,"letter":"b"},{"kind":"crossref","label":"Rv 22:21","book":"Rev","chapter":22,"verse":21,"letter":"c"},{"kind":"text","text":" to the glory of God. "},{"kind":"crossref","label":"Mk 10:37","book":"Mrk","chapter":10,"verse":37,"letter":"d"},{"kind":"crossref","label":"Lk 9:32","book":"Luk","chapter":9,"verse":32,"letter":"e"},{"kind":"crossref","label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24,"letter":"f"},{"kind":"crossref","label":"2Co 3:18","book":"2Co","chapter":3,"verse":18,"letter":"g"},{"kind":"crossref","label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 12:7","book":"Gen","chapter":12,"verse":7},{"label":"Ps 72:19","book":"Psa","chapter":72,"verse":19},{"label":"Rv 22:21","book":"Rev","chapter":22,"verse":21},{"label":"Mk 10:37","book":"Mrk","chapter":10,"verse":37},{"label":"Lk 9:32","book":"Luk","chapter":9,"verse":32},{"label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24},{"label":"2Co 3:18","book":"2Co","chapter":3,"verse":18},{"label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:21","parts":[{"kind":"text","text":"Now it is God who strengthens us together with you in Christ, and who has anointed "},{"kind":"crossref","label":"Lk 4:18","book":"Luk","chapter":4,"verse":18,"letter":"a"},{"kind":"crossref","label":"1Jn 2:20","book":"1Jn","chapter":2,"verse":20,"letter":"b"},{"kind":"text","text":" us. "}],"crossRefs":[{"label":"Lk 4:18","book":"Luk","chapter":4,"verse":18},{"label":"1Jn 2:20","book":"1Jn","chapter":2,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:22","parts":[{"kind":"text","text":"He has also put his seal on us and given us the Spirit in our hearts "},{"kind":"crossref","label":"Jms 4:5","book":"Jas","chapter":4,"verse":5,"letter":"a"},{"kind":"text","text":" as a down payment. "},{"kind":"crossref","label":"Eph 1:14","book":"Eph","chapter":1,"verse":14,"letter":"b"}],"crossRefs":[{"label":"Jms 4:5","book":"Jas","chapter":4,"verse":5},{"label":"Eph 1:14","book":"Eph","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:23","parts":[{"kind":"text","text":"I call on God as a witness, "},{"kind":"crossref","label":"Rm 1:9","book":"Rom","chapter":1,"verse":9,"letter":"a"},{"kind":"crossref","label":"Php 1:8","book":"Php","chapter":1,"verse":8,"letter":"b"},{"kind":"crossref","label":"Heb 12:1","book":"Heb","chapter":12,"verse":1,"letter":"c"},{"kind":"text","text":" on my life, that it was to spare you that I did not come to Corinth. "},{"kind":"crossref","label":"1Co 4:21","book":"1Co","chapter":4,"verse":21,"letter":"d"},{"kind":"crossref","label":"2Co 13:2","book":"2Co","chapter":13,"verse":2,"letter":"e"},{"kind":"crossref","label":"2Co 13:10","book":"2Co","chapter":13,"verse":10,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 1:9","book":"Rom","chapter":1,"verse":9},{"label":"Php 1:8","book":"Php","chapter":1,"verse":8},{"label":"Heb 12:1","book":"Heb","chapter":12,"verse":1},{"label":"1Co 4:21","book":"1Co","chapter":4,"verse":21},{"label":"2Co 13:2","book":"2Co","chapter":13,"verse":2},{"label":"2Co 13:10","book":"2Co","chapter":13,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:1:24","parts":[{"kind":"text","text":"I do not mean that we lord it over your faith, but we are workers with you for your joy, because you stand firm in your "},{"kind":"crossref","label":"Pr 24:16","book":"Pro","chapter":24,"verse":16,"letter":"a"},{"kind":"text","text":" faith."}],"crossRefs":[{"label":"Pr 24:16","book":"Pro","chapter":24,"verse":16}],"footnotes":[]}]},"cachedAt":1783279661513}