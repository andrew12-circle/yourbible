,"chapter":25,"verse":5}],"footnotes":[{"marker":2,"text":"Or become complete, or be restored"}]},{"verseId":"a556c5305ee15c3f-01:2Co:13:10","parts":[{"kind":"text","text":"This is why I am writing these things while absent, so that when I am there I may not have to deal harshly with you, in keeping with the authority the Lord gave me for building up "},{"kind":"crossref","label":"1Co 14:3","book":"1Co","chapter":14,"verse":3,"letter":"a"},{"kind":"text","text":" and not for tearing down. "},{"kind":"crossref","label":"2Co 10:4","book":"2Co","chapter":10,"verse":4,"letter":"b"},{"kind":"crossref","label":"2Co 10:8","book":"2Co","chapter":10,"verse":8,"letter":"c"}],"crossRefs":[{"label":"1Co 14:3","book":"1Co","chapter":14,"verse":3},{"label":"2Co 10:4","book":"2Co","chapter":10,"verse":4},{"label":"2Co 10:8","book":"2Co","chapter":10,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Co:13:11","parts":[{"kind":"text","text":"Finally, brothers and sisters, rejoice. "},{"kind":"footnote","marker":1,"text":"Or farewell"},{"kind":"text","text":" Become mature, be encouraged, "},{"kind":"footnote","marker":2,"text":"Or listen to my appeal"},{"kind":"text","text":" be of the same mind, "},{"kind":"crossref","label":"Rm 12:16","book":"Rom","chapter":12,"verse":16,"letter":"a"},{"kind":"crossref","label":"Php 1:7","book":"Php","chapter":1,"verse":7,"letter":"b"},{"kind":"text","text":" be at peace, "},{"kind":"crossref","label":"Mk 9:50","book":"Mrk","chapter":9,"verse":50,"letter":"c"},{"kind":"crossref","label":"Rm 16:20","book":"Rom","chapter":16,"verse":20,"letter":"d"},{"kind":"crossref","label":"2Tm 1:2","book":"2Ti","chapter":1,"verse":2,"letter":"e"},{"kind":"text","text":" and the God of love "},{"kind":"crossref","label":"1Jn 4:16","book":"1Jn","chapter":4,"verse":16,"letter":"f"},{"kind":"text","text":" and peace will be with you. "}],"crossRefs":[{"label":"Rm 12:16","book":"Rom","chapter":12,"verse":16},{"label":"Php 1:7","book":"Php","chapter":1,"ver