,"verse":13,"letter":"a"},{"kind":"text","text":" of this mystery, "},{"kind":"crossref","label":"Mt 13:11","book":"Mat","chapter":13,"verse":11,"letter":"b"},{"kind":"crossref","label":"Rm 16:25","book":"Rom","chapter":16,"verse":25,"letter":"c"},{"kind":"crossref","label":"1Co 2:7–10","book":"1Co","chapter":2,"verse":7,"letter":"d"},{"kind":"crossref","label":"Eph 3:3–5","book":"Eph","chapter":3,"verse":3,"letter":"e"},{"kind":"crossref","label":"Eph 3:9","book":"Eph","chapter":3,"verse":9,"letter":"f"},{"kind":"text","text":" brothers and sisters, so that you will not be conceited: "},{"kind":"crossref","label":"Rm 12:16","book":"Rom","chapter":12,"verse":16,"letter":"g"},{"kind":"text","text":" A partial hardening has come upon Israel "},{"kind":"crossref","label":"Rm 11:7","book":"Rom","chapter":11,"verse":7,"letter":"h"},{"kind":"text","text":" until the fullness of the Gentiles has come in. "},{"kind":"crossref","label":"Lk 21:24","book":"Luk","chapter":21,"verse":24,"letter":"i"},{"kind":"crossref","label":"Jn 10:16","book":"Jhn","chapter":10,"verse":16,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 1:13","book":"Rom","chapter":1,"verse":13},{"label":"Mt 13:11","book":"Mat","chapter":13,"verse":11},{"label":"Rm 16:25","book":"Rom","chapter":16,"verse":25},{"label":"1Co 2:7–10","book":"1Co","chapter":2,"verse":7},{"label":"Eph 3:3–5","book":"Eph","chapter":3,"verse":3},{"label":"Eph 3:9","book":"Eph","chapter":3,"verse":9},{"label":"Rm 12:16","book":"Rom","chapter":12,"verse":16},{"label":"Rm 11:7","book":"Rom","chapter":11,"verse":7},{"label":"Lk 21:24","book":"Luk","chapter":21,"verse":24},{"label":"Jn 10:16","book":"Jhn","chapter":10,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:11:26","parts":[{"kind":"text","text":"And in this way all "},{"kind":"footnote","marker":1,"text":"Or And then all"},{"kind":"text","text":" Israel will be saved, as it is written,"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or And th