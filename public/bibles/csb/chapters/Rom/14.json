:14,"verse":2},{"label":"Rm 14:20","book":"Rom","chapter":14,"verse":20},{"label":"1Co 8:7","book":"1Co","chapter":8,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:15","parts":[{"kind":"text","text":"For if your brother or sister is hurt by what you eat, you are no longer walking according to love. "},{"kind":"crossref","label":"Eph 5:2","book":"Eph","chapter":5,"verse":2,"letter":"a"},{"kind":"text","text":" Do not destroy, by what you eat, someone for whom Christ died. "},{"kind":"crossref","label":"1Co 8:11","book":"1Co","chapter":8,"verse":11,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Eph 5:2","book":"Eph","chapter":5,"verse":2},{"label":"1Co 8:11","book":"1Co","chapter":8,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:16","parts":[{"kind":"text","text":"Therefore, do not let your good be slandered, "},{"kind":"crossref","label":"1Co 10:30","book":"1Co","chapter":10,"verse":30,"letter":"a"},{"kind":"crossref","label":"Ti 2:5","book":"Tit","chapter":2,"verse":5,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Co 10:30","book":"1Co","chapter":10,"verse":30},{"label":"Ti 2:5","book":"Tit","chapter":2,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:17","parts":[{"kind":"text","text":"for the kingdom of God is not eating and drinking, "},{"kind":"crossref","label":"1Co 8:8","book":"1Co","chapter":8,"verse":8,"letter":"a"},{"kind":"text","text":" but righteousness, peace, and joy "},{"kind":"crossref","label":"Rm 15:13","book":"Rom","chapter":15,"verse":13,"letter":"b"},{"kind":"crossref","label":"Gl 5:22","book":"Gal","chapter":5,"verse":22,"letter":"c"},{"kind":"text","text":" in the Holy Spirit. "}],"crossRefs":[{"label":"1Co 8:8","book":"1Co","chapter":8,"verse":8},{"label":"Rm 15:13","book":"Rom","chapter":15,"verse":13},{"label":"Gl 5:22","book":"Gal","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:18","parts":[{"kind":"text","text":"Whoever serves Christ "},{"kind":"crossref","label":"Rm 16:18","book":"Rom","chapter":16,"verse":18,"letter":"a"},{"kind":"text","text":" in this way is acceptable to God and receives human approval. "},{"kind":"crossref","label":"2Co 8:21","book":"2Co","chapter":8,"verse":21,"letter":"b"},{"kind":"crossref","label":"Php 4:8","book":"Php","chapter":4,"verse":8,"letter":"c"},{"kind":"crossref","label":"1Pt 2:12","book":"1Pe","chapter":2,"verse":12,"letter":"d"}],"crossRefs":[{"label":"Rm 16:18","book":"Rom","chapter":16,"verse":18},{"label":"2Co 8:21","book":"2Co","chapter":8,"verse":21},{"label":"Php 4:8","book":"Php","chapter":4,"verse":8},{"label":"1Pt 2:12","book":"1Pe","chapter":2,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:19","parts":[{"kind":"text","text":"So then, let us pursue what promotes peace "},{"kind":"crossref","label":"Ps 34:14","book":"Psa","chapter":34,"verse":14,"letter":"a"},{"kind":"crossref","label":"Rm 12:18","book":"Rom","chapter":12,"verse":18,"letter":"b"},{"kind":"crossref","label":"1Co 7:15","book":"1Co","chapter":7,"verse":15,"letter":"c"},{"kind":"crossref","label":"2Tm 2:22","book":"2Ti","chapter":2,"verse":22,"letter":"d"},{"kind":"crossref","label":"Heb 12:14","book":"Heb","chapter":12,"verse":14,"letter":"e"},{"kind":"text","text":" and what builds up one another. "},{"kind":"crossref","label":"Rm 15:2","book":"Rom","chapter":15,"verse":2,"letter":"f"},{"kind":"crossref","label":"1Co 10:23","book":"1Co","chapter":10,"verse":23,"letter":"g"},{"kind":"crossref","label":"1Co 14:3","book":"1Co","chapter":14,"verse":3,"letter":"h"},{"kind":"crossref","label":"1Co 14:26","book":"1Co","chapter":14,"verse":26,"letter":"i"},{"kind":"crossref","label":"2Co 12:19","book":"2Co","chapter":12,"verse":19,"letter":"j"},{"kind":"crossref","label":"Eph 4:12","book":"Eph","chapter":4,"verse":12,"letter":"k"},{"kind":"crossref","label":"Eph 4:29","book":"Eph","chapter":4,"verse":29,"letter":"l"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 34:14","book":"Psa","chapter":34,"verse":14},{"label":"Rm 12:18","book":"Rom","chapter":12,"verse":18},{"label":"1Co 7:15","book":"1Co","chapter":7,"verse":15},{"label":"2Tm 2:22","book":"2Ti","chapter":2,"verse":22},{"label":"Heb 12:14","book":"Heb","chapter":12,"verse":14},{"label":"Rm 15:2","book":"Rom","chapter":15,"verse":2},{"label":"1Co 10:23","book":"1Co","chapter":10,"verse":23},{"label":"1Co 14:3","book":"1Co","chapter":14,"verse":3},{"label":"1Co 14:26","book":"1Co","chapter":14,"verse":26},{"label":"2Co 12:19","book":"2Co","chapter":12,"verse":19},{"label":"Eph 4:12","book":"Eph","chapter":4,"verse":12},{"label":"Eph 4:29","book":"Eph","chapter":4,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:20","parts":[{"kind":"text","text":"Do not tear down God’s work because of food. Everything is clean, but it is wrong to make someone fall by what he eats. "},{"kind":"crossref","label":"1Co 8:9–13","book":"1Co","chapter":8,"verse":9,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Co 8:9–13","book":"1Co","chapter":8,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:21","parts":[{"kind":"text","text":"It is a good thing not to eat meat, or drink wine, or do anything that makes your brother or sister stumble. "},{"kind":"footnote","marker":1,"text":"Other mss add or offended or weakened"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss add or offended or weakened"}]},{"verseId":"a556c5305ee15c3f-01:Rom:14:22","parts":[{"kind":"text","text":"Whatever you believe about these things, keep between yourself and God. Blessed is the one who does not condemn himself by what he approves. "},{"kind":"crossref","label":"1Jn 3:21","book":"1Jn","chapter":3,"verse":21,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Jn 3:21","book":"1Jn","chapter":3,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:14:23","parts":[{"kind":"text","text":"But whoever doubts stands condemned if he eats, "},{"kind":"crossref","label":"Rm 14:5","book":"Rom","chapter":14,"verse":5,"letter":"a"},{"kind":"text","text":" because his eating is not from faith, "},{"kind":"footnote","marker":2,"text":"Or conviction"},{"kind":"text","text":" and everything that is not from faith is sin."}],"crossRefs":[{"label":"Rm 14:5","book":"Rom","chapter":14,"verse":5}],"footnotes":[{"marker":2,"text":"Or conviction"}]}]},"cachedAt":1783279655812}