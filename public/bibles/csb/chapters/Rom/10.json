:"text","text":"But not all obeyed the gospel. "},{"kind":"crossref","label":"Rm 3:3","book":"Rom","chapter":3,"verse":3,"letter":"a"},{"kind":"text","text":" For Isaiah says, Lord, who has believed our message?"},{"kind":"crossref","label":"Is 53:1","book":"Isa","chapter":53,"verse":1,"letter":"b"},{"kind":"crossref","label":"Is 53:1","book":"Isa","chapter":53,"verse":1,"letter":"c"},{"kind":"crossref","label":"Jn 12:38","book":"Jhn","chapter":12,"verse":38,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 3:3","book":"Rom","chapter":3,"verse":3},{"label":"Is 53:1","book":"Isa","chapter":53,"verse":1},{"label":"Is 53:1","book":"Isa","chapter":53,"verse":1},{"label":"Jn 12:38","book":"Jhn","chapter":12,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:10:17","parts":[{"kind":"text","text":"So faith comes from what is heard, "},{"kind":"crossref","label":"Gl 3:2","book":"Gal","chapter":3,"verse":2,"letter":"a"},{"kind":"crossref","label":"Gl 3:5","book":"Gal","chapter":3,"verse":5,"letter":"b"},{"kind":"text","text":" and what is heard comes through the message about Christ. "},{"kind":"footnote","marker":2,"text":"Other mss read God"},{"kind":"crossref","label":"Col 3:16","book":"Col","chapter":3,"verse":16,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gl 3:2","book":"Gal","chapter":3,"verse":2},{"label":"Gl 3:5","book":"Gal","chapter":3,"verse":5},{"label":"Col 3:16","book":"Col","chapter":3,"verse":16}],"footnotes":[{"marker":2,"text":"Other mss read God"}]},{"verseId":"a556c5305ee15c3f-01:Rom:10:18","parts":[{"kind":"text","text":"But I ask, “Did they not hear?” Yes, they did:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:10:19","parts":[{"kind":"text","text":"But I ask, “Did Israel not understand?” First, Moses said,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:10:20","parts":[{"kind":"text","text":"And Isaiah says boldly,"}],"crossRefs":[],"footnotes":[]},{"vers