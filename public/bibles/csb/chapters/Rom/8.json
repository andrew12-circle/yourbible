14,"verse":31,"letter":"k"},{"kind":"crossref","label":"Is 53:10","book":"Isa","chapter":53,"verse":10,"letter":"l"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 13:39","book":"Act","chapter":13,"verse":39},{"label":"Heb 10:1–2","book":"Heb","chapter":10,"verse":1},{"label":"Rm 7:18","book":"Rom","chapter":7,"verse":18},{"label":"Heb 7:18","book":"Heb","chapter":7,"verse":18},{"label":"Php 2:7","book":"Php","chapter":2,"verse":7},{"label":"Heb 2:14","book":"Heb","chapter":2,"verse":14},{"label":"Heb 2:17","book":"Heb","chapter":2,"verse":17},{"label":"Heb 4:15","book":"Heb","chapter":4,"verse":15},{"label":"Lv 5:6","book":"Lev","chapter":5,"verse":6},{"label":"Lv 5:11","book":"Lev","chapter":5,"verse":11},{"label":"Lv 14:31","book":"Lev","chapter":14,"verse":31},{"label":"Is 53:10","book":"Isa","chapter":53,"verse":10}],"footnotes":[{"marker":5,"text":"Or for sin"}]},{"verseId":"a556c5305ee15c3f-01:Rom:8:4","parts":[{"kind":"text","text":"in order that the law’s requirement would be fulfilled "},{"kind":"crossref","label":"Lk 1:6","book":"Luk","chapter":1,"verse":6,"letter":"a"},{"kind":"crossref","label":"Rm 2:26","book":"Rom","chapter":2,"verse":26,"letter":"b"},{"kind":"text","text":" in us who do not walk according to the flesh "},{"kind":"crossref","label":"Gl 5:16","book":"Gal","chapter":5,"verse":16,"letter":"c"},{"kind":"text","text":" but according to the Spirit. "}],"crossRefs":[{"label":"Lk 1:6","book":"Luk","chapter":1,"verse":6},{"label":"Rm 2:26","book":"Rom","chapter":2,"verse":26},{"label":"Gl 5:16","book":"Gal","chapter":5,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:5","parts":[{"kind":"text","text":"For those who live according to the flesh have their minds set on the things of the flesh, "},{"kind":"crossref","label":"Gl 5:19–25","book":"Gal","chapter":5,"verse":19,"letter":"a"},{"kind":"text","text":" but those who live according to the Spirit have their minds set on the things of the Spirit. "}],"crossRefs":[{"label":"Gl 5:19–25","book":"Gal","chapter":5,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:6","parts":[{"kind":"text","text":"Now the mindset of the flesh "},{"kind":"crossref","label":"Gl 6:8","book":"Gal","chapter":6,"verse":8,"letter":"a"},{"kind":"text","text":" is death, "},{"kind":"crossref","label":"Rm 6:21","book":"Rom","chapter":6,"verse":21,"letter":"b"},{"kind":"text","text":" but the mindset of the Spirit is life and peace. "}],"crossRefs":[{"label":"Gl 6:8","book":"Gal","chapter":6,"verse":8},{"label":"Rm 6:21","book":"Rom","chapter":6,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:7","parts":[{"kind":"text","text":"The mindset of the flesh is hostile "},{"kind":"crossref","label":"Jms 4:4","book":"Jas","chapter":4,"verse":4,"letter":"a"},{"kind":"text","text":" to God because it does not submit to God’s law. Indeed, it is unable to do so. "}],"crossRefs":[{"label":"Jms 4:4","book":"Jas","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:8","parts":[{"kind":"text","text":"Those who are in the flesh "},{"kind":"crossref","label":"Rm 7:5","book":"Rom","chapter":7,"verse":5,"letter":"a"},{"kind":"text","text":" cannot please God. "}],"crossRefs":[{"label":"Rm 7:5","book":"Rom","chapter":7,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:9","parts":[{"kind":"text","text":"You, however, are not in the flesh, but in the Spirit, if indeed the Spirit of God lives in you. "},{"kind":"crossref","label":"Jn 14:23","book":"Jhn","chapter":14,"verse":23,"letter":"a"},{"kind":"crossref","label":"1Co 3:16","book":"1Co","chapter":3,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Co 6:19","book":"1Co","chapter":6,"verse":19,"letter":"c"},{"kind":"crossref","label":"2Co 6:16","book":"2Co","chapter":6,"verse":16,"letter":"d"},{"kind":"crossref","label":"2Tm 1:14","book":"2Ti","chapter":1,"verse":14,"letter":"e"},{"kind":"text","text":" If anyone does not have the Spirit of Christ, "},{"kind":"crossref","label":"Jn 14:17","book":"Jhn","chapter":14,"verse":17,"letter":"f"},{"kind":"crossref","label":"Gl 4:6","book":"Gal","chapter":4,"verse":6,"letter":"g"},{"kind":"crossref","label":"Php 1:19","book":"Php","chapter":1,"verse":19,"letter":"h"},{"kind":"crossref","label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13,"letter":"i"},{"kind":"text","text":" he does not belong to him. "}],"crossRefs":[{"label":"Jn 14:23","book":"Jhn","chapter":14,"verse":23},{"label":"1Co 3:16","book":"1Co","chapter":3,"verse":16},{"label":"1Co 6:19","book":"1Co","chapter":6,"verse":19},{"label":"2Co 6:16","book":"2Co","chapter":6,"verse":16},{"label":"2Tm 1:14","book":"2Ti","chapter":1,"verse":14},{"label":"Jn 14:17","book":"Jhn","chapter":14,"verse":17},{"label":"Gl 4:6","book":"Gal","chapter":4,"verse":6},{"label":"Php 1:19","book":"Php","chapter":1,"verse":19},{"label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:10","parts":[{"kind":"text","text":"Now if Christ is in you, "},{"kind":"crossref","label":"Jn 17:23","book":"Jhn","chapter":17,"verse":23,"letter":"a"},{"kind":"crossref","label":"Gl 2:20","book":"Gal","chapter":2,"verse":20,"letter":"b"},{"kind":"crossref","label":"Eph 3:17","book":"Eph","chapter":3,"verse":17,"letter":"c"},{"kind":"crossref","label":"Col 1:27","book":"Col","chapter":1,"verse":27,"letter":"d"},{"kind":"text","text":" the body is dead because of sin, but the Spirit "},{"kind":"footnote","marker":6,"text":"Or spirit"},{"kind":"text","text":" gives life "},{"kind":"footnote","marker":7,"text":"Or your spirit is alive"},{"kind":"text","text":" because of righteousness. "}],"crossRefs":[{"label":"Jn 17:23","book":"Jhn","chapter":17,"verse":23},{"label":"Gl 2:20","book":"Gal","chapter":2,"verse":20},{"label":"Eph 3:17","book":"Eph","chapter":3,"verse":17},{"label":"Col 1:27","book":"Col","chapter":1,"verse":27}],"footnotes":[{"marker":6,"text":"Or spirit"},{"marker":7,"text":"Or your spirit is alive"}]},{"verseId":"a556c5305ee15c3f-01:Rom:8:11","parts":[{"kind":"text","text":"And if the Spirit of him who raised Jesus from the dead "},{"kind":"crossref","label":"Ac 2:24","book":"Act","chapter":2,"verse":24,"letter":"a"},{"kind":"crossref","label":"Rm 6:4","book":"Rom","chapter":6,"verse":4,"letter":"b"},{"kind":"text","text":" lives in you, then he who raised Christ from the dead will also bring your mortal bodies to life through "},{"kind":"footnote","marker":8,"text":"Other mss read because of"},{"kind":"text","text":" his Spirit who lives in you."}],"crossRefs":[{"label":"Ac 2:24","book":"Act","chapter":2,"verse":24},{"label":"Rm 6:4","book":"Rom","chapter":6,"verse":4}],"footnotes":[{"marker":8,"text":"Other mss read because of"}]},{"verseId":"a556c5305ee15c3f-01:Rom:8:12","parts":[{"kind":"text","text":"So then, brothers and sisters, we are not obligated to the flesh to live according to the flesh, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:13","parts":[{"kind":"text","text":"because if you live according to the flesh, you are going to die. But if by the Spirit you put to death the deeds of the body, "},{"kind":"crossref","label":"Col 3:5","book":"Col","chapter":3,"verse":5,"letter":"a"},{"kind":"text","text":" you will live. "}],"crossRefs":[{"label":"Col 3:5","book":"Col","chapter":3,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:14","parts":[{"kind":"text","text":"For all those led by God’s Spirit "},{"kind":"crossref","label":"Gl 5:18","book":"Gal","chapter":5,"verse":18,"letter":"a"},{"kind":"text","text":" are God’s sons. "},{"kind":"crossref","label":"Hs 1:10","book":"Hos","chapter":1,"verse":10,"letter":"b"},{"kind":"crossref","label":"Mt 5:9","book":"Mat","chapter":5,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jn 1:12","book":"Jhn","chapter":1,"verse":12,"letter":"d"},{"kind":"crossref","label":"Rm 9:8","book":"Rom","chapter":9,"verse":8,"letter":"e"},{"kind":"crossref","label":"Rm 9:26","book":"Rom","chapter":9,"verse":26,"letter":"f"},{"kind":"crossref","label":"2Co 6:18","book":"2Co","chapter":6,"verse":18,"letter":"g"},{"kind":"crossref","label":"Gl 3:26","book":"Gal","chapter":3,"verse":26,"letter":"h"},{"kind":"crossref","label":"1Jn 3:1","book":"1Jn","chapter":3,"verse":1,"letter":"i"},{"kind":"crossref","label":"Rv 21:7","book":"Rev","chapter":21,"verse":7,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gl 5:18","book":"Gal","chapter":5,"verse":18},{"label":"Hs 1:10","book":"Hos","chapter":1,"verse":10},{"label":"Mt 5:9","book":"Mat","chapter":5,"verse":9},{"label":"Jn 1:12","book":"Jhn","chapter":1,"verse":12},{"label":"Rm 9:8","book":"Rom","chapter":9,"verse":8},{"label":"Rm 9:26","book":"Rom","chapter":9,"verse":26},{"label":"2Co 6:18","book":"2Co","chapter":6,"verse":18},{"label":"Gl 3:26","book":"Gal","chapter":3,"verse":26},{"label":"1Jn 3:1","book":"1Jn","chapter":3,"verse":1},{"label":"Rv 21:7","book":"Rev","chapter":21,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:15","parts":[{"kind":"text","text":"For you did not receive a spirit of slavery to fall back into fear. "},{"kind":"crossref","label":"2Tm 1:7","book":"2Ti","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Heb 2:15","book":"Heb","chapter":2,"verse":15,"letter":"b"},{"kind":"text","text":" Instead, you received the Spirit of adoption, "},{"kind":"crossref","label":"Gl 4:5","book":"Gal","chapter":4,"verse":5,"letter":"c"},{"kind":"text","text":" by whom we cry out, “Abba, "},{"kind":"footnote","marker":1,"text":"Aramaic for father"},{"kind":"text","text":" Father!” "},{"kind":"crossref","label":"Mk 14:36","book":"Mrk","chapter":14,"verse":36,"letter":"d"},{"kind":"crossref","label":"Gl 4:6","book":"Gal","chapter":4,"verse":6,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Tm 1:7","book":"2Ti","chapter":1,"verse":7},{"label":"Heb 2:15","book":"Heb","chapter":2,"verse":15},{"label":"Gl 4:5","book":"Gal","chapter":4,"verse":5},{"label":"Mk 14:36","book":"Mrk","chapter":14,"verse":36},{"label":"Gl 4:6","book":"Gal","chapter":4,"verse":6}],"footnotes":[{"marker":1,"text":"Aramaic for father"}]},{"verseId":"a556c5305ee15c3f-01:Rom:8:16","parts":[{"kind":"text","text":"The Spirit himself testifies together with our spirit "},{"kind":"crossref","label":"Ac 5:32","book":"Act","chapter":5,"verse":32,"letter":"a"},{"kind":"text","text":" that we are God’s children, "}],"crossRefs":[{"label":"Ac 5:32","book":"Act","chapter":5,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:8:17","parts":[{"kind":"text","text":"and if children, also heirs "},{"kind":"crossref","label":"Ac 20:32","book":"Act","chapter":20,"verse":32,"letter":"a"},{"kind":"crossref","label":"Gl 3:29","book":"Gal","chapter":3,"verse":29,"letter":"b"},{"kind":"crossref","label":"Gl 4:7","book":"Gal","chapter":4,"verse":7,"letter":"c"},{"kind":"crossref","label":"Eph 3:6","book":"Eph","chapter":3,"verse":6,"letter":"d"},{"kind":"crossref","label":"Ti 3:7","book":"Tit","chapter":3,"verse":7,"letter":"e"},{"kind":"crossref","label":"Heb 1:14","book":"Heb","chapter":1,"verse":14,"letter":"f"},{"kind":"crossref","label":"Rv 21:7","book":"Rev","chapter":21,"verse":7,"letter":"g"},{"kind":"text","text":" —heirs of God and coheirs with Christ —if indeed we suffer with him "},{"kind":"crossref","label":"2Co 1:5","book":"2Co","chapter":1,"verse":5,"letter":"h"},{"kind":"crossref","label":"2Co 1:7","book":"2Co","chapter":1,"verse":7,"letter":"i"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"j"},{"kind":"crossref","label":"Col 1:24","book":"Col","chapter":1,"verse":24,"letter":"k"},{"kind":"crossref","label":"2Tm 2:12","book":"2Ti","chapter":2,"verse":12,"letter":"l"},{"kind":"text","text":" so that we may also be glorified with him."}],"crossRefs":[{"label":"Ac 20:32","book":"Act","chapter":20,"verse":32},{"label":"Gl 3:29","book":"Gal","chapter":3,"verse":29},{"lab