s":[{"marker":3,"text":"Or and lack the"}]},{"verseId":"a556c5305ee15c3f-01:Rom:3:24","parts":[{"kind":"text","text":"they are justified freely by his grace "},{"kind":"crossref","label":"Rm 4:4","book":"Rom","chapter":4,"verse":4,"letter":"a"},{"kind":"crossref","label":"Rm 4:16","book":"Rom","chapter":4,"verse":16,"letter":"b"},{"kind":"crossref","label":"Eph 2:8","book":"Eph","chapter":2,"verse":8,"letter":"c"},{"kind":"text","text":" through the redemption that is in Christ Jesus. "},{"kind":"crossref","label":"1Co 1:30","book":"1Co","chapter":1,"verse":30,"letter":"d"},{"kind":"crossref","label":"Eph 1:7","book":"Eph","chapter":1,"verse":7,"letter":"e"},{"kind":"crossref","label":"Col 1:14","book":"Col","chapter":1,"verse":14,"letter":"f"},{"kind":"crossref","label":"Heb 9:15","book":"Heb","chapter":9,"verse":15,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 4:4","book":"Rom","chapter":4,"verse":4},{"label":"Rm 4:16","book":"Rom","chapter":4,"verse":16},{"label":"Eph 2:8","book":"Eph","chapter":2,"verse":8},{"label":"1Co 1:30","book":"1Co","chapter":1,"verse":30},{"label":"Eph 1:7","book":"Eph","chapter":1,"verse":7},{"label":"Col 1:14","book":"Col","chapter":1,"verse":14},{"label":"Heb 9:15","book":"Heb","chapter":9,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rom:3:25","parts":[{"kind":"text","text":"God presented him as the mercy seat "},{"kind":"footnote","marker":4,"text":"Or propitiation, or place of atonement"},{"kind":"crossref","label":"1Jn 2:2","book":"1Jn","chapter":2,"verse":2,"letter":"a"},{"kind":"crossref","label":"1Jn 4:10","book":"1Jn","chapter":4,"verse":10,"letter":"b"},{"kind":"text","text":" by his blood, "},{"kind":"crossref","label":"1Co 5:7","book":"1Co","chapter":5,"verse":7,"letter":"c"},{"kind":"crossref","label":"Heb 9:14","book":"Heb","chapter":9,"verse":14,"letter":"d"},{"kind":"crossref","label":"Heb 9:28","book":"Heb","chapter":9,"verse":28,"letter":"e"},{"kind":"crossref","label":"1Pt 1:19","