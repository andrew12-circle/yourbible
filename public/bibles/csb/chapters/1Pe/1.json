":"crossref","label":"Rv 15:1","book":"Rev","chapter":15,"verse":1,"letter":"i"},{"kind":"crossref","label":"Rv 21:9","book":"Rev","chapter":21,"verse":9,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 10:28","book":"Jhn","chapter":10,"verse":28},{"label":"Php 4:7","book":"Php","chapter":4,"verse":7},{"label":"Rm 8:18","book":"Rom","chapter":8,"verse":18},{"label":"2Co 4:17","book":"2Co","chapter":4,"verse":17},{"label":"Heb 12:11","book":"Heb","chapter":12,"verse":11},{"label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13},{"label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1},{"label":"1Pt 5:10","book":"1Pe","chapter":5,"verse":10},{"label":"Rv 15:1","book":"Rev","chapter":15,"verse":1},{"label":"Rv 21:9","book":"Rev","chapter":21,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:6","parts":[{"kind":"text","text":"You rejoice in this, "},{"kind":"footnote","marker":1,"text":"Or In this fact rejoice"},{"kind":"text","text":" even though now for a short time, if necessary, you suffer grief in various trials "},{"kind":"crossref","label":"Jms 1:2","book":"Jas","chapter":1,"verse":2,"letter":"a"},{"kind":"crossref","label":"1Pt 4:12","book":"1Pe","chapter":4,"verse":12,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jms 1:2","book":"Jas","chapter":1,"verse":2},{"label":"1Pt 4:12","book":"1Pe","chapter":4,"verse":12}],"footnotes":[{"marker":1,"text":"Or In this fact rejoice"}]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:7","parts":[{"kind":"text","text":"so that the proven character of your faith "},{"kind":"crossref","label":"Jms 1:3","book":"Jas","chapter":1,"verse":3,"letter":"a"},{"kind":"text","text":" —more valuable than gold which, though perishable, is refined by fire "},{"kind":"crossref","label":"Is 48:10","book":"Isa","chapter":48,"verse":10,"letter":"b"},{"kind":"crossref","label":"Zch 13:9","book":"Zec","chapter":13,"verse":9,"letter":"c"},{"kind":"crossref","label":"Mal 3:3","book":"Mal","chapter":3,"verse":3,"letter":"d"},{"kind":"crossref","label":"1Co 3:13","book":"1Co","chapter":3,"verse":13,"letter":"e"},{"kind":"text","text":" —may result "},{"kind":"crossref","label":"2Co 5:3","book":"2Co","chapter":5,"verse":3,"letter":"f"},{"kind":"crossref","label":"Php 3:9","book":"Php","chapter":3,"verse":9,"letter":"g"},{"kind":"crossref","label":"Rv 14:5","book":"Rev","chapter":14,"verse":5,"letter":"h"},{"kind":"text","text":" in praise, glory, and honor "},{"kind":"crossref","label":"Rm 2:7","book":"Rom","chapter":2,"verse":7,"letter":"i"},{"kind":"crossref","label":"Rm 2:10","book":"Rom","chapter":2,"verse":10,"letter":"j"},{"kind":"crossref","label":"Rm 2:29","book":"Rom","chapter":2,"verse":29,"letter":"k"},{"kind":"crossref","label":"1Co 4:5","book":"1Co","chapter":4,"verse":5,"letter":"l"},{"kind":"text","text":" at the revelation of Jesus Christ. "},{"kind":"crossref","label":"Lk 17:30","book":"Luk","chapter":17,"verse":30,"letter":"m"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jms 1:3","book":"Jas","chapter":1,"verse":3},{"label":"Is 48:10","book":"Isa","chapter":48,"verse":10},{"label":"Zch 13:9","book":"Zec","chapter":13,"verse":9},{"label":"Mal 3:3","book":"Mal","chapter":3,"verse":3},{"label":"1Co 3:13","book":"1Co","chapter":3,"verse":13},{"label":"2Co 5:3","book":"2Co","chapter":5,"verse":3},{"label":"Php 3:9","book":"Php","chapter":3,"verse":9},{"label":"Rv 14:5","book":"Rev","chapter":14,"verse":5},{"label":"Rm 2:7","book":"Rom","chapter":2,"verse":7},{"label":"Rm 2:10","book":"Rom","chapter":2,"verse":10},{"label":"Rm 2:29","book":"Rom","chapter":2,"verse":29},{"label":"1Co 4:5","book":"1Co","chapter":4,"verse":5},{"label":"Lk 17:30","book":"Luk","chapter":17,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:8","parts":[{"kind":"text","text":"Though you have not seen "},{"kind":"crossref","label":"Ex 33:20","book":"Exo","chapter":33,"verse":20,"letter":"a"},{"kind":"crossref","label":"Rm 8:24","book":"Rom","chapter":8,"verse":24,"letter":"b"},{"kind":"text","text":" him, you love him; "},{"kind":"crossref","label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20,"letter":"c"},{"kind":"text","text":" though not seeing him now, you believe in him, and you rejoice "},{"kind":"crossref","label":"Jn 15:11","book":"Jhn","chapter":15,"verse":11,"letter":"d"},{"kind":"crossref","label":"2Co 6:10","book":"2Co","chapter":6,"verse":10,"letter":"e"},{"kind":"text","text":" with inexpressible and glorious joy, "}],"crossRefs":[{"label":"Ex 33:20","book":"Exo","chapter":33,"verse":20},{"label":"Rm 8:24","book":"Rom","chapter":8,"verse":24},{"label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20},{"label":"Jn 15:11","book":"Jhn","chapter":15,"verse":11},{"label":"2Co 6:10","book":"2Co","chapter":6,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:9","parts":[{"kind":"text","text":"because you are receiving the goal of your faith, the salvation of your souls."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:10","parts":[{"kind":"text","text":"Concerning this salvation, the prophets, "},{"kind":"crossref","label":"Lk 1:70","book":"Luk","chapter":1,"verse":70,"letter":"a"},{"kind":"crossref","label":"Lk 10:24","book":"Luk","chapter":10,"verse":24,"letter":"b"},{"kind":"crossref","label":"Lk 16:16","book":"Luk","chapter":16,"verse":16,"letter":"c"},{"kind":"crossref","label":"Lk 16:29","book":"Luk","chapter":16,"verse":29,"letter":"d"},{"kind":"crossref","label":"Lk 18:31","book":"Luk","chapter":18,"verse":31,"letter":"e"},{"kind":"crossref","label":"Lk 24:25","book":"Luk","chapter":24,"verse":25,"letter":"f"},{"kind":"crossref","label":"Lk 24:27","book":"Luk","chapter":24,"verse":27,"letter":"g"},{"kind":"crossref","label":"Lk 24:44","book":"Luk","chapter":24,"verse":44,"letter":"h"},{"kind":"text","text":" who prophesied about the grace that would come to you, searched and carefully investigated. "}],"crossRefs":[{"label":"Lk 1:70","book":"Luk","chapter":1,"verse":70},{"label":"Lk 10:24","book":"Luk","chapter":10,"verse":24},{"label":"Lk 16:16","book":"Luk","chapter":16,"verse":16},{"label":"Lk 16:29","book":"Luk","chapter":16,"verse":29},{"label":"Lk 18:31","book":"Luk","chapter":18,"verse":31},{"label":"Lk 24:25","book":"Luk","chapter":24,"verse":25},{"label":"Lk 24:27","book":"Luk","chapter":24,"verse":27},{"label":"Lk 24:44","book":"Luk","chapter":24,"verse":44}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:11","parts":[{"kind":"text","text":"They inquired into what time or what circumstances the Spirit of Christ "},{"kind":"crossref","label":"Rm 8:9","book":"Rom","chapter":8,"verse":9,"letter":"a"},{"kind":"text","text":" within them was indicating when he testified in advance "},{"kind":"crossref","label":"Mt 26:24","book":"Mat","chapter":26,"verse":24,"letter":"b"},{"kind":"text","text":" to the sufferings of Christ "},{"kind":"crossref","label":"Mk 8:31","book":"Mrk","chapter":8,"verse":31,"letter":"c"},{"kind":"crossref","label":"Lk 24:26","book":"Luk","chapter":24,"verse":26,"letter":"d"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"e"},{"kind":"text","text":" and the glories "},{"kind":"crossref","label":"Lk 24:26","book":"Luk","chapter":24,"verse":26,"letter":"f"},{"kind":"text","text":" that would follow. "},{"kind":"footnote","marker":1,"text":"Or the glories after that"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 8:9","book":"Rom","chapter":8,"verse":9},{"label":"Mt 26:24","book":"Mat","chapter":26,"verse":24},{"label":"Mk 8:31","book":"Mrk","chapter":8,"verse":31},{"label":"Lk 24:26","book":"Luk","chapter":24,"verse":26},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10},{"label":"Lk 24:26","book":"Luk","chapter":24,"verse":26}],"footnotes":[{"marker":1,"text":"Or the glories after that"}]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:12","parts":[{"kind":"text","text":"It was revealed to them that they were not serving themselves but you. These things hav