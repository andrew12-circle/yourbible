3","book":"1Th","chapter":1,"verse":3,"letter":"e"},{"kind":"text","text":" completely on the grace to be brought to you at the revelation "},{"kind":"crossref","label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13,"letter":"f"},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"g"},{"kind":"text","text":" of Jesus Christ. "}],"crossRefs":[{"label":"Ex 12:11","book":"Exo","chapter":12,"verse":11},{"label":"1Pt 5:8","book":"1Pe","chapter":5,"verse":8},{"label":"Mt 12:21","book":"Mat","chapter":12,"verse":21},{"label":"Rm 8:24","book":"Rom","chapter":8,"verse":24},{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3},{"label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13},{"label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:14","parts":[{"kind":"text","text":"As obedient children, "},{"kind":"crossref","label":"Heb 2:13","book":"Heb","chapter":2,"verse":13,"letter":"a"},{"kind":"text","text":" do not be conformed to the desires of your former ignorance. "}],"crossRefs":[{"label":"Heb 2:13","book":"Heb","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:1:15","parts":[{"kind":"text","text":"But as the one who called you "},{"kind":"crossref","label":"Gl 1:6","book":"Gal","chapter":1,"verse":6,"letter":"a"},{"kind":"crossref","label":"Gl 5:8","book":"Gal","chapter":5,"verse":8,"letter":"b"},{"kind":"crossref","label":"1Th 2:12","book":"1Th","chapter":2,"verse":12,"letter":"c"},{"kind":"crossref","label":"1Th 5:24","book":"1Th","chapter":5,"verse":24,"letter":"d"},{"kind":"crossref","label":"1Pt 5:10","book":"1Pe","chapter":5,"verse":10,"letter":"e"},{"kind":"text","text":" is holy, "},{"kind":"crossref","label":"Lk 1:49","book":"Luk","chapter":1,"verse":49,"letter":"f"},{"kind":"crossref","label":"1Co 7:14","book":"1Co","chapter":7,"verse":14,"letter":"g"},{"kind":"text","text":" you also are to be holy in all your conduct; "}],"crossRefs":[{"label":"Gl 1