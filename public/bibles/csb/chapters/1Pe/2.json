5,"verse":19,"letter":"b"},{"kind":"crossref","label":"Lk 1:50","book":"Luk","chapter":1,"verse":50,"letter":"c"},{"kind":"text","text":" but now you have received mercy."}],"crossRefs":[{"label":"Mt 5:7","book":"Mat","chapter":5,"verse":7},{"label":"Mk 5:19","book":"Mrk","chapter":5,"verse":19},{"label":"Lk 1:50","book":"Luk","chapter":1,"verse":50}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:11","parts":[{"kind":"text","text":"Dear friends, I urge you as strangers and exiles "},{"kind":"crossref","label":"1Pt 1:1","book":"1Pe","chapter":1,"verse":1,"letter":"a"},{"kind":"text","text":" to abstain "},{"kind":"crossref","label":"1Tm 4:3","book":"1Ti","chapter":4,"verse":3,"letter":"b"},{"kind":"text","text":" from sinful "},{"kind":"crossref","label":"Rm 7:23","book":"Rom","chapter":7,"verse":23,"letter":"c"},{"kind":"crossref","label":"Php 3:3","book":"Php","chapter":3,"verse":3,"letter":"d"},{"kind":"text","text":" desires that wage war against the soul. "},{"kind":"crossref","label":"Gl 5:17","book":"Gal","chapter":5,"verse":17,"letter":"e"},{"kind":"crossref","label":"Jms 4:1","book":"Jas","chapter":4,"verse":1,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Pt 1:1","book":"1Pe","chapter":1,"verse":1},{"label":"1Tm 4:3","book":"1Ti","chapter":4,"verse":3},{"label":"Rm 7:23","book":"Rom","chapter":7,"verse":23},{"label":"Php 3:3","book":"Php","chapter":3,"verse":3},{"label":"Gl 5:17","book":"Gal","chapter":5,"verse":17},{"label":"Jms 4:1","book":"Jas","chapter":4,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:12","parts":[{"kind":"text","text":"Conduct "},{"kind":"crossref","label":"2Pt 3:11","book":"2Pe","chapter":3,"verse":11,"letter":"a"},{"kind":"text","text":" yourselves honorably among the Gentiles, "},{"kind":"footnote","marker":1,"text":"Or among the nations, or among the pagans"},{"kind":"text","text":" so that when they slander you as evildoers, they will observe your good works and will glorify God on the