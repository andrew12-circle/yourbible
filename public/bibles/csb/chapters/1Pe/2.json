c3f-01:1Pe:2:14","parts":[{"kind":"text","text":"or to governors as those sent out by him to punish those who do what is evil and to praise those who do what is good. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:15","parts":[{"kind":"text","text":"For it is God’s will "},{"kind":"crossref","label":"Gl 1:4","book":"Gal","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Eph 1:9","book":"Eph","chapter":1,"verse":9,"letter":"b"},{"kind":"text","text":" that you silence the ignorance "},{"kind":"crossref","label":"1Pt 3:16","book":"1Pe","chapter":3,"verse":16,"letter":"c"},{"kind":"text","text":" of foolish people by doing good. "}],"crossRefs":[{"label":"Gl 1:4","book":"Gal","chapter":1,"verse":4},{"label":"Eph 1:9","book":"Eph","chapter":1,"verse":9},{"label":"1Pt 3:16","book":"1Pe","chapter":3,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:16","parts":[{"kind":"text","text":"Submit as free people, not using your freedom as a cover-up for evil, "},{"kind":"crossref","label":"1Co 14:20","book":"1Co","chapter":14,"verse":20,"letter":"a"},{"kind":"text","text":" but as God’s slaves. "},{"kind":"crossref","label":"Rm 1:1","book":"Rom","chapter":1,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ti 1:1","book":"Tit","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"Rv 2:20","book":"Rev","chapter":2,"verse":20,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Co 14:20","book":"1Co","chapter":14,"verse":20},{"label":"Rm 1:1","book":"Rom","chapter":1,"verse":1},{"label":"Ti 1:1","book":"Tit","chapter":1,"verse":1},{"label":"Rv 2:20","book":"Rev","chapter":2,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:17","parts":[{"kind":"text","text":"Honor everyone. Love "},{"kind":"crossref","label":"Rv 12:11","book":"Rev","chapter":12,"verse":11,"letter":"a"},{"kind":"text","text":" the brothers and sisters. "},{"kind":"crossref","label":"Heb 13:1","book":"Heb","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Pt 5:9","book":"1Pe","chapter":5,"verse":9,"letter":"c"},{"kind":"text","text":" Fear God. "},{"kind":"crossref","label":"Pr 1:7","book":"Pro","chapter":1,"verse":7,"letter":"d"},{"kind":"crossref","label":"Pr 24:21","book":"Pro","chapter":24,"verse":21,"letter":"e"},{"kind":"crossref","label":"Ac 10:2","book":"Act","chapter":10,"verse":2,"letter":"f"},{"kind":"crossref","label":"Rv 14:7","book":"Rev","chapter":14,"verse":7,"letter":"g"},{"kind":"text","text":" Honor the emperor."}],"crossRefs":[{"label":"Rv 12:11","book":"Rev","chapter":12,"verse":11},{"label":"Heb 13:1","book":"Heb","chapter":13,"verse":1},{"label":"1Pt 5:9","book":"1Pe","chapter":5,"verse":9},{"label":"Pr 1:7","book":"Pro","chapter":1,"verse":7},{"label":"Pr 24:21","book":"Pro","chapter":24,"verse":21},{"label":"Ac 10:2","book":"Act","chapter":10,"verse":2},{"label":"Rv 14:7","book":"Rev","chapter":14,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:18","parts":[{"kind":"text","text":"Household slaves, submit to your masters "},{"kind":"crossref","label":"Eph 6:5","book":"Eph","chapter":6,"verse":5,"letter":"a"},{"kind":"crossref","label":"Col 3:22","book":"Col","chapter":3,"verse":22,"letter":"b"},{"kind":"crossref","label":"Ti 2:9","book":"Tit","chapter":2,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jd 1:4","book":"Jud","chapter":1,"verse":4,"letter":"d"},{"kind":"text","text":" with all reverence "},{"kind":"crossref","label":"Rm 13:3","book":"Rom","chapter":13,"verse":3,"letter":"e"},{"kind":"crossref","label":"Rm 13:7","book":"Rom","chapter":13,"verse":7,"letter":"f"},{"kind":"text","text":" not only to the good and gentle ones but also to the cruel. "},{"kind":"crossref","label":"Php 2:15","book":"Php","chapter":2,"verse":15,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Eph 6:5","book":"Eph","chapter":6,"verse":5},{"label":"Col 3:22","book":"Col","chapter":3,"verse":22},{"label":"Ti 2:9","book":"Tit","chapter":2,"verse":9},{"label":"Jd 1:4","book":"Jud","chapter":1,"verse":4},{"label":"Rm 13:3","book":"Rom","chapter":13,"verse":3},{"label":"Rm 13:7","book":"Rom","chapter":13,"verse":7},{"label":"Php 2:15","book":"Php","chapter":2,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:19","parts":[{"kind":"text","text":"For it brings favor if, because of a consciousness of God, someone endures grief from suffering unjustly. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:20","parts":[{"kind":"text","text":"For what credit is there if when you do wrong and are beaten, you endure it? But when you do what is good and suffer, "},{"kind":"crossref","label":"1Pt 4:14","book":"1Pe","chapter":4,"verse":14,"letter":"a"},{"kind":"text","text":" if you endure it, this brings favor with God."}],"crossRefs":[{"label":"1Pt 4:14","book":"1Pe","chapter":4,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Pe:2:21","parts":[{"kind":"text","text":"For you were called to this, because Christ also suffered "},{"kind":"crossref","label":"Mk 8:31","book":"Mrk","chapter":8,"verse":31,"letter":"a"},{"kind":"crossref","label":"1Pt 3:18","book":"1Pe","chapter":3,"verse":18,"letter":"b"},{"kind":"crossref","label":"1Jn 3:16","book":"1Jn","chapter":3,"verse":16,"letter":"c"},{"kind":"text","text":" for you, leaving you an example, "},{"kind":"crossref","label":"Jn 13:15","book":"Jhn","chapter":13,"verse":15,"letter":"d"},{"kind":"text","text":" that you should follow "},{"kind":"crossref","label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12,"letter":"e"},{"kind":"text","text":" in his steps. "}],"crossRefs":[{"label":"Mk 8:31","book":"Mrk","chapter":8,"verse":31},{"label":"1Pt 3:18","book":"1Pe","chapter":3,"verse":18},{"label":"1Jn 3:16","book":"1Jn","chapter":3,"verse":16},{"label":"Jn 13:15","book":"Jhn","chapter":13,"verse":15},{"label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01: