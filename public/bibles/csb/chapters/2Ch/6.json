{"key":"a556c5305ee15c3f-01|2Ch|6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","chapter":6,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:2Ch:6:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":1,"text":"Then Solomon said:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":2,"text":"but I have built an exalted temple for you,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":3,"text":"Then the king turned and blessed the entire congregation of Israel while they were standing.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":4,"text":"He said:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":5,"text":"“Since the day I brought my people Israel","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":6,"text":"But I have chosen Jerusalem","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":7,"text":"My father David had his heart set","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":8,"text":"However, the Lord said to my father David,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":9,"text":"Yet, you are not the one to build the temple,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":10,"text":"So the Lord has fulfilled what he promised.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":11,"text":"I have put the ark there,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":12,"text":"Then Solomon stood before the altar of the Lord in front of the entire congregation of Israel and spread out his hands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":13,"text":"For Solomon had made a bronze platform 7 1/2 feet long, 7 1/2 feet wide, and 4 1/2 feet high and put it in the court. He stood on it, knelt down in front of the entire congregation of Israel, and spread out his hands toward heaven.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":14,"text":"He said:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":15,"text":"You have kept what you promised","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:16","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":16,"text":"Therefore, Lord God of Israel,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:17","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":17,"text":"Now, Lord God of Israel, please confirm","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:18","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":18,"text":"But will God indeed live on earth with humans?","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":19,"text":"Listen to your servant’s prayer and his petition,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":20,"text":"so that your eyes watch over this temple","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":21,"text":"Hear the petitions of your servant","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":22,"text":"If a man sins against his neighbor","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":23,"text":"may you hear in heaven and act.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":24,"text":"If your people Israel are defeated before an enemy,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":25,"text":"may you hear in heaven","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":26,"text":"When the skies are shut and there is no rain","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":27,"text":"may you hear in heaven","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":28,"text":"When there is famine in the land,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":29,"text":"every prayer or petition","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":30,"text":"may you hear in heaven, your dwelling place,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":31,"text":"so that they may fear you","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":32,"text":"Even for the foreigner who is not of your people Israel","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":33,"text":"may you hear in heaven in your dwelling place,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":34,"text":"When your people go out to fight against their enemies,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter":6,"verse":35,"text":"may you hear their prayer and petition in heaven","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Ch:6:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Ch","bookOrder":13,"chapter"