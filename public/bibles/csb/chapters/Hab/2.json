er","chapter":22,"verse":13,"letter":"b"},{"kind":"crossref","label":"Jr 49:16","book":"Jer","chapter":49,"verse":16,"letter":"c"},{"kind":"crossref","label":"Ob 4","book":"Oba","chapter":1,"verse":4,"letter":"d"},{"kind":"crossref","label":"Rv 18:7","book":"Rev","chapter":18,"verse":7,"letter":"e"}],"crossRefs":[{"label":"Pr 1:9","book":"Pro","chapter":1,"verse":9},{"label":"Pr 15:27","book":"Pro","chapter":15,"verse":27},{"label":"Jr 6:13","book":"Jer","chapter":6,"verse":13},{"label":"Jr 8:10","book":"Jer","chapter":8,"verse":10},{"label":"Ezk 22:27","book":"Ezk","chapter":22,"verse":27},{"label":"Pr 11:28","book":"Pro","chapter":11,"verse":28},{"label":"Jr 22:13","book":"Jer","chapter":22,"verse":13},{"label":"Jr 49:16","book":"Jer","chapter":49,"verse":16},{"label":"Ob 4","book":"Oba","chapter":1,"verse":4},{"label":"Rv 18:7","book":"Rev","chapter":18,"verse":7}],"footnotes":[{"marker":1,"text":"Or dynasty"}]},{"verseId":"a556c5305ee15c3f-01:Hab:2:10","parts":[{"kind":"text","text":"You have planned shame for your house"},{"kind":"text","text":" by wiping out many peoples"},{"kind":"text","text":" and sinning against your own self."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:11","parts":[{"kind":"text","text":"For the stones will cry out "},{"kind":"crossref","label":"Lk 19:40","book":"Luk","chapter":19,"verse":40,"letter":"a"},{"kind":"text","text":" from the wall,"},{"kind":"text","text":" and the rafters will answer them"},{"kind":"text","text":" from the woodwork."}],"crossRefs":[{"label":"Lk 19:40","book":"Luk","chapter":19,"verse":40}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:12","parts":[{"kind":"text","text":"Woe to him who builds a city with bloodshed"},{"kind":"text","text":" and founds a town with injustice! "},{"kind":"crossref","label":"Ezk 22:2–3","book":"Ezk","chapter":22,"verse":2,"letter":"a"},{"kind":"crossref","label":"Mc 3:10","book":"Mic","chapter":3,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Ezk 22:2–3","book":"Ezk","chapter":22,"verse":2},{"label":"Mc 3:10","book":"Mic","chapter":3,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:13","parts":[{"kind":"text","text":"Is it not from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies"},{"kind":"text","text":" that the peoples labor only to fuel the fire"},{"kind":"text","text":" and countries exhaust themselves for nothing? "},{"kind":"crossref","label":"Jr 51:58","book":"Jer","chapter":51,"verse":58,"letter":"a"}],"crossRefs":[{"label":"Jr 51:58","book":"Jer","chapter":51,"verse":58}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:14","parts":[{"kind":"text","text":"For the earth will be filled"},{"kind":"text","text":" with the knowledge of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s glory,"},{"kind":"text","text":" as the water covers the sea. "},{"kind":"crossref","label":"Nm 14:21","book":"Num","chapter":14,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 33:5","book":"Psa","chapter":33,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 72:19","book":"Psa","chapter":72,"verse":19,"letter":"c"},{"kind":"crossref","label":"Ps 119:64","book":"Psa","chapter":119,"verse":64,"letter":"d"},{"kind":"crossref","label":"Is 6:3","book":"Isa","chapter":6,"verse":3,"letter":"e"},{"kind":"crossref","label":"Is 11:9","book":"Isa","chapter":11,"verse":9,"letter":"f"},{"kind":"crossref","label":"Jr 23:24","book":"Jer","chapter":23,"verse":24,"letter":"g"}],"crossRefs":[{"label":"Nm 14:21","book":"Num","chapter":14,"verse":21},{"label":"Ps 33:5","book":"Psa","chapter":33,"verse":5},{"label":"Ps 72:19","book":"Psa","chapter":72,"verse":19},{"label":"Ps 119:64","book":"Psa","chapter":119,"verse":64},{"label":"Is 6:3","book":"Isa","chapter":6,"verse":3},{"label":"Is 11:9","book":"Isa","chapter":11,"verse":9},{"label":"Jr 23:24","book":"Jer","chapter":23,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:15","parts":[{"kind":"text","text":"Woe to him who gives his neighbors drink,"},{"kind":"text","text":" pouring out your wrath "},{"kind":"footnote","marker":1,"text":"Or venom"},{"kind":"text","text":" and even making them drunk,"},{"kind":"text","text":" in order to look at their nakedness!"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or venom"}]},{"verseId":"a556c5305ee15c3f-01:Hab:2:16","parts":[{"kind":"text","text":"You will be filled with disgrace instead of glory."},{"kind":"text","text":" You also —drink,"},{"kind":"text","text":" and expose your uncircumcision! "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Aq, Syr, Vg read and stagger"},{"kind":"text","text":" The cup in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s right hand"},{"kind":"text","text":" will come around to you,"},{"kind":"text","text":" and utter disgrace will cover your glory. "},{"kind":"crossref","label":"Rv 14:8–10","book":"Rev","chapter":14,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Rv 14:8–10","book":"Rev","chapter":14,"verse":8}],"footnotes":[{"marker":1,"text":"DSS, LXX, Aq, Syr, Vg read and stagger"}]},{"verseId":"a556c5305ee15c3f-01:Hab:2:17","parts":[{"kind":"text","text":"For your violence against Lebanon"},{"kind":"text","text":" will overwhelm you;"},{"kind":"text","text":" the destruction of animals will terrify you "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Aq, Syr, Tg, Vg; MT reads them"},{"kind":"text","text":" because of your human bloodshed and violence"},{"kind":"text","text":" against lands, cities, and all who live in them."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"DSS, LXX, Aq, Syr, Tg, Vg; MT reads them"}]},{"verseId":"a556c5305ee15c3f-01:Hab:2:18","parts":[{"kind":"text","text":"What use is a carved idol"},{"kind":"text","text":" after its craftsman carves it?"},{"kind":"text","text":" It is only a cast image, a teacher of lies."},{"kind":"text","text":" For the one who crafts its shape trusts in it"},{"kind":"text","text":" and makes worthless idols that cannot speak."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:19","parts":[{"kind":"text","text":"Woe to him who says to wood: Wake up!"},{"kind":"text","text":" or to mute stone: Come alive!"},{"kind":"text","text":" Can it teach?"},{"kind":"text","text":" Look! It may be plated with gold and silver,"},{"kind":"text","text":" yet there is no breath "},{"kind":"crossref","label":"Ex 32:4","book":"Exo","chapter":32,"verse":4,"letter":"a"},{"kind":"crossref","label":"Dt 27:15","book":"Deu","chapter":27,"verse":15,"letter":"b"},{"kind":"crossref","label":"Jdg 17:4","book":"Jdg","chapter":17,"verse":4,"letter":"c"},{"kind":"crossref","label":"Is 30:22","book":"Isa","chapter":30,"verse":22,"letter":"d"},{"kind":"crossref","label":"Is 40:18–20","book":"Isa","chapter":40,"verse":18,"letter":"e"},{"kind":"crossref","label":"Is 44:9–20","book":"Isa","chapter":44,"verse":9,"letter":"f"},{"kind":"crossref","label":"Jr 10:14","book":"Jer","chapter":10,"verse":14,"letter":"g"},{"kind":"text","text":" in it at all."}],"crossRefs":[{"label":"Ex 32:4","book":"Exo","chapter":32,"verse":4},{"label":"Dt 27:15","book":"Deu","chapter":27,"verse":15},{"label":"Jdg 17:4","book":"Jdg","chapter":17,"verse":4},{"label":"Is 30:22","book":"Isa","chapter":30,"verse":22},{"label":"Is 40:18–20","book":"Isa","chapter":40,"verse":18},{"label":"Is 44:9–20","book":"Isa","chapter":44,"verse":9},{"label":"Jr 10:14","book":"Jer","chapter":10,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:20","parts":[{"kind":"text","text":"But the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is in his holy temple; "},{"kind":"crossref","label":"Ps 11:4","book":"Psa","chapter":11,"verse":4,"letter":"a"},{"kind":"text","text":" let the whole earth"},{"kind":"text","text":" be silent in his presence. "},{"kind":"crossref","label":"Zp 1:7","book":"Zep","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Zch 2:13","book":"Zec","chapter":2,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Ps 11:4","book":"Psa","chapter":11,"verse":4},{"label":"Zp 1:7","book":"Zep","chapter":1,"verse":7},{"label":"Zch 2:13","book":"Zec","chapter":2,"verse":13}],"footnotes":[]}]},"cachedAt":1783279607297}