":"Jr 49:32","book":"Jer","chapter":49,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hab:2:8","parts":[{"kind":"text","text":"Since you have plundered many nations, "},{"kind":"crossref","label":"Is 10:13","book":"Isa","chapter":10,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ezk 36:4","book":"Ezk","chapter":36,"verse":4,"letter":"b"},{"kind":"text","text":" all the peoples who remain will plunder you "},{"kind":"crossref","label":"Zp 3:8","book":"Zep","chapter":3,"verse":8,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" because of human bloodshed"},{"kind":"text","text":" and violence "},{"kind":"crossref","label":"Jr 6:7","book":"Jer","chapter":6,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ezk 7:11","book":"Ezk","chapter":7,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ezk 7:23","book":"Ezk","chapter":7,"verse":23,"letter":"c"},{"kind":"crossref","label":"Ezk 8:17","book":"Ezk","chapter":8,"verse":17,"letter":"d"},{"kind":"crossref","label":"Ezk 12:19","book":"Ezk","chapter":12,"verse":19,"letter":"e"},{"kind":"crossref","label":"Ezk 45:9","book":"Ezk","chapter":45,"verse":9,"letter":"f"},{"kind":"crossref","label":"Mc 6:12","book":"Mic","chapter":6,"verse":12,"letter":"g"},{"kind":"crossref","label":"Hab 1:2–3","book":"Hab","chapter":1,"verse":2,"letter":"h"},{"kind":"crossref","label":"Hb 1:9","book":"Hab","chapter":1,"verse":9,"letter":"i"},{"kind":"crossref","label":"Hb 2:17","book":"Hab","chapter":2,"verse":17,"letter":"j"},{"kind":"text","text":" against lands, cities,"},{"kind":"text","text":" and all who live in them. "},{"kind":"crossref","label":"Is 33:1","book":"Isa","chapter":33,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jr 25:12","book":"Jer","chapter":25,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jr 25:14","book":"Jer","chapter":25,"verse":14,"letter":"c"},{"kind":"crossref","label":"Hab 2:17","book":"Hab","chapter":2,"verse":17,"letter":"d"},{"kind":"crossref","label":"Rv 13: