8:16","book":"Ezk","chapter":8,"verse":16,"letter":"h"},{"kind":"text","text":" which they have loved, served, followed, consulted, and worshiped. Their bones will not be collected and buried but will become like manure on the soil’s surface. "},{"kind":"crossref","label":"Ps 83:10","book":"Psa","chapter":83,"verse":10,"letter":"i"},{"kind":"crossref","label":"Jr 9:22","book":"Jer","chapter":9,"verse":22,"letter":"j"},{"kind":"crossref","label":"Jr 16:4","book":"Jer","chapter":16,"verse":4,"letter":"k"},{"kind":"crossref","label":"Jr 25:33","book":"Jer","chapter":25,"verse":33,"letter":"l"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Sm 21:12","book":"2Sa","chapter":21,"verse":12},{"label":"Ps 53:5","book":"Psa","chapter":53,"verse":5},{"label":"Ezk 6:5","book":"Ezk","chapter":6,"verse":5},{"label":"Dt 4:19","book":"Deu","chapter":4,"verse":19},{"label":"2Kg 17:16","book":"2Ki","chapter":17,"verse":16},{"label":"2Kg 21:3","book":"2Ki","chapter":21,"verse":3},{"label":"2Kg 23:4–5","book":"2Ki","chapter":23,"verse":4},{"label":"Ezk 8:16","book":"Ezk","chapter":8,"verse":16},{"label":"Ps 83:10","book":"Psa","chapter":83,"verse":10},{"label":"Jr 9:22","book":"Jer","chapter":9,"verse":22},{"label":"Jr 16:4","book":"Jer","chapter":16,"verse":4},{"label":"Jr 25:33","book":"Jer","chapter":25,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:8:3","parts":[{"kind":"text","text":"Death will be chosen over life "},{"kind":"crossref","label":"Dt 30:11","book":"Deu","chapter":30,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jb 3:21","book":"Job","chapter":3,"verse":21,"letter":"b"},{"kind":"crossref","label":"Jb 7:15–16","book":"Job","chapter":7,"verse":15,"letter":"c"},{"kind":"crossref","label":"Rv 9:6","book":"Rev","chapter":9,"verse":6,"letter":"d"},{"kind":"text","text":" by all the survivors of this evil family, those who remain wherever I have banished them.” "},{"kind":"crossref","label":"Jr 23:3","book":"Jer","chapter":23,"verse":3,"letter":