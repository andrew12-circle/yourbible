Sa","chapter":15,"verse":23,"letter":"a"},{"kind":"crossref","label":"1Sm 15:26","book":"1Sa","chapter":15,"verse":26,"letter":"b"},{"kind":"text","text":" so what wisdom do they really have?"}],"crossRefs":[{"label":"1Sm 15:23","book":"1Sa","chapter":15,"verse":23},{"label":"1Sm 15:26","book":"1Sa","chapter":15,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:8:10","parts":[{"kind":"text","text":"Therefore, I will give "},{"kind":"crossref","label":"Jr 6:13–15","book":"Jer","chapter":6,"verse":13,"letter":"a"},{"kind":"text","text":" their wives to other men,"},{"kind":"text","text":" their fields to new occupants,"},{"kind":"text","text":" for from the least to the greatest, "},{"kind":"crossref","label":"Est 1:20","book":"Est","chapter":1,"verse":20,"letter":"a"},{"kind":"crossref","label":"Jr 6:13","book":"Jer","chapter":6,"verse":13,"letter":"b"},{"kind":"crossref","label":"Jr 31:34","book":"Jer","chapter":31,"verse":34,"letter":"c"},{"kind":"crossref","label":"Jr 42:1","book":"Jer","chapter":42,"verse":1,"letter":"d"},{"kind":"crossref","label":"Jr 42:8","book":"Jer","chapter":42,"verse":8,"letter":"e"},{"kind":"crossref","label":"Jr 44:12","book":"Jer","chapter":44,"verse":12,"letter":"f"},{"kind":"text","text":" everyone is making profit dishonestly."},{"kind":"text","text":" From prophet to priest,"},{"kind":"text","text":" everyone deals falsely."}],"crossRefs":[{"label":"Jr 6:13–15","book":"Jer","chapter":6,"verse":13},{"label":"Est 1:20","book":"Est","chapter":1,"verse":20},{"label":"Jr 6:13","book":"Jer","chapter":6,"verse":13},{"label":"Jr 31:34","book":"Jer","chapter":31,"verse":34},{"label":"Jr 42:1","book":"Jer","chapter":42,"verse":1},{"label":"Jr 42:8","book":"Jer","chapter":42,"verse":8},{"label":"Jr 44:12","book":"Jer","chapter":44,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:8:11","parts":[{"kind":"text","text":"They have treated the brokenness"},{"kind":"text","text":" of my dear "},{"kind":"footnote","marker":1,"text":"Lit of the daughter of my, also in vv. 19,21,22"},{"kind":"text","text":" people superficially,"},{"kind":"text","text":" claiming, ‘Peace, peace,’"},{"kind":"text","text":" when there is no peace."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit of the daughter of my, also in vv. 19,21,22"}]},{"verseId":"a556c5305ee15c3f-01:Jer:8:12","parts":[{"kind":"text","text":"Were they ashamed when they acted so detestably?"},{"kind":"text","text":" They weren’t at all ashamed."},{"kind":"text","text":" They can no longer feel humiliation."},{"kind":"text","text":" Therefore, they will fall among the fallen."},{"kind":"text","text":" When I punish them, they will collapse,” "},{"kind":"crossref","label":"Jr 10:15","book":"Jer","chapter":10,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jr 49:8","book":"Jer","chapter":49,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jr 51:18","book":"Jer","chapter":51,"verse":18,"letter":"c"},{"kind":"text","text":" says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Jr 10:15","book":"Jer","chapter":10,"verse":15},{"label":"Jr 49:8","book":"Jer","chapter":49,"verse":8},{"label":"Jr 51:18","book":"Jer","chapter":51,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:8:13","parts":[{"kind":"text","text":"“I will gather them and bring them to an end.” "},{"kind":"footnote","marker":1,"text":"Lit Gathering I will end them"},{"kind":"crossref","label":"Zp 1:2","book":"Zep","chapter":1,"verse":2,"letter":"a"},{"kind":"text","text":" “There will be no grapes on the vine,"},{"kind":"text","text":" no figs on the fig tree,"},{"kind":"text","text":" and even the leaf will wither."},{"kind":"text","text":" Whatever I have given them will be lost to them.”"}],"crossRefs":[{"label":"Zp 1:2","book":"Zep","chapter":1,"verse":2}],"footnotes":[{"marker":1,"text":"Lit Gathering I will end them"}]},{"verseId":"a556c5305ee15c3f-01:Jer:8:14","parts":[{"kind":"text