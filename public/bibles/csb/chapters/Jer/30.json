text":"How awful that day will be! "},{"kind":"crossref","label":"Jl 2:11","book":"Jol","chapter":2,"verse":11,"letter":"a"},{"kind":"crossref","label":"Zp 1:14","book":"Zep","chapter":1,"verse":14,"letter":"b"},{"kind":"text","text":" There will be no other like it! "},{"kind":"crossref","label":"Dn 12:1","book":"Dan","chapter":12,"verse":1,"letter":"a"},{"kind":"text","text":" It will be a time of trouble for Jacob,"},{"kind":"text","text":" but he will be saved out of it."}],"crossRefs":[{"label":"Jl 2:11","book":"Jol","chapter":2,"verse":11},{"label":"Zp 1:14","book":"Zep","chapter":1,"verse":14},{"label":"Dn 12:1","book":"Dan","chapter":12,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:8","parts":[{"kind":"text","text":"On that day —"},{"kind":"text","text":" I will break his yoke from your neck "},{"kind":"crossref","label":"Gn 27:40","book":"Gen","chapter":27,"verse":40,"letter":"a"},{"kind":"crossref","label":"Jr 2:20","book":"Jer","chapter":2,"verse":20,"letter":"b"},{"kind":"crossref","label":"Jr 28:4","book":"Jer","chapter":28,"verse":4,"letter":"c"},{"kind":"crossref","label":"Jr 28:11","book":"Jer","chapter":28,"verse":11,"letter":"d"},{"kind":"crossref","label":"Ezk 34:27","book":"Ezk","chapter":34,"verse":27,"letter":"e"},{"kind":"crossref","label":"Nah 1:13","book":"Nam","chapter":1,"verse":13,"letter":"f"},{"kind":"text","text":" and tear off your chains, "},{"kind":"crossref","label":"Jr 27:2","book":"Jer","chapter":27,"verse":2,"letter":"a"},{"kind":"text","text":" and strangers will never again enslave him. "},{"kind":"crossref","label":"Ezk 34:27","book":"Ezk","chapter":34,"verse":27,"letter":"a"}],"crossRefs":[{"label":"Gn 27:40","book":"Gen","chapter":27,"verse":40},{"label":"Jr 2:20","book":"Jer","chapter":2,"verse":20},{"label":"Jr 28:4","book":"Jer","chapter":28,"verse":4},{"label":"Jr 28:11","book":"Jer","chapter":28,"verse":11},{"label":"Ezk 34:27","book":"Ezk","chapter":34,"verse":27},{"label":"Nah 1:13","book":"Nam","chapter":1,"verse":13},{"label":"Jr 27:2","book":"Jer","chapter":27,"verse":2},{"label":"Ezk 34:27","book":"Ezk","chapter":34,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:9","parts":[{"kind":"text","text":"They will serve the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" their God"},{"kind":"text","text":" and David their king,"},{"kind":"text","text":" whom I will raise up for them. "},{"kind":"crossref","label":"Is 55:3–5","book":"Isa","chapter":55,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ezk 34:23–24","book":"Ezk","chapter":34,"verse":23,"letter":"b"},{"kind":"crossref","label":"Ezk 37:24–25","book":"Ezk","chapter":37,"verse":24,"letter":"c"},{"kind":"crossref","label":"Hs 3:5","book":"Hos","chapter":3,"verse":5,"letter":"d"},{"kind":"crossref","label":"Lk 1:69","book":"Luk","chapter":1,"verse":69,"letter":"e"},{"kind":"crossref","label":"Ac 13:23","book":"Act","chapter":13,"verse":23,"letter":"f"},{"kind":"crossref","label":"Ac 13:34","book":"Act","chapter":13,"verse":34,"letter":"g"}],"crossRefs":[{"label":"Is 55:3–5","book":"Isa","chapter":55,"verse":3},{"label":"Ezk 34:23–24","book":"Ezk","chapter":34,"verse":23},{"label":"Ezk 37:24–25","book":"Ezk","chapter":37,"verse":24},{"label":"Hs 3:5","book":"Hos","chapter":3,"verse":5},{"label":"Lk 1:69","book":"Luk","chapter":1,"verse":69},{"label":"Ac 13:23","book":"Act","chapter":13,"verse":23},{"label":"Ac 13:34","book":"Act","chapter":13,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:10","parts":[{"kind":"text","text":"As for you, my servant Jacob, "},{"kind":"crossref","label":"Is 41:8","book":"Isa","chapter":41,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 44:2","book":"Isa","chapter":44,"verse":2,"letter":"b"},{"kind":"crossref","label":"Is 45:4","book":"Isa","chapter":45,"verse":4,"letter":"c"},{"kind":"crossref","label":"Is 48:20","book":"Isa","chapter":48,"verse":20,"letter":"d"},{"kind":"crossref","label":"Jr 46:27","book":"Jer","chapter":46,"verse":27,"letter":"e"},{"kind":"crossref","label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25,"letter":"f"},{"kind":"crossref","label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25,"letter":"g"},{"kind":"text","text":" do not be afraid —"},{"kind":"text","text":" and do not be discouraged, Israel,"},{"kind":"text","text":" for without fail I will save you out of a distant place,"},{"kind":"text","text":" your descendants, from the land of their captivity!"},{"kind":"text","text":" Jacob will return and have calm and quiet"},{"kind":"text","text":" with no one to frighten him. "},{"kind":"crossref","label":"Lv 26:6","book":"Lev","chapter":26,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 46:27","book":"Jer","chapter":46,"verse":27,"letter":"b"},{"kind":"crossref","label":"Ezk 34:28","book":"Ezk","chapter":34,"verse":28,"letter":"c"},{"kind":"crossref","label":"Ezk 39:26","book":"Ezk","chapter":39,"verse":26,"letter":"d"},{"kind":"crossref","label":"Mc 4:4","book":"Mic","chapter":4,"verse":4,"letter":"e"},{"kind":"crossref","label":"Zp 3:13","book":"Zep","chapter":3,"verse":13,"letter":"f"}],"crossRefs":[{"label":"Is 41:8","book":"Isa","chapter":41,"verse":8},{"label":"Is 44:2","book":"Isa","chapter":44,"verse":2},{"label":"Is 45:4","book":"Isa","chapter":45,"verse":4},{"label":"Is 48:20","book":"Isa","chapter":48,"verse":20},{"label":"Jr 46:27","book":"Jer","chapter":46,"verse":27},{"label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25},{"label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25},{"label":"Lv 26:6","book":"Lev","chapter":26,"verse":6},{"label":"Jr 46:27","book":"Jer","chapter":46,"verse":27},{"label":"Ezk 34:28","book":"Ezk","chapter":34,"verse":28},{"label":"Ezk 39:26","book":"Ezk","chapter":39,"verse":26},{"label":"Mc 4:4","book":"Mic","chapter":4,"verse":4},{"label":"Zp 3:13","book":"Zep","chapter":3,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:11","parts":[{"kind":"text","text":"For I will be with you —"},{"kind":"text","text":" to save you! "},{"kind":"crossref","label":"2Kg 19:34","book":"2Ki","chapter":19,"verse":34,"letter":"a"},{"kind":"crossref","label":"Is 37:35","book":"Isa","chapter":37,"verse":35,"letter":"b"},{"kind":"crossref","label":"Jr 15:20","book":"Jer","chapter":15,"verse":20,"letter":"c"},{"kind":"text","text":" I will bring destruction on all the nations"},{"kind":"text","text":" where I have scattered you;"},{"kind":"text","text":" however, I will not bring destruction on you."},{"kind":"text","text":" I will discipline you justly,"},{"kind":"text","text":" and I will by no means leave you unpunished. "},{"kind":"crossref","label":"Ex 34:7","book":"Exo","chapter":34,"verse":7,"letter":"a"},{"kind":"crossref","label":"Jr 46:27–28","book":"Jer","chapter":46,"verse":27,"letter":"b"}],"crossRefs":[{"label":"2Kg 19:34","book":"2Ki","chapter":19,"verse":34},{"label":"Is 37:35","book":"Isa","chapter":37,"verse":35},{"label":"Jr 15:20","book":"Jer","chapter":15,"verse":20},{"label":"Ex 34:7","book":"Exo","chapter":34,"verse":7},{"label":"Jr 46:27–28","book":"Jer","chapter":46,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:12","parts":[{"kind":"text","text":"For this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" Your injury is incurable;"},{"kind":"text","text":" your wound most severe. "},{"kind":"crossref","label":"Jr 10:19","book":"Jer","chapter":10,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 15:18","book":"Jer","chapter":15,"verse":18,"letter":"b"},{"kind":"crossref","label":"Jr 17:9","book":"Jer","chapter":17,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Jr 10:19","book":"Jer","chapter":10,"verse":19},{"label":"Jr 15:18","book":"Jer","chapter":15,"verse":18},{"label":"Jr 17:9","book":"Jer","chapter":17,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:13","parts":[{"kind":"text","text":"You have no defender for your case. "},{"kind":"crossref","label":"Hs 5:13","book":"Hos","chapter":5,"verse":13,"letter":"a"},{"kind":"text","text":" There is no remedy for your sores,"},{"kind":"text","text":" and no healing for you. "},{"kind":"footnote","marker":1,"text":"Or No one pleads that your sores should be healed. There is no remedy for you."}],"crossRefs":[{"label":"Hs 5:13","book":"Hos","chapter":5,"verse":13}],"footnotes":[{"marker":1,"text":"Or No one pleads that your sores should be healed. There is no remedy for you."}]},{"verseId":"a556c5305ee15c3f-01:Jer:30:14","parts":[{"kind":"text","text":"All your lovers have forgotten you; "},{"kind":"crossref","label":"Jr 4:30","book":"Jer","chapter":4,"verse":30,"letter":"a"},{"kind":"crossref","label":"Lm 1:19","book":"Lam","chapter":1,"verse":19,"letter":"b"},{"kind":"text","text":" they no longer look for you,"},{"kind":"text","text":" for I have struck you as an enemy would,"},{"kind":"text","text":" with the discipline "},{"kind":"crossref","label":"Jr 2:30","book":"Jer","chapter":2,"verse":30,"letter":"a"},{"kind":"crossref","label":"Jr 5:3","book":"Jer","chapter":5,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jr 7:28","book":"Jer","chapter":7,"verse":28,"letter":"c"},{"kind":"text","text":" of someone cruel, "},{"kind":"crossref","label":"Is 13:9","book":"Isa","chapter":13,"verse":9,"letter":"d"},{"kind":"text","text":" because of your enormous guilt"},{"kind":"text","text":" and your innumerable sins."}],"crossRefs":[{"label":"Jr 4:30","book":"Jer","chapter":4,"verse":30},{"label":"Lm 1:19","book":"Lam","chapter":1,"verse":19},{"label":"Jr 2:30","book":"Jer","chapter":2,"verse":30},{"label":"Jr 5:3","book":"Jer","chapter":5,"verse":3},{"label":"Jr 7:28","book":"Jer","chapter":7,"verse":28},{"label":"Is 13:9","book":"Isa","chapter":13,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:15","parts":[{"kind":"text","text":"Why do you cry out about your injury?"},{"kind":"text","text":" Your pain has no cure!"},{"kind":"text","text":" I have done these things to you"},{"kind":"text","text":" because of your enormous guilt"},{"kind":"text","text":" and your innumerable sins. "},{"kind":"crossref","label":"Jr 5:6","book":"Jer","chapter":5,"verse":6,"letter":"a"},{"kind":"crossref","label":"Am 5:12","book":"Amo","chapter":5,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Jr 5:6","book":"Jer","chapter":5,"verse":6},{"label":"Am 5:12","book":"Amo","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:16","parts":[{"kind":"text","text":"Nevertheless, all who devoured you will be devoured, "},{"kind":"crossref","label":"Jr 10:25","book":"Jer","chapter":10,"verse":25,"letter":"a"},{"kind":"text","text":" and all your adversaries —all of them —"},{"kind":"text","text":" will go off into exile."},{"kind":"text","text":" Those who plunder you will be plundered,"},{"kind":"text","text":" and all who raid you will be raided. "},{"kind":"crossref","label":"Ezk 39:10","book":"Ezk","chapter":39,"verse":10,"letter":"a"},{"kind":"crossref","label":"Hab 2:8","book":"Hab","chapter":2,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Jr 10:25","book":"Jer","chapter":10,"verse":25},{"label":"Ezk 39:10","book":"Ezk","chapter":39,"verse":10},{"label":"Hab 2:8","book":"Hab","chapter":2,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:17","parts":[{"kind":"text","text":"But I will bring you health "},{"kind":"crossref","label":"Is 58:8","book":"Isa","chapter":58,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jr 8:22","book":"Jer","chapter":8,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jr 33:6","book":"Jer","chapter":33,"verse":6,"letter":"c"},{"kind":"text","text":" and will heal you of your wounds —"},{"kind":"text","text":" for they call you Outcast,"},{"kind":"text","text":" Zion whom no one cares about."}],"crossRefs":[{"label":"Is 58:8","book":"Isa","chapter":58,"verse":8},{"label":"Jr 8:22","book":"Jer","chapter":8,"verse":22},{"label":"Jr 33:6","book":"Jer","chapter":33,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:18","parts":[{"kind":"text","text":"This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" I will certainly restore the fortunes "},{"kind":"footnote","marker":1,"text":"Or certainly end the captivity"},{"kind":"text","text":" of Jacob’s tents "},{"kind":"crossref","label":"Jr 30:3","book":"Jer","chapter":30,"verse":3,"letter":"a"},{"kind":"text","text":" and show compassion "},{"kind":"crossref","label":"Jr 12:15","book":"Jer","chapter":12,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jr 31:20","book":"Jer","chapter":31,"verse":20,"letter":"b"},{"kind":"crossref","label":"Jr 33:26","book":"Jer","chapter":33,"verse":26,"letter":"c"},{"kind":"crossref","label":"Jr 42:12","book":"Jer","chapter":42,"verse":12,"letter":"d"},{"kind":"text","text":" on his dwellings."},{"kind":"text","text":" Every city will be rebuilt on its mound;"},{"kind":"text","text":" every citadel will stand on its proper site."}],"crossRefs":[{"label":"Jr 30:3","book":"Jer","chapter":30,"verse":3},{"label":"Jr 12:15","book":"Jer","chapter":12,"verse":15},{"label":"Jr 31:20","book":"Jer","chapter":31,"verse":20},{"label":"Jr 33:26","book":"Jer","chapter":33,"verse":26},{"label":"Jr 42:12","book":"Jer","chapter":42,"verse":12}],"footnotes":[{"marker":1,"text":"Or certainly end the captivity"}]},{"verseId":"a556c5305ee15c3f-01:Jer:30:19","parts":[{"kind":"text","text":"Thanksgiving will come out of them,"},{"kind":"text","text":" a sound of rejoicing."},{"kind":"text","text":" I will multiply them, and they will not decrease; "},{"kind":"crossref","label":"Jr 29:6","book":"Jer","chapter":29,"verse":6,"letter":"a"},{"kind":"text","text":" I will honor them, and they will not be insignificant."}],"crossRefs":[{"label":"Jr 29:6","book":"Jer","chapter":29,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:20","parts":[{"kind":"text","text":"His children will be as in past days;"},{"kind":"text","text":" his congregation will be established in my presence."},{"kind":"text","text":" I will punish all his oppressors. "},{"kind":"crossref","label":"Jdg 10:12","book":"Jdg","chapter":10,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 19:20–25","book":"Isa","chapter":19,"verse":20,"letter":"b"}],"crossRefs":[{"label":"Jdg 10:12","book":"Jdg","chapter":10,"verse":12},{"label":"Is 19:20–25","book":"Isa","chapter":19,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:21","parts":[{"kind":"text","text":"Jacob’s leader will be one of them;"},{"kind":"text","text":" his ruler will issue from him."},{"kind":"text","text":" I will invite him to me, and he will approach me, "},{"kind":"crossref","label":"Nm 16:5","book":"Num","chapter":16,"verse":5,"letter":"a"},{"kind":"text","text":" for who would otherwise risk his life to approach me?"}],"crossRefs":[{"label":"Nm 16:5","book":"Num","chapter":16,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:22","parts":[{"kind":"text","text":"You will be my people,"},{"kind":"text","text":" and I will be your God. "},{"kind":"crossref","label":"Jr 11:4","book":"Jer","chapter":11,"verse":4,"letter":"a"},{"kind":"crossref","label":"Jr 24:7","book":"Jer","chapter":24,"verse":7,"letter":"b"},{"kind":"crossref","label":"Jr 31:33","book":"Jer","chapter":31,"verse":33,"letter":"c"}],"crossRefs":[{"label":"Jr 11:4","book":"Jer","chapter":11,"verse":4},{"label":"Jr 24:7","book":"Jer","chapter":24,"verse":7},{"label":"Jr 31:33","book":"Jer","chapter":31,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:23","parts":[{"kind":"text","text":"Look, a storm from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"! "},{"kind":"crossref","label":"Ps 83:15","book":"Psa","chapter":83,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 29:6","book":"Isa","chapter":29,"verse":6,"letter":"b"},{"kind":"crossref","label":"Zch 9:14","book":"Zec","chapter":9,"verse":14,"letter":"c"},{"kind":"text","text":" Wrath has gone out,"},{"kind":"text","text":" a churning storm."},{"kind":"text","text":" It will whirl about the heads of the wicked."}],"crossRefs":[{"label":"Ps 83:15","book":"Psa","chapter":83,"verse":15},{"label":"Is 29:6","book":"Isa","chapter":29,"verse":6},{"label":"Zch 9:14","book":"Zec","chapter":9,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:30:24","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s burning anger will not turn back"},{"kind":"text","text":" until he has completely fulfilled the purposes of his heart."},{"kind":"text","text":" In time to come you will understand it. "},{"kind":"crossref","label":"Jr 23:19–20","book":"Jer","chapter":23,"verse":19,"letter":"a"}],"crossRefs":[{"label":"Jr 23:19–20","book":"Jer","chapter":23,"verse":19}],"footnotes":[]}]},"cachedAt":1783279566609}