":"b"},{"kind":"text","text":" and the birds of the sky and the wild animals of the land "},{"kind":"crossref","label":"Is 18:6","book":"Isa","chapter":18,"verse":6,"letter":"c"},{"kind":"crossref","label":"Jr 7:33","book":"Jer","chapter":7,"verse":33,"letter":"d"},{"kind":"crossref","label":"Jr 19:7","book":"Jer","chapter":19,"verse":7,"letter":"e"},{"kind":"text","text":" to devour and destroy. "}],"crossRefs":[{"label":"Jr 22:19","book":"Jer","chapter":22,"verse":19},{"label":"Jr 49:20–50:45","book":"Jer","chapter":49,"verse":20},{"label":"Is 18:6","book":"Isa","chapter":18,"verse":6},{"label":"Jr 7:33","book":"Jer","chapter":7,"verse":33},{"label":"Jr 19:7","book":"Jer","chapter":19,"verse":7}],"footnotes":[{"marker":1,"text":"Lit families"}]},{"verseId":"a556c5305ee15c3f-01:Jer:15:4","parts":[{"kind":"text","text":"I will make them a horror to all the kingdoms of the earth because of Manasseh "},{"kind":"crossref","label":"2Kg 21:1","book":"2Ki","chapter":21,"verse":1,"letter":"a"},{"kind":"crossref","label":"2Ch 33:1–20","book":"2Ch","chapter":33,"verse":1,"letter":"b"},{"kind":"text","text":" son of Hezekiah, the king of Judah, for what he did in Jerusalem."}],"crossRefs":[{"label":"2Kg 21:1","book":"2Ki","chapter":21,"verse":1},{"label":"2Ch 33:1–20","book":"2Ch","chapter":33,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:5","parts":[{"kind":"text","text":"Who will have pity on you, Jerusalem? "},{"kind":"crossref","label":"Lm 1:1","book":"Lam","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Am 5:2","book":"Amo","chapter":5,"verse":2,"letter":"b"},{"kind":"text","text":" Who will show sympathy toward you? "},{"kind":"crossref","label":"Is 51:19","book":"Isa","chapter":51,"verse":19,"letter":"a"},{"kind":"crossref","label":"Nah 3:7","book":"Nam","chapter":3,"verse":7,"letter":"b"},{"kind":"text","text":" Who will turn aside"},{"kind":"text","text":" to ask about your well-being?"}],"crossRefs":[{"label":"Lm 1:1","book":"Lam