still day;"},{"kind":"text","text":" she was ashamed and humiliated."},{"kind":"text","text":" The rest of them I will give over to the sword"},{"kind":"text","text":" in the presence of their enemies.”"}],"crossRefs":[{"label":"Ru 4:15","book":"Rut","chapter":4,"verse":15},{"label":"1Sm 2:5","book":"1Sa","chapter":2,"verse":5},{"label":"Jb 42:13","book":"Job","chapter":42,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:10","parts":[{"kind":"text","text":"Woe is me, my mother,"},{"kind":"text","text":" that you gave birth to me, "},{"kind":"crossref","label":"Jb 3:1","book":"Job","chapter":3,"verse":1,"letter":"a"},{"kind":"text","text":" a man who incites dispute and conflict"},{"kind":"text","text":" in all the land."},{"kind":"text","text":" I did not lend or borrow,"},{"kind":"text","text":" yet everyone curses me. "},{"kind":"crossref","label":"Is 53:3","book":"Isa","chapter":53,"verse":3,"letter":"a"}],"crossRefs":[{"label":"Jb 3:1","book":"Job","chapter":3,"verse":1},{"label":"Is 53:3","book":"Isa","chapter":53,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:11","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said:"},{"kind":"text","text":" Haven’t I set you loose for your good?"},{"kind":"text","text":" Haven’t I punished you"},{"kind":"text","text":" in a time of trouble,"},{"kind":"text","text":" in a time of distress with the enemy? "},{"kind":"footnote","marker":1,"text":"Hb obscure"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Jer:15:12","parts":[{"kind":"text","text":"Can anyone smash iron,"},{"kind":"text","text":" iron from the north, or bronze?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:13","parts":[{"kind":"text","text":"I will give up your wealth"},{"kind":"text","text":" and your treasures as plunder,"},{"kind":"text","text":" without cost, "},{"kind":"crossref","label":"Ps 44:12","book":"Psa","chapter":44,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 52:3","book":"Isa","chapter":52,"verse":3,"letter":"b"},{"kind":"text","text":" for all your sins"},{"kind":"text","text":" in all your borders."}],"crossRefs":[{"label":"Ps 44:12","book":"Psa","chapter":44,"verse":12},{"label":"Is 52:3","book":"Isa","chapter":52,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:14","parts":[{"kind":"text","text":"Then I will make you serve your enemies "},{"kind":"footnote","marker":1,"text":"Some Hb mss, LXX, Syr, Tg; other Hb mss read you pass through"},{"kind":"text","text":" in a land you do not know,"},{"kind":"text","text":" for my anger will kindle a fire"},{"kind":"text","text":" that will burn against you. "},{"kind":"crossref","label":"Dt 32:22","book":"Deu","chapter":32,"verse":22,"letter":"a"},{"kind":"crossref","label":"Jr 17:3–4","book":"Jer","chapter":17,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ezk 32:9","book":"Ezk","chapter":32,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Dt 32:22","book":"Deu","chapter":32,"verse":22},{"label":"Jr 17:3–4","book":"Jer","chapter":17,"verse":3},{"label":"Ezk 32:9","book":"Ezk","chapter":32,"verse":9}],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX, Syr, Tg; other Hb mss read you pass through"}]},{"verseId":"a556c5305ee15c3f-01:Jer:15:15","parts":[{"kind":"text","text":"You know, "},{"kind":"crossref","label":"Jr 12:3","book":"Jer","chapter":12,"verse":3,"letter":"a"},{"kind":"text","text":" "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"},{"kind":"text","text":" remember me and take note of me. "},{"kind":"crossref","label":"Jdg 16:28","book":"Jdg","chapter":16,"verse":28,"letter":"a"},{"kind":"crossref","label":"Neh 5:19","book":"Neh","chapter":5,"verse":19,"letter":"b"},{"kind":"crossref","label":"Neh 13:14","book":"Neh","chapter":13,"verse":14,"letter":"c"},{"kind":"crossref","label":"Neh 13:22","book":"Neh","chapter":13,"verse":22,"letter":"d"},{"kind":"crossref","label":"Neh 13:31","book":"Neh","chapter":13,"verse":31,"letter":"e"},{"kind":"crossref","label":"Ps 106:4","book":"Psa","chapter":106,"verse":4,"letter":"f"},{"kind":"crossref","label":"Lk 23:42","book":"Luk","chapter":23,"verse":42,"letter":"g"},{"kind":"text","text":" Avenge me against my persecutors. "},{"kind":"crossref","label":"Jr 11:20","book":"Jer","chapter":11,"verse":20,"letter":"a"},{"kind":"text","text":" In your patience, "},{"kind":"footnote","marker":1,"text":"Lit In the slowness of your anger"},{"kind":"text","text":" don’t take me away."},{"kind":"text","text":" Know that I suffer disgrace for your honor. "},{"kind":"crossref","label":"Ps 69:7–9","book":"Psa","chapter":69,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Jr 12:3","book":"Jer","chapter":12,"verse":3},{"label":"Jdg 16:28","book":"Jdg","chapter":16,"verse":28},{"label":"Neh 5:19","book":"Neh","chapter":5,"verse":19},{"label":"Neh 13:14","book":"Neh","chapter":13,"verse":14},{"label":"Neh 13:22","book":"Neh","chapter":13,"verse":22},{"label":"Neh 13:31","book":"Neh","chapter":13,"verse":31},{"label":"Ps 106:4","book":"Psa","chapter":106,"verse":4},{"label":"Lk 23:42","book":"Luk","chapter":23,"verse":42},{"label":"Jr 11:20","book":"Jer","chapter":11,"verse":20},{"label":"Ps 69:7–9","book":"Psa","chapter":69,"verse":7}],"footnotes":[{"marker":1,"text":"Lit In the slowness of your anger"}]},{"verseId":"a556c5305ee15c3f-01:Jer:15:16","parts":[{"kind":"text","text":"Your words were found, and I ate them. "},{"kind":"crossref","label":"Ezk 3:3","book":"Ezk","chapter":3,"verse":3,"letter":"a"},{"kind":"text","text":" Your words became a delight to me"},{"kind":"text","text":" and the joy of my heart,"},{"kind":"text","text":" for I bear your name, "},{"kind":"crossref","label":"Jr 14:9","book":"Jer","chapter":14,"verse":9,"letter":"a"},{"kind":"text","text":" Lord","style":"divine"},{"kind":"text","text":" God of Armies."}],"crossRefs":[{"label":"Ezk 3:3","book":"Ezk","chapter":3,"verse":3},{"label":"Jr 14:9","book":"Jer","chapter":14,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:17","parts":[{"kind":"text","text":"I never sat with the band of revelers,"},{"kind":"text","text":" and I did not celebrate with them."},{"kind":"text","text":" Because your hand was on me, I sat alone, "},{"kind":"crossref","label":"2Kg 3:15","book":"2Ki","chapter":3,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ps 102:7","book":"Psa","chapter":102,"verse":7,"letter":"b"},{"kind":"crossref","label":"Is 8:11","book":"Isa","chapter":8,"verse":11,"letter":"c"},{"kind":"crossref","label":"Lm 3:28","book":"Lam","chapter":3,"verse":28,"letter":"d"},{"kind":"text","text":" for you filled me with indignation."}],"crossRefs":[{"label":"2Kg 3:15","book":"2Ki","chapter":3,"verse":15},{"label":"Ps 102:7","book":"Psa","chapter":102,"verse":7},{"label":"Is 8:11","book":"Isa","chapter":8,"verse":11},{"label":"Lm 3:28","book":"Lam","chapter":3,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:18","parts":[{"kind":"text","text":"Why has my pain become unending,"},{"kind":"text","text":" my wound incurable, "},{"kind":"crossref","label":"Jr 19:8","book":"Jer","chapter":19,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jr 30:12","book":"Jer","chapter":30,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jr 30:14","book":"Jer","chapter":30,"verse":14,"letter":"c"},{"kind":"crossref","label":"Jr 30:17","book":"Jer","chapter":30,"verse":17,"letter":"d"},{"kind":"text","text":" refusing to be healed?"},{"kind":"text","text":" You truly have become like a mirage to me —"},{"kind":"text","text":" water that is not reliable."}],"crossRefs":[{"label":"Jr 19:8","book":"Jer","chapter":19,"verse":8},{"label":"Jr 30:12","book":"Jer","chapter":30,"verse":12},{"label":"Jr 30:14","book":"Jer","chapter":30,"verse":14},{"label":"Jr 30:17","book":"Jer","chapter":30,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:19","parts":[{"kind":"text","text":"Therefore, this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" If you return, I will take you back;"},{"kind":"text","text":" you will stand in my presence."},{"kind":"text","text":" And if you speak noble words,"},{"kind":"text","text":" rather than worthless ones,"},{"kind":"text","text":" you will be my spokesman. "},{"kind":"crossref","label":"Ex 4:16","book":"Exo","chapter":4,"verse":16,"letter":"a"},{"kind":"text","text":" It is they who must return to you;"},{"kind":"text","text":" you must not return to them."}],"crossRefs":[{"label":"Ex 4:16","book":"Exo","chapter":4,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:20","parts":[{"kind":"text","text":"Then I will make you a fortified wall of bronze"},{"kind":"text","text":" to this people."},{"kind":"text","text":" They will fight against you"},{"kind":"text","text":" but will not overcome you,"},{"kind":"text","text":" for I am with you"},{"kind":"text","text":" to save you and rescue you. "},{"kind":"crossref","label":"Jr 1:8","book":"Jer","chapter":1,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jr 1:19","book":"Jer","chapter":1,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jr 30:11","book":"Jer","chapter":30,"verse":11,"letter":"c"},{"kind":"crossref","label":"Jr 42:11","book":"Jer","chapter":42,"verse":11,"letter":"d"}],"crossRefs":[{"label":"Jr 1:8","book":"Jer","chapter":1,"verse":8},{"label":"Jr 1:19","book":"Jer","chapter":1,"verse":19},{"label":"Jr 30:11","book":"Jer","chapter":30,"verse":11},{"label":"Jr 42:11","book":"Jer","chapter":42,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:15:21","parts":[{"kind":"text","text":"I will rescue you from the power of evil people"},{"kind":"text","text":" and redeem you from the grasp of the ruthless."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279562037}