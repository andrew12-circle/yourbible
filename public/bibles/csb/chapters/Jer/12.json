{"key":"a556c5305ee15c3f-01|Jer|12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","chapter":12,"textRevision":"api-bible-csb-2024","parserRevision":"v10","verses":[{"verseId":"a556c5305ee15c3f-01:Jer:12:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":1,"text":"You will be righteous, Lord,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":2,"text":"You planted them, and they have taken root.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":3,"text":"As for you, Lord, you know me; you see me. Ps 139","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":4,"text":"How long will the land mourn","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":5,"text":"If you have raced with runners","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":6,"text":"Even your brothers —your own father’s family —","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":7,"text":"I have abandoned my house;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":8,"text":"My inheritance has behaved toward me","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Jer:12:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Jer","bookOrder":23,"chapter":12,"verse":9,"text":"Is