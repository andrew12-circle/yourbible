kind":"text","text":"I will go to the powerful"},{"kind":"text","text":" and speak to them."},{"kind":"text","text":" Surely they know the way of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" the justice of their God. "},{"kind":"crossref","label":"Ps 103:7","book":"Psa","chapter":103,"verse":7,"letter":"a"},{"kind":"text","text":" However, these also had broken the yoke"},{"kind":"text","text":" and torn off the chains. "},{"kind":"crossref","label":"Ps 2:3","book":"Psa","chapter":2,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 2:20","book":"Jer","chapter":2,"verse":20,"letter":"b"}],"crossRefs":[{"label":"Ps 103:7","book":"Psa","chapter":103,"verse":7},{"label":"Ps 2:3","book":"Psa","chapter":2,"verse":3},{"label":"Jr 2:20","book":"Jer","chapter":2,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:5:6","parts":[{"kind":"text","text":"Therefore, a lion from the forest will strike them down. "},{"kind":"crossref","label":"2Kg 17:26","book":"2Ki","chapter":17,"verse":26,"letter":"a"},{"kind":"crossref","label":"Jr 4:7","book":"Jer","chapter":4,"verse":7,"letter":"b"},{"kind":"crossref","label":"Jr 25:38","book":"Jer","chapter":25,"verse":38,"letter":"c"},{"kind":"text","text":" A wolf from arid plains will ravage them."},{"kind":"text","text":" A leopard "},{"kind":"crossref","label":"Hs 13:7","book":"Hos","chapter":13,"verse":7,"letter":"a"},{"kind":"crossref","label":"Rv 13:2","book":"Rev","chapter":13,"verse":2,"letter":"b"},{"kind":"text","text":" stalks their cities."},{"kind":"text","text":" Anyone who leaves them will be torn to pieces"},{"kind":"text","text":" because their rebellious acts are many, "},{"kind":"crossref","label":"Is 59:12","book":"Isa","chapter":59,"verse":12,"letter":"a"},{"kind":"text","text":" their unfaithful deeds numerous. "},{"kind":"crossref","label":"Jr 3:6","book":"Jer","chapter":3,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 3:8","book":"Jer","chapter":3,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jr 3:11","book":"Jer","chapter":3,"verse":11,"letter":"c"},{"kind":"crossref","label":"Jr 3:22","book":"Jer","chapter":3,"verse":22,"letter":"d"},{"kind":"crossref","label":"Jr 14:7","book":"Jer","chapter":14,"verse":7,"letter":"e"},{"kind":"crossref","label":"Jr 30:15","book":"Jer","chapter":30,"verse":15,"letter":"f"},{"kind":"crossref","label":"Am 5:12","book":"Amo","chapter":5,"verse":12,"letter":"g"}],"crossRefs":[{"label":"2Kg 17:26","book":"2Ki","chapter":17,"verse":26},{"label":"Jr 4:7","book":"Jer","chapter":4,"verse":7},{"label":"Jr 25:38","book":"Jer","chapter":25,"verse":38},{"label":"Hs 13:7","book":"Hos","chapter":13,"verse":7},{"label":"Rv 13:2","book":"Rev","chapter":13,"verse":2},{"label":"Is 59:12","book":"Isa","chapter":59,"verse":12},{"label":"Jr 3:6","book":"Jer","chapter":3,"verse":6},{"label":"Jr 3:8","book":"Jer","chapter":3,"verse":8},{"label":"Jr 3:11","book":"Jer","chapter":3,"verse":11},{"label":"Jr 3:22","book":"Jer","chapter":3,"verse":22},{"label":"Jr 14:7","book":"Jer","chapter":14,"verse":7},{"label":"Jr 30:15","book":"Jer","chapter":30,"verse":15},{"label":"Am 5:12","book":"Amo","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:5:7","parts":[{"kind":"text","text":"Why should I forgive you?"},{"kind":"text","text":" Your children have abandoned me"},{"kind":"text","text":" and sworn by those who are not gods. "},{"kind":"crossref","label":"Dt 32:21","book":"Deu","chapter":32,"verse":21,"letter":"a"},{"kind":"crossref","label":"Jos 23:7","book":"Jos","chapter":23,"verse":7,"letter":"b"},{"kind":"crossref","label":"Gl 4:8","book":"Gal","chapter":4,"verse":8,"letter":"c"},{"kind":"text","text":" I satisfied their needs, yet they committed adultery; "},{"kind":"crossref","label":"Hs 4:10","book":"Hos","chapter":4,"verse":10,"letter":"a"},{"kind":"text","text":" they gashed themselves "},{"kind":"crossref","label":"1Kg 18:24","book":"1Ki","chapter":18,"verse":24,"letter":"a"},{"kind":"text","text":" at the "},{"kind":"footnote","marker":1,"text":"Or adultery and trooped to the, or adultery and lodged at the; Hb obscure"},{"kind":"text","text":" prostitute’s house."}],"crossRefs":[{"label":"Dt 32:21","book":"Deu","chapter":32,"verse":21},{"label":"Jos 23:7","book":"Jos","chapter":23,"verse":7},{"label":"Gl 4:8","book":"Gal","chapter":4,"verse":8},{"label":"Hs 4:10","book":"Hos","chapter":4,"verse":10},{"label":"1Kg 18:24","book":"1Ki","chapter":18,"verse":24}],"footnotes":[{"marker":1,"text":"Or adultery and trooped to the, or adultery and lodged at the; Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Jer:5:8","parts":[{"kind":"text","text":"They are well-fed, "},{"kind":"footnote","marker":1,"text":"Lit well-equipped; Hb obscure"},{"kind":"text","text":" eager "},{"kind":"footnote","marker":2,"text":"Lit early-rising; Hb obscure"},{"kind":"text","text":" stallions, "},{"kind":"crossref","label":"Ezk 23:20","book":"Ezk","chapter":23,"verse":20,"letter":"a"},{"kind":"text","text":" each neighing "},{"kind":"crossref","label":"Jr 13:27","book":"Jer","chapter":13,"verse":27,"letter":"a"},{"kind":"text","text":" after someone else’s wife. "},{"kind":"crossref","label":"Ex 20:14","book":"Exo","chapter":20,"verse":14,"letter":"b"},{"kind":"crossref","label":"Ezk 22:11","book":"Ezk","chapter":22,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Ezk 23:20","book":"Ezk","chapter":23,"verse":20},{"label":"Jr 13:27","book":"Jer","chapter":13,"verse":27},{"label":"Ex 20:14","book":"Exo","chapter":20,"verse":14},{"label":"Ezk 22:11","book":"Ezk","chapter":22,"verse":11}],"footnotes":[{"marker":1,"text":"Lit well-equipped; Hb obscure"},{"marker":2,"text":"Lit early-rising; Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Jer:5:9","parts":[{"kind":"text","text":"Should I not punish them for these things? "},{"kind":"crossref","label":"Jr 5:29","book":"Jer","chapter":5,"verse":29,"letter":"a"},{"kind":"crossref","label":"Jr 8:1