 18:20","book":"2Ch","chapter":18,"verse":20},{"label":"Jr 15:18","book":"Jer","chapter":15,"verse":18},{"label":"Gn 38:23","book":"Gen","chapter":38,"verse":23},{"label":"Jb 12:4","book":"Job","chapter":12,"verse":4},{"label":"Ps 44:14","book":"Psa","chapter":44,"verse":14},{"label":"Jr 48:26–27","book":"Jer","chapter":48,"verse":26},{"label":"Jr 48:39","book":"Jer","chapter":48,"verse":39},{"label":"Lm 2:15","book":"Lam","chapter":2,"verse":15},{"label":"Lm 3:14","book":"Lam","chapter":3,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:20:8","parts":[{"kind":"text","text":"For whenever I speak, I cry out,"},{"kind":"text","text":" I proclaim, “Violence and destruction!” "},{"kind":"crossref","label":"Jr 6:7","book":"Jer","chapter":6,"verse":7,"letter":"a"},{"kind":"text","text":" so the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has become my"},{"kind":"text","text":" constant disgrace and derision."}],"crossRefs":[{"label":"Jr 6:7","book":"Jer","chapter":6,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:20:9","parts":[{"kind":"text","text":"I say, “I won’t mention him"},{"kind":"text","text":" or speak any longer in his name.” "},{"kind":"crossref","label":"Ex 5:23","book":"Exo","chapter":5,"verse":23,"letter":"a"},{"kind":"crossref","label":"Dt 18:20","book":"Deu","chapter":18,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ac 5:40","book":"Act","chapter":5,"verse":40,"letter":"c"},{"kind":"text","text":" But his message becomes a fire burning in my heart, "},{"kind":"crossref","label":"Jb 32:18","book":"Job","chapter":32,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ps 39:3","book":"Psa","chapter":39,"verse":3,"letter":"b"},{"kind":"text","text":" shut up in my bones."},{"kind":"text","text":" I become tired of holding it in, "},{"kind":"crossref","label":"Jr 6:11","book":"Jer","chapter":6,"verse":11,"letter":"a"},{"kind":"crossref","label":"Am 3:8","book":"Amo","chapter":3,"