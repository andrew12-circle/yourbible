rn, “Do not prophesy in the name of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"crossref","label":"Am 7:13","book":"Amo","chapter":7,"verse":13,"letter":"c"},{"kind":"text","text":" or you will certainly die at our hand.” "}],"crossRefs":[{"label":"Jr 1:1","book":"Jer","chapter":1,"verse":1},{"label":"Jr 32:7–9","book":"Jer","chapter":32,"verse":7},{"label":"Am 7:13","book":"Amo","chapter":7,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:11:22","parts":[{"kind":"text","text":"Therefore, this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies says: “I am about to punish them. The young men will die by the sword; their sons and daughters will die by famine. "},{"kind":"crossref","label":"Am 7:16–17","book":"Amo","chapter":7,"verse":16,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Am 7:16–17","book":"Amo","chapter":7,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:11:23","parts":[{"kind":"text","text":"They will have no remnant, for I will bring disaster on the people of Anathoth "},{"kind":"crossref","label":"Jr 23:12","book":"Jer","chapter":23,"verse":12,"letter":"a"},{"kind":"text","text":" in the year of their punishment.”"}],"crossRefs":[{"label":"Jr 23:12","book":"Jer","chapter":23,"verse":12}],"footnotes":[]}]},"cachedAt":1783279560839}