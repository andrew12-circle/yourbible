ok":"Isa","chapter":27,"verse":8,"letter":"f"},{"kind":"crossref","label":"Jr 13:24","book":"Jer","chapter":13,"verse":24,"letter":"g"},{"kind":"text","text":" I will show them "},{"kind":"footnote","marker":1,"text":"LXX, Lat, Syr, Tg; MT reads will look at them"},{"kind":"text","text":" my back and not my face "},{"kind":"crossref","label":"2Ch 29:6","book":"2Ch","chapter":29,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 2:27","book":"Jer","chapter":2,"verse":27,"letter":"b"},{"kind":"crossref","label":"Jr 32:33","book":"Jer","chapter":32,"verse":33,"letter":"c"},{"kind":"crossref","label":"Ezk 8:16","book":"Ezk","chapter":8,"verse":16,"letter":"d"},{"kind":"text","text":" on the day of their calamity."}],"crossRefs":[{"label":"Ex 10:13","book":"Exo","chapter":10,"verse":13},{"label":"Ex 14:21","book":"Exo","chapter":14,"verse":21},{"label":"Jb 27:21","book":"Job","chapter":27,"verse":21},{"label":"Jb 38:24","book":"Job","chapter":38,"verse":24},{"label":"Ps 48:7","book":"Psa","chapter":48,"verse":7},{"label":"Is 27:8","book":"Isa","chapter":27,"verse":8},{"label":"Jr 13:24","book":"Jer","chapter":13,"verse":24},{"label":"2Ch 29:6","book":"2Ch","chapter":29,"verse":6},{"label":"Jr 2:27","book":"Jer","chapter":2,"verse":27},{"label":"Jr 32:33","book":"Jer","chapter":32,"verse":33},{"label":"Ezk 8:16","book":"Ezk","chapter":8,"verse":16}],"footnotes":[{"marker":1,"text":"LXX, Lat, Syr, Tg; MT reads will look at them"}]},{"verseId":"a556c5305ee15c3f-01:Jer:18:18","parts":[{"kind":"text","text":"Then certain ones said, “Come, let’s make plans against Jeremiah, "},{"kind":"crossref","label":"Jr 11:19","book":"Jer","chapter":11,"verse":19,"letter":"a"},{"kind":"text","text":" for instruction will never be lost from the priest, "},{"kind":"crossref","label":"Jr 2:8","book":"Jer","chapter":2,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jr 2:26","book":"Jer","chapter":2,"verse":26,"letter":"c"},{"kind":"crossref","label":"Jr 5:31","book":"Jer","chapter":5,"verse":31,"letter":"d"},{"kind":"crossref","label":"Jr 6:13","book":"Jer","chapter":6,"verse":13,"letter":"e"},{"kind":"crossref","label":"Jr 8:10","book":"Jer","chapter":8,"verse":10,"letter":"f"},{"kind":"crossref","label":"Jr 13:13","book":"Jer","chapter":13,"verse":13,"letter":"g"},{"kind":"crossref","label":"Jr 23:11","book":"Jer","chapter":23,"verse":11,"letter":"h"},{"kind":"crossref","label":"Jr 23:33","book":"Jer","chapter":23,"verse":33,"letter":"i"},{"kind":"crossref","label":"Ezk 7:26","book":"Ezk","chapter":7,"verse":26,"letter":"j"},{"kind":"crossref","label":"Mc 3:11","book":"Mic","chapter":3,"verse":11,"letter":"k"},{"kind":"crossref","label":"Zp 3:4","book":"Zep","chapter":3,"verse":4,"letter":"l"},{"kind":"text","text":" or counsel from the wise, or a word from the prophet. "},{"kind":"crossref","label":"Jr 5:13","book":"Jer","chapter":5,"verse":13,"letter":"m"},{"kind":"text","text":" Come, let’s denounce him "},{"kind":"footnote","marker":1,"text":"Lit let’s strike him with the tongue"},{"kind":"text","text":" and pay no attention to all his words.”"}],"crossRefs":[{"label":"Jr 11:19","book":"Jer","chapter":11,"verse":19},{"label":"Jr 2:8","book":"Jer","chapter":2,"verse":8},{"label":"Jr 2:26","book":"Jer","chapter":2,"verse":26},{"label":"Jr 5:31","book":"Jer","chapter":5,"verse":31},{"label":"Jr 6:13","book":"Jer","chapter":6,"verse":13},{"label":"Jr 8:10","book":"Jer","chapter":8,"verse":10},{"label":"Jr 13:13","book":"Jer","chapter":13,"verse":13},{"label":"Jr 23:11","book":"Jer","chapter":23,"verse":11},{"label":"Jr 23:33","book":"Jer","chapter":23,"verse":33},{"label":"Ezk 7:26","book":"Ezk","chapter":7,"verse":26},{"label":"Mc 3:11","book":"Mic","chapter":3,"verse":11},{"label":"Zp 3:4","book":"Zep","chapter":3,"verse":4},{"label":"Jr 5:13","book":"Jer","chapter":5,"verse":13}],"footnotes":[{"marker":1,"text":"Lit let’s strike him with the tongue"}]},{"verseId":"a556c5305ee15c3f-01:Jer:18:19","parts":[{"kind":"text","text":"Pay attention to me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."},{"kind":"text","text":" Hear what my opponents are saying! "},{"kind":"crossref","label":"Ps 55:2–3","book":"Psa","chapter":55,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 142:6","book":"Psa","chapter":142,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Ps 55:2–3","book":"Psa","chapter":55,"verse":2},{"label":"Ps 142:6","book":"Psa","chapter":142,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:18:20","parts":[{"kind":"text","text":"Should good be repaid with evil?"},{"kind":"text","text":" Yet they have dug a pit for me. "},{"kind":"crossref","label":"Ps 35:7","book":"Psa","chapter":35,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ps 57:6","book":"Psa","chapter":57,"verse":6,"letter":"b"},{"kind":"text","text":" Remember how I stood before you"},{"kind":"text","text":" to speak good on their behalf,"},{"kind":"text","text":" to turn your anger from them."}],"crossRefs":[{"label":"Ps 35:7","book":"Psa","chapter":35,"verse":7},{"label":"Ps 57:6","book":"Psa","chapter":57,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:18:21","parts":[{"kind":"text","text":"Therefore, hand their children over to famine, "},{"kind":"crossref","label":"Ps 109:9–20","book":"Psa","chapter":109,"verse":9,"letter":"a"},{"kind":"text","text":" and give them over to the power of the sword."},{"kind":"text","text":" Let their wives become childless and widowed,"},{"kind":"text","text":" their husbands slain by deadly disease, "},{"kind":"footnote","marker":1,"text":"Lit by death"},{"kind":"text","text":" their young men struck down by the sword in battle."}],"crossRefs":[{"label":"Ps 109:9–20","book":"Psa","chapter":109,"verse":9}],"footnotes":[{"marker":1,"text":"Lit by death"}]},{"verseId":"a556c5305ee15c3f-01:Jer:18:22","parts":[{"kind":"text","text":"Let a cry be heard from their houses"},{"kind":"text","text":" when you suddenly bring raiders against them,"},{"kind":"text","text":" for they have dug a pit to capture me"},{"kind":"text","text":" and have hidden snares for my feet. "},{"kind":"crossref","label":"Ps 140:5","book":"Psa","chapter":140,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 142:3","book":"Psa","chapter":142,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Ps 140:5","book":"Psa","chapter":140,"verse":5},{"label":"Ps 142:3","book":"Psa","chapter":142,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:18:23","parts":[{"kind":"text","text":"But you, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", know"},{"kind":"text","text":" all their deadly plots against me."},{"kind":"text","text":" Do not wipe out their iniquity; "},{"kind":"crossref","label":"Neh 4:5","book":"Neh","chapter":4,"verse":5,"letter":"a"},{"kind":"text","text":" do not blot out their sin before you."},{"kind":"text","text":" Let them be forced to stumble before you;"},{"kind":"text","text":" deal with them in the time of your anger."}],"crossRefs":[{"label":"Neh 4:5","book":"Neh","chapter":4,"verse":5}],"footnotes":[]}]},"cachedAt":1783279562976}