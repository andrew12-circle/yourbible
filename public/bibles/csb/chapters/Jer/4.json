er"}]},{"verseId":"a556c5305ee15c3f-01:Jer:4:3","parts":[{"kind":"text","text":"For this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says to the men of Judah and Jerusalem:"},{"kind":"text","text":" Break up the unplowed ground; "},{"kind":"crossref","label":"Hs 10:12","book":"Hos","chapter":10,"verse":12,"letter":"a"},{"kind":"text","text":" do not sow among the thorns. "},{"kind":"crossref","label":"Mt 13:7","book":"Mat","chapter":13,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Hs 10:12","book":"Hos","chapter":10,"verse":12},{"label":"Mt 13:7","book":"Mat","chapter":13,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:4","parts":[{"kind":"text","text":"Circumcise yourselves to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"},{"kind":"text","text":" remove the foreskin of your hearts, "},{"kind":"crossref","label":"Gn 17:14","book":"Gen","chapter":17,"verse":14,"letter":"a"},{"kind":"crossref","label":"Dt 10:16","book":"Deu","chapter":10,"verse":16,"letter":"b"},{"kind":"crossref","label":"Jr 9:25","book":"Jer","chapter":9,"verse":25,"letter":"c"},{"kind":"crossref","label":"Rm 2:28–29","book":"Rom","chapter":2,"verse":28,"letter":"d"},{"kind":"text","text":" men of Judah and residents of Jerusalem."},{"kind":"text","text":" Otherwise, my wrath will break out like fire"},{"kind":"text","text":" and burn with no one to extinguish it "},{"kind":"crossref","label":"Is 1:31","book":"Isa","chapter":1,"verse":31,"letter":"a"},{"kind":"crossref","label":"Jr 21:12","book":"Jer","chapter":21,"verse":12,"letter":"b"},{"kind":"crossref","label":"Am 5:6","book":"Amo","chapter":5,"verse":6,"letter":"c"},{"kind":"crossref","label":"Mal 4:1","book":"Mal","chapter":4,"verse":1,"letter":"d"},{"kind":"text","text":" because of your evil deeds."}],"crossRefs":[{"label":"Gn 17:14","book":"Gen","chapter":17,"verse":14},{"label":"Dt 10:16","book":"Deu","chapter":10,"verse":16},{"label":"Jr 9:25","book":"Jer","chapter":9,"verse":25},{"label":"Rm 2:28–29","book":"Rom","chapter":2,"verse":28},{"label":"Is 1:31","book":"Isa","chapter":1,"verse":31},{"label":"Jr 21:12","book":"Jer","chapter":21,"verse":12},{"label":"Am 5:6","book":"Amo","chapter":5,"verse":6},{"label":"Mal 4:1","book":"Mal","chapter":4,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:5","parts":[{"kind":"text","text":"Declare in Judah, proclaim in Jerusalem, and say,"},{"kind":"text","text":" Blow the ram’s horn throughout the land. "},{"kind":"crossref","label":"Jr 6:1","book":"Jer","chapter":6,"verse":1,"letter":"a"},{"kind":"crossref","label":"Hs 5:8","book":"Hos","chapter":5,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jl 2:1","book":"Jol","chapter":2,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Th 4:16–17","book":"1Th","chapter":4,"verse":16,"letter":"d"},{"kind":"text","text":" Cry out loudly and say,"},{"kind":"text","text":" “Assemble yourselves,"},{"kind":"text","text":" and let’s flee to the fortified cities.”"}],"crossRefs":[{"label":"Jr 6:1","book":"Jer","chapter":6,"verse":1},{"label":"Hs 5:8","book":"Hos","chapter":5,"verse":8},{"label":"Jl 2:1","book":"Jol","chapter":2,"verse":1},{"label":"1Th 4:16–17","book":"1Th","chapter":4,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:6","parts":[{"kind":"text","text":"Lift up a signal flag toward Zion. "},{"kind":"crossref","label":"Is 62:10","book":"Isa","chapter":62,"verse":10,"letter":"a"},{"kind":"text","text":" Run for cover! Don’t stand still!"},{"kind":"text","text":" For I am bringing disaster from the north —"},{"kind":"text","text":" a crushing blow. "},{"kind":"crossref","label":"Is 14:31","book":"Isa","chapter":14,"verse":31,"letter":"a"},{"kind":"crossref","label":"Is 41:25","book":"Isa","chapter":41,"verse":25,"letter":"b"},{"kind":"crossref","label":"Jr 1:13","book":"Jer","chapter":1,"verse":13,"letter":"c"},{"kind":"crossref","label":"Jr 4:20","book":"Jer","chapter":4,"vers