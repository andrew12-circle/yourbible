r","chapter":5,"verse":6,"letter":"e"},{"kind":"crossref","label":"Jr 25:38","book":"Jer","chapter":25,"verse":38,"letter":"f"},{"kind":"crossref","label":"Jr 49:19","book":"Jer","chapter":49,"verse":19,"letter":"g"},{"kind":"crossref","label":"Jr 50:17","book":"Jer","chapter":50,"verse":17,"letter":"h"},{"kind":"crossref","label":"Jr 50:44","book":"Jer","chapter":50,"verse":44,"letter":"i"},{"kind":"text","text":" a destroyer of nations has set out."},{"kind":"text","text":" He has left his lair"},{"kind":"text","text":" to make your land a waste."},{"kind":"text","text":" Your cities will be reduced to uninhabited ruins. "},{"kind":"crossref","label":"Is 1:7","book":"Isa","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 6:11","book":"Isa","chapter":6,"verse":11,"letter":"b"}],"crossRefs":[{"label":"Ps 10:9","book":"Psa","chapter":10,"verse":9},{"label":"Ps 17:12","book":"Psa","chapter":17,"verse":12},{"label":"Is 5:29","book":"Isa","chapter":5,"verse":29},{"label":"Jr 2:15","book":"Jer","chapter":2,"verse":15},{"label":"Jr 5:6","book":"Jer","chapter":5,"verse":6},{"label":"Jr 25:38","book":"Jer","chapter":25,"verse":38},{"label":"Jr 49:19","book":"Jer","chapter":49,"verse":19},{"label":"Jr 50:17","book":"Jer","chapter":50,"verse":17},{"label":"Jr 50:44","book":"Jer","chapter":50,"verse":44},{"label":"Is 1:7","book":"Isa","chapter":1,"verse":7},{"label":"Is 6:11","book":"Isa","chapter":6,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:8","parts":[{"kind":"text","text":"Because of this, put on sackcloth;"},{"kind":"text","text":" mourn and wail, "},{"kind":"crossref","label":"Jl 1:13","book":"Jol","chapter":1,"verse":13,"letter":"a"},{"kind":"text","text":" for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s burning anger "},{"kind":"crossref","label":"Nm 25:4","book":"Num","chapter":25,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 78:49","book":"Psa","chapter":78,"verse":49,"letter":"b"},