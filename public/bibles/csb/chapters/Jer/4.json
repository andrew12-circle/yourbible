verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:29","parts":[{"kind":"text","text":"Every city flees "},{"kind":"crossref","label":"2Kg 25:4","book":"2Ki","chapter":25,"verse":4,"letter":"a"},{"kind":"text","text":" at the sound of the horseman and the archer."},{"kind":"text","text":" They enter the thickets"},{"kind":"text","text":" and climb among the rocks. "},{"kind":"crossref","label":"Is 2:19–21","book":"Isa","chapter":2,"verse":19,"letter":"a"},{"kind":"text","text":" Every city is abandoned;"},{"kind":"text","text":" no inhabitant is left."}],"crossRefs":[{"label":"2Kg 25:4","book":"2Ki","chapter":25,"verse":4},{"label":"Is 2:19–21","book":"Isa","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:4:30","parts":[{"kind":"text","text":"And you, devastated one, what are you doing "},{"kind":"crossref","label":"Is 10:3","book":"Isa","chapter":10,"verse":3,"letter":"a"},{"kind":"text","text":" that you dress yourself in scarlet,"},{"kind":"text","text":" that you adorn yourself with gold jewelry,"},{"kind":"text","text":" that you enhance your eyes with makeup? "},{"kind":"crossref","label":"2Kg 9:30","book":"2Ki","chapter":9,"verse":30,"letter":"a"},{"kind":"text","text":" You beautify yourself for nothing."},{"kind":"text","text":" Your lovers reject you; "},{"kind":"crossref","label":"Jr 30:14","book":"Jer","chapter":30,"verse":14,"letter":"a"},{"kind":"crossref","label":"Lm 1:19","book":"Lam","chapter":1,"verse":19,"letter":"b"},{"kind":"text","text":" they intend to take your life. "},{"kind":"crossref","label":"Ezk 23:9–10","book":"Ezk","chapter":23,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ezk 23:22","book":"Ezk","chapter":23,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Is 10:3","book":"Isa","chapter":10,"verse":3},{"label":"2Kg 9:30","book":"2Ki","chapter":9,"verse":30},{"label":"Jr 30:14","book":"Jer","chapter":30,"verse":14},{"label":"Lm 1:19","book":"Lam","chapter":1,"verse":19},{"label":"Ezk 23