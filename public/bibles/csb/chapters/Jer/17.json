"chapter":50,"verse":7},{"label":"Jr 2:13","book":"Jer","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:14","parts":[{"kind":"text","text":"Heal me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", and I will be healed;"},{"kind":"text","text":" save me, and I will be saved,"},{"kind":"text","text":" for you are my praise. "},{"kind":"crossref","label":"Ps 22:25","book":"Psa","chapter":22,"verse":25,"letter":"a"},{"kind":"crossref","label":"Ps 71:6","book":"Psa","chapter":71,"verse":6,"letter":"b"},{"kind":"crossref","label":"Ps 109:1","book":"Psa","chapter":109,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Ps 22:25","book":"Psa","chapter":22,"verse":25},{"label":"Ps 71:6","book":"Psa","chapter":71,"verse":6},{"label":"Ps 109:1","book":"Psa","chapter":109,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:15","parts":[{"kind":"text","text":"Hear how they keep challenging me, "},{"kind":"crossref","label":"Is 5:19","book":"Isa","chapter":5,"verse":19,"letter":"a"},{"kind":"crossref","label":"2Pt 3:4","book":"2Pe","chapter":3,"verse":4,"letter":"b"},{"kind":"text","text":" “Where is the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"},{"kind":"text","text":" Let it come!”"}],"crossRefs":[{"label":"Is 5:19","book":"Isa","chapter":5,"verse":19},{"label":"2Pt 3:4","book":"2Pe","chapter":3,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:16","parts":[{"kind":"text","text":"But I have not run away from being your shepherd,"},{"kind":"text","text":" and I have not longed for the fatal day. "},{"kind":"crossref","label":"Am 5:18","book":"Amo","chapter":5,"verse":18,"letter":"a"},{"kind":"text","text":" You know my words were spoken in your presence."}],"crossRefs":[{"label":"Am 5:18","book":"Amo","chapter":5,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:17","parts":[{"kind":"text","text":"Don’t become a terror to me."},{"kind":"text","text":" You are my refuge "},{"kind":"crossref","label":"Ps 46:1","book":"Psa","chapter":46,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 61:3","book":"Psa","chapter":61,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ps 62:7–8","book":"Psa","chapter":62,"verse":7,"letter":"c"},{"kind":"text","text":" in the day of disaster."}],"crossRefs":[{"label":"Ps 46:1","book":"Psa","chapter":46,"verse":1},{"label":"Ps 61:3","book":"Psa","chapter":61,"verse":3},{"label":"Ps 62:7–8","book":"Psa","chapter":62,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:18","parts":[{"kind":"text","text":"Let my persecutors be put to shame, "},{"kind":"crossref","label":"Ps 35:4","book":"Psa","chapter":35,"verse":4,"letter":"a"},{"kind":"text","text":" but don’t let me be put to shame."},{"kind":"text","text":" Let them be terrified, but don’t let me be terrified."},{"kind":"text","text":" Bring on them the day of disaster; "},{"kind":"crossref","label":"Ps 35:8","book":"Psa","chapter":35,"verse":8,"letter":"a"},{"kind":"text","text":" shatter them with total "},{"kind":"footnote","marker":1,"text":"Lit double"},{"kind":"text","text":" destruction."}],"crossRefs":[{"label":"Ps 35:4","book":"Psa","chapter":35,"verse":4},{"label":"Ps 35:8","book":"Psa","chapter":35,"verse":8}],"footnotes":[{"marker":1,"text":"Lit double"}]},{"verseId":"a556c5305ee15c3f-01:Jer:17:19","parts":[{"kind":"text","text":"This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said to me, “Go and stand at the People’s Gate, through which the kings of Judah enter and leave, as well as at all the gates of Jerusalem. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:20","parts":[{"kind":"text","text":"Announce to them, ‘Hear the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", kings of Judah, all Judah, and all the residents of Jerusalem who enter through these gates. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:21","parts":[{"kind":"text","text":"This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says: Watch yourselves; do not pick up a load and bring it in through Jerusalem’s gates on the Sabbath day. "},{"kind":"crossref","label":"Neh 13:15–21","book":"Neh","chapter":13,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jn 5:9–12","book":"Jhn","chapter":5,"verse":9,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Neh 13:15–21","book":"Neh","chapter":13,"verse":15},{"label":"Jn 5:9–12","book":"Jhn","chapter":5,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:22","parts":[{"kind":"text","text":"Do not carry a load out of your houses on the Sabbath day or do any work, "},{"kind":"crossref","label":"Ex 20:8–10","book":"Exo","chapter":20,"verse":8,"letter":"a"},{"kind":"crossref","label":"Dt 5:12","book":"Deu","chapter":5,"verse":12,"letter":"b"},{"kind":"crossref","label":"Is 56:2–6","book":"Isa","chapter":56,"verse":2,"letter":"c"},{"kind":"text","text":" but keep the Sabbath day holy, just as I commanded your ancestors. "},{"kind":"crossref","label":"Ezk 20:12","book":"Ezk","chapter":20,"verse":12,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 20:8–10","book":"Exo","chapter":20,"verse":8},{"label":"Dt 5:12","book":"Deu","chapter":5,"verse":12},{"label":"Is 56:2–6","book":"Isa","chapter":56,"verse":2},{"label":"Ezk 20:12","book":"Ezk","chapter":20,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:23","parts":[{"kind":"text","text":"They wouldn’t listen or pay attention but became obstinate, "},{"kind":"crossref","label":"Jr 7:26","book":"Jer","chapter":7,"verse":26,"letter":"a"},{"kind":"text","text":" not listening or accepting discipline."}],"crossRefs":[{"label":"Jr 7:26","book":"Jer","chapter":7,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:24","parts":[{"kind":"text","text":"“ ‘However, if you listen to me —this is the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s declaration —and do not bring loads through the gates of this city on the Sabbath day, but keep the Sabbath day holy and do no work on it, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:25","parts":[{"kind":"text","text":"kings and princes will enter through the gates of this city. They will sit on the throne of David; "},{"kind":"crossref","label":"Jr 22:2","book":"Jer","chapter":22,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 22:30","book":"Jer","chapter":22,"verse":30,"letter":"b"},{"kind":"crossref","label":"Jr 29:16","book":"Jer","chapter":29,"verse":16,"letter":"c"},{"kind":"crossref","label":"Jr 36:30","book":"Jer","chapter":36,"verse":30,"letter":"d"},{"kind":"text","text":" they will ride in chariots and on horses "},{"kind":"crossref","label":"Jr 22:4","book":"Jer","chapter":22,"verse":4,"letter":"e"},{"kind":"text","text":" with their officials, the men of Judah, and the residents of Jerusalem. This city will be inhabited forever. "}],"crossRefs":[{"label":"Jr 22:2","book":"Jer","chapter":22,"verse":2},{"label":"Jr 22:30","book":"Jer","chapter":22,"verse":30},{"label":"Jr 29:16","book":"Jer","chapter":29,"verse":16},{"label":"Jr 36:30","book":"Jer","chapter":36,"verse":30},{"label":"Jr 22:4","book":"Jer","chapter":22,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:26","parts":[{"kind":"text","text":"Then people will come from the cities of Judah and from the area around Jerusalem, from the land of Benjamin and from the Judean foothills, from the hill country and from the Negev "},{"kind":"crossref","label":"Jr 32:44","book":"Jer","chapter":32,"verse":44,"letter":"a"},{"kind":"crossref","label":"Jr 33:13","book":"Jer","chapter":33,"verse":13,"letter":"b"},{"kind":"text","text":" bringing burnt offerings and sacrifices, grain offerings and frankincense, and thanksgiving sacrifices to the house of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "}],"crossRefs":[{"label":"Jr 32:44","book":"Jer","chapter":32,"verse":44},{"label":"Jr 33:13","book":"Jer","chapter":33,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:17:27","parts":[{"kind":"text","text":"But if you do not listen to me to keep the Sabbath day holy by not carrying a load while entering the gates of Jerusalem on the Sabbath day, I will set fire to its gates, "},{"kind":"crossref","label":"Lm 4:11","book":"Lam","chapter":4,"verse":11,"letter":"a"},{"kind":"text","text":" and it will consume the citadels "},{"kind":"crossref","label":"Jr 49:27","book":"Jer","chapter":49,"verse":27,"letter":"b"},{"kind":"crossref","label":"Am 1:14","book":"Amo","chapter":1,"verse":14,"letter":"c"},{"kind":"text","text":" of Jerusalem "},{"kind":"crossref","label":"2Kg 25:9","book":"2Ki","chapter":25,"verse":9,"letter":"d"},{"kind":"text","text":" and not be extinguished.’” "},{"kind":"crossref","label":"Jr 7:20","book":"Jer","chapter":7,"verse":20,"letter":"e"}],"crossRefs":[{"label":"Lm 4:11","book":"Lam","chapter":4,"verse":11},{"label":"Jr 49:27","book":"Jer","chapter":49,"verse":27},{"label":"Am 1:14","book":"Amo","chapter":1,"verse":14},{"label":"2Kg 25:9","book":"2Ki","chapter":25,"verse":9},{"label":"Jr 7:20","book":"Jer","chapter":7,"verse":20}],"footnotes":[]}]},"cachedAt":1783279562696}