rossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:24","parts":[{"kind":"text","text":"“As I live” —this is the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s declaration —“though you, Coniah "},{"kind":"footnote","marker":1,"text":"= Jehoiachin"},{"kind":"crossref","label":"2Kg 24:6","book":"2Ki","chapter":24,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 37:1","book":"Jer","chapter":37,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jr 52:31","book":"Jer","chapter":52,"verse":31,"letter":"c"},{"kind":"text","text":" son of Jehoiakim, the king of Judah, were a signet ring "},{"kind":"crossref","label":"Gn 38:18","book":"Gen","chapter":38,"verse":18,"letter":"d"},{"kind":"crossref","label":"1Kg 21:8","book":"1Ki","chapter":21,"verse":8,"letter":"e"},{"kind":"crossref","label":"Hg 2:23","book":"Hag","chapter":2,"verse":23,"letter":"f"},{"kind":"text","text":" on my right hand, I would tear you from it. "}],"crossRefs":[{"label":"2Kg 24:6","book":"2Ki","chapter":24,"verse":6},{"label":"Jr 37:1","book":"Jer","chapter":37,"verse":1},{"label":"Jr 52:31","book":"Jer","chapter":52,"verse":31},{"label":"Gn 38:18","book":"Gen","chapter":38,"verse":18},{"label":"1Kg 21:8","book":"1Ki","chapter":21,"verse":8},{"label":"Hg 2:23","book":"Hag","chapter":2,"verse":23}],"footnotes":[{"marker":1,"text":"= Jehoiachin"}]},{"verseId":"a556c5305ee15c3f-01:Jer:22:25","parts":[{"kind":"text","text":"In fact, I will hand you over to those you dread, "},{"kind":"crossref","label":"Jr 34:20–21","book":"Jer","chapter":34,"verse":20,"letter":"a"},{"kind":"text","text":" who intend to take your life, to Nebuchadnezzar king of Babylon and the Chaldeans. "}],"crossRefs":[{"label":"Jr 34:20–21","book":"Jer","chapter":34,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:26","parts":[{"kind":"text","text":"I will hurl you and the mother who gave birth "},{"kind":"crossref","label":"2Kg 24:15","book":"2Ki","chapter":24,"verse":15,"letter":"a"},{"kind":"text","text":" to you into another land, "},{"kind":"crossref","label":"2Kg 24:8","book":"2Ki","chapter":24,"verse":8,"letter":"b"},{"kind":"text","text":" where neither of you were born, and there you will both die. "}],"crossRefs":[{"label":"2Kg 24:15","book":"2Ki","chapter":24,"verse":15},{"label":"2Kg 24:8","book":"2Ki","chapter":24,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:27","parts":[{"kind":"text","text":"They will never return to the land they long to return to.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:28","parts":[{"kind":"text","text":"Is this man Coniah a despised, shattered pot, "},{"kind":"crossref","label":"Ps 31:12","book":"Psa","chapter":31,"verse":12,"letter":"a"},{"kind":"crossref","label":"Jr 48:38","book":"Jer","chapter":48,"verse":38,"letter":"b"},{"kind":"crossref","label":"Hs 8:8","book":"Hos","chapter":8,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Ps 31:12","book":"Psa","chapter":31,"verse":12},{"label":"Jr 48:38","book":"Jer","chapter":48,"verse":38},{"label":"Hs 8:8","book":"Hos","chapter":8,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:29","parts":[{"kind":"text","text":"Earth, earth, earth,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:22:30","parts":[{"kind":"text","text":"This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099445020}