15c3f-01:Jer:50:23","parts":[{"kind":"text","text":"How the hammer of the whole earth"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:24","parts":[{"kind":"text","text":"Babylon, I laid a trap for you, and you were caught, "},{"kind":"crossref","label":"Jr 51:31","book":"Jer","chapter":51,"verse":31,"letter":"a"},{"kind":"crossref","label":"Dn 5:30","book":"Dan","chapter":5,"verse":30,"letter":"b"}],"crossRefs":[{"label":"Jr 51:31","book":"Jer","chapter":51,"verse":31},{"label":"Dn 5:30","book":"Dan","chapter":5,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:25","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" opened his armory"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:26","parts":[{"kind":"text","text":"Come against her from the most distant places. "},{"kind":"footnote","marker":1,"text":"Lit from the end"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit from the end"}]},{"verseId":"a556c5305ee15c3f-01:Jer:50:27","parts":[{"kind":"text","text":"Put all her young bulls to the sword;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:28","parts":[{"kind":"text","text":"There is a voice of fugitives and refugees"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:29","parts":[{"kind":"text","text":"Summon the archers to Babylon,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:30","parts":[{"kind":"text","text":"Therefore, her young men will fall"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:31","parts":[{"kind":"text","text":"Look, I am against you, you arrogant one —"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:50:32","parts":[{"kind":"text","text":"The arrogant will stumble and fall "},{"kind":"crossref","label":"Ps 27:2","book":"Psa","chapter":27,"verse":2,"letter":"a"},{"kind":"crossref","label":"Pr 24:16