le":"divine"},{"kind":"text","text":"’s temple, "},{"kind":"crossref","label":"2Ch 20:5","book":"2Ch","chapter":20,"verse":5,"letter":"a"},{"kind":"crossref","label":"Jr 26:2","book":"Jer","chapter":26,"verse":2,"letter":"b"},{"kind":"text","text":" and proclaimed to all the people, "}],"crossRefs":[{"label":"2Ch 20:5","book":"2Ch","chapter":20,"verse":5},{"label":"Jr 26:2","book":"Jer","chapter":26,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:19:15","parts":[{"kind":"text","text":"“This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies, the God of Israel, says: ‘I am about to bring on this city —and on all its cities —every disaster that I spoke against it, for they have become obstinate, not obeying my words.’” "},{"kind":"crossref","label":"Jr 7:26","book":"Jer","chapter":7,"verse":26,"letter":"a"}],"crossRefs":[{"label":"Jr 7:26","book":"Jer","chapter":7,"verse":26}],"footnotes":[]}]},"cachedAt":1783099444133}