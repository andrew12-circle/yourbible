"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:20","parts":[{"kind":"text","text":"My tent is destroyed; "},{"kind":"crossref","label":"Jr 4:20","book":"Jer","chapter":4,"verse":20,"letter":"a"},{"kind":"text","text":" all my tent cords are snapped."},{"kind":"text","text":" My sons have departed from me and are no more."},{"kind":"text","text":" I have no one to pitch my tent again"},{"kind":"text","text":" or to hang up my curtains."}],"crossRefs":[{"label":"Jr 4:20","book":"Jer","chapter":4,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:21","parts":[{"kind":"text","text":"For the shepherds are stupid:"},{"kind":"text","text":" They don’t seek the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"2Ch 16:12","book":"2Ch","chapter":16,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 9:13","book":"Isa","chapter":9,"verse":13,"letter":"b"},{"kind":"crossref","label":"Is 31:1","book":"Isa","chapter":31,"verse":1,"letter":"c"},{"kind":"text","text":" Therefore they have not prospered,"},{"kind":"text","text":" and their whole flock is scattered."}],"crossRefs":[{"label":"2Ch 16:12","book":"2Ch","chapter":16,"verse":12},{"label":"Is 9:13","book":"Isa","chapter":9,"verse":13},{"label":"Is 31:1","book":"Isa","chapter":31,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:22","parts":[{"kind":"text","text":"Listen! A noise —it is coming —"},{"kind":"text","text":" a great commotion "},{"kind":"crossref","label":"Jr 4:29","book":"Jer","chapter":4,"verse":29,"letter":"a"},{"kind":"crossref","label":"Jr 6:22–23","book":"Jer","chapter":6,"verse":22,"letter":"b"},{"kind":"text","text":" from the land to the north."},{"kind":"text","text":" The cities of Judah will be made desolate,"},{"kind":"text","text":" a jackals’ den. "},{"kind":"crossref","label":"Jr 9:11","book":"Jer","chapter":9,"verse":11,"letter":"a"}],"crossRefs":[{"label":"Jr 4:29","book":"Jer","chapter":4,"verse":29},{"label":"Jr 6:22–23","book":"Jer","chapter":6,"verse":22},{"label":"Jr 9:11","book":"Jer","chapter":9,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:23","parts":[{"kind":"text","text":"I know, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" that a person’s way of life is not his own;"},{"kind":"text","text":" no one who walks determines his own steps. "},{"kind":"crossref","label":"Ps 37:23","book":"Psa","chapter":37,"verse":23,"letter":"a"},{"kind":"crossref","label":"Pr 3:5–6","book":"Pro","chapter":3,"verse":5,"letter":"b"},{"kind":"crossref","label":"Pr 16:9","book":"Pro","chapter":16,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Ps 37:23","book":"Psa","chapter":37,"verse":23},{"label":"Pr 3:5–6","book":"Pro","chapter":3,"verse":5},{"label":"Pr 16:9","book":"Pro","chapter":16,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:24","parts":[{"kind":"text","text":"Discipline me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", but with justice —"},{"kind":"text","text":" not in your anger, "},{"kind":"crossref","label":"Ps 6:1","book":"Psa","chapter":6,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 38:1","book":"Psa","chapter":38,"verse":1,"letter":"b"},{"kind":"text","text":" or you will reduce me to nothing."}],"crossRefs":[{"label":"Ps 6:1","book":"Psa","chapter":6,"verse":1},{"label":"Ps 38:1","book":"Psa","chapter":38,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:10:25","parts":[{"kind":"text","text":"Pour out your wrath on the nations"},{"kind":"text","text":" that don’t recognize you"},{"kind":"text","text":" and on the families"},{"kind":"text","text":" that don’t call on your name,"},{"kind":"text","text":" for they have consumed Jacob;"},{"kind":"text","text":" they have consumed him and finished him off"},{"kind":"text","text":" and made his homeland desolate. "},{"kind":"crossref","label":"Ps 79:6–7","book":"Psa","chapter":79,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Ps 79:6–7","book":"Psa","chapter":79,"verse":6}],"footnotes":[]}]},"cachedAt":1783279560410}