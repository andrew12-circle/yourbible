erse":25,"letter":"o"},{"kind":"text","text":" says: ‘If you are firmly resolved to go to Egypt "},{"kind":"crossref","label":"Dt 17:16","book":"Deu","chapter":17,"verse":16,"letter":"p"},{"kind":"crossref","label":"Jr 44:12–14","book":"Jer","chapter":44,"verse":12,"letter":"q"},{"kind":"text","text":" and stay there for a while, "}],"crossRefs":[{"label":"Is 21:10","book":"Isa","chapter":21,"verse":10},{"label":"Jr 7:3","book":"Jer","chapter":7,"verse":3},{"label":"Jr 7:21","book":"Jer","chapter":7,"verse":21},{"label":"Jr 9:15","book":"Jer","chapter":9,"verse":15},{"label":"Jr 16:9","book":"Jer","chapter":16,"verse":9},{"label":"Jr 19:3","book":"Jer","chapter":19,"verse":3},{"label":"Jr 19:15","book":"Jer","chapter":19,"verse":15},{"label":"Jr 27:4","book":"Jer","chapter":27,"verse":4},{"label":"Jr 27:21","book":"Jer","chapter":27,"verse":21},{"label":"Jr 28:2","book":"Jer","chapter":28,"verse":2},{"label":"Jr 28:14","book":"Jer","chapter":28,"verse":14},{"label":"Jr 29:4","book":"Jer","chapter":29,"verse":4},{"label":"Jr 29:8","book":"Jer","chapter":29,"verse":8},{"label":"Jr 29:21","book":"Jer","chapter":29,"verse":21},{"label":"Jr 29:25","book":"Jer","chapter":29,"verse":25},{"label":"Dt 17:16","book":"Deu","chapter":17,"verse":16},{"label":"Jr 44:12–14","book":"Jer","chapter":44,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:42:16","parts":[{"kind":"text","text":"then the sword "},{"kind":"crossref","label":"Ezk 11:8","book":"Ezk","chapter":11,"verse":8,"letter":"a"},{"kind":"text","text":" you fear will overtake you there in the land of Egypt, and the famine you are worried about will follow on your heels "},{"kind":"footnote","marker":1,"text":"Lit will cling after you"},{"kind":"text","text":" there to Egypt, and you will die there. "}],"crossRefs":[{"label":"Ezk 11:8","book":"Ezk","chapter":11,"verse":8}],"footnotes":[{"marker":1,"text":"Lit will cling after you"}]},{"verseId":"a556c5305ee15c3f-01:Jer:42:17","parts":[{"kind":"text","text":"All who resolve to go to Egypt to stay there for a while will die by the sword, famine, and plague. They will have no survivor or fugitive from the disaster I will bring on them.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:42:18","parts":[{"kind":"text","text":"“For this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies, the God of Israel, says: ‘Just as my anger and fury were poured out on Jerusalem’s residents, "},{"kind":"crossref","label":"Jr 7:20","book":"Jer","chapter":7,"verse":20,"letter":"a"},{"kind":"text","text":" so will my fury pour out on you if you go to Egypt. You will become an example for cursing, scorn, "},{"kind":"crossref","label":"Dt 28:37","book":"Deu","chapter":28,"verse":37,"letter":"b"},{"kind":"crossref","label":"2Ch 29:8","book":"2Ch","chapter":29,"verse":8,"letter":"c"},{"kind":"crossref","label":"2Ch 30:7","book":"2Ch","chapter":30,"verse":7,"letter":"d"},{"kind":"crossref","label":"Jr 5:30","book":"Jer","chapter":5,"verse":30,"letter":"e"},{"kind":"crossref","label":"Jr 18:16","book":"Jer","chapter":18,"verse":16,"letter":"f"},{"kind":"crossref","label":"Jr 19:8","book":"Jer","chapter":19,"verse":8,"letter":"g"},{"kind":"crossref","label":"Jr 25:9","book":"Jer","chapter":25,"verse":9,"letter":"h"},{"kind":"crossref","label":"Jr 25:18","book":"Jer","chapter":25,"verse":18,"letter":"i"},{"kind":"crossref","label":"Jr 29:18","book":"Jer","chapter":29,"verse":18,"letter":"j"},{"kind":"crossref","label":"Jr 44:12","book":"Jer","chapter":44,"verse":12,"letter":"k"},{"kind":"crossref","label":"Jr 44:22","book":"Jer","chapter":44,"verse":22,"letter":"l"},{"kind":"crossref","label":"Jr 49:17","book":"Jer","chapter":49,"verse":17,"letter":"m"},{"kind":"crossref","label":"Jr 50:13","book":"Jer","chapter":50,"verse":13,"letter":"n"},{"kind":"crossref","label":"Mc 6:16","book":"Mic","chapter":6,"verse":16,"letter":"o"},{"kind":"crossref","label":"Zp 2:15","book":"Zep","chapter":2,"verse":15,"letter":"p"},{"kind":"text","text":" execration, and disgrace, and you will never see this place again.’ "}],"crossRefs":[{"label":"Jr 7:20","book":"Jer","chapter":7,"verse":20},{"label":"Dt 28:37","book":"Deu","chapter":28,"verse":37},{"label":"2Ch 29:8","book":"2Ch","chapter":29,"verse":8},{"label":"2Ch 30:7","book":"2Ch","chapter":30,"verse":7},{"label":"Jr 5:30","book":"Jer","chapter":5,"verse":30},{"label":"Jr 18:16","book":"Jer","chapter":18,"verse":16},{"label":"Jr 19:8","book":"Jer","chapter":19,"verse":8},{"label":"Jr 25:9","book":"Jer","chapter":25,"verse":9},{"label":"Jr 25:18","book":"Jer","chapter":25,"verse":18},{"label":"Jr 29:18","book":"Jer","chapter":29,"verse":18},{"label":"Jr 44:12","book":"Jer","chapter":44,"verse":12},{"label":"Jr 44:22","book":"Jer","chapter":44,"verse":22},{"label":"Jr 49:17","book":"Jer","chapter":49,"verse":17},{"label":"Jr 50:13","book":"Jer","chapter":50,"verse":13},{"label":"Mc 6:16","book":"Mic","chapter":6,"verse":16},{"label":"Zp 2:15","book":"Zep","chapter":2,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:42:19","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has spoken concerning you, remnant of Judah: ‘Don’t go to Egypt.’ Know for certain that I have warned you today! "},{"kind":"crossref","label":"Ezk 2:5","book":"Ezk","chapter":2,"verse":5,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 2:5","book":"Ezk","chapter":2,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:42:20","parts":[{"kind":"text","text":"You have gone astray at the cost of your lives "},{"kind":"footnote","marker":1,"text":"Or You have led your own selves astray"},{"kind":"text","text":" because you are the ones who sent me to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, saying, ‘Pray to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God on our behalf, and as for all that the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God says, tell it to us, and we’ll act accordingly.’ "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or You have led your own selves astray"}]},{"verseId":"a556c5305ee15c3f-01:Jer:42:21","parts":[{"kind":"text","text":"For I have told you today, but you have not obeyed the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God in everything he has sent me to tell you. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jer:42:22","parts":[{"kind":"text","text":"Now therefore, know for certain that by the sword, famine, and plague you will die in the place where you desired to go to stay for a while.”"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099451109}