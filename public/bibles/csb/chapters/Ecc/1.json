 cycles."}],"crossRefs":[{"label":"Ec 11:5","book":"Ecc","chapter":11,"verse":5},{"label":"Jn 3:8","book":"Jhn","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:7","parts":[{"kind":"text","text":"All the streams flow to the sea,"},{"kind":"text","text":" yet the sea is never full;"},{"kind":"text","text":" to the place where the streams flow,"},{"kind":"text","text":" there they flow again."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:8","parts":[{"kind":"text","text":"All things "},{"kind":"footnote","marker":1,"text":"Or words"},{"kind":"text","text":" are wearisome,"},{"kind":"text","text":" more than anyone can say."},{"kind":"text","text":" The eye is not satisfied by seeing "},{"kind":"crossref","label":"Pr 27:20","book":"Pro","chapter":27,"verse":20,"letter":"a"},{"kind":"crossref","label":"Ec 4:8","book":"Ecc","chapter":4,"verse":8,"letter":"b"},{"kind":"text","text":" or the ear filled with hearing."}],"crossRefs":[{"label":"Pr 27:20","book":"Pro","chapter":27,"verse":20},{"label":"Ec 4:8","book":"Ecc","chapter":4,"verse":8}],"footnotes":[{"marker":1,"text":"Or words"}]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:9","parts":[{"kind":"text","text":"What has been is what will be,"},{"kind":"text","text":" and what has been done is what will be done;"},{"kind":"text","text":" there is nothing new under the sun."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:10","parts":[{"kind":"text","text":"Can one say about anything,"},{"kind":"text","text":" “Look, this is new”?"},{"kind":"text","text":" It has already existed in the ages before us."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:11","parts":[{"kind":"text","text":"There is no remembrance of those who "},{"kind":"footnote","marker":1,"text":"Or of the things that"},{"kind":"text","text":" came before; "},{"kind":"crossref","label":"Dt 9:14","book":"Deu","chapter":9,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ec 2:16","book":"Ecc","chapter":2,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ec 9:5","book":"Ecc","chapter":9,"verse":5,"letter":"c"},{"kind":"text","text":" and of those who will come after"},{"kind":"text","text":" there will also be no remembrance"},{"kind":"text","text":" by those who follow them."}],"crossRefs":[{"label":"Dt 9:14","book":"Deu","chapter":9,"verse":14},{"label":"Ec 2:16","book":"Ecc","chapter":2,"verse":16},{"label":"Ec 9:5","book":"Ecc","chapter":9,"verse":5}],"footnotes":[{"marker":1,"text":"Or of the things that"}]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:12","parts":[{"kind":"text","text":"I, the Teacher, "},{"kind":"crossref","label":"Ec 1:1","book":"Ecc","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ec 7:27","book":"Ecc","chapter":7,"verse":27,"letter":"b"},{"kind":"crossref","label":"Ec 12:8–10","book":"Ecc","chapter":12,"verse":8,"letter":"c"},{"kind":"text","text":" have been "},{"kind":"footnote","marker":1,"text":"Or Teacher, was"},{"kind":"text","text":" king over Israel in Jerusalem. "}],"crossRefs":[{"label":"Ec 1:1","book":"Ecc","chapter":1,"verse":1},{"label":"Ec 7:27","book":"Ecc","chapter":7,"verse":27},{"label":"Ec 12:8–10","book":"Ecc","chapter":12,"verse":8}],"footnotes":[{"marker":1,"text":"Or Teacher, was"}]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:13","parts":[{"kind":"text","text":"I applied my mind to examine "},{"kind":"crossref","label":"Ec 1:17","book":"Ecc","chapter":1,"verse":17,"letter":"a"},{"kind":"text","text":" and explore through wisdom all that is done under heaven. "},{"kind":"crossref","label":"1Kg 4:29","book":"1Ki","chapter":4,"verse":29,"letter":"b"},{"kind":"crossref","label":"Ec 3:10–11","book":"Ecc","chapter":3,"verse":10,"letter":"c"},{"kind":"crossref","label":"Ec 7:25","book":"Ecc","chapter":7,"verse":25,"letter":"d"},{"kind":"crossref","label":"Ec 8:17","book":"Ecc","chapter":8,"verse":17,"letter":"e"},{"kind":"text","text":" God has given people "},{"kind":"footnote","marker":2,"text":"Or given the descendants of Adam"},{"kind":"text","text":" this miserable task to keep them occupied. "},{"kind":"crossref","label":"Gn 3:19","book":"Gen","chapter":3,"verse":19,"letter":"f"},{"kind":"crossref","label":"Ec 2:23","book":"Ecc","chapter":2,"verse":23,"letter":"g"},{"kind":"crossref","label":"Ec 2:26","book":"Ecc","chapter":2,"verse":26,"letter":"h"},{"kind":"crossref","label":"Ec 3:10","book":"Ecc","chapter":3,"verse":10,"letter":"i"},{"kind":"crossref","label":"Ec 4:8","book":"Ecc","chapter":4,"verse":8,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ec 1:17","book":"Ecc","chapter":1,"verse":17},{"label":"1Kg 4:29","book":"1Ki","chapter":4,"verse":29},{"label":"Ec 3:10–11","book":"Ecc","chapter":3,"verse":10},{"label":"Ec 7:25","book":"Ecc","chapter":7,"verse":25},{"label":"Ec 8:17","book":"Ecc","chapter":8,"verse":17},{"label":"Gn 3:19","book":"Gen","chapter":3,"verse":19},{"label":"Ec 2:23","book":"Ecc","chapter":2,"verse":23},{"label":"Ec 2:26","book":"Ecc","chapter":2,"verse":26},{"label":"Ec 3:10","book":"Ecc","chapter":3,"verse":10},{"label":"Ec 4:8","book":"Ecc","chapter":4,"verse":8}],"footnotes":[{"marker":2,"text":"Or given the descendants of Adam"}]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:14","parts":[{"kind":"text","text":"I have seen all the things that are done under the sun and have found everything to be futile, a pursuit of the wind. "},{"kind":"footnote","marker":3,"text":"Or a feeding on wind, or an affliction of spirit; also in v. 17"},{"kind":"crossref","label":"Pr 27:16","book":"Pro","chapter":27,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ec 2:11","book":"Ecc","chapter":2,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ec 2:17","book":"Ecc","chapter":2,"verse":17,"letter":"c"},{"kind":"crossref","label":"Ec 4:4","book":"Ecc","chapter":4,"verse":4,"letter":"d"},{"kind":"crossref","label":"Ec 6:9","book":"Ecc","chapter":6,"verse":9,"letter":"e"}],"crossRefs":[{"label":"Pr 27:16