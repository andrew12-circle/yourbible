k":"Ecc","chapter":2,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ec 7:25","book":"Ecc","chapter":7,"verse":25,"letter":"c"},{"kind":"text","text":" I learned that this too is a pursuit of the wind. "},{"kind":"crossref","label":"Ec 2:11","book":"Ecc","chapter":2,"verse":11,"letter":"d"},{"kind":"crossref","label":"Ec 2:17","book":"Ecc","chapter":2,"verse":17,"letter":"e"},{"kind":"crossref","label":"Ec 4:4","book":"Ecc","chapter":4,"verse":4,"letter":"f"},{"kind":"crossref","label":"Ec 4:6","book":"Ecc","chapter":4,"verse":6,"letter":"g"},{"kind":"crossref","label":"Ec 4:16","book":"Ecc","chapter":4,"verse":16,"letter":"h"},{"kind":"crossref","label":"Ec 6:9","book":"Ecc","chapter":6,"verse":9,"letter":"i"}],"crossRefs":[{"label":"Ec 1:13","book":"Ecc","chapter":1,"verse":13},{"label":"Ec 2:12","book":"Ecc","chapter":2,"verse":12},{"label":"Ec 7:25","book":"Ecc","chapter":7,"verse":25},{"label":"Ec 2:11","book":"Ecc","chapter":2,"verse":11},{"label":"Ec 2:17","book":"Ecc","chapter":2,"verse":17},{"label":"Ec 4:4","book":"Ecc","chapter":4,"verse":4},{"label":"Ec 4:6","book":"Ecc","chapter":4,"verse":6},{"label":"Ec 4:16","book":"Ecc","chapter":4,"verse":16},{"label":"Ec 6:9","book":"Ecc","chapter":6,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ecc:1:18","parts":[{"kind":"text","text":"For with much wisdom is much sorrow; "},{"kind":"crossref","label":"Ec 2:23","book":"Ecc","chapter":2,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ec 12:12","book":"Ecc","chapter":12,"verse":12,"letter":"b"},{"kind":"text","text":" as knowledge increases, grief increases."}],"crossRefs":[{"label":"Ec 2:23","book":"Ecc","chapter":2,"verse":23},{"label":"Ec 12:12","book":"Ecc","chapter":12,"verse":12}],"footnotes":[]}]},"cachedAt":1783279531879}