":"Ecc","chapter":10,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:16:15","parts":[{"kind":"text","text":"When a king’s face lights up, there is life;"},{"kind":"text","text":" his favor is like a cloud with spring rain."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:16:16","parts":[{"kind":"text","text":"Get wisdom —"},{"kind":"text","text":" how much better it is than gold!"},{"kind":"text","text":" And get understanding —"},{"kind":"text","text":" it is preferable to silver. "},{"kind":"crossref","label":"Pr 3:14","book":"Pro","chapter":3,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 8:10","book":"Pro","chapter":8,"verse":10,"letter":"b"},{"kind":"crossref","label":"Pr 8:19","book":"Pro","chapter":8,"verse":19,"letter":"c"},{"kind":"crossref","label":"Pr 22:1","book":"Pro","chapter":22,"verse":1,"letter":"d"}],"crossRefs":[{"label":"Pr 3:14","book":"Pro","chapter":3,"verse":14},{"label":"Pr 8:10","book":"Pro","chapter":8,"verse":10},{"label":"Pr 8:19","book":"Pro","chapter":8,"verse":19},{"label":"Pr 22:1","book":"Pro","chapter":22,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:16:17","parts":[{"kind":"text","text":"The highway of the upright "},{"kind":"crossref","label":"Is 35:8","book":"Isa","chapter":35,"verse":8,"letter":"a"},{"kind":"text","text":" avoids evil;"},{"kind":"text","text":" the one who guards his way protects his life. "},{"kind":"crossref","label":"Pr 2:11–13","book":"Pro","chapter":2,"verse":11,"letter":"a"},{"kind":"crossref","label":"Pr 15:19","book":"Pro","chapter":15,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Is 35:8","book":"Isa","chapter":35,"verse":8},{"label":"Pr 2:11–13","book":"Pro","chapter":2,"verse":11},{"label":"Pr 15:19","book":"Pro","chapter":15,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:16:18","parts":[{"kind":"text","text":"Pride comes before destruction,"},{"kind":"text","text":" and an arrogant spirit before a fall. "},{"kind":"