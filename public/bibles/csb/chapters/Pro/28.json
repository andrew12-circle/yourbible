:27},{"label":"Mt 18:6","book":"Mat","chapter":18,"verse":6},{"label":"Mt 5:6","book":"Mat","chapter":5,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:28:11","parts":[{"kind":"text","text":"A rich person is wise in his own eyes,"},{"kind":"text","text":" but a poor one who has discernment sees through him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:28:12","parts":[{"kind":"text","text":"When the righteous triumph,"},{"kind":"text","text":" there is great rejoicing, "},{"kind":"footnote","marker":1,"text":"Lit glory"},{"kind":"text","text":" but when the wicked come to power,"},{"kind":"text","text":" people hide. "},{"kind":"crossref","label":"Pr 11:10","book":"Pro","chapter":11,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 28:28","book":"Pro","chapter":28,"verse":28,"letter":"b"},{"kind":"crossref","label":"Pr 29:2","book":"Pro","chapter":29,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ec 10:5–6","book":"Ecc","chapter":10,"verse":5,"letter":"d"}],"crossRefs":[{"label":"Pr 11:10","book":"Pro","chapter":11,"verse":10},{"label":"Pr 28:28","book":"Pro","chapter":28,"verse":28},{"label":"Pr 29:2","book":"Pro","chapter":29,"verse":2},{"label":"Ec 10:5–6","book":"Ecc","chapter":10,"verse":5}],"footnotes":[{"marker":1,"text":"Lit glory"}]},{"verseId":"a556c5305ee15c3f-01:Pro:28:13","parts":[{"kind":"text","text":"The one who conceals his sins"},{"kind":"text","text":" will not prosper, "},{"kind":"crossref","label":"Jb 31:33","book":"Job","chapter":31,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ps 32:3","book":"Psa","chapter":32,"verse":3,"letter":"b"},{"kind":"text","text":" but whoever confesses and renounces them"},{"kind":"text","text":" will find mercy. "},{"kind":"crossref","label":"Ps 32:5","book":"Psa","chapter":32,"verse":5,"letter":"a"},{"kind":"crossref","label":"Jms 5:16","book":"Jas","chapter":5,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Jn 1:9","book":"1Jn","chapter":1,"verse":9,