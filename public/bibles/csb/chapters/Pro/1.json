tes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:13","parts":[{"kind":"text","text":"We’ll find all kinds of valuable property"},{"kind":"text","text":" and fill our houses with plunder. "},{"kind":"crossref","label":"Pr 24:4","book":"Pro","chapter":24,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Pr 24:4","book":"Pro","chapter":24,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:14","parts":[{"kind":"text","text":"Throw in your lot with us,"},{"kind":"text","text":" and we’ll all share the loot” "},{"kind":"footnote","marker":1,"text":"Litus; one bag will be for all of us"},{"kind":"text","text":" —"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Litus; one bag will be for all of us"}]},{"verseId":"a556c5305ee15c3f-01:Pro:1:15","parts":[{"kind":"text","text":"my son, don’t travel that road with them "},{"kind":"crossref","label":"Ps 1:1","book":"Psa","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 4:14","book":"Pro","chapter":4,"verse":14,"letter":"b"},{"kind":"text","text":" or set foot on their path, "},{"kind":"crossref","label":"Ps 119:101","book":"Psa","chapter":119,"verse":101,"letter":"a"},{"kind":"crossref","label":"Pr 16:19","book":"Pro","chapter":16,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Ps 1:1","book":"Psa","chapter":1,"verse":1},{"label":"Pr 4:14","book":"Pro","chapter":4,"verse":14},{"label":"Ps 119:101","book":"Psa","chapter":119,"verse":101},{"label":"Pr 16:19","book":"Pro","chapter":16,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:16","parts":[{"kind":"text","text":"because their feet run toward evil"},{"kind":"text","text":" and they hurry to shed blood. "},{"kind":"crossref","label":"Pr 6:17–18","book":"Pro","chapter":6,"verse":17,"letter":"a"},{"kind":"crossref","label":"Is 59:7","book":"Isa","chapter":59,"verse":7,"letter":"b"},{"kind":"crossref","label":"Rm 3:15","book":"Rom","chapter":3,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Pr 6:17–18","book":"Pro","chapter":6,"verse":17},{"label":"Is 59:7","book":"Isa","chapter":59,"verse":7},{"label":"Rm 3:15","book":"Rom","chapter":3,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:17","parts":[{"kind":"text","text":"It is useless to spread a net"},{"kind":"text","text":" where any bird can see it,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:18","parts":[{"kind":"text","text":"but they set an ambush to kill themselves; "},{"kind":"footnote","marker":1,"text":"Lit they ambush for their blood"},{"kind":"text","text":" they attack their own lives."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit they ambush for their blood"}]},{"verseId":"a556c5305ee15c3f-01:Pro:1:19","parts":[{"kind":"text","text":"Such are the paths of all who make profit dishonestly; "},{"kind":"crossref","label":"Pr 15:27","book":"Pro","chapter":15,"verse":27,"letter":"a"},{"kind":"crossref","label":"Ezk 22:27","book":"Ezk","chapter":22,"verse":27,"letter":"b"},{"kind":"crossref","label":"Hab 2:6–12","book":"Hab","chapter":2,"verse":6,"letter":"c"},{"kind":"text","text":" it takes the lives of those who receive it. "},{"kind":"footnote","marker":1,"text":"Lit takes the life of its masters"}],"crossRefs":[{"label":"Pr 15:27","book":"Pro","chapter":15,"verse":27},{"label":"Ezk 22:27","book":"Ezk","chapter":22,"verse":27},{"label":"Hab 2:6–12","book":"Hab","chapter":2,"verse":6}],"footnotes":[{"marker":1,"text":"Lit takes the life of its masters"}]},{"verseId":"a556c5305ee15c3f-01:Pro:1:20","parts":[{"kind":"text","text":"Wisdom calls out in the street;"},{"kind":"text","text":" she makes her voice heard in the public squares. "},{"kind":"crossref","label":"Pr 8:1–3","book":"Pro","chapter":8,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 9:3","book":"Pro","chapter":9,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Pr 8:1–3","book":"Pro","chapter":8,"verse":1},{"label":"Pr 9:3","book":"Pro","chapter":9,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:21","parts":[{"kind":"text","text":"She cries out above "},{"kind":"footnote","marker":1,"text":"Lit at the head of"},{"kind":"text","text":" the commotion;"},{"kind":"text","text":" she speaks at the entrance of the city gates:"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit at the head of"}]},{"verseId":"a556c5305ee15c3f-01:Pro:1:22","parts":[{"kind":"text","text":"“How long, inexperienced ones, will you love ignorance?"},{"kind":"text","text":" How long will you mockers "},{"kind":"crossref","label":"Ps 1:1","book":"Psa","chapter":1,"verse":1,"letter":"a"},{"kind":"text","text":" enjoy mocking"},{"kind":"text","text":" and you fools hate knowledge? "},{"kind":"crossref","label":"Jb 21:14","book":"Job","chapter":21,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 1:29","book":"Pro","chapter":1,"verse":29,"letter":"b"},{"kind":"crossref","label":"Pr 5:12","book":"Pro","chapter":5,"verse":12,"letter":"c"}],"crossRefs":[{"label":"Ps 1:1","book":"Psa","chapter":1,"verse":1},{"label":"Jb 21:14","book":"Job","chapter":21,"verse":14},{"label":"Pr 1:29","book":"Pro","chapter":1,"verse":29},{"label":"Pr 5:12","book":"Pro","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:23","parts":[{"kind":"text","text":"If you respond to my warning, "},{"kind":"footnote","marker":1,"text":"Lit you turn back to my reprimand"},{"kind":"crossref","label":"Pr 3:11","book":"Pro","chapter":3,"verse":11,"letter":"a"},{"kind":"crossref","label":"Pr 15:5","book":"Pro","chapter":15,"verse":5,"letter":"b"},{"kind":"crossref","label":"Pr 15:31","book":"Pro","chapter":15,"verse":31,"letter":"c"},{"kind":"text","text":" then I will pour out my spirit on you "},{"kind":"crossref","label":"Jl 2:28","book":"Jol","chapter":2,"verse":28,"letter":"a"},{"kind":"text","text":" and teach you my words."}],"crossRefs":[{"label":"Pr 3:11","book":"Pro","chapter":3,"verse":11},{"label":"Pr 15:5","book":"Pro","chapter":15,"verse":5},{"label":"Pr 15:31","book":"Pro","chapter":15,"verse":31},{"label":"Jl 2:28","book":"Jol","chapter":2,"verse":28}],"footnotes":[{"marker":1,"text":"Lit you turn back to my reprimand"}]},{"verseId":"a556c5305ee15c3f-01:Pro:1:24","parts":[{"kind":"text","text":"Since I called out and you refused, "},{"kind":"crossref","label":"Is 65:12","book":"Isa","chapter":65,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 66:4","book":"Isa","chapter":66,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jr 7:13","book":"Jer","chapter":7,"verse":13,"letter":"c"},{"kind":"crossref","label":"Zch 7:11","book":"Zec","chapter":7,"verse":11,"letter":"d"},{"kind":"text","text":" extended my hand and no one paid attention, "},{"kind":"crossref","label":"Is 65:2","book":"Isa","chapter":65,"verse":2,"letter":"a"},{"kind":"crossref","label":"Rm 10:21","book":"Rom","chapter":10,"verse":21,"letter":"b"}],"crossRefs":[{"label":"Is 65:12","book":"Isa","chapter":65,"verse":12},{"label":"Is 66:4","book":"Isa","chapter":66,"verse":4},{"label":"Jr 7:13","book":"Jer","chapter":7,"verse":13},{"label":"Zch 7:11","book":"Zec","chapter":7,"verse":11},{"label":"Is 65:2","book":"Isa","chapter":65,"verse":2},{"label":"Rm 10:21","book":"Rom","chapter":10,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:25","parts":[{"kind":"text","text":"since you neglected all my counsel "},{"kind":"crossref","label":"Ps 107:11","book":"Psa","chapter":107,"verse":11,"letter":"a"},{"kind":"crossref","label":"Lk 7:30","book":"Luk","chapter":7,"verse":30,"letter":"b"},{"kind":"text","text":" and did not accept my correction,"}],"crossRefs":[{"label":"Ps 107:11","book":"Psa","chapter":107,"verse":11},{"label":"Lk 7:30","book":"Luk","chapter":7,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:26","parts":[{"kind":"text","text":"I, in turn, will laugh at your calamity. "},{"kind":"crossref","label":"Ps 2:4","book":"Psa","chapter":2,"verse":4,"letter":"a"},{"kind":"text","text":" I will mock when terror strikes you,"}],"crossRefs":[{"label":"Ps 2:4","book":"Psa","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:27","parts":[{"kind":"text","text":"when terror strikes you like a storm"},{"kind":"text","text":" and your calamity comes like a whirlwind,"},{"kind":"text","text":" when trouble and stress overcome you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:28","parts":[{"kind":"text","text":"Then they will call me, but I won’t answer;"},{"kind":"text","text":" they will search for me, but won’t find me. "},{"kind":"crossref","label":"1Sm 8:18","book":"1Sa","chapter":8,"verse":18,"letter":"a"}],"crossRefs":[{"label":"1Sm 8:18","book":"1Sa","chapter":8,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:29","parts":[{"kind":"text","text":"Because they hated knowledge,"},{"kind":"text","text":" didn’t choose to fear the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"crossref","label":"Pr 1:7","book":"Pro","chapter":1,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Pr 1:7","book":"Pro","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:30","parts":[{"kind":"text","text":"were not interested in my counsel,"},{"kind":"text","text":" and rejected all my correction, "},{"kind":"crossref","label":"Pr 5:12","book":"Pro","chapter":5,"verse":12,"letter":"a"},{"kind":"crossref","label":"Pr 15:5","book":"Pro","chapter":15,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Pr 5:12","book":"Pro","chapter":5,"verse":12},{"label":"Pr 15:5","book":"Pro","chapter":15,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:31","parts":[{"kind":"text","text":"they will eat the fruit of their way "},{"kind":"crossref","label":"Jr 6:19","book":"Jer","chapter":6,"verse":19,"letter":"a"},{"kind":"text","text":" and be glutted with their own schemes. "},{"kind":"crossref","label":"Pr 14:14","book":"Pro","chapter":14,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 28:19","book":"Pro","chapter":28,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Jr 6:19","book":"Jer","chapter":6,"verse":19},{"label":"Pr 14:14","book":"Pro","chapter":14,"verse":14},{"label":"Pr 28:19","book":"Pro","chapter":28,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:32","parts":[{"kind":"text","text":"For the apostasy of the inexperienced will kill them, "},{"kind":"crossref","label":"Jr 2:19","book":"Jer","chapter":2,"verse":19,"letter":"a"},{"kind":"text","text":" and the complacency of fools will destroy them."}],"crossRefs":[{"label":"Jr 2:19","book":"Jer","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:1:33","parts":[{"kind":"text","text":"But whoever listens to me will live securely"},{"kind":"text","text":" and be undisturbed by the dread of danger.” "},{"kind":"crossref","label":"Ps 112:7–8","book":"Psa","chapter":112,"verse":7,"letter":"a"},{"kind":"crossref","label":"Pr 3:24–26","book":"Pro","chapter":3,"verse":24,"letter":"b"}],"crossRefs":[{"label":"Ps 112:7–8","book":"Psa","chapter":112,"verse":7},{"label":"Pr 3:24–26","book":"Pro","chapter":3,"verse":24}],"footnotes":[]}]},"cachedAt":1783279522722}