{"label":"Pr 16:2","book":"Pro","chapter":16,"verse":2},{"label":"Pr 21:2","book":"Pro","chapter":21,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:16","parts":[{"kind":"text","text":"A fool’s displeasure is known at once,"},{"kind":"text","text":" but whoever ignores an insult is sensible. "},{"kind":"crossref","label":"Pr 11:13","book":"Pro","chapter":11,"verse":13,"letter":"a"},{"kind":"crossref","label":"Pr 12:23","book":"Pro","chapter":12,"verse":23,"letter":"b"},{"kind":"crossref","label":"Pr 17:9","book":"Pro","chapter":17,"verse":9,"letter":"c"},{"kind":"crossref","label":"Pr 29:11","book":"Pro","chapter":29,"verse":11,"letter":"d"}],"crossRefs":[{"label":"Pr 11:13","book":"Pro","chapter":11,"verse":13},{"label":"Pr 12:23","book":"Pro","chapter":12,"verse":23},{"label":"Pr 17:9","book":"Pro","chapter":17,"verse":9},{"label":"Pr 29:11","book":"Pro","chapter":29,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:17","parts":[{"kind":"text","text":"Whoever speaks the truth declares what is right,"},{"kind":"text","text":" but a false witness speaks deceit. "},{"kind":"crossref","label":"Pr 6:19","book":"Pro","chapter":6,"verse":19,"letter":"a"},{"kind":"crossref","label":"Pr 14:5","book":"Pro","chapter":14,"verse":5,"letter":"b"},{"kind":"crossref","label":"Pr 14:25","book":"Pro","chapter":14,"verse":25,"letter":"c"}],"crossRefs":[{"label":"Pr 6:19","book":"Pro","chapter":6,"verse":19},{"label":"Pr 14:5","book":"Pro","chapter":14,"verse":5},{"label":"Pr 14:25","book":"Pro","chapter":14,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:18","parts":[{"kind":"text","text":"There is one who speaks rashly,"},{"kind":"text","text":" like a piercing sword; "},{"kind":"crossref","label":"Ps 57:4","book":"Psa","chapter":57,"verse":4,"letter":"a"},{"kind":"text","text":" but the tongue of the wise brings healing. "},{"kind":"crossref","label":"Pr 4:22","book":"Pro","chapter":4,"verse":22,"letter":"a"},{"kind":"crossref","label":"Pr 15:4","book":"Pro","chapter":15,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Ps 57:4","book":"Psa","chapter":57,"verse":4},{"label":"Pr 4:22","book":"Pro","chapter":4,"verse":22},{"label":"Pr 15:4","book":"Pro","chapter":15,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:19","parts":[{"kind":"text","text":"Truthful lips endure forever,"},{"kind":"text","text":" but a lying tongue, only a moment. "},{"kind":"crossref","label":"Ps 52:4–5","book":"Psa","chapter":52,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 19:9","book":"Pro","chapter":19,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Ps 52:4–5","book":"Psa","chapter":52,"verse":4},{"label":"Pr 19:9","book":"Pro","chapter":19,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:20","parts":[{"kind":"text","text":"Deceit is in the hearts of those who plot evil,"},{"kind":"text","text":" but those who promote peace have joy. "},{"kind":"crossref","label":"Pr 14:22","book":"Pro","chapter":14,"verse":22,"letter":"a"}],"crossRefs":[{"label":"Pr 14:22","book":"Pro","chapter":14,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:21","parts":[{"kind":"text","text":"No disaster overcomes the righteous, "},{"kind":"crossref","label":"Ps 91:10","book":"Psa","chapter":91,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Pt 3:13","book":"1Pe","chapter":3,"verse":13,"letter":"b"},{"kind":"text","text":" but the wicked are full of misery."}],"crossRefs":[{"label":"Ps 91:10","book":"Psa","chapter":91,"verse":10},{"label":"1Pt 3:13","book":"1Pe","chapter":3,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:22","parts":[{"kind":"text","text":"Lying lips are detestable to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"crossref","label":"Rv 22:15","book":"Rev","chapter":22,"verse":15,"letter":"a"},{"kind":"text","text":" but faithful people are his delight. "},{"kind":"crossref","label":"Pr 3:32","book":"Pro","chapter":3,"verse":32,"letter":"a"},{"kind":"crossref","label":"Pr 11:20","book":"Pro","chapter":11,"verse":20,"letter":"b"},{"kind":"crossref","label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8,"letter":"c"},{"kind":"crossref","label":"Pr 15:26","book":"Pro","chapter":15,"verse":26,"letter":"d"}],"crossRefs":[{"label":"Rv 22:15","book":"Rev","chapter":22,"verse":15},{"label":"Pr 3:32","book":"Pro","chapter":3,"verse":32},{"label":"Pr 11:20","book":"Pro","chapter":11,"verse":20},{"label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8},{"label":"Pr 15:26","book":"Pro","chapter":15,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:23","parts":[{"kind":"text","text":"A shrewd person conceals knowledge,"},{"kind":"text","text":" but a foolish heart publicizes stupidity. "},{"kind":"crossref","label":"Pr 11:13","book":"Pro","chapter":11,"verse":13,"letter":"a"},{"kind":"crossref","label":"Pr 12:16","book":"Pro","chapter":12,"verse":16,"letter":"b"},{"kind":"crossref","label":"Pr 13:16","book":"Pro","chapter":13,"verse":16,"letter":"c"},{"kind":"crossref","label":"Pr 15:2","book":"Pro","chapter":15,"verse":2,"letter":"d"}],"crossRefs":[{"label":"Pr 11:13","book":"Pro","chapter":11,"verse":13},{"label":"Pr 12:16","book":"Pro","chapter":12,"verse":16},{"label":"Pr 13:16","book":"Pro","chapter":13,"verse":16},{"label":"Pr 15:2","book":"Pro","chapter":15,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:24","parts":[{"kind":"text","text":"The diligent hand will rule,"},{"kind":"text","text":" but laziness will lead to forced labor. "},{"kind":"crossref","label":"Pr 10:4","book":"Pro","chapter":10,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 13:4","book":"Pro","chapter":13,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 19:15","book":"Pro","chapter":19,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Pr 10:4","book":"Pro","chapter":10,"verse":4},{"label":"Pr 13:4","book":"Pro","chapter":13,"verse":4},{"label":"Pr 19:15","book":"Pro","chapter":19,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:25","parts":[{"kind":"text","text":"Anxiety in a person’s heart weighs it down,"},{"kind":"text","text":" but a good word cheers it up. "},{"kind":"crossref","label":"Ps 94:19","book":"Psa","chapter":94,"verse":19,"letter":"a"},{"kind":"crossref","label":"Pr 15:13","book":"Pro","chapter":15,"verse":13,"letter":"b"},{"kind":"crossref","label":"Pr 16:24","book":"Pro","chapter":16,"verse":24,"letter":"c"},{"kind":"crossref","label":"Mt 6:25–34","book":"Mat","chapter":6,"verse":25,"letter":"d"}],"crossRefs":[{"label":"Ps 94:19","book":"Psa","chapter":94,"verse":19},{"label":"Pr 15:13","book":"Pro","chapter":15,"verse":13},{"label":"Pr 16:24","book":"Pro","chapter":16,"verse":24},{"label":"Mt 6:25–34","book":"Mat","chapter":6,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:26","parts":[{"kind":"text","text":"A righteous person is careful in dealing with his neighbor, "},{"kind":"footnote","marker":1,"text":"Or person guides his neighbor"},{"kind":"text","text":" but the ways of the wicked lead them astray. "},{"kind":"crossref","label":"Pr 14:22","book":"Pro","chapter":14,"verse":22,"letter":"a"}],"crossRefs":[{"label":"Pr 14:22","book":"Pro","chapter":14,"verse":22}],"footnotes":[{"marker":1,"text":"Or person guides his neighbor"}]},{"verseId":"a556c5305ee15c3f-01:Pro:12:27","parts":[{"kind":"text","text":"A lazy hunter doesn’t roast his game, "},{"kind":"crossref","label":"Pr 19:15","book":"Pro","chapter":19,"verse":15,"letter":"a"},{"kind":"crossref","label":"Pr 19:24","book":"Pro","chapter":19,"verse":24,"letter":"b"},{"kind":"crossref","label":"Pr 26:15","book":"Pro","chapter":26,"verse":15,"letter":"c"},{"kind":"text","text":" but to a diligent person, his wealth is precious. "},{"kind":"crossref","label":"Pr 10:4","book":"Pro","chapter":10,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 13:4","book":"Pro","chapter":13,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Pr 19:15","book":"Pro","chapter":19,"verse":15},{"label":"Pr 19:24","book":"Pro","chapter":19,"verse":24},{"label":"Pr 26:15","book":"Pro","chapter":26,"verse":15},{"label":"Pr 10:4","book":"Pro","chapter":10,"verse":4},{"label":"Pr 13:4","book":"Pro","chapter":13,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:12:28","parts":[{"kind":"text","text":"There is life in the path of righteousness,"},{"kind":"text","text":" and in its path there is no death. "},{"kind":"footnote","marker":1,"text":"Or righteousness, but the crooked way leads to death"},{"kind":"crossref","label":"Pr 10:2","book":"Pro","chapter":10,"verse":2,"letter":"a"},{"kind":"crossref","label":"Pr 13:14","book":"Pro","chapter":13,"verse":14,"letter":"b"},{"kind":"crossref","label":"Pr 14:27","book":"Pro","chapter":14,"verse":27,"letter":"c"}],"crossRefs":[{"label":"Pr 10:2","book":"Pro","chapter":10,"verse":2},{"label":"Pr 13:14","book":"Pro","chapter":13,"verse":14},{"label":"Pr 14:27","book":"Pro","chapter":14,"verse":27}],"footnotes":[{"marker":1,"text":"Or righteousness, but the crooked way leads to death"}]}]},"cachedAt":1783279525881}