"label":"Pr 28:7","book":"Pro","chapter":28,"verse":7,"letter":"c"},{"kind":"text","text":" and a wife’s nagging is an endless dripping. "},{"kind":"crossref","label":"Pr 21:9","book":"Pro","chapter":21,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 21:19","book":"Pro","chapter":21,"verse":19,"letter":"b"},{"kind":"crossref","label":"Pr 27:15","book":"Pro","chapter":27,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Pr 10:1","book":"Pro","chapter":10,"verse":1},{"label":"Pr 17:25","book":"Pro","chapter":17,"verse":25},{"label":"Pr 28:7","book":"Pro","chapter":28,"verse":7},{"label":"Pr 21:9","book":"Pro","chapter":21,"verse":9},{"label":"Pr 21:19","book":"Pro","chapter":21,"verse":19},{"label":"Pr 27:15","book":"Pro","chapter":27,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:14","parts":[{"kind":"text","text":"A house and wealth are inherited from fathers, "},{"kind":"crossref","label":"2Co 12:14","book":"2Co","chapter":12,"verse":14,"letter":"a"},{"kind":"text","text":" but a prudent wife is from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"2Co 12:14","book":"2Co","chapter":12,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:15","parts":[{"kind":"text","text":"Laziness induces deep sleep,"},{"kind":"text","text":" and a lazy person will go hungry. "},{"kind":"crossref","label":"Pr 6:9–11","book":"Pro","chapter":6,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 10:4","book":"Pro","chapter":10,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 13:4","book":"Pro","chapter":13,"verse":4,"letter":"c"},{"kind":"crossref","label":"Pr 21:25","book":"Pro","chapter":21,"verse":25,"letter":"d"}],"crossRefs":[{"label":"Pr 6:9–11","book":"Pro","chapter":6,"verse":9},{"label":"Pr 10:4","book":"Pro","chapter":10,"verse":4},{"label":"Pr 13:4","book":"Pro","chapter":13,"verse":4},{"label":"Pr 21:25","book":"Pro","chapter":21,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:16","parts":[{"kind":"text","text":"The one who keeps commands preserves himself; "},{"kind":"crossref","label":"Lk 10:28","book":"Luk","chapter":10,"verse":28,"letter":"a"},{"kind":"text","text":" one who disregards "},{"kind":"footnote","marker":1,"text":"Or despises, or treats lightly"},{"kind":"text","text":" his ways will die. "},{"kind":"crossref","label":"Pr 3:1–2","book":"Pro","chapter":3,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 4:4","book":"Pro","chapter":4,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 13:13","book":"Pro","chapter":13,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Lk 10:28","book":"Luk","chapter":10,"verse":28},{"label":"Pr 3:1–2","book":"Pro","chapter":3,"verse":1},{"label":"Pr 4:4","book":"Pro","chapter":4,"verse":4},{"label":"Pr 13:13","book":"Pro","chapter":13,"verse":13}],"footnotes":[{"marker":1,"text":"Or despises, or treats lightly"}]},{"verseId":"a556c5305ee15c3f-01:Pro:19:17","parts":[{"kind":"text","text":"Kindness to the poor is a loan to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"crossref","label":"Dt 15:7","book":"Deu","chapter":15,"verse":7,"letter":"a"},{"kind":"crossref","label":"Pr 14:31","book":"Pro","chapter":14,"verse":31,"letter":"b"},{"kind":"crossref","label":"Pr 28:27","book":"Pro","chapter":28,"verse":27,"letter":"c"},{"kind":"crossref","label":"Ec 11:1–2","book":"Ecc","chapter":11,"verse":1,"letter":"d"},{"kind":"crossref","label":"Mt 10:42","book":"Mat","chapter":10,"verse":42,"letter":"e"},{"kind":"crossref","label":"Mt 25:40","book":"Mat","chapter":25,"verse":40,"letter":"f"},{"kind":"crossref","label":"2Co 9:6–8","book":"2Co","chapter":9,"verse":6,"letter":"g"},{"kind":"crossref","label":"Heb 6:10","book":"Heb","chapter":6,"verse":10,"letter":"h"},{"kind":"text","text":" and he will give a reward to the lender. "},{"kind":"footnote","marker":1,"text":"Lit to him"},{"kind":"crossref","label":"Lk 6:38","book":"Luk","chapter":6,"verse":38,"letter":"a"}],"crossRefs":[{"label":"Dt 15:7","book":"Deu","chapter":15,"verse":7},{"label":"Pr 14:31","book":"Pro","chapter":14,"verse":31},{"label":"Pr 28:27","book":"Pro","chapter":28,"verse":27},{"label":"Ec 11:1–2","book":"Ecc","chapter":11,"verse":1},{"label":"Mt 10:42","book":"Mat","chapter":10,"verse":42},{"label":"Mt 25:40","book":"Mat","chapter":25,"verse":40},{"label":"2Co 9:6–8","book":"2Co","chapter":9,"verse":6},{"label":"Heb 6:10","book":"Heb","chapter":6,"verse":10},{"label":"Lk 6:38","book":"Luk","chapter":6,"verse":38}],"footnotes":[{"marker":1,"text":"Lit to him"}]},{"verseId":"a556c5305ee15c3f-01:Pro:19:18","parts":[{"kind":"text","text":"Discipline your son while there is hope;"},{"kind":"text","text":" don’t set your heart on being the cause of his death. "},{"kind":"footnote","marker":1,"text":"Lit don’t lift up your soul to his death"},{"kind":"crossref","label":"Pr 13:24","book":"Pro","chapter":13,"verse":24,"letter":"a"},{"kind":"crossref","label":"Pr 23:13–14","book":"Pro","chapter":23,"verse":13,"letter":"b"},{"kind":"crossref","label":"Pr 29:17","book":"Pro","chapter":29,"verse":17,"letter":"c"}],"crossRefs":[{"label":"Pr 13:24","book":"Pro","chapter":13,"verse":24},{"label":"Pr 23:13–14","book":"Pro","chapter":23,"verse":13},{"label":"Pr 29:17","book":"Pro","chapter":29,"verse":17}],"footnotes":[{"marker":1,"text":"Lit don’t lift up your soul to his death"}]},{"verseId":"a556c5305ee15c3f-01:Pro:19:19","parts":[{"kind":"text","text":"A person with intense anger bears the penalty;"},{"kind":"text","text":" if you rescue him, you’ll have to do it again. "},{"kind":"crossref","label":"Pr 22:24–25","book":"Pro","chapter":22,"verse":24,"letter":"a"},{"kind":"crossref","label":"Pr 29:22","book":"Pro","chapter":29,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Pr 22:24–25","book":"Pro","chapter":22,"verse":24},{"label":"Pr 29:22","book":"Pro","chapter":29,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:20","parts":[{"kind":"text","text":"Listen to counsel and receive instruction"},{"kind":"text","text":" so that you may be wise later in life. "},{"kind":"footnote","marker":1,"text":"Lit in your end"},{"kind":"crossref","label":"Pr 12:1","book":"Pro","chapter":12,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 15:5","book":"Pro","chapter":15,"verse":5,"letter":"b"},{"kind":"crossref","label":"Pr 15:31","book":"Pro","chapter":15,"verse":31,"letter":"c"}],"crossRefs":[{"label":"Pr 12:1","book":"Pro","chapter":12,"verse":1},{"label":"Pr 15:5","book":"Pro","chapter":15,"verse":5},{"label":"Pr 15:31","book":"Pro","chapter":15,"verse":31}],"footnotes":[{"marker":1,"text":"Lit in your end"}]},{"verseId":"a556c5305ee15c3f-01:Pro:19:21","parts":[{"kind":"text","text":"Many plans are in a person’s heart,"},{"kind":"text","text":" but the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s decree will prevail. "},{"kind":"crossref","label":"Ps 33:10–11","book":"Psa","chapter":33,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 16:1","book":"Pro","chapter":16,"verse":1,"letter":"b"},{"kind":"crossref","label":"Pr 16:9","book":"Pro","chapter":16,"verse":9,"letter":"c"},{"kind":"crossref","label":"Pr 16:33","book":"Pro","chapter":16,"verse":33,"letter":"d"},{"kind":"crossref","label":"Pr 21:31","book":"Pro","chapter":21,"verse":31,"letter":"e"},{"kind":"crossref","label":"Is 14:26–27","book":"Isa","chapter":14,"verse":26,"letter":"f"}],"crossRefs":[{"label":"Ps 33:10–11","book":"Psa","chapter":33,"verse":10},{"label":"Pr 16:1","book":"Pro","chapter":16,"verse":1},{"label":"Pr 16:9","book":"Pro","chapter":16,"verse":9},{"label":"Pr 16:33","book":"Pro","chapter":16,"verse":33},{"label":"Pr 21:31","book":"Pro","chapter":21,"verse":31},{"label":"Is 14:26–27","book":"Isa","chapter":14,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:22","parts":[{"kind":"text","text":"What is desirable in a person is his fidelity;"},{"kind":"text","text":" better to be a poor person than a liar. "},{"kind":"crossref","label":"Pr 19:1","book":"Pro","chapter":19,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 28:6","book":"Pro","chapter":28,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Pr 19:1","book":"Pro","chapter":19,"verse":1},{"label":"Pr 28:6","book":"Pro","chapter":28,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:23","parts":[{"kind":"text","text":"The fear of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" leads to life;"},{"kind":"text","text":" one will sleep at night "},{"kind":"footnote","marker":1,"text":"Lit will spend the night satisfied"},{"kind":"text","text":" without danger. "},{"kind":"crossref","label":"Pr 14:26–27","book":"Pro","chapter":14,"verse":26,"letter":"a"}],"crossRefs":[{"label":"Pr 14:26–27","book":"Pro","chapter":14,"verse":26}],"footnotes":[{"marker":1,"text":"Lit will spend the night satisfied"}]},{"verseId":"a556c5305ee15c3f-01:Pro:19:24","parts":[{"kind":"text","text":"The slacker buries his hand in the bowl;"},{"kind":"text","text":" he doesn’t even bring it back to his mouth! "},{"kind":"crossref","label":"Pr 12:27","book":"Pro","chapter":12,"verse":27,"letter":"a"},{"kind":"crossref","label":"Pr 20:4","book":"Pro","chapter":20,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 26:14–15","book":"Pro","chapter":26,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Pr 12:27","book":"Pro","chapter":12,"verse":27},{"label":"Pr 20:4","book":"Pro","chapter":20,"verse":4},{"label":"Pr 26:14–15","book":"Pro","chapter":26,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:25","parts":[{"kind":"text","text":"Strike a mocker, and the inexperienced learn a lesson; "},{"kind":"crossref","label":"Pr 21:11","book":"Pro","chapter":21,"verse":11,"letter":"a"},{"kind":"text","text":" rebuke the discerning, and he gains knowledge. "},{"kind":"crossref","label":"Pr 9:8","book":"Pro","chapter":9,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Pr 21:11","book":"Pro","chapter":21,"verse":11},{"label":"Pr 9:8","book":"Pro","chapter":9,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:26","parts":[{"kind":"text","text":"The one who plunders his father and evicts his mother"},{"kind":"text","text":" is a disgraceful and shameful son."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:27","parts":[{"kind":"text","text":"If you stop listening to correction, my son,"},{"kind":"text","text":" you will stray from the words of knowledge."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:28","parts":[{"kind":"text","text":"A worthless witness mocks justice,"},{"kind":"text","text":" and a wicked mouth swallows iniquity. "},{"kind":"crossref","label":"Jb 15:16","book":"Job","chapter":15,"verse":16,"letter":"a"},{"kind":"crossref","label":"Jb 34:7","book":"Job","chapter":34,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Jb 15:16","book":"Job","chapter":15,"verse":16},{"label":"Jb 34:7","book":"Job","chapter":34,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:19:29","parts":[{"kind":"text","text":"Judgments are prepared for mockers,"},{"kind":"text","text":" and beatings for the backs of fools. "},{"kind":"crossref","label":"Pr 10:13","book":"Pro","chapter":10,"verse":13,"letter":"a"},{"kind":"crossref","label":"Pr 18:6","book":"Pro","chapter":18,"verse":6,"letter":"b"},{"kind":"crossref","label":"Pr 26:3","book":"Pro","chapter":26,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Pr 10:13","book":"Pro","chapter":10,"verse":13},{"label":"Pr 18:6","book":"Pro","chapter":18,"verse":6},{"label":"Pr 26:3","book":"Pro","chapter":26,"verse":3}],"footnotes":[]}]},"cachedAt":1783279528052}