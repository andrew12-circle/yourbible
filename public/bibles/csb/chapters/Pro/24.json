":"crossref","label":"Jb 18:5","book":"Job","chapter":18,"verse":5,"letter":"b"},{"kind":"crossref","label":"Jb 21:17","book":"Job","chapter":21,"verse":17,"letter":"c"},{"kind":"crossref","label":"Pr 13:9","book":"Pro","chapter":13,"verse":9,"letter":"d"},{"kind":"crossref","label":"Pr 20:20","book":"Pro","chapter":20,"verse":20,"letter":"e"}],"crossRefs":[{"label":"Ps 37:38","book":"Psa","chapter":37,"verse":38},{"label":"Pr 14:11","book":"Pro","chapter":14,"verse":11},{"label":"Pr 16:25","book":"Pro","chapter":16,"verse":25},{"label":"2Sm 21:17","book":"2Sa","chapter":21,"verse":17},{"label":"Jb 18:5","book":"Job","chapter":18,"verse":5},{"label":"Jb 21:17","book":"Job","chapter":21,"verse":17},{"label":"Pr 13:9","book":"Pro","chapter":13,"verse":9},{"label":"Pr 20:20","book":"Pro","chapter":20,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:21","parts":[{"kind":"text","text":"My son, fear the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", as well as the king, "},{"kind":"crossref","label":"Mt 22:21","book":"Mat","chapter":22,"verse":21,"letter":"a"},{"kind":"crossref","label":"Rm 13:1–7","book":"Rom","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Pt 2:13","book":"1Pe","chapter":2,"verse":13,"letter":"c"},{"kind":"crossref","label":"1Pt 2:17","book":"1Pe","chapter":2,"verse":17,"letter":"d"},{"kind":"text","text":" and don’t associate with rebels, "},{"kind":"footnote","marker":1,"text":"Or those given to change"}],"crossRefs":[{"label":"Mt 22:21","book":"Mat","chapter":22,"verse":21},{"label":"Rm 13:1–7","book":"Rom","chapter":13,"verse":1},{"label":"1Pt 2:13","book":"1Pe","chapter":2,"verse":13},{"label":"1Pt 2:17","book":"1Pe","chapter":2,"verse":17}],"footnotes":[{"marker":1,"text":"Or those given to change"}]},{"verseId":"a556c5305ee15c3f-01:Pro:24:22","parts":[{"kind":"text","text":"for destruction will come suddenly from them;"},{"kind":"text","text":" who knows what distress these two can bring?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:23","parts":[{"kind":"text","text":"These sayings also belong to the wise: "},{"kind":"crossref","label":"Pr 1:6","book":"Pro","chapter":1,"verse":6,"letter":"a"},{"kind":"crossref","label":"Pr 22:17","book":"Pro","chapter":22,"verse":17,"letter":"b"},{"kind":"text","text":" It is not good to show partiality in judgment. "},{"kind":"crossref","label":"Dt 1:17","book":"Deu","chapter":1,"verse":17,"letter":"a"},{"kind":"crossref","label":"Dt 16:19","book":"Deu","chapter":16,"verse":19,"letter":"b"},{"kind":"crossref","label":"Pr 18:5","book":"Pro","chapter":18,"verse":5,"letter":"c"},{"kind":"crossref","label":"Pr 28:21","book":"Pro","chapter":28,"verse":21,"letter":"d"}],"crossRefs":[{"label":"Pr 1:6","book":"Pro","chapter":1,"verse":6},{"label":"Pr 22:17","book":"Pro","chapter":22,"verse":17},{"label":"Dt 1:17","book":"Deu","chapter":1,"verse":17},{"label":"Dt 16:19","book":"Deu","chapter":16,"verse":19},{"label":"Pr 18:5","book":"Pro","chapter":18,"verse":5},{"label":"Pr 28:21","book":"Pro","chapter":28,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:24","parts":[{"kind":"text","text":"Whoever says to the guilty, “You are innocent” "},{"kind":"crossref","label":"Pr 17:15","book":"Pro","chapter":17,"verse":15,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" peoples will curse him, "},{"kind":"crossref","label":"Pr 11:26","book":"Pro","chapter":11,"verse":26,"letter":"a"},{"kind":"text","text":" and nations will denounce him;"}],"crossRefs":[{"label":"Pr 17:15","book":"Pro","chapter":17,"verse":15},{"label":"Pr 11:26","book":"Pro","chapter":11,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:25","parts":[{"kind":"text","text":"but it will go well with those who convict the guilty,"},{"kind":"text","text":" and a generous blessing will come to them."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:26","parts":[{"kind":"text","text":"He who gives an honest answer"},{"kind":"text","text":" gives a kiss on the lips."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:27","parts":[{"kind":"text","text":"Complete your outdoor work, and prepare your field; "},{"kind":"crossref","label":"Pr 20:4","book":"Pro","chapter":20,"verse":4,"letter":"a"},{"kind":"text","text":" afterward, build your house."}],"crossRefs":[{"label":"Pr 20:4","book":"Pro","chapter":20,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:28","parts":[{"kind":"text","text":"Don’t testify against your neighbor without cause. "},{"kind":"crossref","label":"Ex 20:16","book":"Exo","chapter":20,"verse":16,"letter":"a"},{"kind":"crossref","label":"Pr 25:18","book":"Pro","chapter":25,"verse":18,"letter":"b"},{"kind":"text","text":" Don’t deceive with your lips."}],"crossRefs":[{"label":"Ex 20:16","book":"Exo","chapter":20,"verse":16},{"label":"Pr 25:18","book":"Pro","chapter":25,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:29","parts":[{"kind":"text","text":"Don’t say, “I’ll do to him what he did to me;"},{"kind":"text","text":" I’ll repay the man for what he has done.” "},{"kind":"crossref","label":"Dt 32:35","book":"Deu","chapter":32,"verse":35,"letter":"a"},{"kind":"crossref","label":"Pr 20:22","book":"Pro","chapter":20,"verse":22,"letter":"b"},{"kind":"crossref","label":"Mt 5:39","book":"Mat","chapter":5,"verse":39,"letter":"c"},{"kind":"crossref","label":"Rm 12:17","book":"Rom","chapter":12,"verse":17,"letter":"d"},{"kind":"crossref","label":"Rm 12:19","book":"Rom","chapter":12,"verse":19,"letter":"e"}],"crossRefs":[{"label":"Dt 32:35","book":"Deu","chapter":32,"verse":35},{"label":"Pr 20:22","book":"Pro","chapter":20,"verse":22},{"label":"Mt 5:39","book":"Mat","chapter":5,"verse":39},{"label":"Rm 12:17","book":"Rom","chapter":12,"verse":17},{"label":"Rm 12:19","book":"Rom","chapter":12,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:30","parts":[{"kind":"text","text":"I went by the field of a slacker"},{"kind":"text","text":" and by the vineyard of one lacking sense."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:31","parts":[{"kind":"text","text":"Thistles had come up everywhere,"},{"kind":"text","text":" weeds covered the ground, "},{"kind":"crossref","label":"Gn 3:18","book":"Gen","chapter":3,"verse":18,"letter":"a"},{"kind":"crossref","label":"Pr 20:4","book":"Pro","chapter":20,"verse":4,"letter":"b"},{"kind":"text","text":" and the stone wall was ruined."}],"crossRefs":[{"label":"Gn 3:18","book":"Gen","chapter":3,"verse":18},{"label":"Pr 20:4","book":"Pro","chapter":20,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:32","parts":[{"kind":"text","text":"I saw, and took it to heart;"},{"kind":"text","text":" I looked, and received instruction:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:33","parts":[{"kind":"text","text":"a little sleep, a little slumber,"},{"kind":"text","text":" a little folding of the arms to rest,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:24:34","parts":[{"kind":"text","text":"and your poverty will come like a robber,"},{"kind":"text","text":" and your need, like a bandit. "},{"kind":"crossref","label":"Pr 6:10–11","book":"Pro","chapter":6,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 20:13","book":"Pro","chapter":20,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Pr 6:10–11","book":"Pro","chapter":6,"verse":10},{"label":"Pr 20:13","book":"Pro","chapter":20,"verse":13}],"footnotes":[]}]},"cachedAt":1783279529559}