el":"Pr 5:12–13","book":"Pro","chapter":5,"verse":12,"letter":"a"},{"kind":"crossref","label":"Pr 5:22","book":"Pro","chapter":5,"verse":22,"letter":"b"},{"kind":"crossref","label":"Pr 6:23","book":"Pro","chapter":6,"verse":23,"letter":"c"},{"kind":"crossref","label":"Pr 13:13–14","book":"Pro","chapter":13,"verse":13,"letter":"d"}],"crossRefs":[{"label":"Pr 5:12–13","book":"Pro","chapter":5,"verse":12},{"label":"Pr 5:22","book":"Pro","chapter":5,"verse":22},{"label":"Pr 6:23","book":"Pro","chapter":6,"verse":23},{"label":"Pr 13:13–14","book":"Pro","chapter":13,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:18","parts":[{"kind":"text","text":"The one who conceals hatred has lying lips,"},{"kind":"text","text":" and whoever spreads slander is a fool. "},{"kind":"crossref","label":"Pr 11:13","book":"Pro","chapter":11,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Pr 11:13","book":"Pro","chapter":11,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:19","parts":[{"kind":"text","text":"When there are many words, sin is unavoidable,"},{"kind":"text","text":" but the one who controls his lips is prudent. "},{"kind":"crossref","label":"Pr 17:27–28","book":"Pro","chapter":17,"verse":27,"letter":"a"},{"kind":"crossref","label":"Jms 1:19","book":"Jas","chapter":1,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jms 3:2","book":"Jas","chapter":3,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Pr 17:27–28","book":"Pro","chapter":17,"verse":27},{"label":"Jms 1:19","book":"Jas","chapter":1,"verse":19},{"label":"Jms 3:2","book":"Jas","chapter":3,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:20","parts":[{"kind":"text","text":"The tongue of the righteous is pure silver;"},{"kind":"text","text":" the heart of the wicked is of little value. "},{"kind":"crossref","label":"Pr 8:19","book":"Pro","chapter":8,"verse":19,"letter":"a"},{"kind":"crossref","label":"Pr 10:32","book":"Pro","chapter":10,"verse":32,"letter":"b"}],"crossRefs":[{"label":"Pr 8:19","book":"Pro","chapter":8,"verse":19},{"label":"Pr 10:32","book":"Pro","chapter":10,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:21","parts":[{"kind":"text","text":"The lips of the righteous feed many,"},{"kind":"text","text":" but fools die for lack of sense. "},{"kind":"crossref","label":"Hs 4:6","book":"Hos","chapter":4,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Hs 4:6","book":"Hos","chapter":4,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:22","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s blessing enriches, "},{"kind":"crossref","label":"Gn 24:35","book":"Gen","chapter":24,"verse":35,"letter":"a"},{"kind":"crossref","label":"Gn 26:12","book":"Gen","chapter":26,"verse":12,"letter":"b"},{"kind":"crossref","label":"Dt 8:18","book":"Deu","chapter":8,"verse":18,"letter":"c"},{"kind":"crossref","label":"Jms 1:17","book":"Jas","chapter":1,"verse":17,"letter":"d"},{"kind":"text","text":" and he adds no painful effort to it. "},{"kind":"footnote","marker":1,"text":"Or and painful effort adds nothing to it"},{"kind":"crossref","label":"Mt 6:31–32","book":"Mat","chapter":6,"verse":31,"letter":"a"}],"crossRefs":[{"label":"Gn 24:35","book":"Gen","chapter":24,"verse":35},{"label":"Gn 26:12","book":"Gen","chapter":26,"verse":12},{"label":"Dt 8:18","book":"Deu","chapter":8,"verse":18},{"label":"Jms 1:17","book":"Jas","chapter":1,"verse":17},{"label":"Mt 6:31–32","book":"Mat","chapter":6,"verse":31}],"footnotes":[{"marker":1,"text":"Or and painful effort adds nothing to it"}]},{"verseId":"a556c5305ee15c3f-01:Pro:10:23","parts":[{"kind":"text","text":"As shameful conduct is pleasure for a fool, "},{"kind":"crossref","label":"Pr 2:14","book":"Pro","chapter":2,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 15:21","book":"Pro","chapter":15,"verse":21,"letter":"b"},{"kind":"text","text":" so wisdom is for a person of understanding."}],"crossRefs":[{"label":"Pr 2:14","book":"Pro","chapter":2,"verse":14},{"label":"Pr 15:21","book":"Pro","chapter":15,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:24","parts":[{"kind":"text","text":"What the wicked dreads will come to him, "},{"kind":"crossref","label":"Pr 1:26–27","book":"Pro","chapter":1,"verse":26,"letter":"a"},{"kind":"crossref","label":"Is 66:4","book":"Isa","chapter":66,"verse":4,"letter":"b"},{"kind":"crossref","label":"Heb 10:27","book":"Heb","chapter":10,"verse":27,"letter":"c"},{"kind":"text","text":" but what the righteous desire will be given to them. "},{"kind":"crossref","label":"Ps 37:4","book":"Psa","chapter":37,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 145:19","book":"Psa","chapter":145,"verse":19,"letter":"b"},{"kind":"crossref","label":"Pr 11:23","book":"Pro","chapter":11,"verse":23,"letter":"c"},{"kind":"crossref","label":"Mt 5:6","book":"Mat","chapter":5,"verse":6,"letter":"d"},{"kind":"crossref","label":"1Jn 5:14–15","book":"1Jn","chapter":5,"verse":14,"letter":"e"}],"crossRefs":[{"label":"Pr 1:26–27","book":"Pro","chapter":1,"verse":26},{"label":"Is 66:4","book":"Isa","chapter":66,"verse":4},{"label":"Heb 10:27","book":"Heb","chapter":10,"verse":27},{"label":"Ps 37:4","book":"Psa","chapter":37,"verse":4},{"label":"Ps 145:19","book":"Psa","chapter":145,"verse":19},{"label":"Pr 11:23","book":"Pro","chapter":11,"verse":23},{"label":"Mt 5:6","book":"Mat","chapter":5,"verse":6},{"label":"1Jn 5:14–15","book":"1Jn","chapter":5,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:25","parts":[{"kind":"text","text":"When the whirlwind passes,"},{"kind":"text","text":" the wicked are no more, "},{"kind":"crossref","label":"Jb 21:18","book":"Job","chapter":21,"verse":18,"letter":"a"},{"kind":"crossref","label":"Is 29:5–7","book":"Isa","chapter":29,"verse":5,"letter":"b"},{"kind":"text","text":" but the righteous are secure forever. "},{"kind":"crossref","label":"Ps 15:5","book":"Psa","chapt