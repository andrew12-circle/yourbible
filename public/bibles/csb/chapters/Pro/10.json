rseId":"a556c5305ee15c3f-01:Pro:10:11","parts":[{"kind":"text","text":"The mouth of the righteous is a fountain of life, "},{"kind":"crossref","label":"Ps 37:30","book":"Psa","chapter":37,"verse":30,"letter":"a"},{"kind":"crossref","label":"Pr 13:14","book":"Pro","chapter":13,"verse":14,"letter":"b"},{"kind":"crossref","label":"Pr 14:27","book":"Pro","chapter":14,"verse":27,"letter":"c"},{"kind":"crossref","label":"Pr 16:22","book":"Pro","chapter":16,"verse":22,"letter":"d"},{"kind":"text","text":" but the mouth of the wicked conceals violence. "},{"kind":"crossref","label":"Pr 10:6","book":"Pro","chapter":10,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Ps 37:30","book":"Psa","chapter":37,"verse":30},{"label":"Pr 13:14","book":"Pro","chapter":13,"verse":14},{"label":"Pr 14:27","book":"Pro","chapter":14,"verse":27},{"label":"Pr 16:22","book":"Pro","chapter":16,"verse":22},{"label":"Pr 10:6","book":"Pro","chapter":10,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:12","parts":[{"kind":"text","text":"Hatred stirs up conflicts,"},{"kind":"text","text":" but love covers all offenses. "},{"kind":"crossref","label":"Pr 17:9","book":"Pro","chapter":17,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jms 5:20","book":"Jas","chapter":5,"verse":20,"letter":"b"},{"kind":"crossref","label":"1Pt 4:8","book":"1Pe","chapter":4,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Pr 17:9","book":"Pro","chapter":17,"verse":9},{"label":"Jms 5:20","book":"Jas","chapter":5,"verse":20},{"label":"1Pt 4:8","book":"1Pe","chapter":4,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:10:13","parts":[{"kind":"text","text":"Wisdom is found on the lips of the discerning,"},{"kind":"text","text":" but a rod is for the back of the one who lacks sense. "},{"kind":"crossref","label":"Pr 19:29","book":"Pro","chapter":19,"verse":29,"letter":"a"},{"kind":"crossref","label":"Pr 26:3","book":"Pro","chapter":26,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Pr 19:29","boo