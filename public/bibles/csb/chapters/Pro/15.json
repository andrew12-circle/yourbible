":29,"verse":22,"letter":"c"},{"kind":"text","text":" but one slow to anger "},{"kind":"crossref","label":"Pr 14:29","book":"Pro","chapter":14,"verse":29,"letter":"a"},{"kind":"text","text":" calms strife."}],"crossRefs":[{"label":"Pr 16:28","book":"Pro","chapter":16,"verse":28},{"label":"Pr 26:21","book":"Pro","chapter":26,"verse":21},{"label":"Pr 29:22","book":"Pro","chapter":29,"verse":22},{"label":"Pr 14:29","book":"Pro","chapter":14,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:19","parts":[{"kind":"text","text":"A slacker’s way is like a thorny hedge,"},{"kind":"text","text":" but the path of the upright is a highway. "},{"kind":"crossref","label":"Pr 16:17","book":"Pro","chapter":16,"verse":17,"letter":"a"},{"kind":"crossref","label":"Pr 16:31","book":"Pro","chapter":16,"verse":31,"letter":"b"},{"kind":"crossref","label":"Pr 22:5–6","book":"Pro","chapter":22,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Pr 16:17","book":"Pro","chapter":16,"verse":17},{"label":"Pr 16:31","book":"Pro","chapter":16,"verse":31},{"label":"Pr 22:5–6","book":"Pro","chapter":22,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:20","parts":[{"kind":"text","text":"A wise son brings joy to his father,"},{"kind":"text","text":" but a foolish man despises his mother. "},{"kind":"crossref","label":"Pr 10:1","book":"Pro","chapter":10,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 23:24–25","book":"Pro","chapter":23,"verse":24,"letter":"b"},{"kind":"crossref","label":"Pr 29:3","book":"Pro","chapter":29,"verse":3,"letter":"c"},{"kind":"crossref","label":"Pr 29:15","book":"Pro","chapter":29,"verse":15,"letter":"d"}],"crossRefs":[{"label":"Pr 10:1","book":"Pro","chapter":10,"verse":1},{"label":"Pr 23:24–25","book":"Pro","chapter":23,"verse":24},{"label":"Pr 29:3","book":"Pro","chapter":29,"verse":3},{"label":"Pr 29:15","book":"Pro","chapter":29,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:21","parts":[{"kind":"text","text":