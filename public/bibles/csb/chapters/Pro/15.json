 mouth"}]},{"verseId":"a556c5305ee15c3f-01:Pro:15:24","parts":[{"kind":"text","text":"For the prudent the path of life leads upward,"},{"kind":"text","text":" so that he may avoid going down to Sheol."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:25","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" tears apart the house of the proud,"},{"kind":"text","text":" but he protects the widow’s territory. "},{"kind":"crossref","label":"Ps 68:5","book":"Psa","chapter":68,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 146:9","book":"Psa","chapter":146,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Ps 68:5","book":"Psa","chapter":68,"verse":5},{"label":"Ps 146:9","book":"Psa","chapter":146,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:26","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" detests the plans of the one who is evil,"},{"kind":"text","text":" but pleasant words are pure. "},{"kind":"crossref","label":"Pr 11:20","book":"Pro","chapter":11,"verse":20,"letter":"a"},{"kind":"crossref","label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8,"letter":"b"},{"kind":"crossref","label":"Pr 16:24","book":"Pro","chapter":16,"verse":24,"letter":"c"}],"crossRefs":[{"label":"Pr 11:20","book":"Pro","chapter":11,"verse":20},{"label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8},{"label":"Pr 16:24","book":"Pro","chapter":16,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:15:27","parts":[{"kind":"text","text":"The one who profits dishonestly "},{"kind":"crossref","label":"Pr 1:19","book":"Pro","chapter":1,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 17:11","book":"Jer","chapter":17,"verse":11,"letter":"b"},{"kind":"text","text":" troubles his household,"},{"kind":"text","text":" but the one who hates bribes will live. "},{"kind":"crossref","label":"Ex 23:8","book":"Exo","chapter"