":"Ec 7:9","book":"Ecc","chapter":7,"verse":9},{"label":"Jms 1:19","book":"Jas","chapter":1,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:30","parts":[{"kind":"text","text":"A tranquil heart is life to the body, "},{"kind":"crossref","label":"Pr 3:8","book":"Pro","chapter":3,"verse":8,"letter":"a"},{"kind":"crossref","label":"Pr 4:22","book":"Pro","chapter":4,"verse":22,"letter":"b"},{"kind":"crossref","label":"Pr 16:24","book":"Pro","chapter":16,"verse":24,"letter":"c"},{"kind":"text","text":" but jealousy is rottenness to the bones. "},{"kind":"crossref","label":"Pr 12:4","book":"Pro","chapter":12,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 27:4","book":"Pro","chapter":27,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jms 3:16","book":"Jas","chapter":3,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Pr 3:8","book":"Pro","chapter":3,"verse":8},{"label":"Pr 4:22","book":"Pro","chapter":4,"verse":22},{"label":"Pr 16:24","book":"Pro","chapter":16,"verse":24},{"label":"Pr 12:4","book":"Pro","chapter":12,"verse":4},{"label":"Pr 27:4","book":"Pro","chapter":27,"verse":4},{"label":"Jms 3:16","book":"Jas","chapter":3,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:31","parts":[{"kind":"text","text":"The one who oppresses the poor person insults his Maker, "},{"kind":"crossref","label":"Pr 17:5","book":"Pro","chapter":17,"verse":5,"letter":"a"},{"kind":"crossref","label":"Pr 21:13","book":"Pro","chapter":21,"verse":13,"letter":"b"},{"kind":"crossref","label":"Mt 25:40","book":"Mat","chapter":25,"verse":40,"letter":"c"},{"kind":"crossref","label":"1Jn 3:17","book":"1Jn","chapter":3,"verse":17,"letter":"d"},{"kind":"text","text":" but one who is kind to the needy honors him. "},{"kind":"crossref","label":"Pr 3:9","book":"Pro","chapter":3,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 14:21","book":"Pro","chapter":14,"verse":21,"letter":"b"},{"kind":"crossref","label":"Pr 19:17","book":"Pro","chapter":19,"verse