 18:20","book":"Pro","chapter":18,"verse":20,"letter":"c"},{"kind":"crossref","label":"Pr 28:19","book":"Pro","chapter":28,"verse":19,"letter":"d"}],"crossRefs":[{"label":"Pr 1:31","book":"Pro","chapter":1,"verse":31},{"label":"Pr 12:14","book":"Pro","chapter":12,"verse":14},{"label":"Pr 18:20","book":"Pro","chapter":18,"verse":20},{"label":"Pr 28:19","book":"Pro","chapter":28,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:15","parts":[{"kind":"text","text":"The inexperienced one believes anything, "},{"kind":"crossref","label":"Eph 4:14","book":"Eph","chapter":4,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jms 1:5","book":"Jas","chapter":1,"verse":5,"letter":"b"},{"kind":"text","text":" but the sensible one watches "},{"kind":"footnote","marker":1,"text":"Lit the prudent understands"},{"kind":"text","text":" his steps."}],"crossRefs":[{"label":"Eph 4:14","book":"Eph","chapter":4,"verse":14},{"label":"Jms 1:5","book":"Jas","chapter":1,"verse":5}],"footnotes":[{"marker":1,"text":"Lit the prudent understands"}]},{"verseId":"a556c5305ee15c3f-01:Pro:14:16","parts":[{"kind":"text","text":"A wise person is cautious and turns from evil, "},{"kind":"crossref","label":"Jb 28:28","book":"Job","chapter":28,"verse":28,"letter":"a"},{"kind":"crossref","label":"Ps 34:14","book":"Psa","chapter":34,"verse":14,"letter":"b"},{"kind":"crossref","label":"Pr 3:7","book":"Pro","chapter":3,"verse":7,"letter":"c"},{"kind":"crossref","label":"Pr 22:3","book":"Pro","chapter":22,"verse":3,"letter":"d"},{"kind":"text","text":" but a fool is easily angered and is careless. "},{"kind":"footnote","marker":1,"text":"Or and falls"}],"crossRefs":[{"label":"Jb 28:28","book":"Job","chapter":28,"verse":28},{"label":"Ps 34:14","book":"Psa","chapter":34,"verse":14},{"label":"Pr 3:7","book":"Pro","chapter":3,"verse":7},{"label":"Pr 22:3","book":"Pro","chapter":22,"verse":3}],"footnotes":[{"marker":1,"text":"Or and falls"}]},{"verseId":"a556c5305ee15c3f-01:Pro:14:17","parts":[{"kind":"text","text":"A quick-tempered person acts foolishly,"},{"kind":"text","text":" and one who schemes is hated. "},{"kind":"crossref","label":"Pr 12:2","book":"Pro","chapter":12,"verse":2,"letter":"a"},{"kind":"crossref","label":"Pr 24:8","book":"Pro","chapter":24,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Pr 12:2","book":"Pro","chapter":12,"verse":2},{"label":"Pr 24:8","book":"Pro","chapter":24,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:18","parts":[{"kind":"text","text":"The inexperienced inherit foolishness,"},{"kind":"text","text":" but the sensible are crowned with knowledge."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:19","parts":[{"kind":"text","text":"The evil bow before those who are good,"},{"kind":"text","text":" and the wicked, at the gates of the righteous."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:20","parts":[{"kind":"text","text":"A poor person is hated even by his neighbor, "},{"kind":"crossref","label":"Pr 19:7","book":"Pro","chapter":19,"verse":7,"letter":"a"},{"kind":"text","text":" but there are many who love the rich. "},{"kind":"crossref","label":"Pr 19:4","book":"Pro","chapter":19,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Pr 19:7","book":"Pro","chapter":19,"verse":7},{"label":"Pr 19:4","book":"Pro","chapter":19,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:21","parts":[{"kind":"text","text":"The one who despises his neighbor sins, "},{"kind":"crossref","label":"Pr 11:12","book":"Pro","chapter":11,"verse":12,"letter":"a"},{"kind":"text","text":" but whoever shows kindness to the poor will be happy. "},{"kind":"crossref","label":"Ps 41:1","book":"Psa","chapter":41,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Pr 11:12","book":"Pro","chapter":11,"verse":12},{"label":"Ps 41:1","book":"Psa","chapter":41,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:14:22","parts":[{"kind":"text","text":"Don’t those who plan 