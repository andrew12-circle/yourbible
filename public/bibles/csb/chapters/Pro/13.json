6c5305ee15c3f-01:Pro:13:15","parts":[{"kind":"text","text":"Good sense wins favor, "},{"kind":"crossref","label":"Pr 3:4","book":"Pro","chapter":3,"verse":4,"letter":"a"},{"kind":"text","text":" but the way of the treacherous never changes. "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Tg read treacherous will perish"}],"crossRefs":[{"label":"Pr 3:4","book":"Pro","chapter":3,"verse":4}],"footnotes":[{"marker":1,"text":"LXX, Syr, Tg read treacherous will perish"}]},{"verseId":"a556c5305ee15c3f-01:Pro:13:16","parts":[{"kind":"text","text":"Every sensible person acts knowledgeably,"},{"kind":"text","text":" but a fool displays his stupidity. "},{"kind":"crossref","label":"Pr 12:23","book":"Pro","chapter":12,"verse":23,"letter":"a"},{"kind":"crossref","label":"Pr 15:2","book":"Pro","chapter":15,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ec 10:3","book":"Ecc","chapter":10,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Pr 12:23","book":"Pro","chapter":12,"verse":23},{"label":"Pr 15:2","book":"Pro","chapter":15,"verse":2},{"label":"Ec 10:3","book":"Ecc","chapter":10,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:17","parts":[{"kind":"text","text":"A wicked envoy falls into trouble,"},{"kind":"text","text":" but a trustworthy courier brings healing. "},{"kind":"crossref","label":"Pr 25:13","book":"Pro","chapter":25,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Pr 25:13","book":"Pro","chapter":25,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:18","parts":[{"kind":"text","text":"Poverty and disgrace come to those"},{"kind":"text","text":" who ignore discipline,"},{"kind":"text","text":" but the one who accepts correction will be honored. "},{"kind":"crossref","label":"Pr 5:12–14","book":"Pro","chapter":5,"verse":12,"letter":"a"},{"kind":"crossref","label":"Pr 12:1","book":"Pro","chapter":12,"verse":1,"letter":"b"},{"kind":"crossref","label":"Pr 15:31–33","book":"Pro","chapter":15,"verse":31,"letter":"c"}],"crossRefs":[{"label":"Pr 5:12–14","book":"Pro","chapter":5,"verse":12},{"label":"Pr 12:1","book":"Pro","chapter":12,"verse":1},{"label":"Pr 15:31–33","book":"Pro","chapter":15,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:19","parts":[{"kind":"text","text":"Desire fulfilled is sweet to the taste,"},{"kind":"text","text":" but to turn from evil is detestable to fools. "},{"kind":"crossref","label":"Pr 16:22","book":"Pro","chapter":16,"verse":22,"letter":"a"},{"kind":"crossref","label":"Pr 29:27","book":"Pro","chapter":29,"verse":27,"letter":"b"}],"crossRefs":[{"label":"Pr 16:22","book":"Pro","chapter":16,"verse":22},{"label":"Pr 29:27","book":"Pro","chapter":29,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:20","parts":[{"kind":"text","text":"The one who walks with the wise will become wise,"},{"kind":"text","text":" but a companion of fools will suffer harm."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:21","parts":[{"kind":"text","text":"Disaster pursues sinners,"},{"kind":"text","text":" but good rewards the righteous. "},{"kind":"crossref","label":"Ps 32:10","book":"Psa","chapter":32,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 11:31","book":"Pro","chapter":11,"verse":31,"letter":"b"},{"kind":"crossref","label":"Pr 13:13","book":"Pro","chapter":13,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Ps 32:10","book":"Psa","chapter":32,"verse":10},{"label":"Pr 11:31","book":"Pro","chapter":11,"verse":31},{"label":"Pr 13:13","book":"Pro","chapter":13,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:22","parts":[{"kind":"text","text":"A good man leaves an inheritance to his "},{"kind":"footnote","marker":1,"text":"Or inheritance: his"},{"kind":"text","text":" grandchildren,"},{"kind":"text","text":" but the sinner’s wealth is stored up for the righteous. "},{"kind":"crossref","label":"Jb 27:13","book":"Job","chapter":27,"verse":13,"letter":"a"},{"kind":"crossref","label":"Pr 28:8","book":"Pro","chapter":28,"verse":8,"letter":"b"},{"kind":"crossref","label":"Ec 2:26","book":"Ecc","chapter":2,"verse":26,"letter":"c"}],"crossRefs":[{"label":"Jb 27:13","book":"Job","chapter":27,"verse":13},{"label":"Pr 28:8","book":"Pro","chapter":28,"verse":8},{"label":"Ec 2:26","book":"Ecc","chapter":2,"verse":26}],"footnotes":[{"marker":1,"text":"Or inheritance: his"}]},{"verseId":"a556c5305ee15c3f-01:Pro:13:23","parts":[{"kind":"text","text":"The uncultivated field of the poor yields abundant food,"},{"kind":"text","text":" but without justice, it is swept away."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:24","parts":[{"kind":"text","text":"The one who will not use the rod hates his son, "},{"kind":"crossref","label":"Pr 19:18","book":"Pro","chapter":19,"verse":18,"letter":"a"},{"kind":"crossref","label":"Pr 22:15","book":"Pro","chapter":22,"verse":15,"letter":"b"},{"kind":"crossref","label":"Pr 23:13–14","book":"Pro","chapter":23,"verse":13,"letter":"c"},{"kind":"crossref","label":"Pr 29:15","book":"Pro","chapter":29,"verse":15,"letter":"d"},{"kind":"crossref","label":"Pr 29:17","book":"Pro","chapter":29,"verse":17,"letter":"e"},{"kind":"text","text":" but the one who loves him disciplines him diligently. "},{"kind":"crossref","label":"Dt 8:5","book":"Deu","chapter":8,"verse":5,"letter":"a"},{"kind":"crossref","label":"Pr 3:12","book":"Pro","chapter":3,"verse":12,"letter":"b"},{"kind":"crossref","label":"Heb 12:5–7","book":"Heb","chapter":12,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Pr 19:18","book":"Pro","chapter":19,"verse":18},{"label":"Pr 22:15","book":"Pro","chapter":22,"verse":15},{"label":"Pr 23:13–14","book":"Pro","chapter":23,"verse":13},{"label":"Pr 29:15","book":"Pro","chapter":29,"verse":15},{"label":"Pr 29:17","book":"Pro","chapter":29,"verse":17},{"label":"Dt 8:5","book":"Deu","chapter":8,"verse":5},{"label":"Pr 3:12","book":"Pro","chapter":3,"verse":12},{"label":"Heb 12:5–7","book":"Heb","chapter":12,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:13:25","parts":[{"kind":"text","text":"A righteous person eats until he is satisfied,"},{"kind":"text","text":" but the stomach of the wicked is empty. "},{"kind":"crossref","label":"Pr 10:3","book":"Pro","chapter":10,"verse":3,"letter":"a"}],"crossRefs":[{"label":"Pr 10:3","book":"Pro","chapter":10,"verse":3}],"footnotes":[]}]},"cachedAt":1783279526179}