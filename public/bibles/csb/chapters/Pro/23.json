,{"kind":"text","text":" and grogginess will clothe them in rags. "},{"kind":"crossref","label":"Pr 6:10–11","book":"Pro","chapter":6,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Pr 6:10–11","book":"Pro","chapter":6,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:22","parts":[{"kind":"text","text":"Listen to your father who gave you life,"},{"kind":"text","text":" and don’t despise your mother when "},{"kind":"footnote","marker":1,"text":"Or because"},{"kind":"text","text":" she is old. "},{"kind":"crossref","label":"Pr 1:8","book":"Pro","chapter":1,"verse":8,"letter":"a"},{"kind":"crossref","label":"Pr 15:20","book":"Pro","chapter":15,"verse":20,"letter":"b"},{"kind":"crossref","label":"Eph 6:1","book":"Eph","chapter":6,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Pr 1:8","book":"Pro","chapter":1,"verse":8},{"label":"Pr 15:20","book":"Pro","chapter":15,"verse":20},{"label":"Eph 6:1","book":"Eph","chapter":6,"verse":1}],"footnotes":[{"marker":1,"text":"Or because"}]},{"verseId":"a556c5305ee15c3f-01:Pro:23:23","parts":[{"kind":"text","text":"Buy —and do not sell —truth,"},{"kind":"text","text":" wisdom, instruction, and understanding. "},{"kind":"crossref","label":"Pr 4:5","book":"Pro","chapter":4,"verse":5,"letter":"a"},{"kind":"crossref","label":"Pr 4:7","book":"Pro","chapter":4,"verse":7,"letter":"b"},{"kind":"crossref","label":"Pr 16:16","book":"Pro","chapter":16,"verse":16,"letter":"c"},{"kind":"crossref","label":"Pr 18:15","book":"Pro","chapter":18,"verse":15,"letter":"d"},{"kind":"crossref","label":"Mt 13:44","book":"Mat","chapter":13,"verse":44,"letter":"e"}],"crossRefs":[{"label":"Pr 4:5","book":"Pro","chapter":4,"verse":5},{"label":"Pr 4:7","book":"Pro","chapter":4,"verse":7},{"label":"Pr 16:16","book":"Pro","chapter":16,"verse":16},{"label":"Pr 18:15","book":"Pro","chapter":18,"verse":15},{"label":"Mt 13:44","book":"Mat","chapter":13,"verse":44}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:24","parts":[{"kind":"text","text":"The father of a righteous son will rejoice greatly,"},{"kind":"text","text":" and one who fathers a wise son will delight in him. "},{"kind":"crossref","label":"Pr 10:1","book":"Pro","chapter":10,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 23:15","book":"Pro","chapter":23,"verse":15,"letter":"b"},{"kind":"crossref","label":"Pr 29:3","book":"Pro","chapter":29,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Pr 10:1","book":"Pro","chapter":10,"verse":1},{"label":"Pr 23:15","book":"Pro","chapter":23,"verse":15},{"label":"Pr 29:3","book":"Pro","chapter":29,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:25","parts":[{"kind":"text","text":"Let your father and mother have joy, "},{"kind":"crossref","label":"Pr 27:11","book":"Pro","chapter":27,"verse":11,"letter":"a"},{"kind":"text","text":" and let her who gave birth to you rejoice."}],"crossRefs":[{"label":"Pr 27:11","book":"Pro","chapter":27,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:26","parts":[{"kind":"text","text":"My son, give me your heart,"},{"kind":"text","text":" and let your eyes observe my ways."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:27","parts":[{"kind":"text","text":"For a prostitute is a deep pit, "},{"kind":"crossref","label":"Pr 22:14","book":"Pro","chapter":22,"verse":14,"letter":"a"},{"kind":"text","text":" and a wayward woman is a narrow well;"}],"crossRefs":[{"label":"Pr 22:14","book":"Pro","chapter":22,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:28","parts":[{"kind":"text","text":"indeed, she sets an ambush like a robber "},{"kind":"crossref","label":"Pr 6:26","book":"Pro","chapter":6,"verse":26,"letter":"a"},{"kind":"crossref","label":"Pr 7:12","book":"Pro","chapter":7,"verse":12,"letter":"b"},{"kind":"crossref","label":"Pr 7:22","book":"Pro","chapter":7,"verse":22,"letter":"c"},{"kind":"crossref","label":"Ec 7:26","book":"Ecc","chapter":7,"verse":26,"letter":"d"},{"kind":"text","text":" and increases the number of unfaithful people."}],"crossRefs":[{"label":"Pr 6:26","book":"Pro","chapter":6,"verse":26},{"label":"Pr 7:12","book":"Pro","chapter":7,"verse":12},{"label":"Pr 7:22","book":"Pro","chapter":7,"verse":22},{"label":"Ec 7:26","book":"Ecc","chapter":7,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:29","parts":[{"kind":"text","text":"Who has woe? Who has sorrow?"},{"kind":"text","text":" Who has conflicts? Who has complaints?"},{"kind":"text","text":" Who has wounds for no reason? "},{"kind":"crossref","label":"Pr 23:35","book":"Pro","chapter":23,"verse":35,"letter":"a"},{"kind":"text","text":" Who has red eyes?"}],"crossRefs":[{"label":"Pr 23:35","book":"Pro","chapter":23,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:30","parts":[{"kind":"text","text":"Those who linger over wine;"},{"kind":"text","text":" those who go looking for mixed wine. "},{"kind":"crossref","label":"Is 5:11","book":"Isa","chapter":5,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 5:22","book":"Isa","chapter":5,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Is 5:11","book":"Isa","chapter":5,"verse":11},{"label":"Is 5:22","book":"Isa","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:31","parts":[{"kind":"text","text":"Don’t gaze at wine because it is red, "},{"kind":"crossref","label":"Eph 5:18","book":"Eph","chapter":5,"verse":18,"letter":"a"},{"kind":"text","text":" because it gleams in the cup"},{"kind":"text","text":" and goes down smoothly. "},{"kind":"crossref","label":"Sg 7:9","book":"Sng","chapter":7,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Eph 5:18","book":"Eph","chapter":5,"verse":18},{"label":"Sg 7:9","book":"Sng","chapter":7,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:32","parts":[{"kind":"text","text":"In the end it bites like a snake"},{"kind":"text","text":" and stings like a viper."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:33","parts":[{"kind":"text","text":"Your eyes will see strange things,"},{"kind":"text","text":" and you will say absurd things. "},{"kind":"footnote","marker":1,"text":"Or will speak perversities, or inverted things"},{"kind":"crossref","label":"Is 28:7","book":"Isa","chapter":28,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Is 28:7","book":"Isa","chapter":28,"verse":7}],"footnotes":[{"marker":1,"text":"Or will speak perversities, or inverted things"}]},{"verseId":"a556c5305ee15c3f-01:Pro:23:34","parts":[{"kind":"text","text":"You’ll be like someone sleeping out at sea"},{"kind":"text","text":" or lying down on the top of a ship’s mast."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:23:35","parts":[{"kind":"text","text":"“They struck me, but "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Tg, Vg read me,” you will say, “but"},{"kind":"text","text":" I feel no pain!"},{"kind":"text","text":" They beat me, but I didn’t know it! "},{"kind":"crossref","label":"Pr 23:29","book":"Pro","chapter":23,"verse":29,"letter":"a"},{"kind":"crossref","label":"Jr 5:3","book":"Jer","chapter":5,"verse":3,"letter":"b"},{"kind":"text","text":" When will I wake up?"},{"kind":"text","text":" I’ll look for another drink.” "},{"kind":"crossref","label":"Is 56:12","book":"Isa","chapter":56,"verse":12,"letter":"a"}],"crossRefs":[{"label":"Pr 23:29","book":"Pro","chapter":23,"verse":29},{"label":"Jr 5:3","book":"Jer","chapter":5,"verse":3},{"label":"Is 56:12","book":"Isa","chapter":56,"verse":12}],"footnotes":[{"marker":1,"text":"LXX, Syr, Tg, Vg read me,” you will say, “but"}]}]},"cachedAt":1783279529275}