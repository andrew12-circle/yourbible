right hand;"},{"kind":"text","text":" in her left, riches and honor."},{"kind":"crossref","label":"Pr 8:18","book":"Pro","chapter":8,"verse":18,"letter":"a"},{"kind":"crossref","label":"Pr 21:21","book":"Pro","chapter":21,"verse":21,"letter":"b"},{"kind":"crossref","label":"Pr 22:4","book":"Pro","chapter":22,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Pr 8:18","book":"Pro","chapter":8,"verse":18},{"label":"Pr 21:21","book":"Pro","chapter":21,"verse":21},{"label":"Pr 22:4","book":"Pro","chapter":22,"verse":4}],"footnotes":[{"marker":1,"text":"Lit Length of days"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:17","parts":[{"kind":"text","text":"Her ways are pleasant, "},{"kind":"crossref","label":"Mt 11:19","book":"Mat","chapter":11,"verse":19,"letter":"a"},{"kind":"text","text":" and all her paths, peaceful."}],"crossRefs":[{"label":"Mt 11:19","book":"Mat","chapter":11,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:18","parts":[{"kind":"text","text":"She is a tree of life "},{"kind":"crossref","label":"Gn 2:9","book":"Gen","chapter":2,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 11:30","book":"Pro","chapter":11,"verse":30,"letter":"b"},{"kind":"crossref","label":"Pr 13:12","book":"Pro","chapter":13,"verse":12,"letter":"c"},{"kind":"crossref","label":"Pr 15:4","book":"Pro","chapter":15,"verse":4,"letter":"d"},{"kind":"crossref","label":"Rv 2:7","book":"Rev","chapter":2,"verse":7,"letter":"e"},{"kind":"text","text":" to those who embrace her,"},{"kind":"text","text":" and those who hold on to her are happy."}],"crossRefs":[{"label":"Gn 2:9","book":"Gen","chapter":2,"verse":9},{"label":"Pr 11:30","book":"Pro","chapter":11,"verse":30},{"label":"Pr 13:12","book":"Pro","chapter":13,"verse":12},{"label":"Pr 15:4","book":"Pro","chapter":15,"verse":4},{"label":"Rv 2:7","book":"Rev","chapter":2,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:19","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" founded the earth by wisdom "},{"kind":"crossref","label":"Ps 104:24","book":"Psa","chapter":104,"verse":24,"letter":"a"},{"kind":"crossref","label":"Pr 8:27","book":"Pro","chapter":8,"verse":27,"letter":"b"},{"kind":"text","text":" and established the heavens by understanding."}],"crossRefs":[{"label":"Ps 104:24","book":"Psa","chapter":104,"verse":24},{"label":"Pr 8:27","book":"Pro","chapter":8,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:20","parts":[{"kind":"text","text":"By his knowledge the watery depths broke open, "},{"kind":"crossref","label":"Gn 7:11","book":"Gen","chapter":7,"verse":11,"letter":"a"},{"kind":"text","text":" and the clouds dripped with dew."},{"kind":"crossref","label":"Dt 33:28","book":"Deu","chapter":33,"verse":28,"letter":"a"},{"kind":"crossref","label":"Jb 36:28","book":"Job","chapter":36,"verse":28,"letter":"b"}],"crossRefs":[{"label":"Gn 7:11","book":"Gen","chapter":7,"verse":11},{"label":"Dt 33:28","book":"Deu","chapter":33,"verse":28},{"label":"Jb 36:28","book":"Job","chapter":36,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:21","parts":[{"kind":"text","text":"Maintain sound wisdom and discretion."},{"kind":"text","text":" My son, don’t lose sight of them."},{"kind":"crossref","label":"Pr 4:21","book":"Pro","chapter":4,"verse":21,"letter":"a"}],"crossRefs":[{"label":"Pr 4:21","book":"Pro","chapter":4,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:22","parts":[{"kind":"text","text":"They will be life for you "},{"kind":"footnote","marker":1,"text":"Or be your throat"},{"kind":"crossref","label":"Pr 4:22","book":"Pro","chapter":4,"verse":22,"letter":"a"},{"kind":"text","text":" and adornment"},{"kind":"footnote","marker":1,"text":"Or grace"},{"kind":"text","text":" for your neck."}],"crossRefs":[{"label":"Pr 4:22","book":"Pro","chapter":4,"verse":22}],"footnotes":[{"marker":1,"text":"Or be your throat"},{"marker":1,"text":"Or grace"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:23","parts":[{"kind":"text","text":"Then you will go safely on your way;"},{"kind":"text","text":" your foot will not stumble."},{"kind":"crossref","label":"Ps 91:12","book":"Psa","chapter":91,"verse":12,"letter":"a"},{"kind":"crossref","label":"Pr 4:12","book":"Pro","chapter":4,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Ps 91:12","book":"Psa","chapter":91,"verse":12},{"label":"Pr 4:12","book":"Pro","chapter":4,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:24","parts":[{"kind":"text","text":"When you lie "},{"kind":"footnote","marker":1,"text":"LXX reads sit"},{"kind":"text","text":" down, you will not be afraid; "},{"kind":"crossref","label":"Jb 11:19","book":"Job","chapter":11,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ps 3:5","book":"Psa","chapter":3,"verse":5,"letter":"b"},{"kind":"crossref","label":"Pr 6:22","book":"Pro","chapter":6,"verse":22,"letter":"c"},{"kind":"text","text":" you will lie down, and your sleep will be pleasant."}],"crossRefs":[{"label":"Jb 11:19","book":"Job","chapter":11,"verse":19},{"label":"Ps 3:5","book":"Psa","chapter":3,"verse":5},{"label":"Pr 6:22","book":"Pro","chapter":6,"verse":22}],"footnotes":[{"marker":1,"text":"LXX reads sit"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:25","parts":[{"kind":"text","text":"Don’t fear sudden danger"},{"kind":"text","text":" or the ruin of the wicked when it comes,"},{"kind":"crossref","label":"Jb 5:21","book":"Job","chapter":5,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 91:5","book":"Psa","chapter":91,"verse":5,"letter":"b"},{"kind":"crossref","label":"1Pt 3:14","book":"1Pe","chapter":3,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Jb 5:21","book":"Job","chapter":5,"verse":21},{"label":"Ps 91:5","book":"Psa","chapter":91,"verse":5},{"label":"1Pt 3:14","book":"1Pe","chapter":3,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:26","parts":[{"kind":"text","text":"for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will be your confidence "},{"kind":"footnote","marker":1,"text":"Or be at your side"},{"kind":"text","text":" and will keep your foot from a snare."},{"kind":"crossref","label":"1Sm 2:9","book":"1Sa","chapter":2,"verse":9,"letter":"a"}],"crossRefs":[{"label":"1Sm 2:9","book":"1Sa","chapter":2,"verse":9}],"footnotes":[{"marker":1,"text":"Or be at your side"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:27","parts":[{"kind":"text","text":"When it is in your power, "},{"kind":"footnote","marker":1,"text":"Lit in the power of your hands"},{"kind":"text","text":" don’t withhold good"},{"kind":"crossref","label":"Gl 6:10","book":"Gal","chapter":6,"verse":10,"letter":"a"},{"kind":"text","text":" from the one to whom it belongs."}],"crossRefs":[{"label":"Gl 6:10","book":"Gal","chapter":6,"verse":10}],"footnotes":[{"marker":1,"text":"Lit in the power of your hands"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:28","parts":[{"kind":"text","text":"Don’t say to your neighbor, “Go away! Come back later."},{"kind":"text","text":" I’ll give it tomorrow” —when it is there with you."},{"kind":"crossref","label":"Lv 19:13","book":"Lev","chapter":19,"verse":13,"letter":"a"},{"kind":"crossref","label":"Dt 24:15","book":"Deu","chapter":24,"verse":15,"letter":"b"}],"crossRefs":[{"label":"Lv 19:13","book":"Lev","chapter":19,"verse":13},{"label":"Dt 24:15","book":"Deu","chapter":24,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:29","parts":[{"kind":"text","text":"Don’t plan any harm against your neighbor, "},{"kind":"crossref","label":"Pr 6:14","book":"Pro","chapter":6,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 14:22","book":"Pro","chapter":14,"verse":22,"letter":"b"},{"kind":"text","text":" for he trusts you and lives near you."}],"crossRefs":[{"label":"Pr 6:14","book":"Pro","chapter":6,"verse":14},{"label":"Pr 14:22","book":"Pro","chapter":14,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:30","parts":[{"kind":"text","text":"Don’t accuse anyone without cause, "},{"kind":"crossref","label":"Pr 24:28","book":"Pro","chapter":24,"verse":28,"letter":"a"},{"kind":"crossref","label":"Rm 12:18","book":"Rom","chapter":12,"verse":18,"letter":"b"},{"kind":"text","text":" when he has done you no harm."}],"crossRefs":[{"label":"Pr 24:28","book":"Pro","chapter":24,"verse":28},{"label":"Rm 12:18","book":"Rom","chapter":12,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:31","parts":[{"kind":"text","text":"Don’t envy a violent man "},{"kind":"crossref","label":"Ps 37:1","book":"Psa","chapter":37,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 23:17","book":"Pro","chapter":23,"verse":17,"letter":"b"},{"kind":"crossref","label":"Pr 24:1","book":"Pro","chapter":24,"verse":1,"letter":"c"},{"kind":"crossref","label":"Pr 24:19","book":"Pro","chapter":24,"verse":19,"letter":"d"},{"kind":"text","text":" or choose any of his ways;"}],"crossRefs":[{"label":"Ps 37:1","book":"Psa","chapter":37,"verse":1},{"label":"Pr 23:17","book":"Pro","chapter":23,"verse":17},{"label":"Pr 24:1","book":"Pro","chapter":24,"verse":1},{"label":"Pr 24:19","book":"Pro","chapter":24,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:32","parts":[{"kind":"text","text":"for the devious are detestable to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" but he is a friend"},{"kind":"footnote","marker":1,"text":"Or confidential counsel"},{"kind":"text","text":" to the upright. "},{"kind":"crossref","label":"Ps 25:14","book":"Psa","chapter":25,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 11:20","book":"Pro","chapter":11,"verse":20,"letter":"b"},{"kind":"crossref","label":"Pr 12:22","book":"Pro","chapter":12,"verse":22,"letter":"c"},{"kind":"crossref","label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8,"letter":"d"}],"crossRefs":[{"label":"Ps 25:14","book":"Psa","chapter":25,"verse":14},{"label":"Pr 11:20","book":"Pro","chapter":11,"verse":20},{"label":"Pr 12:22","book":"Pro","chapter":12,"verse":22},{"label":"Pr 15:8–9","book":"Pro","chapter":15,"verse":8}],"footnotes":[{"marker":1,"text":"Or confidential counsel"}]},{"verseId":"a556c5305ee15c3f-01:Pro:3:33","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s curse is on the household of the wicked, "},{"kind":"crossref","label":"Zch 5:3","book":"Zec","chapter":5,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mal 2:2","book":"Mal","chapter":2,"verse":2,"letter":"b"},{"kind":"text","text":" but he blesses the home of the righteous;"}],"crossRefs":[{"label":"Zch 5:3","book":"Zec","chapter":5,"verse":3},{"label":"Mal 2:2","book":"Mal","chapter":2,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:34","parts":[{"kind":"text","text":"He mocks those who mock"},{"kind":"text","text":" but gives grace to the humble."},{"kind":"crossref","label":"Jms 4:6","book":"Jas","chapter":4,"verse":6,"letter":"a"},{"kind":"crossref","label":"1Pt 5:5","book":"1Pe","chapter":5,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Jms 4:6","book":"Jas","chapter":4,"verse":6},{"label":"1Pt 5:5","book":"1Pe","chapter":5,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:3:35","parts":[{"kind":"text","text":"The wise will inherit honor,"},{"kind":"text","text":" but he holds up fools to dishonor."},{"kind":"footnote","marker":1,"text":"Or but haughty fools dishonor, or but fools exalt dishonor"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or but haughty fools dishonor, or but fools exalt dishonor"}]}]},"cachedAt":1783280289986}