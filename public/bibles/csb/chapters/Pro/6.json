kind":"crossref","label":"Pr 16:27–28","book":"Pro","chapter":16,"verse":27,"letter":"b"},{"kind":"crossref","label":"Pr 28:25","book":"Pro","chapter":28,"verse":25,"letter":"c"}],"crossRefs":[{"label":"Pr 3:29","book":"Pro","chapter":3,"verse":29},{"label":"Mc 2:1","book":"Mic","chapter":2,"verse":1},{"label":"Pr 6:19","book":"Pro","chapter":6,"verse":19},{"label":"Pr 16:27–28","book":"Pro","chapter":16,"verse":27},{"label":"Pr 28:25","book":"Pro","chapter":28,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:15","parts":[{"kind":"text","text":"Therefore calamity will strike him suddenly;"},{"kind":"text","text":" he will be shattered instantly, beyond recovery. "},{"kind":"crossref","label":"2Ch 36:16","book":"2Ch","chapter":36,"verse":16,"letter":"a"},{"kind":"crossref","label":"Pr 24:22","book":"Pro","chapter":24,"verse":22,"letter":"b"},{"kind":"crossref","label":"Pr 29:1","book":"Pro","chapter":29,"verse":1,"letter":"c"},{"kind":"crossref","label":"Is 30:13–14","book":"Isa","chapter":30,"verse":13,"letter":"d"},{"kind":"crossref","label":"Jr 19:11","book":"Jer","chapter":19,"verse":11,"letter":"e"}],"crossRefs":[{"label":"2Ch 36:16","book":"2Ch","chapter":36,"verse":16},{"label":"Pr 24:22","book":"Pro","chapter":24,"verse":22},{"label":"Pr 29:1","book":"Pro","chapter":29,"verse":1},{"label":"Is 30:13–14","book":"Isa","chapter":30,"verse":13},{"label":"Jr 19:11","book":"Jer","chapter":19,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:16","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" hates six things;"},{"kind":"text","text":" in fact, seven are detestable to him:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:17","parts":[{"kind":"text","text":"arrogant eyes, "},{"kind":"crossref","label":"Ps 18:27","book":"Psa","chapter":18,"verse":27,"letter":"a"},{"kind":"crossref","label":"Pr 21:4","book":"Pro","chapter":21,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 30:13","book":"Pro","chapter":30,"verse":13,"letter":"c"},{"kind":"text","text":" a lying tongue, "},{"kind":"crossref","label":"Ps 31:18","book":"Psa","chapter":31,"verse":18,"letter":"d"},{"kind":"crossref","label":"Ps 120:2","book":"Psa","chapter":120,"verse":2,"letter":"e"},{"kind":"crossref","label":"Pr 12:22","book":"Pro","chapter":12,"verse":22,"letter":"f"},{"kind":"crossref","label":"Pr 17:7","book":"Pro","chapter":17,"verse":7,"letter":"g"},{"kind":"text","text":" hands that shed innocent blood, "},{"kind":"crossref","label":"Dt 19:10","book":"Deu","chapter":19,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 1:16","book":"Pro","chapter":1,"verse":16,"letter":"b"},{"kind":"crossref","label":"Is 1:15","book":"Isa","chapter":1,"verse":15,"letter":"c"},{"kind":"crossref","label":"Is 59:7","book":"Isa","chapter":59,"verse":7,"letter":"d"}],"crossRefs":[{"label":"Ps 18:27","book":"Psa","chapter":18,"verse":27},{"label":"Pr 21:4","book":"Pro","chapter":21,"verse":4},{"label":"Pr 30:13","book":"Pro","chapter":30,"verse":13},{"label":"Ps 31:18","book":"Psa","chapter":31,"verse":18},{"label":"Ps 120:2","book":"Psa","chapter":120,"verse":2},{"label":"Pr 12:22","book":"Pro","chapter":12,"verse":22},{"label":"Pr 17:7","book":"Pro","chapter":17,"verse":7},{"label":"Dt 19:10","book":"Deu","chapter":19,"verse":10},{"label":"Pr 1:16","book":"Pro","chapter":1,"verse":16},{"label":"Is 1:15","book":"Isa","chapter":1,"verse":15},{"label":"Is 59:7","book":"Isa","chapter":59,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:18","parts":[{"kind":"text","text":"a heart that plots wicked schemes, "},{"kind":"crossref","label":"Gn 6:5","book":"Gen","chapter":6,"verse":5,"letter":"a"},{"kind":"text","text":" feet eager to run to evil, "},{"kind":"crossref","label":"Pr 1:16","book":"Pro","chapter":1,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Gn 6:5","book":"Gen","chapter":6,"verse":5},{"label":"Pr 1:16","book":"Pro","chapter":1,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:19","parts":[{"kind":"text","text":"a lying witness who gives false testimony, "},{"kind":"crossref","label":"Ex 20:16","book":"Exo","chapter":20,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ps 27:12","book":"Psa","chapter":27,"verse":12,"letter":"b"},{"kind":"crossref","label":"Pr 12:17","book":"Pro","chapter":12,"verse":17,"letter":"c"},{"kind":"crossref","label":"Pr 14:5","book":"Pro","chapter":14,"verse":5,"letter":"d"},{"kind":"crossref","label":"Pr 14:25","book":"Pro","chapter":14,"verse":25,"letter":"e"},{"kind":"text","text":" and one who stirs up trouble among brothers. "},{"kind":"crossref","label":"Pr 6:14","book":"Pro","chapter":6,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 16:27–28","book":"Pro","chapter":16,"verse":27,"letter":"b"},{"kind":"crossref","label":"Pr 28:25","book":"Pro","chapter":28,"verse":25,"letter":"c"}],"crossRefs":[{"label":"Ex 20:16","book":"Exo","chapter":20,"verse":16},{"label":"Ps 27:12","book":"Psa","chapter":27,"verse":12},{"label":"Pr 12:17","book":"Pro","chapter":12,"verse":17},{"label":"Pr 14:5","book":"Pro","chapter":14,"verse":5},{"label":"Pr 14:25","book":"Pro","chapter":14,"verse":25},{"label":"Pr 6:14","book":"Pro","chapter":6,"verse":14},{"label":"Pr 16:27–28","book":"Pro","chapter":16,"verse":27},{"label":"Pr 28:25","book":"Pro","chapter":28,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:20","parts":[{"kind":"text","text":"My son, keep your father’s command,"},{"kind":"text","text":" and don’t reject your mother’s teaching. "},{"kind":"crossref","label":"Pr 1:8","book":"Pro","chapter":1,"verse":8,"letter":"a"},{"kind":"crossref","label":"Pr 31:1","book":"Pro","chapter":31,"verse":1,"letter":"b"}],"crossRefs":[{"label":"Pr 1:8","book":"Pro","chapter":1,"verse":8},{"label":"Pr 31:1","book":"Pro","chapter":31,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:21","parts":[{"kind":"text","text":"Always bind them to your heart;"},{"kind":"text","text":" tie them around your neck. "},{"kind":"crossref","label":"Pr 1:9","book":"Pro","chapter":1,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 3:3","book":"Pro","chapter":3,"verse":3,"letter":"b"},{"kind":"crossref","label":"Pr 7:3","book":"Pro","chapter":7,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Pr 1:9","book":"Pro","chapter":1,"verse":9},{"label":"Pr 3:3","book":"Pro","chapter":3,"verse":3},{"label":"Pr 7:3","book":"Pro","chapter":7,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:22","parts":[{"kind":"text","text":"When you walk here and there, they will guide you;"},{"kind":"text","text":" when you lie down, they will watch over you;"},{"kind":"text","text":" when you wake up, they will talk to you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:23","parts":[{"kind":"text","text":"For a command is a lamp, teaching is a light, "},{"kind":"crossref","label":"Ps 119:105","book":"Psa","chapter":119,"verse":105,"letter":"a"},{"kind":"text","text":" and corrective discipline is the way to life. "},{"kind":"crossref","label":"Pr 3:1–2","book":"Pro","chapter":3,"verse":1,"letter":"a"},{"kind":"crossref","label":"Pr 4:4","book":"Pro","chapter":4,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 7:2","book":"Pro","chapter":7,"verse":2,"letter":"c"},{"kind":"crossref","label":"Pr 19:16","book":"Pro","chapter":19,"verse":16,"letter":"d"}],"crossRefs":[{"label":"Ps 119:105","book":"Psa","chapter":119,"verse":105},{"label":"Pr 3:1–2","book":"Pro","chapter":3,"verse":1},{"label":"Pr 4:4","book":"Pro","chapter":4,"verse":4},{"label":"Pr 7:2","book":"Pro","chapter":7,"verse":2},{"label":"Pr 19:16","book":"Pro","chapter":19,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:24","parts":[{"kind":"text","text":"They will protect you from an evil woman, "},{"kind":"footnote","marker":1,"text":"LXX reads from a married woman"},{"kind":"text","text":" from the flattering tongue of a wayward woman. "},{"kind":"crossref","label":"Pr 7:5","book":"Pro","chapter":7,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Pr 7:5","book":"Pro","chapter":7,"verse":5}],"footnotes":[{"marker":1,"text":"LXX reads from a married woman"}]},{"verseId":"a556c5305ee15c3f-01:Pro:6:25","parts":[{"kind":"text","text":"Don’t lust in your heart for her beauty "},{"kind":"crossref","label":"Mt 5:28","book":"Mat","chapter":5,"verse":28,"letter":"a"},{"kind":"text","text":" or let her captivate you with her eyelashes. "},{"kind":"crossref","label":"Sg 4:9","book":"Sng","chapter":4,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Mt 5:28","book":"Mat","chapter":5,"verse":28},{"label":"Sg 4:9","book":"Sng","chapter":4,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:26","parts":[{"kind":"text","text":"For a prostitute’s fee is only a loaf of bread, "},{"kind":"footnote","marker":1,"text":"Or On account of a prostitute, one is left with only a loaf of bread"},{"kind":"text","text":" but the wife of another man "},{"kind":"footnote","marker":1,"text":"Lit but a wife of a man"},{"kind":"text","text":" goes after a precious life. "},{"kind":"crossref","label":"Pr 2:18–19","book":"Pro","chapter":2,"verse":18,"letter":"a"},{"kind":"crossref","label":"Pr 7:21–23","book":"Pro","chapter":7,"verse":21,"letter":"b"},{"kind":"crossref","label":"Pr 7:27","book":"Pro","chapter":7,"verse":27,"letter":"c"},{"kind":"crossref","label":"Pr 23:27–28","book":"Pro","chapter":23,"verse":27,"letter":"d"},{"kind":"crossref","label":"Ezk 13:18","book":"Ezk","chapter":13,"verse":18,"letter":"e"}],"crossRefs":[{"label":"Pr 2:18–19","book":"Pro","chapter":2,"verse":18},{"label":"Pr 7:21–23","book":"Pro","chapter":7,"verse":21},{"label":"Pr 7:27","book":"Pro","chapter":7,"verse":27},{"label":"Pr 23:27–28","book":"Pro","chapter":23,"verse":27},{"label":"Ezk 13:18","book":"Ezk","chapter":13,"verse":18}],"footnotes":[{"marker":1,"text":"Or On account of a prostitute, one is left with only a loaf of bread"},{"marker":1,"text":"Lit but a wife of a man"}]},{"verseId":"a556c5305ee15c3f-01:Pro:6:27","parts":[{"kind":"text","text":"Can a man embrace fire"},{"kind":"text","text":" and his clothes not be burned?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:28","parts":[{"kind":"text","text":"Can a man walk on burning coals"},{"kind":"text","text":" without scorching his feet?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:29","parts":[{"kind":"text","text":"So it is with the one who sleeps with"},{"kind":"text","text":" another man’s wife;"},{"kind":"text","text":" no one who touches her will go unpunished. "},{"kind":"crossref","label":"Pr 16:5","book":"Pro","chapter":16,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Pr 16:5","book":"Pro","chapter":16,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:30","parts":[{"kind":"text","text":"People don’t despise the thief if he steals"},{"kind":"text","text":" to satisfy himself when he is hungry. "},{"kind":"crossref","label":"Jr 49:9","book":"Jer","chapter":49,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ob 5","book":"Oba","chapter":1,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Jr 49:9","book":"Jer","chapter":49,"verse":9},{"label":"Ob 5","book":"Oba","chapter":1,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:31","parts":[{"kind":"text","text":"Still, if caught, he must pay seven times as much; "},{"kind":"crossref","label":"Ex 22:1–4","book":"Exo","chapter":22,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 79:12","book":"Psa","chapter":79,"verse":12,"letter":"b"},{"kind":"text","text":" he must give up all the wealth in his house."}],"crossRefs":[{"label":"Ex 22:1–4","book":"Exo","chapter":22,"verse":1},{"label":"Ps 79:12","book":"Psa","chapter":79,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:32","parts":[{"kind":"text","text":"The one who commits adultery "},{"kind":"footnote","marker":1,"text":"Lit commits adultery with a woman"},{"kind":"text","text":" lacks sense;"},{"kind":"text","text":" whoever does so destroys himself. "},{"kind":"crossref","label":"Pr 7:22–23","book":"Pro","chapter":7,"verse":22,"letter":"a"}],"crossRefs":[{"label":"Pr 7:22–23","book":"Pro","chapter":7,"verse":22}],"footnotes":[{"marker":1,"text":"Lit commits adultery with a woman"}]},{"verseId":"a556c5305ee15c3f-01:Pro:6:33","parts":[{"kind":"text","text":"He will get a beating "},{"kind":"footnote","marker":1,"text":"Or plague"},{"kind":"text","text":" and dishonor,"},{"kind":"text","text":" and his disgrace will never be removed."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or plague"}]},{"verseId":"a556c5305ee15c3f-01:Pro:6:34","parts":[{"kind":"text","text":"For jealousy enrages a husband, "},{"kind":"crossref","label":"Pr 27:4","book":"Pro","chapter":27,"verse":4,"letter":"a"},{"kind":"crossref","label":"Sg 8:6","book":"Sng","chapter":8,"verse":6,"letter":"b"},{"kind":"text","text":" and he will show no mercy when he takes revenge."}],"crossRefs":[{"label":"Pr 27:4","book":"Pro","chapter":27,"verse":4},{"label":"Sg 8:6","book":"Sng","chapter":8,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:6:35","parts":[{"kind":"text","text":"He will not be appeased by anything"},{"kind":"text","text":" or be persuaded by lavish bribes."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279524187}