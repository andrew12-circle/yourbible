}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Pro:8:22","parts":[{"kind":"text","text":"“The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" acquired "},{"kind":"footnote","marker":1,"text":"Or possessed, or made"},{"kind":"text","text":" me"},{"kind":"text","text":" at the beginning of his creation, "},{"kind":"footnote","marker":1,"text":"Lit way"},{"kind":"text","text":" before his works of long ago. "},{"kind":"crossref","label":"Gn 1:1","book":"Gen","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jb 28:26","book":"Job","chapter":28,"verse":26,"letter":"b"},{"kind":"crossref","label":"Ps 104:24","book":"Psa","chapter":104,"verse":24,"letter":"c"}],"crossRefs":[{"label":"Gn 1:1","book":"Gen","chapter":1,"verse":1},{"label":"Jb 28:26","book":"Job","chapter":28,"verse":26},{"label":"Ps 104:24","book":"Psa","chapter":104,"verse":24}],"footnotes":[{"marker":1,"text":"Or possessed, or made"},{"marker":1,"text":"Lit way"}]},{"verseId":"a556c5305ee15c3f-01:Pro:8:23","parts":[{"kind":"text","text":"I was formed "},{"kind":"footnote","marker":1,"text":"Or consecrated"},{"kind":"text","text":" before ancient times,"},{"kind":"text","text":" from the beginning, before the earth began. "},{"kind":"crossref","label":"Jn 1:1–3","book":"Jhn","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jn 17:5","book":"Jhn","chapter":17,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Jn 1:1–3","book":"Jhn","chapter":1,"verse":1},{"label":"Jn 17:5","book":"Jhn","chapter":17,"verse":5}],"footnotes":[{"marker":1,"text":"Or consecrated"}]},{"verseId":"a556c5305ee15c3f-01:Pro:8:24","parts":[{"kind":"text","text":"I was born"},{"kind":"text","text":" when there were no watery depths "},{"kind":"crossref","label":"Gn 1:2","book":"Gen","chapter":1,"verse":2,"letter":"a"},{"kind":"crossref","label":"Pr 3:20","book":"Pro","chapter":3,"verse":20,"letter":"b"},{"kind":"text","text":" and no springs filled with water."}],"cross