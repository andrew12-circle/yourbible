,"style":"divine"},{"kind":"text","text":" said, “You cared about the plant, which you did not labor over and did not grow. It appeared in a night and perished in a night. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jon:4:11","parts":[{"kind":"text","text":"So may I not care about the great city of Nineveh, "},{"kind":"crossref","label":"Jnh 3:10","book":"Jon","chapter":3,"verse":10,"letter":"a"},{"kind":"text","text":" which has more than a hundred twenty thousand people who cannot distinguish between their right and their left, "},{"kind":"crossref","label":"Dt 1:39","book":"Deu","chapter":1,"verse":39,"letter":"b"},{"kind":"crossref","label":"Is 7:16","book":"Isa","chapter":7,"verse":16,"letter":"c"},{"kind":"text","text":" as well as many animals?” "},{"kind":"crossref","label":"Ps 36:6","book":"Psa","chapter":36,"verse":6,"letter":"d"}],"crossRefs":[{"label":"Jnh 3:10","book":"Jon","chapter":3,"verse":10},{"label":"Dt 1:39","book":"Deu","chapter":1,"verse":39},{"label":"Is 7:16","book":"Isa","chapter":7,"verse":16},{"label":"Ps 36:6","book":"Psa","chapter":36,"verse":6}],"footnotes":[]}]},"cachedAt":1783099483813}