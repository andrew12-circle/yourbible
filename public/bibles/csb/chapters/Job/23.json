","chapter":4,"verse":14},{"label":"Jb 22:10","book":"Job","chapter":22,"verse":10},{"label":"Jb 23:15","book":"Job","chapter":23,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:23:16","parts":[{"kind":"text","text":"God has made my heart faint; "},{"kind":"crossref","label":"Dt 20:3","book":"Deu","chapter":20,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 7:4","book":"Isa","chapter":7,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jr 51:46","book":"Jer","chapter":51,"verse":46,"letter":"c"},{"kind":"text","text":" the Almighty has terrified me."}],"crossRefs":[{"label":"Dt 20:3","book":"Deu","chapter":20,"verse":3},{"label":"Is 7:4","book":"Isa","chapter":7,"verse":4},{"label":"Jr 51:46","book":"Jer","chapter":51,"verse":46}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:23:17","parts":[{"kind":"text","text":"Yet I am not destroyed "},{"kind":"footnote","marker":1,"text":"Or silenced"},{"kind":"text","text":" by the darkness, "},{"kind":"crossref","label":"Jb 19:8","book":"Job","chapter":19,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jb 29:3","book":"Job","chapter":29,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jb 30:26","book":"Job","chapter":30,"verse":26,"letter":"c"},{"kind":"text","text":" by the thick darkness that covers my face."}],"crossRefs":[{"label":"Jb 19:8","book":"Job","chapter":19,"verse":8},{"label":"Jb 29:3","book":"Job","chapter":29,"verse":3},{"label":"Jb 30:26","book":"Job","chapter":30,"verse":26}],"footnotes":[{"marker":1,"text":"Or silenced"}]}]},"cachedAt":1783279470472}