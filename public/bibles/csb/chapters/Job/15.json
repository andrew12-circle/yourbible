","parts":[{"kind":"text","text":"as you turn your anger "},{"kind":"footnote","marker":1,"text":"Or spirit"},{"kind":"text","text":" against God"},{"kind":"text","text":" and allow such words to leave your mouth?"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or spirit"}]},{"verseId":"a556c5305ee15c3f-01:Job:15:14","parts":[{"kind":"text","text":"What is a mere human, that he should be pure, "},{"kind":"crossref","label":"Jb 4:17","book":"Job","chapter":4,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jb 25:4","book":"Job","chapter":25,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 20:9","book":"Pro","chapter":20,"verse":9,"letter":"c"},{"kind":"text","text":" or one born of a woman, that he should be righteous?"}],"crossRefs":[{"label":"Jb 4:17","book":"Job","chapter":4,"verse":17},{"label":"Jb 25:4","book":"Job","chapter":25,"verse":4},{"label":"Pr 20:9","book":"Pro","chapter":20,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:15","parts":[{"kind":"text","text":"If God puts no trust in his holy ones "},{"kind":"crossref","label":"Jb 5:1","book":"Job","chapter":5,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 89:5–7","book":"Psa","chapter":89,"verse":5,"letter":"b"},{"kind":"crossref","label":"Dn 4:17","book":"Dan","chapter":4,"verse":17,"letter":"c"},{"kind":"text","text":" and the heavens are not pure in his sight, "},{"kind":"crossref","label":"Jb 4:18","book":"Job","chapter":4,"verse":18,"letter":"a"},{"kind":"crossref","label":"Jb 21:22","book":"Job","chapter":21,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jb 25:5","book":"Job","chapter":25,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Jb 5:1","book":"Job","chapter":5,"verse":1},{"label":"Ps 89:5–7","book":"Psa","chapter":89,"verse":5},{"label":"Dn 4:17","book":"Dan","chapter":4,"verse":17},{"label":"Jb 4:18","book":"Job","chapter":4,"verse":18},{"label":"Jb 21:22","book":"Job","chapter":21,"verse":22},{"label":"Jb 25:5","book":"Job","chapter":25,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:16","parts":[{"kind":"text","text":"how much less one who is revolting and corrupt, "},{"kind":"crossref","label":"Ps 14:3","book":"Psa","chapter":14,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 53:3","book":"Psa","chapter":53,"verse":3,"letter":"b"},{"kind":"text","text":" who drinks injustice "},{"kind":"crossref","label":"Jb 34:7","book":"Job","chapter":34,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ps 14:3","book":"Psa","chapter":14,"verse":3,"letter":"b"},{"kind":"text","text":" like water?"}],"crossRefs":[{"label":"Ps 14:3","book":"Psa","chapter":14,"verse":3},{"label":"Ps 53:3","book":"Psa","chapter":53,"verse":3},{"label":"Jb 34:7","book":"Job","chapter":34,"verse":7},{"label":"Ps 14:3","book":"Psa","chapter":14,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:17","parts":[{"kind":"text","text":"Listen to me and I will inform you."},{"kind":"text","text":" I will describe what I have seen,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:18","parts":[{"kind":"text","text":"what the wise have declared and not concealed, "},{"kind":"text","text":" that came from their ancestors, "},{"kind":"crossref","label":"Dt 4:32","book":"Deu","chapter":4,"verse":32,"letter":"a"},{"kind":"crossref","label":"Dt 32:7","book":"Deu","chapter":32,"verse":7,"letter":"b"},{"kind":"crossref","label":"Jb 8:8","book":"Job","chapter":8,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Dt 4:32","book":"Deu","chapter":4,"verse":32},{"label":"Dt 32:7","book":"Deu","chapter":32,"verse":7},{"label":"Jb 8:8","book":"Job","chapter":8,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:19","parts":[{"kind":"text","text":"to whom alone the land was given"},{"kind":"text","text":" when no foreigner passed among them."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:15:20","parts":[{"kind":"text","text":"A wicked person writhes in pain all his