"kind":"crossref","label":"Ps 107:40","book":"Psa","chapter":107,"verse":40,"letter":"c"}],"crossRefs":[{"label":"Ex 22:28","book":"Exo","chapter":22,"verse":28},{"label":"Jb 12:21","book":"Job","chapter":12,"verse":21},{"label":"Ps 107:40","book":"Psa","chapter":107,"verse":40}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:19","parts":[{"kind":"text","text":"God is not partial "},{"kind":"crossref","label":"Dt 10:17","book":"Deu","chapter":10,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jb 13:8","book":"Job","chapter":13,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jb 32:21","book":"Job","chapter":32,"verse":21,"letter":"c"},{"kind":"text","text":" to princes"},{"kind":"text","text":" and does not favor the rich over the poor,"},{"kind":"text","text":" for they are all the work of his hands."}],"crossRefs":[{"label":"Dt 10:17","book":"Deu","chapter":10,"verse":17},{"label":"Jb 13:8","book":"Job","chapter":13,"verse":8},{"label":"Jb 32:21","book":"Job","chapter":32,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:20","parts":[{"kind":"text","text":"They die suddenly in the middle of the night;"},{"kind":"text","text":" people shudder, then pass away."},{"kind":"text","text":" Even the mighty are removed without effort."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:21","parts":[{"kind":"text","text":"For his eyes watch over a man’s ways,"},{"kind":"text","text":" and he observes all his steps. "},{"kind":"crossref","label":"Jb 14:16","book":"Job","chapter":14,"verse":16,"letter":"a"},{"kind":"crossref","label":"Jb 31:4","book":"Job","chapter":31,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 5:21","book":"Pro","chapter":5,"verse":21,"letter":"c"}],"crossRefs":[{"label":"Jb 14:16","book":"Job","chapter":14,"verse":16},{"label":"Jb 31:4","book":"Job","chapter":31,"verse":4},{"label":"Pr 5:21","book":"Pro","chapter":5,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:22","parts":[{"kind":"text","text":"There is no darkness, no deep darkness,"},{"kind":"text","text":" where evildoers can hide. "},{"kind":"crossref","label":"Ps 139:12","book":"Psa","chapter":139,"verse":12,"letter":"a"},{"kind":"crossref","label":"Am 9:2–3","book":"Amo","chapter":9,"verse":2,"letter":"b"},{"kind":"crossref","label":"Heb 4:13","book":"Heb","chapter":4,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Ps 139:12","book":"Psa","chapter":139,"verse":12},{"label":"Am 9:2–3","book":"Amo","chapter":9,"verse":2},{"label":"Heb 4:13","book":"Heb","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:23","parts":[{"kind":"text","text":"God does not need to examine a person further,"},{"kind":"text","text":" that one should "},{"kind":"footnote","marker":1,"text":"Some emend to God has not appointed a time for man to"},{"kind":"text","text":" approach him in court."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Some emend to God has not appointed a time for man to"}]},{"verseId":"a556c5305ee15c3f-01:Job:34:24","parts":[{"kind":"text","text":"He shatters the mighty without an investigation"},{"kind":"text","text":" and sets others in their place. "},{"kind":"crossref","label":"Jb 12:19","book":"Job","chapter":12,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ps 2:9","book":"Psa","chapter":2,"verse":9,"letter":"b"},{"kind":"crossref","label":"Dn 2:21","book":"Dan","chapter":2,"verse":21,"letter":"c"}],"crossRefs":[{"label":"Jb 12:19","book":"Job","chapter":12,"verse":19},{"label":"Ps 2:9","book":"Psa","chapter":2,"verse":9},{"label":"Dn 2:21","book":"Dan","chapter":2,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:25","parts":[{"kind":"text","text":"Therefore, he recognizes their deeds "},{"kind":"crossref","label":"Jb 11:11","book":"Job","chapter":11,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 10:14","book":"Psa","chapter":10,"verse":14,"letter":"b"},{"kind":"text","text":" and overthrows them by night, and they are crushed."}],"crossRefs":[{"label":"Jb 11:11","book":"Job","chapter":11,"verse":11},{"label":"Ps 10:14","book":"Psa","chapter":10,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:26","parts":[{"kind":"text","text":"In full view of the public, "},{"kind":"footnote","marker":1,"text":"Lit In a place of spectators"},{"kind":"text","text":" he strikes them for their wickedness,"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit In a place of spectators"}]},{"verseId":"a556c5305ee15c3f-01:Job:34:27","parts":[{"kind":"text","text":"because they turned aside from following him"},{"kind":"text","text":" and did not understand any of his ways"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:28","parts":[{"kind":"text","text":"but caused the poor to cry out to him,"},{"kind":"text","text":" and he heard the outcry of the needy. "},{"kind":"crossref","label":"Ex 3:7","book":"Exo","chapter":3,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ex 22:23","book":"Exo","chapter":22,"verse":23,"letter":"b"},{"kind":"crossref","label":"Jms 5:4","book":"Jas","chapter":5,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Ex 3:7","book":"Exo","chapter":3,"verse":7},{"label":"Ex 22:23","book":"Exo","chapter":22,"verse":23},{"label":"Jms 5:4","book":"Jas","chapter":5,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:29","parts":[{"kind":"text","text":"But when God is silent, who can declare him guilty?"},{"kind":"text","text":" When he hides his face, who can see him?"},{"kind":"text","text":" Yet he watches over both individuals and nations,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:30","parts":[{"kind":"text","text":"so that godless men should not rule"},{"kind":"text","text":" or ensnare the people."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:31","parts":[{"kind":"text","text":"Suppose someone says to God,"},{"kind":"text","text":" “I have endured my punishment;"},{"kind":"text","text":" I will no longer act wickedly."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:32","parts":[{"kind":"text","text":"Teach me what I cannot see;"},{"kind":"text","text":" if I have done wrong, I won’t do it again.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:33","parts":[{"kind":"text","text":"Should God repay you on your terms"},{"kind":"text","text":" when you have rejected his?"},{"kind":"text","text":" You must choose, not I!"},{"kind":"text","text":" So declare what you know."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:34","parts":[{"kind":"text","text":"Reasonable men will say to me,"},{"kind":"text","text":" along with the wise men who hear me,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:35","parts":[{"kind":"text","text":"“Job speaks without knowledge; "},{"kind":"crossref","label":"Jb 35:16","book":"Job","chapter":35,"verse":16,"letter":"a"},{"kind":"crossref","label":"Jb 38:2","book":"Job","chapter":38,"verse":2,"letter":"b"},{"kind":"crossref","label":"Jb 42:3","book":"Job","chapter":42,"verse":3,"letter":"c"},{"kind":"text","text":" his words are without insight.”"}],"crossRefs":[{"label":"Jb 35:16","book":"Job","chapter":35,"verse":16},{"label":"Jb 38:2","book":"Job","chapter":38,"verse":2},{"label":"Jb 42:3","book":"Job","chapter":42,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:36","parts":[{"kind":"text","text":"If only Job were tested to the limit,"},{"kind":"text","text":" because his answers are like those of wicked men."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:34:37","parts":[{"kind":"text","text":"For he adds rebellion to his sin;"},{"kind":"text","text":" he scornfully claps "},{"kind":"crossref","label":"Nm 24:10","book":"Num","chapter":24,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jb 27:23","book":"Job","chapter":27,"verse":23,"letter":"b"},{"kind":"crossref","label":"Lm 2:15","book":"Lam","chapter":2,"verse":15,"letter":"c"},{"kind":"text","text":" in our presence,"},{"kind":"text","text":" while multiplying "},{"kind":"crossref","label":"Jb 16:4","book":"Job","chapter":16,"verse":4,"letter":"a"},{"kind":"crossref","label":"Jb 35:16","book":"Job","chapter":35,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ezk 35:13","book":"Ezk","chapter":35,"verse":13,"letter":"c"},{"kind":"text","text":" his words against God."}],"crossRefs":[{"label":"Nm 24:10","book":"Num","chapter":24,"verse":10},{"label":"Jb 27:23","book":"Job","chapter":27,"verse":23},{"label":"Lm 2:15","book":"Lam","chapter":2,"verse":15},{"label":"Jb 16:4","book":"Job","chapter":16,"verse":4},{"label":"Jb 35:16","book":"Job","chapter":35,"verse":16},{"label":"Ezk 35:13","book":"Ezk","chapter":35,"verse":13}],"footnotes":[]}]},"cachedAt":1783279474391}