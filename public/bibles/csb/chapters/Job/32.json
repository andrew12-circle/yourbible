note","marker":1,"text":"Lit answer my part"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit answer my part"}]},{"verseId":"a556c5305ee15c3f-01:Job:32:18","parts":[{"kind":"text","text":"For I am full of words,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:32:19","parts":[{"kind":"text","text":"My heart "},{"kind":"footnote","marker":1,"text":"Lit belly"},{"kind":"text","text":" is like unvented wine;"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit belly"}]},{"verseId":"a556c5305ee15c3f-01:Job:32:20","parts":[{"kind":"text","text":"I must speak so that I can find relief;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:32:21","parts":[{"kind":"text","text":"I will be partial to no one, "},{"kind":"crossref","label":"Dt 10:17","book":"Deu","chapter":10,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jb 13:8","book":"Job","chapter":13,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jb 34:19","book":"Job","chapter":34,"verse":19,"letter":"c"}],"crossRefs":[{"label":"Dt 10:17","book":"Deu","chapter":10,"verse":17},{"label":"Jb 13:8","book":"Job","chapter":13,"verse":8},{"label":"Jb 34:19","book":"Job","chapter":34,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:32:22","parts":[{"kind":"text","text":"For I do not know how to give such titles;"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099356634}