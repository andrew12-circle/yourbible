er":"c"},{"kind":"crossref","label":"Pr 20:30","book":"Pro","chapter":20,"verse":30,"letter":"d"}],"crossRefs":[{"label":"Jb 15:35","book":"Job","chapter":15,"verse":35},{"label":"Jb 37:1","book":"Job","chapter":37,"verse":1},{"label":"Pr 20:27","book":"Pro","chapter":20,"verse":27},{"label":"Pr 20:30","book":"Pro","chapter":20,"verse":30}],"footnotes":[{"marker":1,"text":"Lit belly"}]},{"verseId":"a556c5305ee15c3f-01:Job:32:20","parts":[{"kind":"text","text":"I must speak so that I can find relief;"},{"kind":"text","text":" I must open my lips and respond."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:32:21","parts":[{"kind":"text","text":"I will be partial to no one, "},{"kind":"crossref","label":"Dt 10:17","book":"Deu","chapter":10,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jb 13:8","book":"Job","chapter":13,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jb 34:19","book":"Job","chapter":34,"verse":19,"letter":"c"},{"kind":"text","text":" and I will not give anyone an undeserved title."}],"crossRefs":[{"label":"Dt 10:17","book":"Deu","chapter":10,"verse":17},{"label":"Jb 13:8","book":"Job","chapter":13,"verse":8},{"label":"Jb 34:19","book":"Job","chapter":34,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:32:22","parts":[{"kind":"text","text":"For I do not know how to give such titles;"},{"kind":"text","text":" otherwise, my Maker would remove me in an instant."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279473682}