":"a"},{"kind":"crossref","label":"Ps 4:8","book":"Psa","chapter":4,"verse":8,"letter":"b"},{"kind":"crossref","label":"Pr 3:24","book":"Pro","chapter":3,"verse":24,"letter":"c"},{"kind":"text","text":" but his eyes "},{"kind":"crossref","label":"Ps 11:4","book":"Psa","chapter":11,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 15:3","book":"Pro","chapter":15,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jr 16:17","book":"Jer","chapter":16,"verse":17,"letter":"c"},{"kind":"text","text":" watch over their ways."}],"crossRefs":[{"label":"Jb 11:18","book":"Job","chapter":11,"verse":18},{"label":"Ps 4:8","book":"Psa","chapter":4,"verse":8},{"label":"Pr 3:24","book":"Pro","chapter":3,"verse":24},{"label":"Ps 11:4","book":"Psa","chapter":11,"verse":4},{"label":"Pr 15:3","book":"Pro","chapter":15,"verse":3},{"label":"Jr 16:17","book":"Jer","chapter":16,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:24:24","parts":[{"kind":"text","text":"They are exalted for a moment, then gone;"},{"kind":"text","text":" they are brought low and shrivel up like everything else. "},{"kind":"footnote","marker":1,"text":"LXX reads like a mallow plant in the heat"},{"kind":"text","text":" They wither like heads of grain. "},{"kind":"crossref","label":"Jb 14:21","book":"Job","chapter":14,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 37:10","book":"Psa","chapter":37,"verse":10,"letter":"b"},{"kind":"crossref","label":"Ps 106:43","book":"Psa","chapter":106,"verse":43,"letter":"c"}],"crossRefs":[{"label":"Jb 14:21","book":"Job","chapter":14,"verse":21},{"label":"Ps 37:10","book":"Psa","chapter":37,"verse":10},{"label":"Ps 106:43","book":"Psa","chapter":106,"verse":43}],"footnotes":[{"marker":1,"text":"LXX reads like a mallow plant in the heat"}]},{"verseId":"a556c5305ee15c3f-01:Job:24:25","parts":[{"kind":"text","text":"If this is not true, then who can prove me a liar "},{"kind":"crossref","label":"Jb 6:28","book":"Job","chapter":6,"verse":28,"letter":"a"},