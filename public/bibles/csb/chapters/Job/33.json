verse":7,"letter":"a"},{"kind":"crossref","label":"2Kg 5:14","book":"2Ki","chapter":5,"verse":14,"letter":"b"},{"kind":"crossref","label":"Jb 20:11","book":"Job","chapter":20,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Dt 34:7","book":"Deu","chapter":34,"verse":7},{"label":"2Kg 5:14","book":"2Ki","chapter":5,"verse":14},{"label":"Jb 20:11","book":"Job","chapter":20,"verse":11}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Job:33:26","parts":[{"kind":"text","text":"He will pray to God, and God will delight in him."},{"kind":"text","text":" That person will see his face "},{"kind":"crossref","label":"Gn 33:10","book":"Gen","chapter":33,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ps 11:7","book":"Psa","chapter":11,"verse":7,"letter":"b"},{"kind":"crossref","label":"Ps 17:15","book":"Psa","chapter":17,"verse":15,"letter":"c"},{"kind":"text","text":" with a shout of joy,"},{"kind":"text","text":" and God will restore his righteousness to him. "},{"kind":"crossref","label":"Ps 23:3","book":"Psa","chapter":23,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 51:12","book":"Psa","chapter":51,"verse":12,"letter":"b"},{"kind":"crossref","label":"1Jn 1:9","book":"1Jn","chapter":1,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Gn 33:10","book":"Gen","chapter":33,"verse":10},{"label":"Ps 11:7","book":"Psa","chapter":11,"verse":7},{"label":"Ps 17:15","book":"Psa","chapter":17,"verse":15},{"label":"Ps 23:3","book":"Psa","chapter":23,"verse":3},{"label":"Ps 51:12","book":"Psa","chapter":51,"verse":12},{"label":"1Jn 1:9","book":"1Jn","chapter":1,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:33:27","parts":[{"kind":"text","text":"He will look at men and say,"},{"kind":"text","text":" “I have sinned and perverted what was right;"},{"kind":"text","text":" yet I did not get what I deserved. "},{"kind":"footnote","marker":1,"text":"Lit and the same was not to me"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit and the same was not to me"}]},{"verseId":"a556c5305ee15c3f-01:Job:33:28","parts":[{"kind":"text","text":"He redeemed my soul from going down to the Pit,"},{"kind":"text","text":" and I will continue to see the light.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:33:29","parts":[{"kind":"text","text":"God certainly does all these things"},{"kind":"text","text":" two or three times to a person"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:33:30","parts":[{"kind":"text","text":"in order to turn him back from the Pit,"},{"kind":"text","text":" so he may shine with the light of life. "},{"kind":"crossref","label":"Ps 56:13","book":"Psa","chapter":56,"verse":13,"letter":"a"},{"kind":"crossref","label":"Jn 1:4","book":"Jhn","chapter":1,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jn 1:9","book":"Jhn","chapter":1,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Ps 56:13","book":"Psa","chapter":56,"verse":13},{"label":"Jn 1:4","book":"Jhn","chapter":1,"verse":4},{"label":"Jn 1:9","book":"Jhn","chapter":1,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:33:31","parts":[{"kind":"text","text":"Pay attention, Job, and listen to me."},{"kind":"text","text":" Be quiet, and I will speak."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Job:33:32","parts":[{"kind":"text","text":"But if you have something to say, "},{"kind":"footnote","marker":1,"text":"Lit If there are words"},{"kind":"text","text":" answer me;"},{"kind":"text","text":" speak, for I would like to justify you."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit If there are words"}]},{"verseId":"a556c5305ee15c3f-01:Job:33:33","parts":[{"kind":"text","text":"If not, then listen to me;"},{"kind":"text","text":" be quiet, and I will teach you wisdom."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279474045}