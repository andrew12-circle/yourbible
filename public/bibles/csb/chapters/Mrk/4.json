":"text","text":"He sleeps"},{"kind":"crossref","label":"Mt 9:24","book":"Mat","chapter":9,"verse":24,"letter":"a"},{"kind":"text","text":" and rises"},{"kind":"crossref","label":"Mk 5:41","book":"Mrk","chapter":5,"verse":41,"letter":"b"},{"kind":"text","text":" night"},{"kind":"crossref","label":"Jn 9:4","book":"Jhn","chapter":9,"verse":4,"letter":"c"},{"kind":"text","text":" and day; the seed sprouts and grows, although he doesn’t know how. "}],"crossRefs":[{"label":"Mt 9:24","book":"Mat","chapter":9,"verse":24},{"label":"Mk 5:41","book":"Mrk","chapter":5,"verse":41},{"label":"Jn 9:4","book":"Jhn","chapter":9,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:4:28","parts":[{"kind":"text","text":"The soil produces a crop"},{"kind":"crossref","label":"Col 1:10","book":"Col","chapter":1,"verse":10,"letter":"a"},{"kind":"text","text":" by itself —first the blade, then the head, and then the full grain"},{"kind":"crossref","label":"Lk 16:7","book":"Luk","chapter":16,"verse":7,"letter":"b"},{"kind":"text","text":" on the head. "}],"crossRefs":[{"label":"Col 1:10","book":"Col","chapter":1,"verse":10},{"label":"Lk 16:7","book":"Luk","chapter":16,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:4:29","parts":[{"kind":"text","text":"As soon as the crop is ready, he sends for the sickle,"},{"kind":"crossref","label":"Jl 3:13","book":"Jol","chapter":3,"verse":13,"letter":"a"},{"kind":"crossref","label":"Rv 14:14–19","book":"Rev","chapter":14,"verse":14,"letter":"b"},{"kind":"text","text":" because the harvest"},{"kind":"crossref","label":"Rv 14:15","book":"Rev","chapter":14,"verse":15,"letter":"c"},{"kind":"text","text":" has come.”"}],"crossRefs":[{"label":"Jl 3:13","book":"Jol","chapter":3,"verse":13},{"label":"Rv 14:14–19","book":"Rev","chapter":14,"verse":14},{"label":"Rv 14:15","book":"Rev","chapter":14,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:4:30","parts":[{"kind":"text","text":"And "},{"kind":"crossref","label":"Mt 