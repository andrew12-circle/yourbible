":"Mrk","chapter":10,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:15:21","parts":[{"kind":"text","text":"They "},{"kind":"crossref","label":"Mt 27:32","book":"Mat","chapter":27,"verse":32,"letter":"a"},{"kind":"crossref","label":"Lk 23:26–31","book":"Luk","chapter":23,"verse":26,"letter":"b"},{"kind":"text","text":" forced a man coming in from the country, who was passing by, to carry Jesus’s cross. "},{"kind":"crossref","label":"Lk 9:23","book":"Luk","chapter":9,"verse":23,"letter":"c"},{"kind":"text","text":" He was Simon of Cyrene, "},{"kind":"crossref","label":"Ac 6:9","book":"Act","chapter":6,"verse":9,"letter":"d"},{"kind":"text","text":" the father of Alexander and Rufus. "},{"kind":"crossref","label":"Rm 16:13","book":"Rom","chapter":16,"verse":13,"letter":"e"}],"crossRefs":[{"label":"Mt 27:32","book":"Mat","chapter":27,"verse":32},{"label":"Lk 23:26–31","book":"Luk","chapter":23,"verse":26},{"label":"Lk 9:23","book":"Luk","chapter":9,"verse":23},{"label":"Ac 6:9","book":"Act","chapter":6,"verse":9},{"label":"Rm 16:13","book":"Rom","chapter":16,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:15:22","parts":[{"kind":"text","text":"They "},{"kind":"crossref","label":"Mt 27:33–37","book":"Mat","chapter":27,"verse":33,"letter":"a"},{"kind":"crossref","label":"Lk 22:32–34","book":"Luk","chapter":22,"verse":32,"letter":"b"},{"kind":"crossref","label":"Jn 19:17–24","book":"Jhn","chapter":19,"verse":17,"letter":"c"},{"kind":"text","text":" brought Jesus to the place called Golgotha (which means Place of the Skull "},{"kind":"crossref","label":"Jn 19:17","book":"Jhn","chapter":19,"verse":17,"letter":"d"},{"kind":"text","text":"). "}],"crossRefs":[{"label":"Mt 27:33–37","book":"Mat","chapter":27,"verse":33},{"label":"Lk 22:32–34","book":"Luk","chapter":22,"verse":32},{"label":"Jn 19:17–24","book":"Jhn","chapter":19,"verse":17},{"label":"Jn 19:17","book":"Jhn","chapter":19,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01