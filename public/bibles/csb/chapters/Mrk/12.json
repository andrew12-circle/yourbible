u","chapter":25,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:20","parts":[{"kind":"text","text":"There were seven brothers. The first married a woman, and dying, left no offspring. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:21","parts":[{"kind":"text","text":"The second also took her, and he died, leaving no offspring. And the third likewise. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:22","parts":[{"kind":"text","text":"None of the seven "},{"kind":"footnote","marker":1,"text":"Other mss add had taken her and"},{"kind":"text","text":" left offspring. Last of all, the woman died too. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss add had taken her and"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:23","parts":[{"kind":"text","text":"In the resurrection, when they rise, "},{"kind":"footnote","marker":2,"text":"Other mss omit when they rise"},{"kind":"text","text":" whose wife will she be, since the seven had married her?”"}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Other mss omit when they rise"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:24","parts":[{"kind":"text","text":"Jesus spoke to them, “Isn’t this the reason why you’re mistaken: you don’t know the Scriptures"},{"kind":"crossref","label":"Mt 26:54","book":"Mat","chapter":26,"verse":54,"letter":"a"},{"kind":"crossref","label":"2Pt 1:20","book":"2Pe","chapter":1,"verse":20,"letter":"b"},{"kind":"text","text":" or the power"},{"kind":"crossref","label":"Lk 1:35","book":"Luk","chapter":1,"verse":35,"letter":"c"},{"kind":"crossref","label":"Lk 6:19","book":"Luk","chapter":6,"verse":19,"letter":"d"},{"kind":"text","text":" of God?"},{"kind":"crossref","label":"2Co 13:4","book":"2Co","chapter":13,"verse":4,"letter":"e"},{"kind":"crossref","label":"Rv 11:17","book":"Rev","chapter":11,"verse":17,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 26:54","book":"Mat","chapter":26,"verse":54},{"label":"2Pt 1:20","book":"2Pe","chapter":1,"verse":20},{"label":"Lk 1:35","book":"Luk","chapter":1,"verse":35},{"label":"Lk 6:19","book":"Luk","chapter":6,"verse":19},{"label":"2Co 13:4","book":"2Co","chapter":13,"verse":4},{"label":"Rv 11:17","book":"Rev","chapter":11,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:25","parts":[{"kind":"text","text":"For when they rise"},{"kind":"crossref","label":"Lk 18:33","book":"Luk","chapter":18,"verse":33,"letter":"a"},{"kind":"text","text":" from the dead,"},{"kind":"crossref","label":"Jn 5:25","book":"Jhn","chapter":5,"verse":25,"letter":"b"},{"kind":"crossref","label":"Jn 20:9","book":"Jhn","chapter":20,"verse":9,"letter":"c"},{"kind":"text","text":" they neither marry nor are given in marriage"},{"kind":"crossref","label":"1Tm 5:14","book":"1Ti","chapter":5,"verse":14,"letter":"d"},{"kind":"text","text":" but are like angels"},{"kind":"crossref","label":"Mt 13:49","book":"Mat","chapter":13,"verse":49,"letter":"e"},{"kind":"crossref","label":"Ac 5:19","book":"Act","chapter":5,"verse":19,"letter":"f"},{"kind":"crossref","label":"Rv 14:6","book":"Rev","chapter":14,"verse":6,"letter":"g"},{"kind":"text","text":" in heaven. "}],"crossRefs":[{"label":"Lk 18:33","book":"Luk","chapter":18,"verse":33},{"label":"Jn 5:25","book":"Jhn","chapter":5,"verse":25},{"label":"Jn 20:9","book":"Jhn","chapter":20,"verse":9},{"label":"1Tm 5:14","book":"1Ti","chapter":5,"verse":14},{"label":"Mt 13:49","book":"Mat","chapter":13,"verse":49},{"label":"Ac 5:19","book":"Act","chapter":5,"verse":19},{"label":"Rv 14:6","book":"Rev","chapter":14,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:26","parts":[{"kind":"text","text":"And as for the dead being raised —haven’t you read in the book of Moses, in the passage about the burning bush, how God said to him: I"},{"kind":"crossref","label":"Ex 3:6","book":"Exo","chapter":3,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ex 3:15","book":"Exo","chapter":3,"verse":15,"letter":