","parts":[{"kind":"text","text":"Jesus answered, “The most important"},{"kind":"footnote","marker":1,"text":"Other mss add of all the commands"},{"kind":"text","text":" is Listen, Israel! The Lord"},{"kind":"crossref","label":"Col 4:1","book":"Col","chapter":4,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jd 1:5","book":"Jud","chapter":1,"verse":5,"letter":"b"},{"kind":"text","text":" our God, the Lord"},{"kind":"crossref","label":"Dt 6:4","book":"Deu","chapter":6,"verse":4,"letter":"c"},{"kind":"text","text":" is one."},{"kind":"footnote","marker":2,"text":"Or the Lord our God is Lord alone."},{"kind":"text","text":" "}],"crossRefs":[{"label":"Col 4:1","book":"Col","chapter":4,"verse":1},{"label":"Jd 1:5","book":"Jud","chapter":1,"verse":5},{"label":"Dt 6:4","book":"Deu","chapter":6,"verse":4}],"footnotes":[{"marker":1,"text":"Other mss add of all the commands"},{"marker":2,"text":"Or the Lord our God is Lord alone."}]},{"verseId":"a556c5305ee15c3f-01:Mrk:12:30","parts":[{"kind":"text","text":"Love"},{"kind":"crossref","label":"Lk 6:35","book":"Luk","chapter":6,"verse":35,"letter":"a"},{"kind":"text","text":" the Lord your God"},{"kind":"crossref","label":"Dt 6:5","book":"Deu","chapter":6,"verse":5,"letter":"b"},{"kind":"crossref","label":"Lk 10:27","book":"Luk","chapter":10,"verse":27,"letter":"c"},{"kind":"text","text":" with all your heart, with all your soul, with all your mind,"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"d"},{"kind":"text","text":" and with all your strength."},{"kind":"footnote","marker":3,"text":"Other mss add This is the first commandment."},{"kind":"crossref","label":"Dt 6:4","book":"Deu","chapter":6,"verse":4,"letter":"e"},{"kind":"crossref","label":"Jos 22:5","book":"Jos","chapter":22,"verse":5,"letter":"f"},{"kind":"crossref","label":"Dt 6:4","book":"Deu","chapter":6,"verse":4,"letter":"g"},{"kind":"crossref","label":"Jos 22:5","book":"Jos","chapter":22,"verse":5,"letter":"h"},{"kind":"te