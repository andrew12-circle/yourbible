 1:7","book":"Act","chapter":1,"verse":7,"letter":"b"},{"kind":"crossref","label":"1Th 5:1–2","book":"1Th","chapter":5,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Pt 5:6","book":"1Pe","chapter":5,"verse":6,"letter":"d"}],"crossRefs":[{"label":"Lk 20:20","book":"Luk","chapter":20,"verse":20},{"label":"Ac 1:7","book":"Act","chapter":1,"verse":7},{"label":"1Th 5:1–2","book":"1Th","chapter":5,"verse":1},{"label":"1Pt 5:6","book":"1Pe","chapter":5,"verse":6}],"footnotes":[{"marker":1,"text":"Other mss add and pray"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:34","parts":[{"kind":"text","text":"“It is like"},{"kind":"crossref","label":"Lk 12:35–40","book":"Luk","chapter":12,"verse":35,"letter":"a"},{"kind":"text","text":" a man on a journey, who left his house, gave authority to his servants,"},{"kind":"crossref","label":"Mt 10:24","book":"Mat","chapter":10,"verse":24,"letter":"b"},{"kind":"text","text":" gave each one his work, and commanded the doorkeeper to be alert. "}],"crossRefs":[{"label":"Lk 12:35–40","book":"Luk","chapter":12,"verse":35},{"label":"Mt 10:24","book":"Mat","chapter":10,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:35","parts":[{"kind":"text","text":"Therefore be alert,"},{"kind":"crossref","label":"Rv 16:15","book":"Rev","chapter":16,"verse":15,"letter":"a"},{"kind":"text","text":" since you don’t know when the master"},{"kind":"crossref","label":"Col 3:22","book":"Col","chapter":3,"verse":22,"letter":"b"},{"kind":"text","text":" of the house is coming —whether in the evening or at midnight or at the crowing of the rooster or early in the morning. "}],"crossRefs":[{"label":"Rv 16:15","book":"Rev","chapter":16,"verse":15},{"label":"Col 3:22","book":"Col","chapter":3,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:36","parts":[{"kind":"text","text":"Otherwise, when he comes suddenly he might find you sleeping."},{"kind":"crossref","label":"Pr 6:4","book":"Pro","chapter":6,"verse":4,"letter":"a"},{"kind"