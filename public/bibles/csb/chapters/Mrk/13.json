ref","label":"Ex 7:3","book":"Exo","chapter":7,"verse":3,"letter":"a"},{"kind":"crossref","label":"Dn 6:27","book":"Dan","chapter":6,"verse":27,"letter":"b"},{"kind":"crossref","label":"Jn 4:48","book":"Jhn","chapter":4,"verse":48,"letter":"c"},{"kind":"crossref","label":"Ac 4:30","book":"Act","chapter":4,"verse":30,"letter":"d"},{"kind":"crossref","label":"Rm 15:19","book":"Rom","chapter":15,"verse":19,"letter":"e"},{"kind":"crossref","label":"2Th 2:9","book":"2Th","chapter":2,"verse":9,"letter":"f"},{"kind":"crossref","label":"Heb 2:4","book":"Heb","chapter":2,"verse":4,"letter":"g"},{"kind":"text","text":" to lead astray, if possible, the elect. "}],"crossRefs":[{"label":"Ex 7:3","book":"Exo","chapter":7,"verse":3},{"label":"Dn 6:27","book":"Dan","chapter":6,"verse":27},{"label":"Jn 4:48","book":"Jhn","chapter":4,"verse":48},{"label":"Ac 4:30","book":"Act","chapter":4,"verse":30},{"label":"Rm 15:19","book":"Rom","chapter":15,"verse":19},{"label":"2Th 2:9","book":"2Th","chapter":2,"verse":9},{"label":"Heb 2:4","book":"Heb","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:23","parts":[{"kind":"text","text":"And you must watch! I have told you everything in advance."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:24","parts":[{"kind":"text","text":"“But in those days, after that tribulation:"},{"kind":"crossref","label":"2Co 1:4","book":"2Co","chapter":1,"verse":4,"letter":"a"},{"kind":"text","text":" The sun will be darkened, and the moon will not shed its light; "}],"crossRefs":[{"label":"2Co 1:4","book":"2Co","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:13:25","parts":[{"kind":"text","text":"the stars"},{"kind":"crossref","label":"Rv 1:16","book":"Rev","chapter":1,"verse":16,"letter":"a"},{"kind":"text","text":" will be falling from the sky, and the powers in the heavens will be shaken."},{"kind":"crossref","label":"Is 13:10","book":"Isa","chapter":13,"verse":10,"letter":"b"},{"