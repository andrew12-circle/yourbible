":"Mk 9:33","book":"Mrk","chapter":9,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:7","parts":[{"kind":"text","text":"“Why does he speak like this? He’s blaspheming! "},{"kind":"crossref","label":"Ex 22:28","book":"Exo","chapter":22,"verse":28,"letter":"a"},{"kind":"crossref","label":"Mk 3:29","book":"Mrk","chapter":3,"verse":29,"letter":"b"},{"kind":"crossref","label":"Rv 13:6","book":"Rev","chapter":13,"verse":6,"letter":"c"},{"kind":"text","text":" Who can forgive "},{"kind":"crossref","label":"Ps 25:11","book":"Psa","chapter":25,"verse":11,"letter":"d"},{"kind":"crossref","label":"Mt 9:2","book":"Mat","chapter":9,"verse":2,"letter":"e"},{"kind":"text","text":" sins "},{"kind":"crossref","label":"Jn 15:22","book":"Jhn","chapter":15,"verse":22,"letter":"f"},{"kind":"text","text":" but God alone?” "},{"kind":"crossref","label":"Ex 34:6–7","book":"Exo","chapter":34,"verse":6,"letter":"g"},{"kind":"crossref","label":"Is 43:25","book":"Isa","chapter":43,"verse":25,"letter":"h"},{"kind":"crossref","label":"Is 44:2","book":"Isa","chapter":44,"verse":2,"letter":"i"}],"crossRefs":[{"label":"Ex 22:28","book":"Exo","chapter":22,"verse":28},{"label":"Mk 3:29","book":"Mrk","chapter":3,"verse":29},{"label":"Rv 13:6","book":"Rev","chapter":13,"verse":6},{"label":"Ps 25:11","book":"Psa","chapter":25,"verse":11},{"label":"Mt 9:2","book":"Mat","chapter":9,"verse":2},{"label":"Jn 15:22","book":"Jhn","chapter":15,"verse":22},{"label":"Ex 34:6–7","book":"Exo","chapter":34,"verse":6},{"label":"Is 43:25","book":"Isa","chapter":43,"verse":25},{"label":"Is 44:2","book":"Isa","chapter":44,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:8","parts":[{"kind":"text","text":"Right away "},{"kind":"crossref","label":"Mk 10:52","book":"Mrk","chapter":10,"verse":52,"letter":"a"},{"kind":"text","text":" Jesus perceived in his spirit "},{"kind":"crossref","label":"Lk 5:22","book":"Luk","chapter":5,"verse":22,"letter":"b"},{"kind":"crossref","label":"Lk 16:15","book":"Luk","chapter":16,"verse":15,"letter":"c"},{"kind":"crossref","label":"Jn 2:25","book":"Jhn","chapter":2,"verse":25,"letter":"d"},{"kind":"text","text":" that they were thinking like this within themselves and said to them, “Why are you thinking these things in your hearts? "}],"crossRefs":[{"label":"Mk 10:52","book":"Mrk","chapter":10,"verse":52},{"label":"Lk 5:22","book":"Luk","chapter":5,"verse":22},{"label":"Lk 16:15","book":"Luk","chapter":16,"verse":15},{"label":"Jn 2:25","book":"Jhn","chapter":2,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:9","parts":[{"kind":"text","text":"Which is easier:"},{"kind":"crossref","label":"Lk 16:17","book":"Luk","chapter":16,"verse":17,"letter":"a"},{"kind":"crossref","label":"Lk 18:25","book":"Luk","chapter":18,"verse":25,"letter":"b"},{"kind":"text","text":" to say to the paralytic,"},{"kind":"crossref","label":"Mk 2:3","book":"Mrk","chapter":2,"verse":3,"letter":"c"},{"kind":"text","text":" ‘Your sins are forgiven,’ or to say, ‘Get up, take your mat, and walk’?"},{"kind":"crossref","label":"Mt 11:5","book":"Mat","chapter":11,"verse":5,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 16:17","book":"Luk","chapter":16,"verse":17},{"label":"Lk 18:25","book":"Luk","chapter":18,"verse":25},{"label":"Mk 2:3","book":"Mrk","chapter":2,"verse":3},{"label":"Mt 11:5","book":"Mat","chapter":11,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:10","parts":[{"kind":"text","text":"But so that you may know that the Son of Man"},{"kind":"crossref","label":"Ps 8:4","book":"Psa","chapter":8,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lk 5:24","book":"Luk","chapter":5,"verse":24,"letter":"b"},{"kind":"crossref","label":"Ac 7:56","book":"Act","chapter":7,"verse":56,"letter":"c"},{"kind":"text","text":" has authority"},{"kind":"crossref","label":"Mt 28:18","book":"Mat","chapter":28,"verse":18,"letter":"d"},{"kind":"crossref","label":"Mk 1:22","book":"Mrk","chapter":1,"verse":22,"letter":"e"},{"kind":"text","text":" on earth to forgive sins”"},{"kind":"crossref","label":"Jn 15:22","book":"Jhn","chapter":15,"verse":22,"letter":"f"},{"kind":"text","text":" —he told the paralytic — "}],"crossRefs":[{"label":"Ps 8:4","book":"Psa","chapter":8,"verse":4},{"label":"Lk 5:24","book":"Luk","chapter":5,"verse":24},{"label":"Ac 7:56","book":"Act","chapter":7,"verse":56},{"label":"Mt 28:18","book":"Mat","chapter":28,"verse":18},{"label":"Mk 1:22","book":"Mrk","chapter":1,"verse":22},{"label":"Jn 15:22","book":"Jhn","chapter":15,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:11","parts":[{"kind":"text","text":"“I tell you: get up,"},{"kind":"crossref","label":"Mk 5:41","book":"Mrk","chapter":5,"verse":41,"letter":"a"},{"kind":"text","text":" take your mat, and go home.”"}],"crossRefs":[{"label":"Mk 5:41","book":"Mrk","chapter":5,"verse":41}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:12","parts":[{"kind":"text","text":"Immediately he got up, took the mat, and went out in front of everyone. As a result, they were all astounded "},{"kind":"crossref","label":"Ac 10:45","book":"Act","chapter":10,"verse":45,"letter":"a"},{"kind":"text","text":" and gave glory "},{"kind":"crossref","label":"Jn 11:4","book":"Jhn","chapter":11,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jn 17:1","book":"Jhn","chapter":17,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Pt 2:12","book":"1Pe","chapter":2,"verse":12,"letter":"d"},{"kind":"text","text":" to God, "},{"kind":"crossref","label":"Lk 2:14","book":"Luk","chapter":2,"verse":14,"letter":"e"},{"kind":"text","text":" saying, “We have never seen anything like this!” "},{"kind":"crossref","label":"Mt 9:33","book":"Mat","chapter":9,"verse":33,"letter":"f"}],"crossRefs":[{"label":"Ac 10:45","book":"Act","chapter":10,"verse":45},{"label":"Jn 11:4","book":"Jhn","chapter":11,"verse":4},{"label":"Jn 17:1","book":"Jhn","chapter":17,"verse":1},{"label":"1Pt 2:12","book":"1Pe","chapter":2,"ve