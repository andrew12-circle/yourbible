7","book":"Luk","chapter":5,"verse":27},{"label":"Lk 5:29","book":"Luk","chapter":5,"verse":29},{"label":"Lk 5:27","book":"Luk","chapter":5,"verse":27},{"label":"Lk 5:27","book":"Luk","chapter":5,"verse":27},{"label":"Lk 5:11","book":"Luk","chapter":5,"verse":11},{"label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:15","parts":[{"kind":"text","text":"While he was reclining at the table in Levi’s house, many tax collectors "},{"kind":"crossref","label":"Lk 3:12","book":"Luk","chapter":3,"verse":12,"letter":"a"},{"kind":"crossref","label":"Lk 18:13","book":"Luk","chapter":18,"verse":13,"letter":"b"},{"kind":"text","text":" and sinners "},{"kind":"crossref","label":"Mt 9:10","book":"Mat","chapter":9,"verse":10,"letter":"c"},{"kind":"crossref","label":"1Tm 1:15","book":"1Ti","chapter":1,"verse":15,"letter":"d"},{"kind":"text","text":" were eating "},{"kind":"footnote","marker":1,"text":"Lit reclining together"},{"kind":"text","text":" with Jesus and his disciples, for there were many who were following him. "}],"crossRefs":[{"label":"Lk 3:12","book":"Luk","chapter":3,"verse":12},{"label":"Lk 18:13","book":"Luk","chapter":18,"verse":13},{"label":"Mt 9:10","book":"Mat","chapter":9,"verse":10},{"label":"1Tm 1:15","book":"1Ti","chapter":1,"verse":15}],"footnotes":[{"marker":1,"text":"Lit reclining together"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:2:16","parts":[{"kind":"text","text":"When the scribes "},{"kind":"crossref","label":"Mt 2:4","book":"Mat","chapter":2,"verse":4,"letter":"a"},{"kind":"text","text":" who were Pharisees "},{"kind":"footnote","marker":2,"text":"Other mss read scribes and Pharisees"},{"kind":"crossref","label":"Mk 7:3","book":"Mrk","chapter":7,"verse":3,"letter":"b"},{"kind":"text","text":" saw that he was eating "},{"kind":"crossref","label":"Mt 11:18","book":"Mat","chapter":11,"verse":18,"letter":"c"},{"kind":"text","text":" with sinners "},{"kind":"crossref","label":"1Tm 1:15","book":"1Ti","