","chapter":20,"verse":9},{"label":"Ex 21:17","book":"Exo","chapter":21,"verse":17},{"label":"Lv 20:9","book":"Lev","chapter":20,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:11","parts":[{"kind":"text","text":"But you say, ‘If anyone tells his father or mother: Whatever benefit"},{"kind":"crossref","label":"Mk 5:26","book":"Mrk","chapter":5,"verse":26,"letter":"a"},{"kind":"text","text":" you might have received from me is corban’” (that is, an offering "},{"kind":"crossref","label":"Heb 5:1","book":"Heb","chapter":5,"verse":1,"letter":"b"},{"kind":"crossref","label":"Heb 9:9","book":"Heb","chapter":9,"verse":9,"letter":"c"},{"kind":"crossref","label":"Heb 11:4","book":"Heb","chapter":11,"verse":4,"letter":"d"},{"kind":"text","text":" devoted to God), "}],"crossRefs":[{"label":"Mk 5:26","book":"Mrk","chapter":5,"verse":26},{"label":"Heb 5:1","book":"Heb","chapter":5,"verse":1},{"label":"Heb 9:9","book":"Heb","chapter":9,"verse":9},{"label":"Heb 11:4","book":"Heb","chapter":11,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:12","parts":[{"kind":"text","text":"“you no longer let him do anything for his father or mother. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:13","parts":[{"kind":"text","text":"You nullify the word of God"},{"kind":"crossref","label":"Mk 4:14","book":"Mrk","chapter":4,"verse":14,"letter":"a"},{"kind":"crossref","label":"Lk 8:21","book":"Luk","chapter":8,"verse":21,"letter":"b"},{"kind":"crossref","label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32,"letter":"c"},{"kind":"text","text":" by your tradition that you have handed"},{"kind":"crossref","label":"Jd 1:3","book":"Jud","chapter":1,"verse":3,"letter":"d"},{"kind":"text","text":" down. And you do many other similar things.”"}],"crossRefs":[{"label":"Mk 4:14","book":"Mrk","chapter":4,"verse":14},{"label":"Lk 8:21","book":"Luk","chapter":8,"verse":21},{"label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32},{"label":"Jd 1:3","book":"Jud","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:14","parts":[{"kind":"text","text":"Summoning "},{"kind":"crossref","label":"Lk 18:16","book":"Luk","chapter":18,"verse":16,"letter":"a"},{"kind":"text","text":" the crowd again, he told them, “Listen to me, all of you, and understand:"},{"kind":"crossref","label":"Mt 13:13","book":"Mat","chapter":13,"verse":13,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 18:16","book":"Luk","chapter":18,"verse":16},{"label":"Mt 13:13","book":"Mat","chapter":13,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:15","parts":[{"kind":"text","text":"Nothing that goes into a person from outside can defile him but the things that come out of a person are what defile him.”"},{"kind":"footnote","marker":1,"text":"Some mss include v. 16: “If anyone has ears to hear, let him listen.”"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Some mss include v. 16: “If anyone has ears to hear, let him listen.”"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:17","parts":[{"kind":"text","text":"When he went into the house away from the crowd, his disciples asked him about the parable. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:18","parts":[{"kind":"text","text":"He said to them, “Are you also as lacking in understanding? Don’t you realize that nothing going into a person from the outside can defile him? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:19","parts":[{"kind":"text","text":"For it doesn’t go into his heart but into the stomach"},{"kind":"crossref","label":"Php 3:19","book":"Php","chapter":3,"verse":19,"letter":"a"},{"kind":"text","text":" and is eliminated” (thus he declared all foods clean "},{"kind":"crossref","label":"1Jn 1:7","book":"1Jn","chapter":1,"verse":7,"letter":"b"},{"kind":"text","text":"). "}],"crossRefs":[{"label":"Php 3:19","book":"Php","chapter":3,"verse":19},{"label":"1Jn 1:7","book":"1Jn","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:20","parts":[{"kind":"text","text":"And he said, “What comes out of a person is what defiles him. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:21","parts":[{"kind":"text","text":"For from within, out of people’s hearts, come evil thoughts, sexual immoralities,"},{"kind":"crossref","label":"1Th 4:3","book":"1Th","chapter":4,"verse":3,"letter":"a"},{"kind":"text","text":" thefts, murders,"},{"kind":"crossref","label":"Pr 1:16","book":"Pro","chapter":1,"verse":16,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Th 4:3","book":"1Th","chapter":4,"verse":3},{"label":"Pr 1:16","book":"Pro","chapter":1,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:22","parts":[{"kind":"text","text":"adulteries,"},{"kind":"crossref","label":"Nm 5:11","book":"Num","chapter":5,"verse":11,"letter":"a"},{"kind":"text","text":" greed,"},{"kind":"crossref","label":"Eph 5:3","book":"Eph","chapter":5,"verse":3,"letter":"b"},{"kind":"text","text":" evil actions, deceit,"},{"kind":"crossref","label":"Ps 10:7","book":"Psa","chapter":10,"verse":7,"letter":"c"},{"kind":"text","text":" self-indulgence,"},{"kind":"crossref","label":"Rm 13:13","book":"Rom","chapter":13,"verse":13,"letter":"d"},{"kind":"crossref","label":"2Co 12:21","book":"2Co","chapter":12,"verse":21,"letter":"e"},{"kind":"crossref","label":"Gl 5:19","book":"Gal","chapter":5,"verse":19,"letter":"f"},{"kind":"crossref","label":"Eph 4:19","book":"Eph","chapter":4,"verse":19,"letter":"g"},{"kind":"crossref","label":"1Pt 4:3","book":"1Pe","chapter":4,"verse":3,"letter":"h"},{"kind":"crossref","label":"2Pt 2:2","book":"2Pe","chapter":2,"verse":2,"letter":"i"},{"kind":"crossref","label":"2Pt 2:7","book":"2Pe","chapter":2,"verse":7,"letter":"j"},{"kind":"crossref","label":"2Pt 2:18","book":"2Pe","chapter":2,"verse":18,"letter":"k"},{"kind":"text","text":" envy,"},{"kind":"footnote","marker":1,"text":"Or evil eye"},{"kind":"text","text":" slander,"},{"kind":"crossref","label":"Jn 10:33","book":"Jhn","chapter":10,"verse":33,"letter":"l"},{"kind":"crossref","label":"Rv 13:6","book":"Rev","chapter":13,"verse":6,"letter":"m"},{"kind":"text","text":" pride,"},{"kind":"crossref","label":"Ps 17:10","book":"Psa","chapter":17,"verse":10,"letter":"n"},{"kind":"text","text":" and foolishness."},{"kind":"crossref","label":"2Co 11:1","book":"2Co","chapter":11,"verse":1,"letter":"o"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 5:11","book":"Num","chapter":5,"verse":11},{"label":"Eph 5:3","book":"Eph","chapter":5,"verse":3},{"label":"Ps 10:7","book":"Psa","chapter":10,"verse":7},{"label":"Rm 13:13","book":"Rom","chapter":13,"verse":13},{"label":"2Co 12:21","book":"2Co","chapter":12,"verse":21},{"label":"Gl 5:19","book":"Gal","chapter":5,"verse":19},{"label":"Eph 4:19","book":"Eph","chapter":4,"verse":19},{"label":"1Pt 4:3","book":"1Pe","chapter":4,"verse":3},{"label":"2Pt 2:2","book":"2Pe","chapter":2,"verse":2},{"label":"2Pt 2:7","book":"2Pe","chapter":2,"verse":7},{"label":"2Pt 2:18","book":"2Pe","chapter":2,"verse":18},{"label":"Jn 10:33","book":"Jhn","chapter":10,"verse":33},{"label":"Rv 13:6","book":"Rev","chapter":13,"verse":6},{"label":"Ps 17:10","book":"Psa","chapter":17,"verse":10},{"label":"2Co 11:1","book":"2Co","chapter":11,"verse":1}],"footnotes":[{"marker":1,"text":"Or evil eye"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:23","parts":[{"kind":"text","text":"All these evil things come from within and defile a person.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:24","parts":[{"kind":"text","text":"He got up and departed from "},{"kind":"crossref","label":"Mt 15:21–28","book":"Mat","chapter":15,"verse":21,"letter":"a"},{"kind":"text","text":" there to the region of Tyre. "},{"kind":"footnote","marker":1,"text":"Many early mss add and Sidon"},{"kind":"crossref","label":"Ac 21:7","book":"Act","chapter":21,"verse":7,"letter":"b"},{"kind":"text","text":" He entered a house and did not want anyone to know it, but he could not escape notice. "}],"crossRefs":[{"label":"Mt 15:21–28","book":"Mat","chapter":15,"verse":21},{"label":"Ac 21:7","book":"Act","chapter":21,"verse":7}],"footnotes":[{"marker":1,"text":"Many early mss add and Sidon"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:25","parts":[{"kind":"text","text":"Instead, immediately after hearing about him, a woman whose little daughter had an unclean spirit "},{"kind":"crossref","label":"Lk 11:24","book":"Luk","chapter":11,"verse":24,"letter":"a"},{"kind":"text","text":" came and fell at his feet. "},{"kind":"crossref","label":"Lk 8:47","book":"Luk","chapter":8,"verse":47,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 11:24","book":"Luk","chapter":11,"verse":24},{"label":"Lk 8:47","book":"Luk","chapter":8,"verse":47}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:26","parts":[{"kind":"text","text":"The woman was a Gentile, "},{"kind":"footnote","marker":2,"text":"Or a Greek (speaker)"},{"kind":"crossref","label":"Ac 17:12","book":"Act","chapter":17,"verse":12,"letter":"a"},{"kind":"text","text":" a Syrophoenician by birth, and she was asking him to cast the demon "},{"kind":"crossref","label":"Mk 3:15","book":"Mrk","chapter":3,"verse":15,"letter":"b"},{"kind":"crossref","label":"Rv 9:20","book":"Rev","chapter":9,"verse":20,"letter":"c"},{"kind":"crossref","label":"Rv 18:2","book":"Rev","chapter":18,"verse":2,"letter":"d"},{"kind":"text","text":" out of her daughter. "}],"crossRefs":[{"label":"Ac 17:12","book":"Act","chapter":17,"verse":12},{"label":"Mk 3:15","book":"Mrk","chapter":3,"verse":15},{"label":"Rv 9:20","book":"Rev","chapter":9,"verse":20},{"label":"Rv 18:2","book":"Rev","chapter":18,"verse":2}],"footnotes":[{"marker":2,"text":"Or a Greek (speaker)"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:27","parts":[{"kind":"text","text":"He said to her, “Let the children be fed first, because it isn’t right to take the children’s bread and throw it to the dogs.”"},{"kind":"crossref","label":"Ex 22:31","book":"Exo","chapter":22,"verse":31,"letter":"a"}],"crossRefs":[{"label":"Ex 22:31","book":"Exo","chapter":22,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:28","parts":[{"kind":"text","text":"But she replied to him, “Lord, "},{"kind":"crossref","label":"Lk 10:1","book":"Luk","chapter":10,"verse":1,"letter":"a"},{"kind":"text","text":" even the dogs under the table eat the children’s crumbs.”"}],"crossRefs":[{"label":"Lk 10:1","book":"Luk","chapter":10,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:29","parts":[{"kind":"text","text":"Then he told her, “Because of this reply, you may go. The demon has left your daughter.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:30","parts":[{"kind":"text","text":"When she went back to her home, she found her child lying on the bed, and the demon was gone."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:31","parts":[{"kind":"text","text":"Again, leaving the region of Tyre, "},{"kind":"crossref","label":"Ac 21:7","book":"Act","chapter":21,"verse":7,"letter":"a"},{"kind":"text","text":" he went by way of Sidon to the Sea of Galilee, "},{"kind":"crossref","label":"Mt 4:18","book":"Mat","chapter":4,"verse":18,"letter":"b"},{"kind":"crossref","label":"Mt 15:29","book":"Mat","chapter":15,"verse":29,"letter":"c"},{"kind":"crossref","label":"Mk 1:16","book":"Mrk","chapter":1,"verse":16,"letter":"d"},{"kind":"crossref","label":"Jn 6:1","book":"Jhn","chapter":6,"verse":1,"letter":"e"},{"kind":"text","text":" through "},{"kind":"footnote","marker":1,"text":"Or into"},{"kind":"text","text":" the region of the Decapolis. "},{"kind":"crossref","label":"Mt 4:25","book":"Mat","chapter":4,"verse":25,"letter":"f"},{"kind":"crossref","label":"Mk 5:20","book":"Mrk","chapter":5,"verse":20,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 21:7","book":"Act","chapter":21,"verse":7},{"label":"Mt 4:18","book":"Mat","chapter":4,"verse":18},{"label":"Mt 15:29","book":"Mat","chapter":15,"verse":29},{"label":"Mk 1:16","book":"Mrk","chapter":1,"verse":16},{"label":"Jn 6:1","book":"Jhn","chapter":6,"verse":1},{"label":"Mt 4:25","book":"Mat","chapter":4,"verse":25},{"label":"Mk 5:20","book":"Mrk","chapter":5,"verse":20}],"footnotes":[{"marker":1,"text":"Or into"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:32","parts":[{"kind":"text","text":"They brought to him a deaf "},{"kind":"crossref","label":"Lk 7:22","book":"Luk","chapter":7,"verse":22,"letter":"a"},{"kind":"text","text":" man who had difficulty speaking "},{"kind":"crossref","label":"Ex 4:11","book":"Exo","chapter":4,"verse":11,"letter":"b"},{"kind":"crossref","label":"Is 35:6","book":"Isa","chapter":35,"verse":6,"letter":"c"},{"kind":"crossref","label":"Is 56:10","book":"Isa","chapter":56,"verse":10,"letter":"d"},{"kind":"text","text":" and begged Jesus to lay his hand on "},{"kind":"crossref","label":"1Tm 5:22","book":"1Ti","chapter":5,"verse":22,"letter":"e"},{"kind":"text","text":" him. "}],"crossRefs":[{"label":"Lk 7:22","book":"Luk","chapter":7,"verse":22},{"label":"Ex 4:11","book":"Exo","chapter":4,"verse":11},{"label":"Is 35:6","book":"Isa","chapter":35,"verse":6},{"label":"Is 56:10","book":"Isa","chapter":56,"verse":10},{"label":"1Tm 5:22","book":"1Ti","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:33","parts":[{"kind":"text","text":"So he took him away from the crowd in private. After putting his fingers in the man’s ears and spitting, "},{"kind":"crossref","label":"Jn 9:6","book":"Jhn","chapter":9,"verse":6,"letter":"a"},{"kind":"text","text":" he touched his tongue. "}],"crossRefs":[{"label":"Jn 9:6","book":"Jhn","chapter":9,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:34","parts":[{"kind":"text","text":"Looking up to heaven, "},{"kind":"crossref","label":"Mt 24:35","book":"Mat","chapter":24,"verse":35,"letter":"a"},{"kind":"crossref","label":"Lk 12:33","book":"Luk","chapter":12,"verse":33,"letter":"b"},{"kind":"crossref","label":"Ac 17:24","book":"Act","chapter":17,"verse":24,"letter":"c"},{"kind":"crossref","label":"Eph 6:9","book":"Eph","chapter":6,"verse":9,"letter":"d"},{"kind":"crossref","label":"Rv 21:10","book":"Rev","chapter":21,"verse":10,"letter":"e"},{"kind":"text","text":" he sighed deeply and said to him, “Ephphatha!” "},{"kind":"footnote","marker":2,"text":"An Aramaic expression"},{"kind":"text","text":" (that is, “Be opened!”). "}],"crossRefs":[{"label":"Mt 24:35","book":"Mat","chapter":24,"verse":35},{"label":"Lk 12:33","book":"Luk","chapter":12,"verse":33},{"label":"Ac 17:24","book":"Act","chapter":17,"verse":24},{"label":"Eph 6:9","book":"Eph","chapter":6,"verse":9},{"label":"Rv 21:10","book":"Rev","chapter":21,"verse":10}],"footnotes":[{"marker":2,"text":"An Aramaic expression"}]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:35","parts":[{"kind":"text","text":"Immediately his ears were opened, "},{"kind":"crossref","label":"Phm 10","book":"Phm","chapter":1,"verse":10,"letter":"a"},{"kind":"text","text":" his tongue was loosened, and he began to speak clearly. "},{"kind":"crossref","label":"Lk 20:21","book":"Luk","chapter":20,"verse":21,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Phm 10","book":"Phm","chapter":1,"verse":10},{"label":"Lk 20:21","book":"Luk","chapter":20,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:36","parts":[{"kind":"text","text":"He ordered them to tell no one, "},{"kind":"crossref","label":"Mk 1:44","book":"Mrk","chapter":1,"verse":44,"letter":"a"},{"kind":"crossref","label":"Lk 8:56","book":"Luk","chapter":8,"verse":56,"letter":"b"},{"kind":"text","text":" but the more he ordered them, the more they proclaimed it. "},{"kind":"crossref","label":"Mk 1:4","book":"Mrk","chapter":1,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Mk 1:44","book":"Mrk","chapter":1,"verse":44},{"label":"Lk 8:56","book":"Luk","chapter":8,"verse":56},{"label":"Mk 1:4","book":"Mrk","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:7:37","parts":[{"kind":"text","text":"They were extremely astonished and said, “He has done everything well. "},{"kind":"crossref","label":"Gn 1:31","book":"Gen","chapter":1,"verse":31,"letter":"a"},{"kind":"text","text":" He even makes the deaf "},{"kind":"crossref","label":"Lk 7:22","book":"Luk","chapter":7,"verse":22,"letter":"b"},{"kind":"text","text":" hear and the mute speak.” "},{"kind":"crossref","label":"Mk 9:17","book":"Mrk","chapter":9,"verse":17,"letter":"c"}],"crossRefs":[{"label":"Gn 1:31","book":"Gen","chapter":1,"verse":31},{"label":"Lk 7:22","book":"Luk","chapter":7,"verse":22},{"label":"Mk 9:17","book":"Mrk","chapter":9,"verse":17}],"footnotes":[]}]},"cachedAt":1783099505245}