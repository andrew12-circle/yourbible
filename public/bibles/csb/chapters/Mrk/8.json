fs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:8:21","parts":[{"kind":"text","text":"And he said to them, “Don’t you understand yet?”"},{"kind":"crossref","label":"Mk 4:40","book":"Mrk","chapter":4,"verse":40,"letter":"a"}],"crossRefs":[{"label":"Mk 4:40","book":"Mrk","chapter":4,"verse":40}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:8:22","parts":[{"kind":"text","text":"They came to Bethsaida. "},{"kind":"crossref","label":"Jn 12:21","book":"Jhn","chapter":12,"verse":21,"letter":"a"},{"kind":"text","text":" They brought a blind "},{"kind":"crossref","label":"Mt 15:14","book":"Mat","chapter":15,"verse":14,"letter":"b"},{"kind":"text","text":" man to him and begged him to touch him. "}],"crossRefs":[{"label":"Jn 12:21","book":"Jhn","chapter":12,"verse":21},{"label":"Mt 15:14","book":"Mat","chapter":15,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:8:23","parts":[{"kind":"text","text":"He took the blind man by the hand and brought him out of the village. Spitting "},{"kind":"crossref","label":"Mk 7:33","book":"Mrk","chapter":7,"verse":33,"letter":"a"},{"kind":"crossref","label":"Mk 8:23","book":"Mrk","chapter":8,"verse":23,"letter":"b"},{"kind":"crossref","label":"Jn 9:6","book":"Jhn","chapter":9,"verse":6,"letter":"c"},{"kind":"text","text":" on his eyes and laying his hands on "},{"kind":"crossref","label":"1Tm 5:22","book":"1Ti","chapter":5,"verse":22,"letter":"d"},{"kind":"text","text":" him, he asked him, “Do you see anything?”"}],"crossRefs":[{"label":"Mk 7:33","book":"Mrk","chapter":7,"verse":33},{"label":"Mk 8:23","book":"Mrk","chapter":8,"verse":23},{"label":"Jn 9:6","book":"Jhn","chapter":9,"verse":6},{"label":"1Tm 5:22","book":"1Ti","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mrk:8:24","parts":[{"kind":"text","text":"He looked up and said, “I see people —they look like trees walking.” "},{"kind":"crossref","label":"Mt 11:5","book":"Mat","chapter":11,"verse":5,"letter":"a"}],"crossRefs":[{"