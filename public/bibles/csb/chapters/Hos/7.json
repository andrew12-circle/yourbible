}],"crossRefs":[{"label":"Ezk 12:13","book":"Ezk","chapter":12,"verse":13}],"footnotes":[{"marker":1,"text":"Lit news to"}]},{"verseId":"a556c5305ee15c3f-01:Hos:7:13","parts":[{"kind":"text","text":"Woe to them, "},{"kind":"crossref","label":"Hs 9:12","book":"Hos","chapter":9,"verse":12,"letter":"a"},{"kind":"text","text":" for they fled from me; "},{"kind":"crossref","label":"Jr 14:10","book":"Jer","chapter":14,"verse":10,"letter":"b"},{"kind":"crossref","label":"Hs 9:17","book":"Hos","chapter":9,"verse":17,"letter":"c"},{"kind":"text","text":" destruction to them, for they rebelled against me!"},{"kind":"text","text":" Though I want to redeem them, "},{"kind":"crossref","label":"Jr 51:9","book":"Jer","chapter":51,"verse":9,"letter":"a"},{"kind":"crossref","label":"Hs 7:1","book":"Hos","chapter":7,"verse":1,"letter":"b"},{"kind":"crossref","label":"Mt 23:37","book":"Mat","chapter":23,"verse":37,"letter":"c"},{"kind":"text","text":" they speak lies against me."}],"crossRefs":[{"label":"Hs 9:12","book":"Hos","chapter":9,"verse":12},{"label":"Jr 14:10","book":"Jer","chapter":14,"verse":10},{"label":"Hs 9:17","book":"Hos","chapter":9,"verse":17},{"label":"Jr 51:9","book":"Jer","chapter":51,"verse":9},{"label":"Hs 7:1","book":"Hos","chapter":7,"verse":1},{"label":"Mt 23:37","book":"Mat","chapter":23,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:7:14","parts":[{"kind":"text","text":"They do not cry to me from their hearts;"},{"kind":"text","text":" rather, they wail on their beds."},{"kind":"text","text":" They slash themselves "},{"kind":"footnote","marker":1,"text":"Some Hb mss, LXX; other Hb mss read They stay"},{"kind":"crossref","label":"1Kg 18:28","book":"1Ki","chapter":18,"verse":28,"letter":"a"},{"kind":"text","text":" for grain and new wine; "},{"kind":"crossref","label":"Am 2:8","book":"Amo","chapter":2,"verse":8,"letter":"b"},{"kind":"text","text":" they turn away from me."}],"crossRefs":[{"label":"1Kg 18:28","book":"1Ki","chapter":18,"verse":28},{"label":"Am 2:8","book":"Amo","chapter":2,"verse":8}],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX; other Hb mss read They stay"}]},{"verseId":"a556c5305ee15c3f-01:Hos:7:15","parts":[{"kind":"text","text":"I trained and strengthened their arms, "},{"kind":"crossref","label":"Hs 11:3","book":"Hos","chapter":11,"verse":3,"letter":"a"},{"kind":"text","text":" but they plot evil against me. "},{"kind":"crossref","label":"Nah 1:9","book":"Nam","chapter":1,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Hs 11:3","book":"Hos","chapter":11,"verse":3},{"label":"Nah 1:9","book":"Nam","chapter":1,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:7:16","parts":[{"kind":"text","text":"They turn, but not to what is above; "},{"kind":"footnote","marker":1,"text":"Some emend to turn to what is useless"},{"kind":"text","text":" they are like a faulty bow. "},{"kind":"crossref","label":"Ps 78:57","book":"Psa","chapter":78,"verse":57,"letter":"a"},{"kind":"text","text":" Their leaders will fall by the sword"},{"kind":"text","text":" because of their insolent tongue. "},{"kind":"crossref","label":"Ps 12:3–4","book":"Psa","chapter":12,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 17:10","book":"Psa","chapter":17,"verse":10,"letter":"b"},{"kind":"crossref","label":"Dn 7:25","book":"Dan","chapter":7,"verse":25,"letter":"c"},{"kind":"crossref","label":"Mal 3:13–14","book":"Mal","chapter":3,"verse":13,"letter":"d"},{"kind":"text","text":" They will be ridiculed for this in the land of Egypt. "},{"kind":"crossref","label":"Ezk 23:32","book":"Ezk","chapter":23,"verse":32,"letter":"a"}],"crossRefs":[{"label":"Ps 78:57","book":"Psa","chapter":78,"verse":57},{"label":"Ps 12:3–4","book":"Psa","chapter":12,"verse":3},{"label":"Ps 17:10","book":"Psa","chapter":17,"verse":10},{"label":"Dn 7:25","book":"Dan","chapter":7,"verse":25},{"label":"Mal 3:13–14","book":"Mal","chapter":3,"verse":13},{"label":"Ezk 23:32","book":"Ezk","chapter":23,"verse":32}],"footnotes":[{"m