d":"text","text":" my wool and flax, my oil and drink.” "},{"kind":"crossref","label":"Jr 44:17–18","book":"Jer","chapter":44,"verse":17,"letter":"a"}],"crossRefs":[{"label":"Is 1:21","book":"Isa","chapter":1,"verse":21},{"label":"Hs 3:1","book":"Hos","chapter":3,"verse":1},{"label":"Jr 2:25","book":"Jer","chapter":2,"verse":25},{"label":"Jr 44:17–18","book":"Jer","chapter":44,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:6","parts":[{"kind":"text","text":"Therefore, this is what I will do:"},{"kind":"text","text":" I will block her "},{"kind":"footnote","marker":1,"text":"LXX, Syr; MT reads your"},{"kind":"text","text":" way "},{"kind":"crossref","label":"Jb 19:8","book":"Job","chapter":19,"verse":8,"letter":"a"},{"kind":"text","text":" with thorns; "},{"kind":"crossref","label":"Hs 9:6","book":"Hos","chapter":9,"verse":6,"letter":"b"},{"kind":"crossref","label":"Hs 10:8","book":"Hos","chapter":10,"verse":8,"letter":"c"},{"kind":"text","text":" I will enclose her with a wall,"},{"kind":"text","text":" so that she cannot find her paths. "},{"kind":"crossref","label":"Jr 18:15","book":"Jer","chapter":18,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Jb 19:8","book":"Job","chapter":19,"verse":8},{"label":"Hs 9:6","book":"Hos","chapter":9,"verse":6},{"label":"Hs 10:8","book":"Hos","chapter":10,"verse":8},{"label":"Jr 18:15","book":"Jer","chapter":18,"verse":15}],"footnotes":[{"marker":1,"text":"LXX, Syr; MT reads your"}]},{"verseId":"a556c5305ee15c3f-01:Hos:2:7","parts":[{"kind":"text","text":"She will pursue her lovers but not catch them; "},{"kind":"crossref","label":"Hs 5:13","book":"Hos","chapter":5,"verse":13,"letter":"a"},{"kind":"text","text":" she will look for them but not find them."},{"kind":"text","text":" Then she will think,"},{"kind":"text","text":" “I will go back to my former husband, "},{"kind":"crossref","label":"Jr 2:2","book":"Jer","chapter":2,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 3:1","book":"Jer","chapter":3,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ezk 16:8","book":"Ezk","chapter":16,"verse":8,"letter":"c"},{"kind":"crossref","label":"Ezk 23:4","book":"Ezk","chapter":23,"verse":4,"letter":"d"},{"kind":"text","text":" for then it was better for me than now.” "},{"kind":"crossref","label":"Jr 14:22","book":"Jer","chapter":14,"verse":22,"letter":"a"},{"kind":"crossref","label":"Hs 13:6","book":"Hos","chapter":13,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Hs 5:13","book":"Hos","chapter":5,"verse":13},{"label":"Jr 2:2","book":"Jer","chapter":2,"verse":2},{"label":"Jr 3:1","book":"Jer","chapter":3,"verse":1},{"label":"Ezk 16:8","book":"Ezk","chapter":16,"verse":8},{"label":"Ezk 23:4","book":"Ezk","chapter":23,"verse":4},{"label":"Jr 14:22","book":"Jer","chapter":14,"verse":22},{"label":"Hs 13:6","book":"Hos","chapter":13,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:8","parts":[{"kind":"text","text":"She does not recognize "},{"kind":"crossref","label":"Is 1:3","book":"Isa","chapter":1,"verse":3,"letter":"a"},{"kind":"text","text":" that it is I who gave her the grain, "},{"kind":"crossref","label":"Ezk 16:19","book":"Ezk","chapter":16,"verse":19,"letter":"a"},{"kind":"text","text":" the new wine, and the fresh oil."},{"kind":"text","text":" I lavished silver and gold on her,"},{"kind":"text","text":" which they used for Baal."}],"crossRefs":[{"label":"Is 1:3","book":"Isa","chapter":1,"verse":3},{"label":"Ezk 16:19","book":"Ezk","chapter":16,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:9","parts":[{"kind":"text","text":"Therefore, I will take back my grain in its time "},{"kind":"crossref","label":"Hs 8:7","book":"Hos","chapter":8,"verse":7,"letter":"a"},{"kind":"crossref","label":"Hs 9:2","book":"Hos","chapter":9,"verse":2,"letter":"b"},{"kind":"text","text":" and my new wine in its season;"},{"kind":"text","text":" I will take away my wool and linen,"},{"kind":"text","text":" which were to cover her nakedness."}],"crossRefs":[{"label":"Hs 8:7","book":"Hos","chapter":8,"verse":7},{"label":"Hs 9:2","book":"Hos","chapter":9,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:10","parts":[{"kind":"text","text":"Now I will expose her shame "},{"kind":"crossref","label":"Ezk 16:37","book":"Ezk","chapter":16,"verse":37,"letter":"a"},{"kind":"text","text":" in the sight of her lovers,"},{"kind":"text","text":" and no one will rescue her from my power."}],"crossRefs":[{"label":"Ezk 16:37","book":"Ezk","chapter":16,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:11","parts":[{"kind":"text","text":"I will put an end to all her celebrations: "},{"kind":"crossref","label":"Jr 7:34","book":"Jer","chapter":7,"verse":34,"letter":"a"},{"kind":"crossref","label":"Jr 16:9","book":"Jer","chapter":16,"verse":9,"letter":"b"},{"kind":"text","text":" her feasts, "},{"kind":"crossref","label":"Hs 3:4","book":"Hos","chapter":3,"verse":4,"letter":"a"},{"kind":"crossref","label":"Am 5:21","book":"Amo","chapter":5,"verse":21,"letter":"b"},{"kind":"crossref","label":"Am 8:10","book":"Amo","chapter":8,"verse":10,"letter":"c"},{"kind":"text","text":" New Moons, "},{"kind":"crossref","label":"Is 1:13–14","book":"Isa","chapter":1,"verse":13,"letter":"d"},{"kind":"text","text":" and Sabbaths —"},{"kind":"text","text":" all her festivals."}],"crossRefs":[{"label":"Jr 7:34","book":"Jer","chapter":7,"verse":34},{"label":"Jr 16:9","book":"Jer","chapter":16,"verse":9},{"label":"Hs 3:4","book":"Hos","chapter":3,"verse":4},{"label":"Am 5:21","book":"Amo","chapter":5,"verse":21},{"label":"Am 8:10","book":"Amo","chapter":8,"verse":10},{"label":"Is 1:13–14","book":"Isa","chapter":1,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:12","parts":[{"kind":"text","text":"I will devastate her vines and fig trees. "},{"kind":"crossref","label":"Jr 5:17","book":"Jer","chapter":5,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jr 8:13","book":"Jer","chapter":8,"verse":13,"letter":"b"},{"kind":"text","text":" She thinks that these are her wages"},{"kind":"text","text":" that her lovers have given her."},{"kind":"text","text":" I will turn them into a thicket, "},{"kind":"crossref","label":"Ps 80:12","book":"Psa","chapter":80,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 5:5","book":"Isa","chapter":5,"verse":5,"letter":"b"},{"kind":"crossref","label":"Is 7:23","book":"Isa","chapter":7,"verse":23,"letter":"c"},{"kind":"text","text":" and the wild animals will eat them. "},{"kind":"crossref","label":"Is 32:13–15","book":"Isa","chapter":32,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Jr 5:17","book":"Jer","chapter":5,"verse":17},{"label":"Jr 8:13","book":"Jer","chapter":8,"verse":13},{"label":"Ps 80:12","book":"Psa","chapter":80,"verse":12},{"label":"Is 5:5","book":"Isa","chapter":5,"verse":5},{"label":"Is 7:23","book":"Isa","chapter":7,"verse":23},{"label":"Is 32:13–15","book":"Isa","chapter":32,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:13","parts":[{"kind":"text","text":"And I will punish her for the days of the Baals, "},{"kind":"crossref","label":"Hs 4:13","book":"Hos","chapter":4,"verse":13,"letter":"a"},{"kind":"crossref","label":"Hs 11:2","book":"Hos","chapter":11,"verse":2,"letter":"b"},{"kind":"text","text":" to which she burned incense. "},{"kind":"crossref","label":"Jr 7:9","book":"Jer","chapter":7,"verse":9,"letter":"a"},{"kind":"text","text":" She put on her rings and her jewelry "},{"kind":"crossref","label":"Ezk 16:12","book":"Ezk","chapter":16,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ezk 16:17","book":"Ezk","chapter":16,"verse":17,"letter":"b"},{"kind":"crossref","label":"Ezk 23:40","book":"Ezk","chapter":23,"verse":40,"letter":"c"},{"kind":"text","text":" and followed her lovers,"},{"kind":"text","text":" but she forgot me. "},{"kind":"crossref","label":"Hs 4:6","book":"Hos","chapter":4,"verse":6,"letter":"a"},{"kind":"crossref","label":"Hs 8:14","book":"Hos","chapter":8,"verse":14,"letter":"b"},{"kind":"crossref","label":"Hs 13:6","book":"Hos","chapter":13,"verse":6,"letter":"c"}],"crossRefs":[{"label":"Hs 4:13","book":"Hos","chapter":4,"verse":13},{"label":"Hs 11:2","book":"Hos","chapter":11,"verse":2},{"label":"Jr 7:9","book":"Jer","chapter":7,"verse":9},{"label":"Ezk 16:12","book":"Ezk","chapter":16,"verse":12},{"label":"Ezk 16:17","book":"Ezk","chapter":16,"verse":17},{"label":"Ezk 23:40","book":"Ezk","chapter":23,"verse":40},{"label":"Hs 4:6","book":"Hos","chapter":4,"verse":6},{"label":"Hs 8:14","book":"Hos","chapter":8,"verse":14},{"label":"Hs 13:6","book":"Hos","chapter":13,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:14","parts":[{"kind":"text","text":"Therefore, I am going to persuade her,"},{"kind":"text","text":" lead her to the wilderness, "},{"kind":"crossref","label":"Ezk 20:33–38","book":"Ezk","chapter":20,"verse":33,"letter":"a"},{"kind":"text","text":" and speak tenderly to her. "},{"kind":"footnote","marker":1,"text":"Lit speak to her heart"}],"crossRefs":[{"label":"Ezk 20:33–38","book":"Ezk","chapter":20,"verse":33}],"footnotes":[{"marker":1,"text":"Lit speak to her heart"}]},{"verseId":"a556c5305ee15c3f-01:Hos:2:15","parts":[{"kind":"text","text":"There I will give her vineyards back to her "},{"kind":"crossref","label":"Ezk 28:25–26","book":"Ezk","chapter":28,"verse":25,"letter":"a"},{"kind":"text","text":" and make the Valley of Achor "},{"kind":"footnote","marker":1,"text":"= Trouble"},{"kind":"crossref","label":"Jos 7:26","book":"Jos","chapter":7,"verse":26,"letter":"a"},{"kind":"text","text":" into a gateway of hope."},{"kind":"text","text":" There she will respond as she did"},{"kind":"text","text":" in the days of her youth, "},{"kind":"crossref","label":"Jr 2:1–3","book":"Jer","chapter":2,"verse":1,"letter":"a"},{"kind":"text","text":" as in the day she came out of the land of Egypt."}],"crossRefs":[{"label":"Ezk 28:25–26","book":"Ezk","chapter":28,"verse":25},{"label":"Jos 7:26","book":"Jos","chapter":7,"verse":26},{"label":"Jr 2:1–3","book":"Jer","chapter":2,"verse":1}],"footnotes":[{"marker":1,"text":"= Trouble"}]},{"verseId":"a556c5305ee15c3f-01:Hos:2:16","parts":[{"kind":"text","text":"In that day —"},{"kind":"text","text":" you will call me “my husband” "},{"kind":"crossref","label":"Is 54:5","book":"Isa","chapter":54,"verse":5,"letter":"a"},{"kind":"text","text":" and no longer call me “my Baal.” "},{"kind":"footnote","marker":1,"text":"Or my master"}],"crossRefs":[{"label":"Is 54:5","book":"Isa","chapter":54,"verse":5}],"footnotes":[{"marker":1,"text":"Or my master"}]},{"verseId":"a556c5305ee15c3f-01:Hos:2:17","parts":[{"kind":"text","text":"For I will remove the names of the Baals"},{"kind":"text","text":" from her mouth;"},{"kind":"text","text":" they will no longer be remembered by their names."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:18","parts":[{"kind":"text","text":"On that day I will make a covenant for them"},{"kind":"text","text":" with the wild animals, the birds of the sky,"},{"kind":"text","text":" and the creatures that crawl on the ground. "},{"kind":"crossref","label":"Jb 5:23","book":"Job","chapter":5,"verse":23,"letter":"a"},{"kind":"crossref","label":"Is 11:6–9","book":"Isa","chapter":11,"verse":6,"letter":"b"},{"kind":"crossref","label":"Ezk 34:25","book":"Ezk","chapter":34,"verse":25,"letter":"c"},{"kind":"text","text":" I will shatter bow, sword,"},{"kind":"text","text":" and weapons of war in the land "},{"kind":"footnote","marker":1,"text":"Or war on the earth"},{"kind":"crossref","label":"Ezk 39:1–10","book":"Ezk","chapter":39,"verse":1,"letter":"a"},{"kind":"text","text":" and will enable the people to rest securely. "},{"kind":"crossref","label":"Ezk 34:25","book":"Ezk","chapter":34,"verse":25,"letter":"a"}],"crossRefs":[{"label":"Jb 5:23","book":"Job","chapter":5,"verse":23},{"label":"Is 11:6–9","book":"Isa","chapter":11,"verse":6},{"label":"Ezk 34:25","book":"Ezk","chapter":34,"verse":25},{"label":"Ezk 39:1–10","book":"Ezk","chapter":39,"verse":1},{"label":"Ezk 34:25","book":"Ezk","chapter":34,"verse":25}],"footnotes":[{"marker":1,"text":"Or war on the earth"}]},{"verseId":"a556c5305ee15c3f-01:Hos:2:19","parts":[{"kind":"text","text":"I will take you to be my wife forever. "},{"kind":"crossref","label":"Is 62:4–5","book":"Isa","chapter":62,"verse":4,"letter":"a"},{"kind":"text","text":" I will take you to be my wife in righteousness,"},{"kind":"text","text":" justice, love, and compassion. "},{"kind":"crossref","label":"Is 1:27","book":"Isa","chapter":1,"verse":27,"letter":"a"},{"kind":"crossref","label":"Is 54:6–8","book":"Isa","chapter":54,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Is 62:4–5","book":"Isa","chapter":62,"verse":4},{"label":"Is 1:27","book":"Isa","chapter":1,"verse":27},{"label":"Is 54:6–8","book":"Isa","chapter":54,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:20","parts":[{"kind":"text","text":"I will take you to be my wife in faithfulness,"},{"kind":"text","text":" and you will know the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Hs 6:6","book":"Hos","chapter":6,"verse":6,"letter":"a"},{"kind":"crossref","label":"Hs 13:4","book":"Hos","chapter":13,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Hs 6:6","book":"Hos","chapter":6,"verse":6},{"label":"Hs 13:4","book":"Hos","chapter":13,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:21","parts":[{"kind":"text","text":"On that day I will respond "},{"kind":"crossref","label":"Is 55:10","book":"Isa","chapter":55,"verse":10,"letter":"a"},{"kind":"crossref","label":"Zch 8:12","book":"Zec","chapter":8,"verse":12,"letter":"b"},{"kind":"crossref","label":"Mal 3:10–11","book":"Mal","chapter":3,"verse":10,"letter":"c"},{"kind":"text","text":" —"},{"kind":"text","text":" I will respond to the sky,"},{"kind":"text","text":" and it will respond to the earth."}],"crossRefs":[{"label":"Is 55:10","book":"Isa","chapter":55,"verse":10},{"label":"Zch 8:12","book":"Zec","chapter":8,"verse":12},{"label":"Mal 3:10–11","book":"Mal","chapter":3,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:22","parts":[{"kind":"text","text":"The earth will respond to the grain, "},{"kind":"crossref","label":"Jr 31:12","book":"Jer","chapter":31,"verse":12,"letter":"a"},{"kind":"crossref","label":"Jl 2:19","book":"Jol","chapter":2,"verse":19,"letter":"b"},{"kind":"text","text":" the new wine, and the fresh oil,"},{"kind":"text","text":" and they will respond to Jezreel."}],"crossRefs":[{"label":"Jr 31:12","book":"Jer","chapter":31,"verse":12},{"label":"Jl 2:19","book":"Jol","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:2:23","parts":[{"kind":"text","text":"I will sow her "},{"kind":"footnote","marker":1,"text":"= Israel"},{"kind":"text","text":" in the land for myself, "},{"kind":"crossref","label":"Jr 31:37","book":"Jer","chapter":31,"verse":37,"letter":"a"},{"kind":"text","text":" and I will have compassion "},{"kind":"crossref","label":"Hs 1:6","book":"Hos","chapter":1,"verse":6,"letter":"a"},{"kind":"text","text":" on Lo-ruhamah;"},{"kind":"text","text":" I will say to Lo-ammi: "},{"kind":"crossref","label":"Hs 1:9","book":"Hos","chapter":1,"verse":9,"letter":"a"},{"kind":"text","text":" You are my people, "},{"kind":"crossref","label":"Hs 2:1","book":"Hos","chapter":2,"verse":1,"letter":"a"},{"kind":"crossref","label":"Rm 9:25","book":"Rom","chapter":9,"verse":25,"letter":"b"},{"kind":"text","text":" and he will say, “You are my God.”"}],"crossRefs":[{"label":"Jr 31:37","book":"Jer","chapter":31,"verse":37},{"label":"Hs 1:6","book":"Hos","chapter":1,"verse":6},{"label":"Hs 1:9","book":"Hos","chapter":1,"verse":9},{"label":"Hs 2:1","book":"Hos","chapter":2,"verse":1},{"label":"Rm 9:25","book":"Rom","chapter":9,"verse":25}],"footnotes":[{"marker":1,"text":"= Israel"}]}]},"cachedAt":1783279594827}