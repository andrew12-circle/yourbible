shed for!” "},{"kind":"footnote","marker":1,"text":"Lit iniquity which is sin"}],"crossRefs":[{"label":"Ps 62:10","book":"Psa","chapter":62,"verse":10},{"label":"Hs 13:6","book":"Hos","chapter":13,"verse":6},{"label":"Hs 4:8","book":"Hos","chapter":4,"verse":8},{"label":"Hs 14:1","book":"Hos","chapter":14,"verse":1},{"label":"Am 3:15","book":"Amo","chapter":3,"verse":15},{"label":"Am 6:4–6","book":"Amo","chapter":6,"verse":4}],"footnotes":[{"marker":1,"text":"Lit iniquity which is sin"}]},{"verseId":"a556c5305ee15c3f-01:Hos:12:9","parts":[{"kind":"text","text":"I have been the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God"},{"kind":"text","text":" ever since "},{"kind":"footnote","marker":1,"text":"LXX reads God who brought you out of"},{"kind":"text","text":" the land of Egypt. "},{"kind":"crossref","label":"Hs 11:1","book":"Hos","chapter":11,"verse":1,"letter":"a"},{"kind":"crossref","label":"Hs 13:3","book":"Hos","chapter":13,"verse":3,"letter":"b"},{"kind":"text","text":" I will make you live in tents again, "},{"kind":"crossref","label":"Lv 23:42","book":"Lev","chapter":23,"verse":42,"letter":"a"},{"kind":"text","text":" as in the festival days."}],"crossRefs":[{"label":"Hs 11:1","book":"Hos","chapter":11,"verse":1},{"label":"Hs 13:3","book":"Hos","chapter":13,"verse":3},{"label":"Lv 23:42","book":"Lev","chapter":23,"verse":42}],"footnotes":[{"marker":1,"text":"LXX reads God who brought you out of"}]},{"verseId":"a556c5305ee15c3f-01:Hos:12:10","parts":[{"kind":"text","text":"I will speak through the prophets "},{"kind":"crossref","label":"Jr 7:25","book":"Jer","chapter":7,"verse":25,"letter":"a"},{"kind":"text","text":" and grant many visions;"},{"kind":"text","text":" I will give parables through the prophets. "},{"kind":"crossref","label":"Ezk 17:2","book":"Ezk","chapter":17,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ezk 20:49","book":"Ezk","chapter":20,"verse":49,"letter":"b"}],"crossRefs":[{"label":"Jr 7:25","bo