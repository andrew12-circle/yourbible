"chapter":6,"verse":14},{"label":"Hs 7:4","book":"Hos","chapter":7,"verse":4},{"label":"Hs 9:17","book":"Hos","chapter":9,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:11","parts":[{"kind":"text","text":"Promiscuity, "},{"kind":"crossref","label":"Hs 5:4","book":"Hos","chapter":5,"verse":4,"letter":"a"},{"kind":"text","text":" wine, and new wine"},{"kind":"text","text":" take away one’s understanding. "},{"kind":"crossref","label":"Is 5:12","book":"Isa","chapter":5,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 28:7","book":"Isa","chapter":28,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Hs 5:4","book":"Hos","chapter":5,"verse":4},{"label":"Is 5:12","book":"Isa","chapter":5,"verse":12},{"label":"Is 28:7","book":"Isa","chapter":28,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:12","parts":[{"kind":"text","text":"My people consult their wooden idols, "},{"kind":"crossref","label":"Is 44:19","book":"Isa","chapter":44,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 2:27","book":"Jer","chapter":2,"verse":27,"letter":"b"},{"kind":"text","text":" and their divining rods inform them."},{"kind":"text","text":" For a spirit of promiscuity leads them astray; "},{"kind":"crossref","label":"Hs 5:4","book":"Hos","chapter":5,"verse":4,"letter":"a"},{"kind":"text","text":" they act promiscuously "},{"kind":"crossref","label":"Hs 9:1","book":"Hos","chapter":9,"verse":1,"letter":"a"},{"kind":"text","text":" in disobedience to "},{"kind":"footnote","marker":1,"text":"Lit promiscuously from under"},{"kind":"text","text":" their God."}],"crossRefs":[{"label":"Is 44:19","book":"Isa","chapter":44,"verse":19},{"label":"Jr 2:27","book":"Jer","chapter":2,"verse":27},{"label":"Hs 5:4","book":"Hos","chapter":5,"verse":4},{"label":"Hs 9:1","book":"Hos","chapter":9,"verse":1}],"footnotes":[{"marker":1,"text":"Lit promiscuously from under"}]},{"verseId":"a556c5305ee15c3f-01:Hos:4:13","parts":[{"kind":"text","text":"They sacrifice on the mountaintops, "},{"kind":"crossref","label":"Jr 3:6","book":"Jer","chapter":3,"verse":6,"letter":"a"},{"kind":"text","text":" and they burn offerings on the hills, "},{"kind":"crossref","label":"Hs 2:13","book":"Hos","chapter":2,"verse":13,"letter":"a"},{"kind":"crossref","label":"Hs 11:2","book":"Hos","chapter":11,"verse":2,"letter":"b"},{"kind":"text","text":" and under oaks, poplars, and terebinths, "},{"kind":"crossref","label":"Jr 2:20","book":"Jer","chapter":2,"verse":20,"letter":"a"},{"kind":"text","text":" because their shade is pleasant."},{"kind":"text","text":" And so your daughters act promiscuously"},{"kind":"text","text":" and your daughters-in-law commit adultery."}],"crossRefs":[{"label":"Jr 3:6","book":"Jer","chapter":3,"verse":6},{"label":"Hs 2:13","book":"Hos","chapter":2,"verse":13},{"label":"Hs 11:2","book":"Hos","chapter":11,"verse":2},{"label":"Jr 2:20","book":"Jer","chapter":2,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:14","parts":[{"kind":"text","text":"I will not punish your daughters"},{"kind":"text","text":" when they act promiscuously"},{"kind":"text","text":" or your daughters-in-law"},{"kind":"text","text":" when they commit adultery,"},{"kind":"text","text":" for the men themselves go off with prostitutes "},{"kind":"crossref","label":"Hs 4:18","book":"Hos","chapter":4,"verse":18,"letter":"a"},{"kind":"crossref","label":"Hs 7:4","book":"Hos","chapter":7,"verse":4,"letter":"b"},{"kind":"text","text":" and make sacrifices with cult prostitutes. "},{"kind":"crossref","label":"Dt 23:17","book":"Deu","chapter":23,"verse":17,"letter":"a"},{"kind":"text","text":" People without discernment are doomed. "},{"kind":"crossref","label":"Hs 5:4","book":"Hos","chapter":5,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Hs 4:18","book":"Hos","chapter":4,"verse":18},{"label":"Hs 7:4","book":"Hos","chapter":7,"verse":4},{"label":"Dt 23:17","book":"Deu","chapter":23,"verse":17},{"label":"Hs 5:4","book":"Hos","chapter":5,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:15","parts":[{"kind":"text","text":"Israel, if you act promiscuously,"},{"kind":"text","text":" don’t let Judah become guilty!"},{"kind":"text","text":" Do not go to Gilgal "},{"kind":"crossref","label":"Hs 9:15","book":"Hos","chapter":9,"verse":15,"letter":"a"},{"kind":"crossref","label":"Hs 12:1","book":"Hos","chapter":12,"verse":1,"letter":"b"},{"kind":"text","text":" or make a pilgrimage to Beth-aven, "},{"kind":"footnote","marker":1,"text":"= House of Wickedness"},{"kind":"crossref","label":"1Kg 12:28","book":"1Ki","chapter":12,"verse":28,"letter":"a"},{"kind":"crossref","label":"Hs 5:8","book":"Hos","chapter":5,"verse":8,"letter":"b"},{"kind":"crossref","label":"Hs 10:5","book":"Hos","chapter":10,"verse":5,"letter":"c"},{"kind":"crossref","label":"Hs 10:8","book":"Hos","chapter":10,"verse":8,"letter":"d"},{"kind":"text","text":" and do not swear an oath: As the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" lives! "},{"kind":"crossref","label":"Jr 5:2","book":"Jer","chapter":5,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 44:26","book":"Jer","chapter":44,"verse":26,"letter":"b"}],"crossRefs":[{"label":"Hs 9:15","book":"Hos","chapter":9,"verse":15},{"label":"Hs 12:1","book":"Hos","chapter":12,"verse":1},{"label":"1Kg 12:28","book":"1Ki","chapter":12,"verse":28},{"label":"Hs 5:8","book":"Hos","chapter":5,"verse":8},{"label":"Hs 10:5","book":"Hos","chapter":10,"verse":5},{"label":"Hs 10:8","book":"Hos","chapter":10,"verse":8},{"label":"Jr 5:2","book":"Jer","chapter":5,"verse":2},{"label":"Jr 44:26","book":"Jer","chapter":44,"verse":26}],"footnotes":[{"marker":1,"text":"= House of Wickedness"}]},{"verseId":"a556c5305ee15c3f-01:Hos:4:16","parts":[{"kind":"text","text":"For Israel is as obstinate as a stubborn cow. "},{"kind":"crossref","label":"Ps 78:8","book":"Psa","chapter":78,"verse":8,"letter":"a"},{"kind":"text","text":" Can the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" now shepherd them"},{"kind":"text","text":" like a lamb in an open meadow? "},{"kind":"crossref","label":"Is 5:17","book":"Isa","chapter":5,"verse":17,"letter":"a"},{"kind":"crossref","label":"Is 7:25","book":"Isa","chapter":7,"verse":25,"letter":"b"}],"crossRefs":[{"label":"Ps 78:8","book":"Psa","chapter":78,"verse":8},{"label":"Is 5:17","book":"Isa","chapter":5,"verse":17},{"label":"Is 7:25","book":"Isa","chapter":7,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:17","parts":[{"kind":"text","text":"Ephraim is attached to idols; "},{"kind":"crossref","label":"Hs 13:2","book":"Hos","chapter":13,"verse":2,"letter":"a"},{"kind":"text","text":" leave him alone! "},{"kind":"crossref","label":"Ps 81:12","book":"Psa","chapter":81,"verse":12,"letter":"a"},{"kind":"crossref","label":"Hs 4:4","book":"Hos","chapter":4,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Hs 13:2","book":"Hos","chapter":13,"verse":2},{"label":"Ps 81:12","book":"Psa","chapter":81,"verse":12},{"label":"Hs 4:4","book":"Hos","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Hos:4:18","parts":[{"kind":"text","text":"When their drinking is over,"},{"kind":"text","text":" they turn to promiscuity."},{"kind":"text","text":" Israel’s leaders "},{"kind":"footnote","marker":1,"text":"Lit Her shields; Ps 47:9; 89:18"},{"kind":"text","text":" fervently love disgrace. "},{"kind":"footnote","marker":2,"text":"Hb obscure"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit Her shields; Ps 47:9; 89:18"},{"marker":2,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Hos:4:19","parts":[{"kind":"text","text":"A wind with its wings will carry them off, "},{"kind":"footnote","marker":1,"text":"Lit wind will bind it in its wings"},{"kind":"crossref","label":"Hs 12:1","book":"Hos","chapter":12,"verse":1,"letter":"a"},{"kind":"crossref","label":"Hs 13:5","book":"Hos","chapter":13,"verse":5,"letter":"b"},{"kind":"text","text":" and they will be a