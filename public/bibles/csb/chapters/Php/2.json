":"Mk 1:27","book":"Mrk","chapter":1,"verse":27},{"label":"Ac 16:14","book":"Act","chapter":16,"verse":14},{"label":"Ac 16:32","book":"Act","chapter":16,"verse":32},{"label":"Rm 6:12","book":"Rom","chapter":6,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:13","parts":[{"kind":"text","text":"For it is God who is working in you both to will and to work according to his good purpose. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:14","parts":[{"kind":"text","text":"Do everything without grumbling "},{"kind":"crossref","label":"Jn 7:12","book":"Jhn","chapter":7,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ac 6:1","book":"Act","chapter":6,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Pt 4:9","book":"1Pe","chapter":4,"verse":9,"letter":"c"},{"kind":"text","text":" and arguing, "},{"kind":"crossref","label":"1Tm 2:8","book":"1Ti","chapter":2,"verse":8,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 7:12","book":"Jhn","chapter":7,"verse":12},{"label":"Ac 6:1","book":"Act","chapter":6,"verse":1},{"label":"1Pt 4:9","book":"1Pe","chapter":4,"verse":9},{"label":"1Tm 2:8","book":"1Ti","chapter":2,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:15","parts":[{"kind":"text","text":"so that you may be blameless "},{"kind":"crossref","label":"Lk 1:6","book":"Luk","chapter":1,"verse":6,"letter":"a"},{"kind":"text","text":" and pure, "},{"kind":"crossref","label":"Mt 10:16","book":"Mat","chapter":10,"verse":16,"letter":"b"},{"kind":"crossref","label":"Rm 16:19","book":"Rom","chapter":16,"verse":19,"letter":"c"},{"kind":"text","text":" children of God who are faultless "},{"kind":"crossref","label":"Jd 1:24","book":"Jud","chapter":1,"verse":24,"letter":"d"},{"kind":"text","text":" in a crooked "},{"kind":"crossref","label":"Lk 3:5","book":"Luk","chapter":3,"verse":5,"letter":"e"},{"kind":"crossref","label":"Ac 2:40","book":"Act","chapter":2,"verse":40,"letter":"f"},{"kind":"crossref","label":"1Pt 2:18","book":"1Pe","chapter":2,"verse":18,"letter":"g"},{"kind":"text","text":" and perverted "},{"kind":"crossref","label":"Mt 17:17","book":"Mat","chapter":17,"verse":17,"letter":"h"},{"kind":"text","text":" generation, "},{"kind":"crossref","label":"Dt 32:5","book":"Deu","chapter":32,"verse":5,"letter":"i"},{"kind":"text","text":" among whom you shine like stars in the world, "}],"crossRefs":[{"label":"Lk 1:6","book":"Luk","chapter":1,"verse":6},{"label":"Mt 10:16","book":"Mat","chapter":10,"verse":16},{"label":"Rm 16:19","book":"Rom","chapter":16,"verse":19},{"label":"Jd 1:24","book":"Jud","chapter":1,"verse":24},{"label":"Lk 3:5","book":"Luk","chapter":3,"verse":5},{"label":"Ac 2:40","book":"Act","chapter":2,"verse":40},{"label":"1Pt 2:18","book":"1Pe","chapter":2,"verse":18},{"label":"Mt 17:17","book":"Mat","chapter":17,"verse":17},{"label":"Dt 32:5","book":"Deu","chapter":32,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:16","parts":[{"kind":"text","text":"by holding firm to the word "},{"kind":"crossref","label":"Lk 8:21","book":"Luk","chapter":8,"verse":21,"letter":"a"},{"kind":"crossref","label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32,"letter":"b"},{"kind":"crossref","label":"Ac 17:11","book":"Act","chapter":17,"verse":11,"letter":"c"},{"kind":"crossref","label":"Heb 4:12","book":"Heb","chapter":4,"verse":12,"letter":"d"},{"kind":"text","text":" of life. Then I can boast "},{"kind":"crossref","label":"Rm 2:17","book":"Rom","chapter":2,"verse":17,"letter":"e"},{"kind":"crossref","label":"Gl 6:4","book":"Gal","chapter":6,"verse":4,"letter":"f"},{"kind":"crossref","label":"Php 1:26","book":"Php","chapter":1,"verse":26,"letter":"g"},{"kind":"text","text":" in the day of Christ "},{"kind":"crossref","label":"Php 1:6","book":"Php","chapter":1,"verse":6,"letter":"h"},{"kind":"crossref","label":"Php 1:15","book":"Php","chapter":1,"verse":15,"letter":"i"},{"kind":"text","text":" that I didn’t run or labor for nothing. "}],"crossRefs":[{"label":"Lk 8:21","book":"Luk","chapter":8,"verse":21},{"label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32},{"label":"Ac 17:11","book":"Act","chapter":17,"verse":11},{"label":"Heb 4:12","book":"Heb","chapter":4,"verse":12},{"label":"Rm 2:17","book":"Rom","chapter":2,"verse":17},{"label":"Gl 6:4","book":"Gal","chapter":6,"verse":4},{"label":"Php 1:26","book":"Php","chapter":1,"verse":26},{"label":"Php 1:6","book":"Php","chapter":1,"verse":6},{"label":"Php 1:15","book":"Php","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:17","parts":[{"kind":"text","text":"But even if I am poured out "},{"kind":"crossref","label":"Php 1:7","book":"Php","chapter":1,"verse":7,"letter":"a"},{"kind":"text","text":" as a drink offering "},{"kind":"crossref","label":"Ex 25:29","book":"Exo","chapter":25,"verse":29,"letter":"b"},{"kind":"crossref","label":"Nm 28:7","book":"Num","chapter":28,"verse":7,"letter":"c"},{"kind":"text","text":" on the sacrificial service of your faith, I am glad and rejoice with all of you. "}],"crossRefs":[{"label":"Php 1:7","book":"Php","chapter":1,"verse":7},{"label":"Ex 25:29","book":"Exo","chapter":25,"verse":29},{"label":"Nm 28:7","book":"Num","chapter":28,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:18","parts":[{"kind":"text","text":"In the same way you should also be glad and rejoice with me."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:19","parts":[{"kind":"text","text":"Now I hope in the Lord Jesus "},{"kind":"crossref","label":"Lk 24:3","book":"Luk","chapter":24,"verse":3,"letter":"a"},{"kind":"text","text":" to send Timothy "},{"kind":"crossref","label":"Ac 16:1","book":"Act","chapter":16,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Tm 1:2","book":"1Ti","chapter":1,"verse":2,"letter":"c"},{"kind":"text","text":" to you soon so that I too may be encouraged by news about you. "}],"crossRefs":[{"label":"Lk 24:3","book":"Luk","chapter":24,"verse":3},{"label":"Ac 16:1","book":"Act","chapter":16,"verse":1},{"label":"1Tm 1:2","book":"1Ti","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:20","parts":[{"kind":"text","text":"For I have no one else like-minded who will genuinely care about your interests; "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:21","parts":[{"kind":"text","text":"all seek their own interests, "},{"kind":"crossref","label":"Rm 15:1","book":"Rom","chapter":15,"verse":1,"letter":"a"},{"kind":"crossref","label":"2Tm 3:2","book":"2Ti","chapter":3,"verse":2,"letter":"b"},{"kind":"text","text":" not those of Jesus Christ. "},{"kind":"crossref","label":"1Co 10:24","book":"1Co","chapter":10,"verse":24,"letter":"c"},{"kind":"crossref","label":"Php 1:15","book":"Php","chapter":1,"verse":15,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 15:1","book":"Rom","chapter":15,"verse":1},{"label":"2Tm 3:2","book":"2Ti","chapter":3,"verse":2},{"label":"1Co 10:24","book":"1Co","chapter":10,"verse":24},{"label":"Php 1:15","book":"Php","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:22","parts":[{"kind":"text","text":"But you know his proven character, because he has served with me in the gospel ministry like a son with a father. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:23","parts":[{"kind":"text","text":"Therefore, I hope to send him as soon as I see how things go with me. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:24","parts":[{"kind":"text","text":"I am confident in the Lord that I myself will also come soon. "},{"kind":"crossref","label":"Php 1:7","book":"Php","chapter":1,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Php 1:7","book":"Php","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:25","parts":[{"kind":"text","text":"But I considered it necessary to send you Epaphroditus "},{"kind":"crossref","label":"Php 4:18","book":"Php","chapter":4,"verse":18,"letter":"a"},{"kind":"text","text":" —my brother, coworker, and fellow soldier, as well as your messenger and minister to my need "},{"kind":"crossref","label":"Mt 6:8","book":"Mat","chapter":6,"verse":8,"letter":"b"},{"kind":"text","text":" — "}],"crossRefs":[{"label":"Php 4:18","book":"Php","chapter":4,"verse":18},{"label":"Mt 6:8","book":"Mat","chapter":6,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:26","parts":[{"kind":"text","text":"since he has been longing for all of you and was distressed because you heard that he was sick. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:27","parts":[{"kind":"text","text":"Indeed, he was so sick that he nearly died. However, God had mercy on him, and not only on him but also on me, so that I would not have sorrow upon sorrow. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:28","parts":[{"kind":"text","text":"For this reason, I am very eager to send him so that you may rejoice again when you see him and I may be less anxious. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:29","parts":[{"kind":"text","text":"Therefore, welcome him in the Lord with great joy and hold people like him in honor, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:2:30","parts":[{"kind":"text","text":"because he came close to death for the work "},{"kind":"crossref","label":"Mk 14:6","book":"Mrk","chapter":14,"verse":6,"letter":"a"},{"kind":"crossref","label":"2Co 9:8","book":"2Co","chapter":9,"verse":8,"letter":"b"},{"kind":"crossref","label":"Gl 3:10","book":"Gal","chapter":3,"verse":10,"letter":"c"},{"kind":"crossref","label":"Jms 2:14","book":"Jas","chapter":2,"verse":14,"letter":"d"},{"kind":"text","text":" of Christ, risking his life to make up what was lacking in your ministry to me."}],"crossRefs":[{"label":"Mk 14:6","book":"Mrk","chapter":14,"verse":6},{"label":"2Co 9:8","book":"2Co","chapter":9,"verse":8},{"label":"Gl 3:10","book":"Gal","chapter":3,"verse":10},{"label":"Jms 2:14","book":"Jas","chapter":2,"verse":14}],"footnotes":[]}]},"cachedAt":1783279668864}