":2,"letter":"b"},{"kind":"crossref","label":"Ac 26:9–11","book":"Act","chapter":26,"verse":9,"letter":"c"},{"kind":"crossref","label":"1Co 15:9","book":"1Co","chapter":15,"verse":9,"letter":"d"},{"kind":"crossref","label":"Gl 1:13","book":"Gal","chapter":1,"verse":13,"letter":"e"},{"kind":"crossref","label":"1Tm 1:13","book":"1Ti","chapter":1,"verse":13,"letter":"f"},{"kind":"crossref","label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12,"letter":"g"},{"kind":"text","text":" the church; regarding the righteousness that is in the law, "},{"kind":"crossref","label":"Rm 3:21","book":"Rom","chapter":3,"verse":21,"letter":"h"},{"kind":"crossref","label":"Rm 9:31","book":"Rom","chapter":9,"verse":31,"letter":"i"},{"kind":"crossref","label":"Rm 10:4–5","book":"Rom","chapter":10,"verse":4,"letter":"j"},{"kind":"crossref","label":"Gl 2:21","book":"Gal","chapter":2,"verse":21,"letter":"k"},{"kind":"crossref","label":"Gl 3:21","book":"Gal","chapter":3,"verse":21,"letter":"l"},{"kind":"text","text":" blameless. "},{"kind":"crossref","label":"Lk 1:6","book":"Luk","chapter":1,"verse":6,"letter":"m"},{"kind":"crossref","label":"Rm 7:9–10","book":"Rom","chapter":7,"verse":9,"letter":"n"}],"crossRefs":[{"label":"Rm 10:2","book":"Rom","chapter":10,"verse":2},{"label":"Ac 22:2–5","book":"Act","chapter":22,"verse":2},{"label":"Ac 26:9–11","book":"Act","chapter":26,"verse":9},{"label":"1Co 15:9","book":"1Co","chapter":15,"verse":9},{"label":"Gl 1:13","book":"Gal","chapter":1,"verse":13},{"label":"1Tm 1:13","book":"1Ti","chapter":1,"verse":13},{"label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12},{"label":"Rm 3:21","book":"Rom","chapter":3,"verse":21},{"label":"Rm 9:31","book":"Rom","chapter":9,"verse":31},{"label":"Rm 10:4–5","book":"Rom","chapter":10,"verse":4},{"label":"Gl 2:21","book":"Gal","chapter":2,"verse":21},{"label":"Gl 3:21","book":"Gal","chapter":3,"verse":21},{"label":"Lk 1:6","book":"Luk","chapter":1,"verse":6},{"label":"Rm 7:9–10","book":"Rom","chapter":7,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:7","parts":[{"kind":"text","text":"But everything that was a gain to me, I have considered to be a loss because of Christ. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:8","parts":[{"kind":"text","text":"More than that, I also consider everything to be a loss in view of the surpassing value "},{"kind":"crossref","label":"Php 2:3","book":"Php","chapter":2,"verse":3,"letter":"a"},{"kind":"text","text":" of knowing Christ "},{"kind":"crossref","label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3,"letter":"b"},{"kind":"crossref","label":"2Co 4:6","book":"2Co","chapter":4,"verse":6,"letter":"c"},{"kind":"crossref","label":"Gl 4:8–9","book":"Gal","chapter":4,"verse":8,"letter":"d"},{"kind":"crossref","label":"Php 1:15","book":"Php","chapter":1,"verse":15,"letter":"e"},{"kind":"crossref","label":"Col 2:2","book":"Col","chapter":2,"verse":2,"letter":"f"},{"kind":"crossref","label":"1Jn 4:8","book":"1Jn","chapter":4,"verse":8,"letter":"g"},{"kind":"text","text":" Jesus my Lord. Because of him I have suffered the loss of all things and consider them as dung, so that I may gain Christ "},{"kind":"crossref","label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Php 2:3","book":"Php","chapter":2,"verse":3},{"label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3},{"label":"2Co 4:6","book":"2Co","chapter":4,"verse":6},{"label":"Gl 4:8–9","book":"Gal","chapter":4,"verse":8},{"label":"Php 1:15","book":"Php","chapter":1,"verse":15},{"label":"Col 2:2","book":"Col","chapter":2,"verse":2},{"label":"1Jn 4:8","book":"1Jn","chapter":4,"verse":8},{"label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:9","parts":[{"kind":"text","text":"and be found in him, not having a righteousness of my own from the law, "},{"kind":"crossref","label":"Rm 10:5","book":"Rom","chapter":10,"verse":5,"letter":"a"},{"kind":"text","text":" but one that is through faith in Christ "},{"kind":"footnote","marker":1,"text":"Or through the faithfulness of Christ"},{"kind":"text","text":" —the righteousness from God based on faith. "},{"kind":"crossref","label":"Rm 3:22","book":"Rom","chapter":3,"verse":22,"letter":"b"},{"kind":"crossref","label":"Rm 10:4","book":"Rom","chapter":10,"verse":4,"letter":"c"},{"kind":"crossref","label":"Gl 2:21","book":"Gal","chapter":2,"verse":21,"letter":"d"},{"kind":"crossref","label":"Heb 11:7","book":"Heb","chapter":11,"verse":7,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 10:5","book":"Rom","chapter":10,"verse":5},{"label":"Rm 3:22","book":"Rom","chapter":3,"verse":22},{"label":"Rm 10:4","book":"Rom","chapter":10,"verse":4},{"label":"Gl 2:21","book":"Gal","chapter":2,"verse":21},{"label":"Heb 11:7","book":"Heb","chapter":11,"verse":7}],"footnotes":[{"marker":1,"text":"Or through the faithfulness of Christ"}]},{"verseId":"a556c5305ee15c3f-01:Php:3:10","parts":[{"kind":"text","text":"My goal is to know him and the power of his resurrection and the fellowship of his sufferings, "},{"kind":"crossref","label":"Rm 8:17","book":"Rom","chapter":8,"verse":17,"letter":"a"},{"kind":"crossref","label":"2Co 1:5–7","book":"2Co","chapter":1,"verse":5,"letter":"b"},{"kind":"crossref","label":"Col 1:24","book":"Col","chapter":1,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13,"letter":"d"},{"kind":"crossref","label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1,"letter":"e"},{"kind":"crossref","label":"1Pt 5:9","book":"1Pe","chapter":5,"verse":9,"letter":"f"},{"kind":"text","text":" being conformed to his death, "},{"kind":"crossref","label":"Rm 6:5","book":"Rom","chapter":6,"verse":5,"letter":"g"},{"kind":"crossref","label":"Rm 8:36","book":"Rom","chapter":8,"verse":36,"letter":"h"},{"kind":"crossref","label":"2Co 4:7–12","book":"2Co","chapter":4,"verse":7,"letter":"i"},{"kind":"crossref","label":"2Co 12:9–10","book":"2Co","chapter":12,"verse":9,"letter":"j"},{"kind":"crossref","label":"Gl 6:17","book":"Gal","chapter":6,"verse":17,"letter":"k"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 8:17","book":"Rom","chapter":8,"verse":17},{"label":"2Co 1:5–7","book":"2Co","chapter":1,"verse":5},{"label":"Col 1:24","book":"Col","chapter":1,"verse":24},{"label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13},{"label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1},{"label":"1Pt 5:9","book":"1Pe","chapter":5,"verse":9},{"label":"Rm 6:5","book":"Rom","chapter":6,"verse":5},{"label":"Rm 8:36","book":"Rom","chapter":8,"verse":36},{"label":"2Co 4:7–12","book":"2Co","chapter":4,"verse":7},{"label":"2Co 12:9–10","book":"2Co","chapter":12,"verse":9},{"label":"Gl 6:17","book":"Gal","chapter":6,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:11","parts":[{"kind":"text","text":"assuming that I will somehow reach the resurrection from among the dead."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:12","parts":[{"kind":"text","text":"Not that I have already reached the goal or am already perfect, but I make every effort to take hold "},{"kind":"crossref","label":"Jn 1:5","book":"Jhn","chapter":1,"verse":5,"letter":"a"},{"kind":"crossref","label":"Jn 12:35","book":"Jhn","chapter":12,"verse":35,"letter":"b"},{"kind":"crossref","label":"Rm 9:30","book":"Rom","chapter":9,"verse":30,"letter":"c"},{"kind":"crossref","label":"1Co 9:24","book":"1Co","chapter":9,"verse":24,"letter":"d"},{"kind":"crossref","label":"Eph 3:18","book":"Eph","chapter":3,"verse":18,"letter":"e"},{"kind":"text","text":" of it because I also have been taken hold of by Christ Jesus. "}],"crossRefs":[{"label":"Jn 1:5","book":"Jhn","chapter":1,"verse":5},{"label":"Jn 12:35","book":"Jhn","chapter":12,"verse":35},{"label":"Rm 9:30","book":"Rom","chapter":9,"verse":30},{"label":"1Co 9:24","book":"1Co","chapter":9,"verse":24},{"label":"Eph 3:18","book":"Eph","chapter":3,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:13","parts":[{"kind":"text","text":"Brothers and sisters, I do not "},{"kind":"footnote","marker":1,"text":"Other mss read not yet"},{"kind":"text","text":" consider myself to have taken hold of it. But one thing I do: Forgetting what is behind "},{"kind":"crossref","label":"Lk 9:62","book":"Luk","chapter":9,"verse":62,"letter":"a"},{"kind":"crossref","label":"Lk 17:31","book":"Luk","chapter":17,"verse":31,"letter":"b"},{"kind":"text","text":" and reaching forward to what is ahead, "}],"crossRefs":[{"label":"Lk 9:62","book":"Luk","chapter":9,"verse":62},{"label":"Lk 17:31","book":"Luk","chapter":17,"verse":31}],"footnotes":[{"marker":1,"text":"Other mss read not yet"}]},{"verseId":"a556c5305ee15c3f-01:Php:3:14","parts":[{"kind":"text","text":"I pursue as my goal the prize promised by God’s heavenly "},{"kind":"footnote","marker":2,"text":"Or upward"},{"kind":"text","text":" call in Christ Jesus. "},{"kind":"crossref","label":"Rm 16:7","book":"Rom","chapter":16,"verse":7,"letter":"a"},{"kind":"crossref","label":"Eph 2:6","book":"Eph","chapter":2,"verse":6,"letter":"b"},{"kind":"crossref","label":"Php 1:1","book":"Php","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"Php 1:15","book":"Php","chapter":1,"verse":15,"letter":"d"},{"kind":"crossref","label":"1Pt 5:14","book":"1Pe","chapter":5,"verse":14,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 16:7","book":"Rom","chapter":16,"verse":7},{"label":"Eph 2:6","book":"Eph","chapter":2,"verse":6},{"label":"Php 1:1","book":"Php","chapter":1,"verse":1},{"label":"Php 1:15","book":"Php","chapter":1,"verse":15},{"label":"1Pt 5:14","book":"1Pe","chapter":5,"verse":14}],"footnotes":[{"marker":2,"text":"Or upward"}]},{"verseId":"a556c5305ee15c3f-01:Php:3:15","parts":[{"kind":"text","text":"Therefore, let all of us who are mature think this way. And if you think differently about anything, God will reveal "},{"kind":"crossref","label":"Lk 10:21","book":"Luk","chapter":10,"verse":21,"letter":"a"},{"kind":"text","text":" this also to you. "}],"crossRefs":[{"label":"Lk 10:21","book":"Luk","chapter":10,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:16","parts":[{"kind":"text","text":"In any case, we should live up to whatever truth we have attained. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:17","parts":[{"kind":"text","text":"Join in imitating me, brothers and sisters, and pay careful attention to those who live according to the example you have in us. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:18","parts":[{"kind":"text","text":"For I have often told you, and now say again with tears, that many live as enemies of the cross "},{"kind":"crossref","label":"Lk 23:26","book":"Luk","chapter":23,"verse":26,"letter":"a"},{"kind":"crossref","label":"1Co 1:17","book":"1Co","chapter":1,"verse":17,"letter":"b"},{"kind":"crossref","label":"Gl 6:12","book":"Gal","chapter":6,"verse":12,"letter":"c"},{"kind":"text","text":" of Christ. "}],"crossRefs":[{"label":"Lk 23:26","book":"Luk","chapter":23,"verse":26},{"label":"1Co 1:17","book":"1Co","chapter":1,"verse":17},{"label":"Gl 6:12","book":"Gal","chapter":6,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:19","parts":[{"kind":"text","text":"Their end is destruction; their god is their stomach; their glory "},{"kind":"crossref","label":"Lk 14:10","book":"Luk","chapter":14,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jn 5:41","book":"Jhn","chapter":5,"verse":41,"letter":"b"},{"kind":"crossref","label":"Jn 5:44","book":"Jhn","chapter":5,"verse":44,"letter":"c"},{"kind":"crossref","label":"Jn 8:50","book":"Jhn","chapter":8,"verse":50,"letter":"d"},{"kind":"crossref","label":"Jn 8:54","book":"Jhn","chapter":8,"verse":54,"letter":"e"},{"kind":"crossref","label":"Jn 12:43","book":"Jhn","chapter":12,"verse":43,"letter":"f"},{"kind":"crossref","label":"Rm 9:4","book":"Rom","chapter":9,"verse":4,"letter":"g"},{"kind":"crossref","label":"1Co 11:15","book":"1Co","chapter":11,"verse":15,"letter":"h"},{"kind":"crossref","label":"2Co 6:8","book":"2Co","chapter":6,"verse":8,"letter":"i"},{"kind":"crossref","label":"1Th 2:6","book":"1Th","chapter":2,"verse":6,"letter":"j"},{"kind":"text","text":" is in their shame; and they are focused on earthly things. "}],"crossRefs":[{"label":"Lk 14:10","book":"Luk","chapter":14,"verse":10},{"label":"Jn 5:41","book":"Jhn","chapter":5,"verse":41},{"label":"Jn 5:44","book":"Jhn","chapter":5,"verse":44},{"label":"Jn 8:50","book":"Jhn","chapter":8,"verse":50},{"label":"Jn 8:54","book":"Jhn","chapter":8,"verse":54},{"label":"Jn 12:43","book":"Jhn","chapter":12,"verse":43},{"label":"Rm 9:4","book":"Rom","chapter":9,"verse":4},{"label":"1Co 11:15","book":"1Co","chapter":11,"verse":15},{"label":"2Co 6:8","book":"2Co","chapter":6,"verse":8},{"label":"1Th 2:6","book":"1Th","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:20","parts":[{"kind":"text","text":"Our citizenship is in heaven, and we eagerly wait for a Savior from there, the Lord Jesus Christ. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Php:3:21","parts":[{"kind":"text","text":"He will transform the body of our humble condition into the likeness of his glorious "},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"a"},{"kind":"text","text":" body, "},{"kind":"crossref","label":"1Co 6:13","book":"1Co","chapter":6,"verse":13,"letter":"b"},{"kind":"crossref","label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2,"letter":"c"},{"kind":"text","text":" by the power that enables him to subject everything to himself."}],"crossRefs":[{"label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4},{"label":"1Co 6:13","book":"1Co","chapter":6,"verse":13},{"label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2}],"footnotes":[]}]},"cachedAt":1783099548731}