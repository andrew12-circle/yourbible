ext","text":" So the one who fears is not complete in love. "},{"kind":"crossref","label":"Eph 4:11–16","book":"Eph","chapter":4,"verse":11,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 8:15","book":"Rom","chapter":8,"verse":15},{"label":"Eph 4:11–16","book":"Eph","chapter":4,"verse":11}],"footnotes":[{"marker":1,"text":"Or fear has its own punishment or torment"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:4:19","parts":[{"kind":"text","text":"We love "},{"kind":"footnote","marker":2,"text":"Other mss add him"},{"kind":"text","text":" because he first loved us. "},{"kind":"crossref","label":"2Th 2:13","book":"2Th","chapter":2,"verse":13,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Th 2:13","book":"2Th","chapter":2,"verse":13}],"footnotes":[{"marker":2,"text":"Other mss add him"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:4:20","parts":[{"kind":"text","text":"If anyone says, “I love God,” and yet hates his brother or sister, "},{"kind":"crossref","label":"1Jn 2:9","book":"1Jn","chapter":2,"verse":9,"letter":"a"},{"kind":"crossref","label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15,"letter":"c"},{"kind":"text","text":" he is a liar. "},{"kind":"crossref","label":"1Jn 1:10","book":"1Jn","chapter":1,"verse":10,"letter":"d"},{"kind":"text","text":" For the person who does not love his brother or sister "},{"kind":"crossref","label":"1Jn 2:10","book":"1Jn","chapter":2,"verse":10,"letter":"e"},{"kind":"crossref","label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10,"letter":"f"},{"kind":"crossref","label":"1Jn 3:14","book":"1Jn","chapter":3,"verse":14,"letter":"g"},{"kind":"text","text":" whom he has seen cannot love God whom he has not seen. "},{"kind":"footnote","marker":3,"text":"Other mss read has seen, how is he able to love... seen? (as a question)"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Jn 2:9","book":"1Jn","chapter":2,"verse":9},{"label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11},{"label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15},{"label":"1Jn 1:10","book":"1Jn","chapter":1,"verse":10},{"label":"1Jn 2:10","book":"1Jn","chapter":2,"verse":10},{"label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10},{"label":"1Jn 3:14","book":"1Jn","chapter":3,"verse":14}],"footnotes":[{"marker":3,"text":"Other mss read has seen, how is he able to love... seen? (as a question)"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:4:21","parts":[{"kind":"text","text":"And we have this command from him: The one who loves God must also love his brother and sister."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279686324}