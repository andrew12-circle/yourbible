is the word "},{"kind":"crossref","label":"Lk 6:47","book":"Luk","chapter":6,"verse":47,"letter":"d"},{"kind":"crossref","label":"Jn 1:1","book":"Jhn","chapter":1,"verse":1,"letter":"e"},{"kind":"text","text":" you have heard. "}],"crossRefs":[{"label":"Mk 7:8","book":"Mrk","chapter":7,"verse":8},{"label":"Jn 13:34","book":"Jhn","chapter":13,"verse":34},{"label":"2Jn 5","book":"2Jn","chapter":1,"verse":5},{"label":"Lk 6:47","book":"Luk","chapter":6,"verse":47},{"label":"Jn 1:1","book":"Jhn","chapter":1,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:8","parts":[{"kind":"text","text":"Yet I am writing you a new command, which is true in him and in you, because the darkness is passing away "},{"kind":"crossref","label":"Rm 13:12","book":"Rom","chapter":13,"verse":12,"letter":"a"},{"kind":"crossref","label":"1Co 7:31","book":"1Co","chapter":7,"verse":31,"letter":"b"},{"kind":"crossref","label":"1Jn 2:17","book":"1Jn","chapter":2,"verse":17,"letter":"c"},{"kind":"text","text":" and the true light "},{"kind":"crossref","label":"Jn 1:9","book":"Jhn","chapter":1,"verse":9,"letter":"d"},{"kind":"crossref","label":"Jn 3:19–21","book":"Jhn","chapter":3,"verse":19,"letter":"e"},{"kind":"crossref","label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12,"letter":"f"},{"kind":"crossref","label":"Jn 12:46","book":"Jhn","chapter":12,"verse":46,"letter":"g"},{"kind":"text","text":" is already shining. "},{"kind":"crossref","label":"Jn 1:5","book":"Jhn","chapter":1,"verse":5,"letter":"h"},{"kind":"crossref","label":"Jn 12:35–36","book":"Jhn","chapter":12,"verse":35,"letter":"i"},{"kind":"crossref","label":"Rv 22:5","book":"Rev","chapter":22,"verse":5,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 13:12","book":"Rom","chapter":13,"verse":12},{"label":"1Co 7:31","book":"1Co","chapter":7,"verse":31},{"label":"1Jn 2:17","book":"1Jn","chapter":2,"verse":17},{"label":"Jn 1:9","book":"Jhn","chapter":1,"verse":9},{"label":"Jn 3:19–21","book":"Jhn","chapter":3,"verse":19},{"label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12},{"label":"Jn 12:46","book":"Jhn","chapter":12,"verse":46},{"label":"Jn 1:5","book":"Jhn","chapter":1,"verse":5},{"label":"Jn 12:35–36","book":"Jhn","chapter":12,"verse":35},{"label":"Rv 22:5","book":"Rev","chapter":22,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:9","parts":[{"kind":"text","text":"The one who says he is in the light but hates his brother or sister "},{"kind":"crossref","label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11,"letter":"a"},{"kind":"crossref","label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15,"letter":"b"},{"kind":"crossref","label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20,"letter":"c"},{"kind":"text","text":" is in the darkness until now. "}],"crossRefs":[{"label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11},{"label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15},{"label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:10","parts":[{"kind":"text","text":"The one who loves his brother or sister "},{"kind":"crossref","label":"Rm 12:10","book":"Rom","chapter":12,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Th 4:9","book":"1Th","chapter":4,"verse":9,"letter":"b"},{"kind":"crossref","label":"Heb 13:1","book":"Heb","chapter":13,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Pt 1:22","book":"1Pe","chapter":1,"verse":22,"letter":"d"},{"kind":"crossref","label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10,"letter":"e"},{"kind":"crossref","label":"1Jn 3:14","book":"1Jn","chapter":3,"verse":14,"letter":"f"},{"kind":"crossref","label":"1Jn 4:20–21","book":"1Jn","chapter":4,"verse":20,"letter":"g"},{"kind":"text","text":" remains in the light, and there is no cause for stumbling in him. "},{"kind":"footnote","marker":1,"text":"Or it"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 12:10","book":"Rom","chapter":12,"verse":10},{"label":"1Th 4:9","book":"1Th","chapter":4,"verse":9},{"label":"Heb 13:1","book":"Heb","chapter":13,"verse":1},{"label":"1Pt 1:22","book":"1Pe","chapter":1,"verse":22},{"label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10},{"label":"1Jn 3:14","book":"1Jn","chapter":3,"verse":14},{"label":"1Jn 4:20–21","book":"1Jn","chapter":4,"verse":20}],"footnotes":[{"marker":1,"text":"Or it"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:11","parts":[{"kind":"text","text":"But the one who hates his brother or sister "},{"kind":"crossref","label":"Lv 19:17","book":"Lev","chapter":19,"verse":17,"letter":"a"},{"kind":"crossref","label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15,"letter":"b"},{"kind":"crossref","label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20,"letter":"c"},{"kind":"text","text":" is in the darkness, walks in the darkness, "},{"kind":"crossref","label":"1Jn 1:6","book":"1Jn","chapter":1,"verse":6,"letter":"d"},{"kind":"text","text":" and doesn’t know where he’s going, "},{"kind":"crossref","label":"Jn 14:6","book":"Jhn","chapter":14,"verse":6,"letter":"e"},{"kind":"text","text":" because the darkness has blinded his eyes."}],"crossRefs":[{"label":"Lv 19:17","book":"Lev","chapter":19,"verse":17},{"label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15},{"label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20},{"label":"1Jn 1:6","book":"1Jn","chapter":1,"verse":6},{"label":"Jn 14:6","book":"Jhn","chapter":14,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:12","parts":[{"kind":"text","text":"I am writing to you, little children,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:13","parts":[{"kind":"text","text":"I am writing to you, fathers,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:14","parts":[{"kind":"text","text":"I have written to you, children,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:15","parts":[{"kind":"text","text":"Do not love the world "},{"kind":"crossref","label":"Jn 15:19","book":"Jhn","chapter":15,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jn 17:16","book":"Jhn","chapter":17,"verse":16,"letter":"b"},{"kind":"crossref","label":"Rm 12:2","book":"Rom","chapter":12,"verse":2,"letter":"c"},{"kind":"crossref","label":"Jms 1:27","book":"Jas","chapter":1,"verse":27,"letter":"d"},{"kind":"crossref","label":"Jms 4:4","book":"Jas","chapter":4,"verse":4,"letter":"e"},{"kind":"text","text":" or the things in the world. If anyone loves the world, the love of the Father is not in him. "}],"crossRefs":[{"label":"Jn 15:19","book":"Jhn","chapter":15,"verse":19},{"label":"Jn 17:16","book":"Jhn","chapter":17,"verse":16},{"label":"Rm 12:2","book":"Rom","chapter":12,"verse":2},{"label":"Jms 1:27","book":"Jas","chapter":1,"verse":27},{"label":"Jms 4:4","book":"Jas","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:16","parts":[{"kind":"text","text":"For everything in the world —the lust of the flesh, "},{"kind":"crossref","label":"Rm 13:14","book":"Rom","chapter":13,"verse":14,"letter":"a"},{"kind":"crossref","label":"Eph 2:3","book":"Eph","chapter":2,"verse":3,"letter":"b"},{"kind":"crossref","label":"1Pt 4:2","book":"1Pe","chapter":4,"verse":2,"letter":"c"},{"kind":"crossref","label":"2Pt 2:18","book":"2Pe","chapter":2,"verse":18,"letter":"d"},{"kind":"text","text":" the lust of the eyes, "},{"kind":"crossref","label":"Gn 3:6","book":"Gen","chapter":3,"verse":6,"letter":"e"},{"kind":"crossref","label":"Pr 27:20","book":"Pro","chapter":27,"verse":20,"letter":"f"},{"kind":"text","text":" and the pride "},{"kind":"crossref","label":"Jms 4:16","book":"Jas","chapter":4,"verse":16,"letter":"g"},{"kind":"text","text":" in one’s possessions —is not from the Father, but is from the world. "}],"crossRefs":[{"label":"Rm 13:14","book":"Rom","chapter":13,"verse":14},{"label":"Eph 2:3","book":"Eph","chapter":2,"verse":3},{"label":"1Pt 4:2","book":"1Pe","chapter":4,"verse":2},{"label":"2Pt 2:18","book":"2Pe","chapter":2,"verse":18},{"label":"Gn 3:6","book":"Gen","chapter":3,"verse":6},{"label":"Pr 27:20","book":"Pro","chapter":27,"verse":20},{"label":"Jms 4:16","book":"Jas","chapter":4,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:17","parts":[{"kind":"text","text":"And the world with its lust is passing away, "},{"kind":"crossref","label":"1Jn 2:8","book":"1Jn","chapter":2,"verse":8,"letter":"a"},{"kind":"text","text":" but the one who does the will of God "},{"kind":"crossref","label":"Mk 3:35","book":"Mrk","chapter":3,"verse":35,"letter":"b"},{"kind":"crossref","label":"Eph 6:6","book":"Eph","chapter":6,"verse":6,"letter":"c"},{"kind":"crossref","label":"1Th 4:3","book":"1Th","chapter":4,"verse":3,"letter":"d"},{"kind":"crossref","label":"1Pt 2:15","book":"1Pe","chapter":2,"verse":15,"letter":"e"},{"kind":"text","text":" remains forever. "},{"kind":"crossref","label":"Jn 8:35","book":"Jhn","chapter":8,"verse":35,"letter":"f"},{"kind":"crossref","label":"Jn 12:34","book":"Jhn","chapter":12,"verse":34,"letter":"g"},{"kind":"crossref","label":"2Co 9:9","book":"2Co","chapter":9,"verse":9,"letter":"h"},{"kind":"crossref","label":"1Pt 1:25","book":"1Pe","chapter":1,"verse":25,"letter":"i"}],"crossRefs":[{"label":"1Jn 2:8","book":"1Jn","chapter":2,"verse":8},{"label":"Mk 3:35","book":"Mrk","chapter":3,"verse":35},{"label":"Eph 6:6","book":"Eph","chapter":6,"verse":6},{"label":"1Th 4:3","book":"1Th","chapter":4,"verse":3},{"label":"1Pt 2:15","book":"1Pe","chapter":2,"verse":15},{"label":"Jn 8:35","book":"Jhn","chapter":8,"verse":35},{"label":"Jn 12:34","book":"Jhn","chapter":12,"verse":34},{"label":"2Co 9:9","book":"2Co","chapter":9,"verse":9},{"label":"1Pt 1:25","book":"1Pe","chapter":1,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:18","parts":[{"kind":"text","text":"Children, it is the last hour. "},{"kind":"crossref","label":"Jn 2:4","book":"Jhn","chapter":2,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Pt 4:7","book":"1Pe","chapter":4,"verse":7,"letter":"b"},{"kind":"text","text":" And as you have heard that antichrist "},{"kind":"crossref","label":"Mt 24:5","book":"Mat","chapter":24,"verse":5,"letter":"c"},{"kind":"crossref","label":"Mt 24:24","book":"Mat","chapter":24,"verse":24,"letter":"d"},{"kind":"crossref","label":"1Jn 2:22","book":"1Jn","chapter":2,"verse":22,"letter":"e"},{"kind":"crossref","label":"1Jn 4:3","book":"1Jn","chapter":4,"verse":3,"letter":"f"},{"kind":"crossref","label":"2Jn 7","book":"2Jn","chapter":1,"verse":7,"letter":"g"},{"kind":"text","text":" is coming, even now many antichrists have come. By this we know that it is the last hour. "}],"crossRefs":[{"label":"Jn 2:4","book":"Jhn","chapter":2,"verse":4},{"label":"1Pt 4:7","book":"1Pe","chapter":4,"verse":7},{"label":"Mt 24:5","book":"Mat","chapter":24,"verse":5},{"label":"Mt 24:24","book":"Mat","chapter":24,"verse":24},{"label":"1Jn 2:22","book":"1Jn","chapter":2,"verse":22},{"label":"1Jn 4:3","book":"1Jn","chapter":4,"verse":3},{"label":"2Jn 7","book":"2Jn","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:19","parts":[{"kind":"text","text":"They went out from us, but they did not belong to us; for if they had belonged to us, they would have remained with us. However, they went out so that it might be made clear that none of them belongs to us."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:20","parts":[{"kind":"text","text":"But you have an anointing "},{"kind":"crossref","label":"2Co 1:21","book":"2Co","chapter":1,"verse":21,"letter":"a"},{"kind":"text","text":" from the Holy One, "},{"kind":"crossref","label":"Ps 89:18","book":"Psa","chapter":89,"verse":18,"letter":"b"},{"kind":"crossref","label":"Mk 1:24","book":"Mrk","chapter":1,"verse":24,"letter":"c"},{"kind":"crossref","label":"Ac 10:38","book":"Act","chapter":10,"verse":38,"letter":"d"},{"kind":"text","text":" and all of you know the truth. "},{"kind":"footnote","marker":1,"text":"Other mss read and you know all things"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Co 1:21","book":"2Co","chapter":1,"verse":21},{"label":"Ps 89:18","book":"Psa","chapter":89,"verse":18},{"label":"Mk 1:24","book":"Mrk","chapter":1,"verse":24},{"label":"Ac 10:38","book":"Act","chapter":10,"verse":38}],"footnotes":[{"marker":1,"text":"Other mss read and you know all things"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:21","parts":[{"kind":"text","text":"I have not written to you because you don’t know the truth, but because you do know it, and because no lie comes from the truth. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:22","parts":[{"kind":"text","text":"Who is the liar, if not the one who denies that Jesus is the Christ? "},{"kind":"crossref","label":"Jn 20:31","book":"Jhn","chapter":20,"verse":31,"letter":"a"},{"kind":"crossref","label":"Ac 18:5","book":"Act","chapter":18,"verse":5,"letter":"b"},{"kind":"crossref","label":"Eph 5:2","book":"Eph","chapter":5,"verse":2,"letter":"c"},{"kind":"crossref","label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1,"letter":"d"},{"kind":"text","text":" This one is the antichrist: the one who denies the Father and the Son. "}],"crossRefs":[{"label":"Jn 20:31","book":"Jhn","chapter":20,"verse":31},{"label":"Ac 18:5","book":"Act","chapter":18,"verse":5},{"label":"Eph 5:2","book":"Eph","chapter":5,"verse":2},{"label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:23","parts":[{"kind":"text","text":"No one who denies the Son has the Father; "},{"kind":"crossref","label":"Jn 5:23","book":"Jhn","chapter":5,"verse":23,"letter":"a"},{"kind":"text","text":" he who confesses the Son has the Father as well. "},{"kind":"crossref","label":"Jn 8:19","book":"Jhn","chapter":8,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jn 16:3","book":"Jhn","chapter":16,"verse":3,"letter":"c"},{"kind":"crossref","label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3,"letter":"d"},{"kind":"crossref","label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15,"letter":"e"},{"kind":"crossref","label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1,"letter":"f"},{"kind":"crossref","label":"2Jn 9","book":"2Jn","chapter":1,"verse":9,"letter":"g"}],"crossRefs":[{"label":"Jn 5:23","book":"Jhn","chapter":5,"verse":23},{"label":"Jn 8:19","book":"Jhn","chapter":8,"verse":19},{"label":"Jn 16:3","book":"Jhn","chapter":16,"verse":3},{"label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3},{"label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15},{"label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1},{"label":"2Jn 9","book":"2Jn","chapter":1,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:24","parts":[{"kind":"text","text":"What you have heard from the beginning is to remain in you. If what you have heard from the beginning remains in you, then you will remain in the Son "},{"kind":"crossref","label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6,"letter":"b"},{"kind":"crossref","label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27,"letter":"c"},{"kind":"crossref","label":"1Jn 3:6","book":"1Jn","chapter":3,"verse":6,"letter":"d"},{"kind":"crossref","label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24,"letter":"e"},{"kind":"crossref","label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13,"letter":"f"},{"kind":"crossref","label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15,"letter":"g"},{"kind":"text","text":" and in the Father. "},{"kind":"crossref","label":"Jn 10:38","book":"Jhn","chapter":10,"verse":38,"letter":"h"},{"kind":"crossref","label":"Col 3:3","book":"Col","chapter":3,"verse":3,"letter":"i"},{"kind":"crossref","label":"1Th 1:1","book":"1Th","chapter":1,"verse":1,"letter":"j"},{"kind":"crossref","label":"1Jn 4:15–16","book":"1Jn","chapter":4,"verse":15,"letter":"k"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4},{"label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6},{"label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27},{"label":"1Jn 3:6","book":"1Jn","chapter":3,"verse":6},{"label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24},{"label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13},{"label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15},{"label":"Jn 10:38","book":"Jhn","chapter":10,"verse":38},{"label":"Col 3:3","book":"Col","chapter":3,"verse":3},{"label":"1Th 1:1","book":"1Th","chapter":1,"verse":1},{"label":"1Jn 4:15–16","book":"1Jn","chapter":4,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:25","parts":[{"kind":"text","text":"And this is the promise that he himself made to us: eternal life. "},{"kind":"crossref","label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14,"letter":"a"},{"kind":"crossref","label":"1Tm 4:8","book":"1Ti","chapter":4,"verse":8,"letter":"b"},{"kind":"crossref","label":"2Tm 1:1","book":"2Ti","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"Ti 1:2","book":"Tit","chapter":1,"verse":2,"letter":"d"}],"crossRefs":[{"label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14},{"label":"1Tm 4:8","book":"1Ti","chapter":4,"verse":8},{"label":"2Tm 1:1","book":"2Ti","chapter":1,"verse":1},{"label":"Ti 1:2","book":"Tit","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:26","parts":[{"kind":"text","text":"I have written these things to you concerning those who are trying to deceive you. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:27","parts":[{"kind":"text","text":"As for you, the anointing you received from him remains in you, and you don’t need anyone to teach you. Instead, his anointing teaches you about all things "},{"kind":"crossref","label":"Jn 14:26","book":"Jhn","chapter":14,"verse":26,"letter":"a"},{"kind":"text","text":" and is true and is not a lie; just as it has taught you, "},{"kind":"footnote","marker":1,"text":"Or as he has taught you"},{"kind":"text","text":" remain in him. "},{"kind":"crossref","label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4,"letter":"b"},{"kind":"crossref","label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6,"letter":"c"},{"kind":"crossref","label":"1Jn 3:6","book":"1Jn","chapter":3,"verse":6,"letter":"d"},{"kind":"crossref","label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24,"letter":"e"},{"kind":"crossref","label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13,"letter":"f"},{"kind":"crossref","label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15,"letter":"g"}],"crossRefs":[{"label":"Jn 14:26","book":"Jhn","chapter":14,"verse":26},{"label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4},{"label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6},{"label":"1Jn 3:6","book":"1Jn","chapter":3,"verse":6},{"label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24},{"label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13},{"label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15}],"footnotes":[{"marker":1,"text":"Or as he has taught you"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:28","parts":[{"kind":"text","text":"So now, little children, remain in him so that when he appears "},{"kind":"crossref","label":"Lk 17:30","book":"Luk","chapter":17,"verse":30,"letter":"a"},{"kind":"crossref","label":"Col 3:4","book":"Col","chapter":3,"verse":4,"letter":"b"},{"kind":"crossref","label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2,"letter":"c"},{"kind":"text","text":" we may have confidence and not be ashamed before him at his coming. "},{"kind":"crossref","label":"1Th 2:19","book":"1Th","chapter":2,"verse":19,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 17:30","book":"Luk","chapter":17,"verse":30},{"label":"Col 3:4","book":"Col","chapter":3,"verse":4},{"label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2},{"label":"1Th 2:19","book":"1Th","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:2:29","parts":[{"kind":"text","text":"If you know that he is righteous, you know this as well: Everyone who does what is right "},{"kind":"crossref","label":"Gn 18:19","book":"Gen","chapter":18,"verse":19,"letter":"a"},{"kind":"crossref","label":"Dt 6:18","book":"Deu","chapter":6,"verse":18,"letter":"b"},{"kind":"crossref","label":"1Jn 3:7","book":"1Jn","chapter":3,"verse":7,"letter":"c"},{"kind":"crossref","label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10,"letter":"d"},{"kind":"text","text":" has been born of him. "},{"kind":"crossref","label":"Jn 1:12–13","book":"Jhn","chapter":1,"verse":12,"letter":"e"},{"kind":"crossref","label":"Jn 3:3–7","book":"Jhn","chapter":3,"verse":3,"letter":"f"},{"kind":"crossref","label":"Jn 8:41","book":"Jhn","chapter":8,"verse":41,"letter":"g"},{"kind":"crossref","label":"1Jn 3:9","book":"1Jn","chapter":3,"verse":9,"letter":"h"},{"kind":"crossref","label":"1Jn 4:7","book":"1Jn","chapter":4,"verse":7,"letter":"i"},{"kind":"crossref","label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1,"letter":"j"},{"kind":"crossref","label":"1Jn 5:4","book":"1Jn","chapter":5,"verse":4,"letter":"k"},{"kind":"crossref","label":"1Jn 5:18","book":"1Jn","chapter":5,"verse":18,"letter":"l"}],"crossRefs":[{"label":"Gn 18:19","book":"Gen","chapter":18,"verse":19},{"label":"Dt 6:18","book":"Deu","chapter":6,"verse":18},{"label":"1Jn 3:7","book":"1Jn","chapter":3,"verse":7},{"label":"1Jn 3:10","book":"1Jn","chapter":3,"verse":10},{"label":"Jn 1:12–13","book":"Jhn","chapter":1,"verse":12},{"label":"Jn 3:3–7","book":"Jhn","chapter":3,"verse":3},{"label":"Jn 8:41","book":"Jhn","chapter":8,"verse":41},{"label":"1Jn 3:9","book":"1Jn","chapter":3,"verse":9},{"label":"1Jn 4:7","book":"1Jn","chapter":4,"verse":7},{"label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1},{"label":"1Jn 5:4","book":"1Jn","chapter":5,"verse":4},{"label":"1Jn 5:18","book":"1Jn","chapter":5,"verse":18}],"footnotes":[]}]},"cachedAt":1783099564646}