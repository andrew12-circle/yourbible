tter":"a"},{"kind":"crossref","label":"1Th 1:3","book":"1Th","chapter":1,"verse":3,"letter":"b"},{"kind":"text","text":" in him purifies himself just as he is pure. "},{"kind":"crossref","label":"Php 4:8","book":"Php","chapter":4,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Ac 23:6","book":"Act","chapter":23,"verse":6},{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3},{"label":"Php 4:8","book":"Php","chapter":4,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:4","parts":[{"kind":"text","text":"Everyone who commits sin practices lawlessness; and sin is lawlessness. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:5","parts":[{"kind":"text","text":"You know that he was revealed so that he might take away sins, "},{"kind":"footnote","marker":1,"text":"Other mss read our sins"},{"kind":"crossref","label":"Jn 1:29","book":"Jhn","chapter":1,"verse":29,"letter":"a"},{"kind":"crossref","label":"1Co 15:3","book":"1Co","chapter":15,"verse":3,"letter":"b"},{"kind":"crossref","label":"Heb 10:4","book":"Heb","chapter":10,"verse":4,"letter":"c"},{"kind":"crossref","label":"1Pt 2:24","book":"1Pe","chapter":2,"verse":24,"letter":"d"},{"kind":"text","text":" and there is no sin in him. "},{"kind":"crossref","label":"2Co 5:21","book":"2Co","chapter":5,"verse":21,"letter":"e"},{"kind":"crossref","label":"Heb 4:15","book":"Heb","chapter":4,"verse":15,"letter":"f"},{"kind":"crossref","label":"Heb 7:26","book":"Heb","chapter":7,"verse":26,"letter":"g"},{"kind":"crossref","label":"1Pt 2:21","book":"1Pe","chapter":2,"verse":21,"letter":"h"},{"kind":"crossref","label":"1Pt 3:18","book":"1Pe","chapter":3,"verse":18,"letter":"i"},{"kind":"crossref","label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 1:29","book":"Jhn","chapter":1,"verse":29},{"label":"1Co 15:3","book":"1Co","chapter":15,"verse":3},{"label":"Heb 10:4","book":"Heb","chapter":10,"verse":4},{"label":"1Pt 2:24","book":"1Pe","chapter":2,"verse":24},{"label":"2Co 5:21","book":"2Co","chapter":5,"verse":21},{"label":"Heb 4:15","book":"Heb","chapter":4,"verse":15},{"label":"Heb 7:26","book":"Heb","chapter":7,"verse":26},{"label":"1Pt 2:21","book":"1Pe","chapter":2,"verse":21},{"label":"1Pt 3:18","book":"1Pe","chapter":3,"verse":18},{"label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29}],"footnotes":[{"marker":1,"text":"Other mss read our sins"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:6","parts":[{"kind":"text","text":"Everyone who remains in him "},{"kind":"crossref","label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6,"letter":"b"},{"kind":"crossref","label":"1Jn 2:24","book":"1Jn","chapter":2,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27,"letter":"d"},{"kind":"crossref","label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24,"letter":"e"},{"kind":"crossref","label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13,"letter":"f"},{"kind":"crossref","label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15,"letter":"g"},{"kind":"text","text":" does not sin; "},{"kind":"footnote","marker":2,"text":"Or not keep on sinning"},{"kind":"crossref","label":"Rm 6:11–12","book":"Rom","chapter":6,"verse":11,"letter":"h"},{"kind":"crossref","label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29,"letter":"i"},{"kind":"crossref","label":"1Jn 5:18","book":"1Jn","chapter":5,"verse":18,"letter":"j"},{"kind":"text","text":" everyone who sins "},{"kind":"footnote","marker":3,"text":"Or who keeps on sinning"},{"kind":"text","text":" has not seen him or known him."}],"crossRefs":[{"label":"Jn 15:4–7","book":"Jhn","chapter":15,"verse":4},{"label":"1Jn 2:6","book":"1Jn","chapter":2,"verse":6},{"label":"1Jn 2:24","book":"1Jn","chapter":2,"verse":24},{"label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27},{"label":"1Jn 3:24","book":"1Jn","chapter":3,"verse":24},{"label":"1Jn 4:13","book":"1Jn","chapter":4,"verse":13},{"label":"1Jn 4:15","book":"1Jn","chapter":4,"verse":15},{"label":"Rm 6:11–12","book":"Rom","chapter":6,"verse":11},{"label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29},{"label":"1Jn 5:18","book":"1Jn","chapter":5,"verse":18}],"footnotes":[{"marker":2,"text":"Or not keep on sinning"},{"marker":3,"text":"Or who keeps on sinning"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:7","parts":[{"kind":"text","text":"Little children, let no one deceive you. The one who does what is right is righteous, just as he is righteous. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:8","parts":[{"kind":"text","text":"The one who commits "},{"kind":"footnote","marker":1,"text":"Or practices"},{"kind":"text","text":" sin is of the devil, for the devil has sinned from the beginning. The Son of God "},{"kind":"crossref","label":"Mk 1:11","book":"Mrk","chapter":1,"verse":11,"letter":"a"},{"kind":"text","text":" was revealed "},{"kind":"crossref","label":"Jn 21:1","book":"Jhn","chapter":21,"verse":1,"letter":"b"},{"kind":"crossref","label":"2Co 4:11","book":"2Co","chapter":4,"verse":11,"letter":"c"},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"d"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"e"},{"kind":"text","text":" for this purpose: to destroy the devil’s works. "}],"crossRefs":[{"label":"Mk 1:11","book":"Mrk","chapter":1,"verse":11},{"label":"Jn 21:1","book":"Jhn","chapter":21,"verse":1},{"label":"2Co 4:11","book":"2Co","chapter":4,"verse":11},{"label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4},{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20}],"footnotes":[{"marker":1,"text":"Or practices"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:9","parts":[{"kind":"text","text":"Everyone who has been born of God "},{"kind":"crossref","label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29,"letter":"a"},{"kind":"text","text":" does not sin, "},{"kind":"footnote","marker":2,"text":"Or not practice sin"},{"kind":"text","text":" because his seed "},{"kind":"crossref","label":"1Pt 1:23","book":"1Pe","chapter":1,"verse":23,"letter":"b"},{"kind":"text","text":" remains in him; he is not able to sin, "},{"kind":"footnote","marker":3,"text":"Or to keep on sinning"},{"kind":"text","text":" because he has been born of God. "}],"crossRefs":[{"label":"1Jn 2:29","book":"1Jn","chapter":2,"verse":29},{"label":"1Pt 1:23","book":"1Pe","chapter":1,"verse":23}],"footnotes":[{"marker":2,"text":"Or not practice sin"},{"marker":3,"text":"Or to keep on sinning"}]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:10","parts":[{"kind":"text","text":"This is how God’s children and the devil’s children become obvious. Whoever does not do what is right is not of God, especially the one who does not love his brother or sister. "},{"kind":"crossref","label":"1Jn 2:10","book":"1Jn","chapter":2,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Jn 3:14–17","book":"1Jn","chapter":3,"verse":14,"letter":"b"},{"kind":"crossref","label":"1Jn 4:20–21","book":"1Jn","chapter":4,"verse":20,"letter":"c"}],"crossRefs":[{"label":"1Jn 2:10","book":"1Jn","chapter":2,"verse":10},{"label":"1Jn 3:14–17","book":"1Jn","chapter":3,"verse":14},{"label":"1Jn 4:20–21","book":"1Jn","chapter":4,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:11","parts":[{"kind":"text","text":"For this is the message you have heard from the beginning: We should love one another, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:12","parts":[{"kind":"text","text":"unlike Cain, "},{"kind":"crossref","label":"Gn 4:1","book":"Gen","chapter":4,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jd 1:11","book":"Jud","chapter":1,"verse":11,"letter":"b"},{"kind":"text","text":" who was of the evil one "},{"kind":"crossref","label":"2Th 3:3","book":"2Th","chapter":3,"verse":3,"letter":"c"},{"kind":"text","text":" and murdered his brother. And why did he murder him? Because his deeds were evil, and his brother’s were righteous."}],"crossRefs":[{"label":"Gn 4:1","book":"Gen","chapter":4,"verse":1},{"label":"Jd 1:11","book":"Jud","chapter":1,"verse":11},{"label":"2Th 3:3","book":"2Th","chapter":3,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:13","parts":[{"kind":"text","text":"Do not be surprised, brothers and sisters, if the world hates "},{"kind":"crossref","label":"Jn 17:14","book":"Jhn","chapter":17,"verse":14,"letter":"a"},{"kind":"text","text":" you. "}],"crossRefs":[{"label":"Jn 17:14","book":"Jhn","chapter":17,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:14","parts":[{"kind":"text","text":"We know that we have passed from death to life because we love our brothers and sisters. The one who does not love remains in death. "},{"kind":"crossref","label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:15","parts":[{"kind":"text","text":"Everyone who hates his brother or sister "},{"kind":"crossref","label":"1Jn 2:9","book":"1Jn","chapter":2,"verse":9,"letter":"a"},{"kind":"crossref","label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20,"letter":"c"},{"kind":"text","text":" is a murderer, "},{"kind":"crossref","label":"Mt 5:21–22","book":"Mat","chapter":5,"verse":21,"letter":"d"},{"kind":"crossref","label":"Jn 8:44","book":"Jhn","chapter":8,"verse":44,"letter":"e"},{"kind":"text","text":" and you know that no murderer has eternal life residing in him. "}],"crossRefs":[{"label":"1Jn 2:9","book":"1Jn","chapter":2,"verse":9},{"label":"1Jn 2:11","book":"1Jn","chapter":2,"verse":11},{"label":"1Jn 4:20","book":"1Jn","chapter":4,"verse":20},{"label":"Mt 5:21–22","book":"Mat","chapter":5,"verse":21},{"label":"Jn 8:44","book":"Jhn","chapter":8,"verse":44}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:16","parts":[{"kind":"text","text":"This is how we have come to know love: He laid down his life "},{"kind":"crossref","label":"Jn 10:11","book":"Jhn","chapter":10,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 10:14","book":"Jhn","chapter":10,"verse":14,"letter":"b"},{"kind":"crossref","label":"Jn 10:17","book":"Jhn","chapter":10,"verse":17,"letter":"c"},{"kind":"crossref","label":"Jn 13:37–38","book":"Jhn","chapter":13,"verse":37,"letter":"d"},{"kind":"crossref","label":"Jn 15:13","book":"Jhn","chapter":15,"verse":13,"letter":"e"},{"kind":"text","text":" for us. "},{"kind":"crossref","label":"Is 53:10","book":"Isa","chapter":53,"verse":10,"letter":"f"},{"kind":"crossref","label":"Mk 10:45","book":"Mrk","chapter":10,"verse":45,"letter":"g"},{"kind":"text","text":" We should also lay down our lives for our brothers and sisters. "},{"kind":"crossref","label":"Mk 8:34–35","book":"Mrk","chapter":8,"verse":34,"letter":"h"},{"kind":"crossref","label":"1Co 11:1","book":"1Co","chapter":11,"verse":1,"letter":"i"},{"kind":"crossref","label":"Php 2:5–8","book":"Php","chapter":2,"verse":5,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 10:11","book":"Jhn","chapter":10,"verse":11},{"label":"Jn 10:14","book":"Jhn","chapter":10,"verse":14},{"label":"Jn 10:17","book":"Jhn","chapter":10,"verse":17},{"label":"Jn 13:37–38","book":"Jhn","chapter":13,"verse":37},{"label":"Jn 15:13","book":"Jhn","chapter":15,"verse":13},{"label":"Is 53:10","book":"Isa","chapter":53,"verse":10},{"label":"Mk 10:45","book":"Mrk","chapter":10,"verse":45},{"label":"Mk 8:34–35","book":"Mrk","chapter":8,"verse":34},{"label":"1Co 11:1","book":"1Co","chapter":11,"verse":1},{"label":"Php 2:5–8","book":"Php","chapter":2,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Jn:3:17","parts":[{"kind":"text","text":"If anyone has this world’s goods "},{"kind":"crossref","label":"Mk 12:44","book":"Mrk","cha