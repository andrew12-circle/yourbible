xt":" and the Lord Jesus Christ."}],"crossRefs":[{"label":"Rm 1:7","book":"Rom","chapter":1,"verse":7},{"label":"2Co 1:2","book":"2Co","chapter":1,"verse":2},{"label":"Gl 1:3","book":"Gal","chapter":1,"verse":3},{"label":"Eph 1:2","book":"Eph","chapter":1,"verse":2},{"label":"Php 1:2","book":"Php","chapter":1,"verse":2},{"label":"2Th 1:2","book":"2Th","chapter":1,"verse":2},{"label":"Ti 1:4","book":"Tit","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:4","parts":[{"kind":"text","text":"I always thank "},{"kind":"crossref","label":"Rm 1:8","book":"Rom","chapter":1,"verse":8,"letter":"a"},{"kind":"crossref","label":"Php 1:3","book":"Php","chapter":1,"verse":3,"letter":"b"},{"kind":"crossref","label":"Col 1:3","book":"Col","chapter":1,"verse":3,"letter":"c"},{"kind":"crossref","label":"1Th 1:2","book":"1Th","chapter":1,"verse":2,"letter":"d"},{"kind":"crossref","label":"2Th 1:3","book":"2Th","chapter":1,"verse":3,"letter":"e"},{"kind":"crossref","label":"2Tm 1:3","book":"2Ti","chapter":1,"verse":3,"letter":"f"},{"kind":"crossref","label":"Phm 4","book":"Phm","chapter":1,"verse":4,"letter":"g"},{"kind":"text","text":" my God for you because of the grace of God given to you in Christ Jesus, "}],"crossRefs":[{"label":"Rm 1:8","book":"Rom","chapter":1,"verse":8},{"label":"Php 1:3","book":"Php","chapter":1,"verse":3},{"label":"Col 1:3","book":"Col","chapter":1,"verse":3},{"label":"1Th 1:2","book":"1Th","chapter":1,"verse":2},{"label":"2Th 1:3","book":"2Th","chapter":1,"verse":3},{"label":"2Tm 1:3","book":"2Ti","chapter":1,"verse":3},{"label":"Phm 4","book":"Phm","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:5","parts":[{"kind":"text","text":"that you were enriched in him "},{"kind":"crossref","label":"2Co 8:9","book":"2Co","chapter":8,"verse":9,"letter":"a"},{"kind":"crossref","label":"2Co 9:11","book":"2Co","chapter":9,"verse":11,"letter":"b"},{"kind":"text","text":" in every way, in all speech and all knowledge. "},{"kind":"crossref","label":"Rm 15:14","book":"Rom","chapter":15,"verse":14,"letter":"c"},{"kind":"crossref","label":"1Co 12:8","book":"1Co","chapter":12,"verse":8,"letter":"d"},{"kind":"crossref","label":"2Co 8:7","book":"2Co","chapter":8,"verse":7,"letter":"e"},{"kind":"crossref","label":"1Jn 2:20","book":"1Jn","chapter":2,"verse":20,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Co 8:9","book":"2Co","chapter":8,"verse":9},{"label":"2Co 9:11","book":"2Co","chapter":9,"verse":11},{"label":"Rm 15:14","book":"Rom","chapter":15,"verse":14},{"label":"1Co 12:8","book":"1Co","chapter":12,"verse":8},{"label":"2Co 8:7","book":"2Co","chapter":8,"verse":7},{"label":"1Jn 2:20","book":"1Jn","chapter":2,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:6","parts":[{"kind":"text","text":"In this way, the testimony about Christ was confirmed among you, "},{"kind":"crossref","label":"2Th 1:10","book":"2Th","chapter":1,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6,"letter":"b"},{"kind":"crossref","label":"2Tm 1:8","book":"2Ti","chapter":1,"verse":8,"letter":"c"},{"kind":"crossref","label":"Rv 1:2","book":"Rev","chapter":1,"verse":2,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Th 1:10","book":"2Th","chapter":1,"verse":10},{"label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6},{"label":"2Tm 1:8","book":"2Ti","chapter":1,"verse":8},{"label":"Rv 1:2","book":"Rev","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:7","parts":[{"kind":"text","text":"so that you do not lack any spiritual gift as you eagerly wait "},{"kind":"crossref","label":"Lk 17:30","book":"Luk","chapter":17,"verse":30,"letter":"a"},{"kind":"crossref","label":"Rm 8:19","book":"Rom","chapter":8,"verse":19,"letter":"b"},{"kind":"crossref","label":"Php 3:20","book":"Php","chapter":3,"verse":20,"letter":"c"},{"kind":"crossref","label":"Heb 9:28","book":"Heb","chapter":9,"verse":28,"letter":"d"},{"kind":"crossref","label":"2Pt 3:12","book":"2Pe","chapter":3,"verse":12,"letter":"e"},{"kind":"text","text":" for the revelation "},{"kind":"crossref","label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13,"letter":"f"},{"kind":"text","text":" of our Lord Jesus Christ. "}],"crossRefs":[{"label":"Lk 17:30","book":"Luk","chapter":17,"verse":30},{"label":"Rm 8:19","book":"Rom","chapter":8,"verse":19},{"label":"Php 3:20","book":"Php","chapter":3,"verse":20},{"label":"Heb 9:28","book":"Heb","chapter":9,"verse":28},{"label":"2Pt 3:12","book":"2Pe","chapter":3,"verse":12},{"label":"1Pt 4:13","book":"1Pe","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:8","parts":[{"kind":"text","text":"He will also strengthen you to the end, "},{"kind":"crossref","label":"Php 1:6","book":"Php","chapter":1,"verse":6,"letter":"a"},{"kind":"crossref","label":"1Th 3:13","book":"1Th","chapter":3,"verse":13,"letter":"b"},{"kind":"text","text":" so that you will be blameless in the day of our Lord Jesus Christ. "},{"kind":"crossref","label":"Lk 17:24","book":"Luk","chapter":17,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Co 5:5","book":"1Co","chapter":5,"verse":5,"letter":"d"},{"kind":"crossref","label":"2Co 1:14","book":"2Co","chapter":1,"verse":14,"letter":"e"},{"kind":"crossref","label":"Php 2:16","book":"Php","chapter":2,"verse":16,"letter":"f"},{"kind":"crossref","label":"Col 1:22","book":"Col","chapter":1,"verse":22,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Php 1:6","book":"Php","chapter":1,"verse":6},{"label":"1Th 3:13","book":"1Th","chapter":3,"verse":13},{"label":"Lk 17:24","book":"Luk","chapter":17,"verse":24},{"label":"1Co 5:5","book":"1Co","chapter":5,"verse":5},{"label":"2Co 1:14","book":"2Co","chapter":1,"verse":14},{"label":"Php 2:16","book":"Php","chapter":2,"verse":16},{"label":"Col 1:22","book":"Col","chapter":1,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:9","parts":[{"kind":"text","text":"God is faithful; "},{"kind":"crossref","label":"Dt 7:9","book":"Deu","chapter":7,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 49:7","book":"Isa","chapter":49,"verse":7,"letter":"b"},{"kind":"crossref","label":"1Co 10:13","book":"1Co","chapter":10,"verse":13,"letter":"c"},{"kind":"crossref","label":"2Co 1:18","book":"2Co","chapter":1,"verse":18,"letter":"d"},{"kind":"text","text":" you were called by him "},{"kind":"crossref","label":"Rm 8:28","book":"Rom","chapter":8,"verse":28,"letter":"e"},{"kind":"text","text":" into fellowship with his Son, "},{"kind":"crossref","label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19,"letter":"f"},{"kind":"crossref","label":"Heb 1:2","book":"Heb","chapter":1,"verse":2,"letter":"g"},{"kind":"crossref","label":"1Jn 1:3","book":"1Jn","chapter":1,"verse":3,"letter":"h"},{"kind":"text","text":" Jesus Christ our Lord."}],"crossRefs":[{"label":"Dt 7:9","book":"Deu","chapter":7,"verse":9},{"label":"Is 49:7","book":"Isa","chapter":49,"verse":7},{"label":"1Co 10:13","book":"1Co","chapter":10,"verse":13},{"label":"2Co 1:18","book":"2Co","chapter":1,"verse":18},{"label":"Rm 8:28","book":"Rom","chapter":8,"verse":28},{"label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19},{"label":"Heb 1:2","book":"Heb","chapter":1,"verse":2},{"label":"1Jn 1:3","book":"1Jn","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:10","parts":[{"kind":"text","text":"Now I urge you, brothers and sisters, in the name of our Lord Jesus Christ, that all of you agree in what you say, that there be no divisions among you, and that you be united with the same understanding and the same conviction. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:11","parts":[{"kind":"text","text":"For it has been reported to me about you, my brothers and sisters, by members of Chloe’s people, that there is rivalry "},{"kind":"crossref","label":"Ti 3:9","book":"Tit","chapter":3,"verse":9,"letter":"a"},{"kind":"text","text":" among you. "}],"crossRefs":[{"label":"Ti 3:9","book":"Tit","chapter":3,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:12","parts":[{"kind":"text","text":"What I am saying is this: One of you says, “I belong to Paul,” or “I belong to Apollos,” "},{"kind":"crossref","label":"Ti 3:13","book":"Tit","chapter":3,"verse":13,"letter":"a"},{"kind":"text","text":" or “I belong to Cephas,” "},{"kind":"crossref","label":"Jn 1:42","book":"Jhn","chapter":1,"verse":42,"letter":"b"},{"kind":"text","text":" or “I belong to Christ.” "},{"kind":"crossref","label":"Mt 23:9–10","book":"Mat","chapter":23,"verse":9,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ti 3:13","book":"Tit","chapter":3,"verse":13},{"label":"Jn 1:42","book":"Jhn","chapter":1,"verse":42},{"label":"Mt 23:9–10","book":"Mat","chapter":23,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:13","parts":[{"kind":"text","text":"Is Christ divided? "},{"kind":"crossref","label":"1Co 12:5","book":"1Co","chapter":12,"verse":5,"letter":"a"},{"kind":"crossref","label":"2Co 11:4","book":"2Co","chapter":11,"verse":4,"letter":"b"},{"kind":"crossref","label":"Eph 4:5","book":"Eph","chapter":4,"verse":5,"letter":"c"},{"kind":"text","text":" Was Paul crucified for you? Or were you baptized in Paul’s name? "}],"crossRefs":[{"label":"1Co 12:5","book":"1Co","chapter":12,"verse":5},{"label":"2Co 11:4","book":"2Co","chapter":11,"verse":4},{"label":"Eph 4:5","book":"Eph","chapter":4,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:14","parts":[{"kind":"text","text":"I thank God "},{"kind":"footnote","marker":1,"text":"Other mss omit God"},{"kind":"footnote","marker":2,"text":"Or I am thankful"},{"kind":"text","text":" that I baptized none of you except Crispus "},{"kind":"crossref","label":"Ac 18:8","book":"Act","chapter":18,"verse":8,"letter":"a"},{"kind":"text","text":" and Gaius, "},{"kind":"crossref","label":"Rm 16:23","book":"Rom","chapter":16,"verse":23,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 18:8","book":"Act","chapter":18,"verse":8},{"label":"Rm 16:23","book":"Rom","chapter":16,"verse":23}],"footnotes":[{"marker":1,"text":"Other mss omit God"},{"marker":2,"text":"Or I am thankful"}]},{"verseId":"a556c5305ee15c3f-01:1Co:1:15","parts":[{"kind":"text","text":"so that no one can say you were baptized in my name. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:16","parts":[{"kind":"text","text":"I did, in fact, baptize the household "},{"kind":"crossref","label":"Rm 16:5","book":"Rom","chapter":16,"verse":5,"letter":"a"},{"kind":"text","text":" of Stephanas; "},{"kind":"crossref","label":"1Co 16:15","book":"1Co","chapter":16,"verse":15,"letter":"b"},{"kind":"crossref","label":"1Co 16:17","book":"1Co","chapter":16,"verse":17,"letter":"c"},{"kind":"text","text":" beyond that, I don’t recall if I baptized anyone else. "}],"crossRefs":[{"label":"Rm 16:5","book":"Rom","chapter":16,"verse":5},{"label":"1Co 16:15","book":"1Co","chapter":16,"verse":15},{"label":"1Co 16:17","book":"1Co","chapter":16,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:17","parts":[{"kind":"text","text":"For Christ did not send me to baptize, but to preach the gospel —not with eloquent wisdom, so that the cross "},{"kind":"crossref","label":"Lk 23:26","book":"Luk","chapter":23,"verse":26,"letter":"a"},{"kind":"crossref","label":"Php 3:18","book":"Php","chapter":3,"verse":18,"letter":"b"},{"kind":"text","text":" of Christ will not be emptied of its effect."}],"crossRefs":[{"label":"Lk 23:26","book":"Luk","chapter":23,"verse":26},{"label":"Php 3:18","book":"Php","chapter":3,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:18","parts":[{"kind":"text","text":"For the word of the cross is foolishness to those who are perishing, but it is the power of God to us who are being saved. "},{"kind":"crossref","label":"Ac 19:11","book":"Act","chapter":19,"verse":11,"letter":"a"},{"kind":"crossref","label":"Rm 1:16","book":"Rom","chapter":1,"verse":16,"letter":"b"},{"kind":"crossref","label":"2Co 13:4","book":"2Co","chapter":13,"verse":4,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 19:11","book":"Act","chapter":19,"verse":11},{"label":"Rm 1:16","book":"Rom","chapter":1,"verse":16},{"label":"2Co 13:4","book":"2Co","chapter":13,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:19","parts":[{"kind":"text","text":"For it is written,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:20","parts":[{"kind":"text","text":"Where is the one who is wise? Where is the teacher of the law? "},{"kind":"footnote","marker":1,"text":"Or scholar"},{"kind":"text","text":" Where is the debater of this age? "},{"kind":"crossref","label":"Lk 16:8","book":"Luk","chapter":16,"verse":8,"letter":"a"},{"kind":"text","text":" Hasn’t God made the world’s wisdom foolish? "}],"crossRefs":[{"label":"Lk 16:8","book":"Luk","chapter":16,"verse":8}],"footnotes":[{"marker":1,"text":"Or scholar"}]},{"verseId":"a556c5305ee15c3f-01:1Co:1:21","parts":[{"kind":"text","text":"For since, in God’s wisdom, the world did not know God through wisdom, God was pleased to save those who believe through the foolishness of what is preached. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:22","parts":[{"kind":"text","text":"For the Jews ask for signs "},{"kind":"crossref","label":"Mt 12:38","book":"Mat","chapter":12,"verse":38,"letter":"a"},{"kind":"text","text":" and the Greeks seek wisdom, "}],"crossRefs":[{"label":"Mt 12:38","book":"Mat","chapter":12,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:23","parts":[{"kind":"text","text":"but we preach Christ crucified, "},{"kind":"crossref","label":"Lk 23:26","book":"Luk","chapter":23,"verse":26,"letter":"a"},{"kind":"crossref","label":"1Co 2:2","book":"1Co","chapter":2,"verse":2,"letter":"b"},{"kind":"crossref","label":"Gl 3:1","book":"Gal","chapter":3,"verse":1,"letter":"c"},{"kind":"crossref","label":"Gl 5:11","book":"Gal","chapter":5,"verse":11,"letter":"d"},{"kind":"text","text":" a stumbling block to the Jews and foolishness to the Gentiles. "},{"kind":"footnote","marker":2,"text":"Other mss read Greeks"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 23:26","book":"Luk","chapter":23,"verse":26},{"label":"1Co 2:2","book":"1Co","chapter":2,"verse":2},{"label":"Gl 3:1","book":"Gal","chapter":3,"verse":1},{"label":"Gl 5:11","book":"Gal","chapter":5,"verse":11}],"footnotes":[{"marker":2,"text":"Other mss read Greeks"}]},{"verseId":"a556c5305ee15c3f-01:1Co:1:24","parts":[{"kind":"text","text":"Yet to those who are called, "},{"kind":"crossref","label":"Rm 1:6","book":"Rom","chapter":1,"verse":6,"letter":"a"},{"kind":"text","text":" both Jews and Greeks, Christ is the power of God and the wisdom of God, "}],"crossRefs":[{"label":"Rm 1:6","book":"Rom","chapter":1,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:25","parts":[{"kind":"text","text":"because God’s foolishness is wiser than human wisdom, and God’s weakness is stronger than human strength."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:26","parts":[{"kind":"text","text":"Brothers and sisters, consider your calling: Not many were wise from a human perspective, "},{"kind":"footnote","marker":1,"text":"Lit wise according to the flesh"},{"kind":"text","text":" not many powerful, "},{"kind":"crossref","label":"Ac 25:5","book":"Act","chapter":25,"verse":5,"letter":"a"},{"kind":"text","text":" not many of noble birth. "}],"crossRefs":[{"label":"Ac 25:5","book":"Act","chapter":25,"verse":5}],"footnotes":[{"marker":1,"text":"Lit wise according to the flesh"}]},{"verseId":"a556c5305ee15c3f-01:1Co:1:27","parts":[{"kind":"text","text":"Instead, God has chosen "},{"kind":"crossref","label":"Mt 24:22","book":"Mat","chapter":24,"verse":22,"letter":"a"},{"kind":"crossref","label":"Eph 1:4","book":"Eph","chapter":1,"verse":4,"letter":"b"},{"kind":"text","text":" what is foolish in the world to shame the wise, and God has chosen what is weak in the world to shame the strong. "}],"crossRefs":[{"label":"Mt 24:22","book":"Mat","chapter":24,"verse":22},{"label":"Eph 1:4","book":"Eph","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:28","parts":[{"kind":"text","text":"God has chosen what is insignificant and despised in the world "},{"kind":"crossref","label":"Lk 18:9","book":"Luk","chapter":18,"verse":9,"letter":"a"},{"kind":"text","text":" —what is viewed as nothing —to bring to nothing what is viewed as something, "}],"crossRefs":[{"label":"Lk 18:9","book":"Luk","chapter":18,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:29","parts":[{"kind":"text","text":"so that no one "},{"kind":"footnote","marker":2,"text":"Lit that not all flesh"},{"kind":"text","text":" may boast in his presence. "},{"kind":"crossref","label":"Ac 7:46","book":"Act","chapter":7,"verse":46,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 7:46","book":"Act","chapter":7,"verse":46}],"footnotes":[{"marker":2,"text":"Lit that not all flesh"}]},{"verseId":"a556c5305ee15c3f-01:1Co:1:30","parts":[{"kind":"text","text":"It is from him that you are in Christ Jesus, who became wisdom from God for us —our righteousness, "},{"kind":"crossref","label":"Mt 6:33","book":"Mat","chapter":6,"verse":33,"letter":"a"},{"kind":"crossref","label":"Rm 1:17","book":"Rom","chapter":1,"verse":17,"letter":"b"},{"kind":"crossref","label":"2Pt 1:1","book":"2Pe","chapter":1,"verse":1,"letter":"c"},{"kind":"text","text":" sanctification, "},{"kind":"crossref","label":"1Th 4:3","book":"1Th","chapter":4,"verse":3,"letter":"d"},{"kind":"text","text":" and redemption "},{"kind":"crossref","label":"Eph 1:7","book":"Eph","chapter":1,"verse":7,"letter":"e"},{"kind":"text","text":" — "}],"crossRefs":[{"label":"Mt 6:33","book":"Mat","chapter":6,"verse":33},{"label":"Rm 1:17","book":"Rom","chapter":1,"verse":17},{"label":"2Pt 1:1","book":"2Pe","chapter":1,"verse":1},{"label":"1Th 4:3","book":"1Th","chapter":4,"verse":3},{"label":"Eph 1:7","book":"Eph","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:1:31","parts":[{"kind":"text","text":"in order that, as it is written: "},{"kind":"crossref","label":"Mk 1:2","book":"Mrk","chapter":1,"verse":2,"letter":"a"},{"kind":"text","text":" Let the one who boasts, boast in the Lord."},{"kind":"crossref","label":"Jr 9:24","book":"Jer","chapter":9,"verse":24,"letter":"b"},{"kind":"crossref","label":"Jr 9:23–24","book":"Jer","chapter":9,"verse":23,"letter":"c"}],"crossRefs":[{"label":"Mk 1:2","book":"Mrk","chapter":1,"verse":2},{"label":"Jr 9:24","book":"Jer","chapter":9,"verse":24},{"label":"Jr 9:23–24","book":"Jer","chapter":9,"verse":23}],"footnotes":[]}]},"cachedAt":1783279656944}