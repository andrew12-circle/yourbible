5,"verse":2,"letter":"i"},{"kind":"crossref","label":"1Th 5:10","book":"1Th","chapter":5,"verse":10,"letter":"j"},{"kind":"text","text":" is ruined "},{"kind":"footnote","marker":3,"text":"Or destroyed"},{"kind":"crossref","label":"Heb 6:8","book":"Heb","chapter":6,"verse":8,"letter":"k"},{"kind":"text","text":" by your knowledge. "},{"kind":"crossref","label":"Mt 25:45","book":"Mat","chapter":25,"verse":45,"letter":"l"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 11:51","book":"Jhn","chapter":11,"verse":51},{"label":"Rm 5:6","book":"Rom","chapter":5,"verse":6},{"label":"Rm 5:8","book":"Rom","chapter":5,"verse":8},{"label":"Rm 8:34","book":"Rom","chapter":8,"verse":34},{"label":"Rm 14:9","book":"Rom","chapter":14,"verse":9},{"label":"Rm 14:15","book":"Rom","chapter":14,"verse":15},{"label":"1Co 15:3","book":"1Co","chapter":15,"verse":3},{"label":"Gl 2:21","book":"Gal","chapter":2,"verse":21},{"label":"Eph 5:2","book":"Eph","chapter":5,"verse":2},{"label":"1Th 5:10","book":"1Th","chapter":5,"verse":10},{"label":"Heb 6:8","book":"Heb","chapter":6,"verse":8},{"label":"Mt 25:45","book":"Mat","chapter":25,"verse":45}],"footnotes":[{"marker":3,"text":"Or destroyed"}]},{"verseId":"a556c5305ee15c3f-01:1Co:8:12","parts":[{"kind":"text","text":"Now when you sin like this against brothers and sisters and wound their weak conscience, you are sinning against Christ. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:8:13","parts":[{"kind":"text","text":"Therefore, if food causes my brother or sister to fall, I will never again eat meat, "},{"kind":"crossref","label":"Dt 12:15","book":"Deu","chapter":12,"verse":15,"letter":"a"},{"kind":"text","text":" so that I won’t cause my brother or sister to fall."}],"crossRefs":[{"label":"Dt 12:15","book":"Deu","chapter":12,"verse":15}],"footnotes":[]}]},"cachedAt":1783099538203}