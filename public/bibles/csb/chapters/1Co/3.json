s 94:11","book":"Psa","chapter":94,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:3:21","parts":[{"kind":"text","text":"So let no one boast in human leaders, for everything is yours "},{"kind":"crossref","label":"Rm 8:32","book":"Rom","chapter":8,"verse":32,"letter":"a"},{"kind":"text","text":" — "}],"crossRefs":[{"label":"Rm 8:32","book":"Rom","chapter":8,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:3:22","parts":[{"kind":"text","text":"whether Paul or Apollos or Cephas "},{"kind":"crossref","label":"Jn 1:42","book":"Jhn","chapter":1,"verse":42,"letter":"a"},{"kind":"text","text":" or the world or life "},{"kind":"crossref","label":"1Jn 5:12","book":"1Jn","chapter":5,"verse":12,"letter":"b"},{"kind":"text","text":" or death "},{"kind":"crossref","label":"Mt 10:21","book":"Mat","chapter":10,"verse":21,"letter":"c"},{"kind":"crossref","label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51,"letter":"d"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"e"},{"kind":"text","text":" or things present or things to come "},{"kind":"crossref","label":"Rm 8:38","book":"Rom","chapter":8,"verse":38,"letter":"f"},{"kind":"text","text":" —everything is yours, "}],"crossRefs":[{"label":"Jn 1:42","book":"Jhn","chapter":1,"verse":42},{"label":"1Jn 5:12","book":"1Jn","chapter":5,"verse":12},{"label":"Mt 10:21","book":"Mat","chapter":10,"verse":21},{"label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10},{"label":"Rm 8:38","book":"Rom","chapter":8,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Co:3:23","parts":[{"kind":"text","text":"and you belong to Christ, "},{"kind":"crossref","label":"Nm 3:12","book":"Num","chapter":3,"verse":12,"letter":"a"},{"kind":"text","text":" and Christ belongs to God."}],"crossRefs":[{"label":"Nm 3:12","book":"Num","chapter":3,"verse":12}],"footnotes":[]}]},"cachedAt":1783099536702}