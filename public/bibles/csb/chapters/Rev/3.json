letter":"l"},{"kind":"crossref","label":"Heb 3:7","book":"Heb","chapter":3,"verse":7,"letter":"m"},{"kind":"crossref","label":"Heb 10:15","book":"Heb","chapter":10,"verse":15,"letter":"n"},{"kind":"crossref","label":"Rv 14:13","book":"Rev","chapter":14,"verse":13,"letter":"o"},{"kind":"crossref","label":"Rv 22:17","book":"Rev","chapter":22,"verse":17,"letter":"p"},{"kind":"text","text":" to the churches."}],"crossRefs":[{"label":"Mt 11:15","book":"Mat","chapter":11,"verse":15},{"label":"Mt 13:9","book":"Mat","chapter":13,"verse":9},{"label":"Mt 13:43","book":"Mat","chapter":13,"verse":43},{"label":"Lk 8:8","book":"Luk","chapter":8,"verse":8},{"label":"Lk 14:35","book":"Luk","chapter":14,"verse":35},{"label":"Ac 8:29","book":"Act","chapter":8,"verse":29},{"label":"Ac 10:19","book":"Act","chapter":10,"verse":19},{"label":"Ac 11:12","book":"Act","chapter":11,"verse":12},{"label":"Ac 13:2","book":"Act","chapter":13,"verse":2},{"label":"Ac 21:11","book":"Act","chapter":21,"verse":11},{"label":"Ac 28:25","book":"Act","chapter":28,"verse":25},{"label":"1Tm 4:1","book":"1Ti","chapter":4,"verse":1},{"label":"Heb 3:7","book":"Heb","chapter":3,"verse":7},{"label":"Heb 10:15","book":"Heb","chapter":10,"verse":15},{"label":"Rv 14:13","book":"Rev","chapter":14,"verse":13},{"label":"Rv 22:17","book":"Rev","chapter":22,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:7","parts":[{"kind":"text","text":"“Write to the angel of the church in Philadelphia: Thus says the Holy One, the true one,"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"a"},{"kind":"crossref","label":"Rv 6:10","book":"Rev","chapter":6,"verse":10,"letter":"b"},{"kind":"crossref","label":"Rv 19:11","book":"Rev","chapter":19,"verse":11,"letter":"c"},{"kind":"text","text":" the one who has the key of David, who opens and no one will close, and who closes and no one opens:"},{"kind":"crossref","label":"Is 22:22","book":"Isa","chapter":22,"verse":22,"letter":"d"},{"kind":"crossref","label":"Mt 16:19","book":"Mat","chapter":16,"verse":19,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20},{"label":"Rv 6:10","book":"Rev","chapter":6,"verse":10},{"label":"Rv 19:11","book":"Rev","chapter":19,"verse":11},{"label":"Is 22:22","book":"Isa","chapter":22,"verse":22},{"label":"Mt 16:19","book":"Mat","chapter":16,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:8","parts":[{"kind":"text","text":"I know your works. Look, I have placed before you an open door that no one can close because you have but little power; yet you have kept my word and have not denied my name."},{"kind":"crossref","label":"Ac 14:27","book":"Act","chapter":14,"verse":27,"letter":"a"},{"kind":"crossref","label":"1Co 16:9","book":"1Co","chapter":16,"verse":9,"letter":"b"},{"kind":"crossref","label":"2Co 2:12","book":"2Co","chapter":2,"verse":12,"letter":"c"},{"kind":"crossref","label":"Col 4:3","book":"Col","chapter":4,"verse":3,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 14:27","book":"Act","chapter":14,"verse":27},{"label":"1Co 16:9","book":"1Co","chapter":16,"verse":9},{"label":"2Co 2:12","book":"2Co","chapter":2,"verse":12},{"label":"Col 4:3","book":"Col","chapter":4,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:9","parts":[{"kind":"text","text":"Note this: I will make those from the synagogue of Satan, who claim to be Jews and are not, but are lying —I will make them come and bow down at your feet,"},{"kind":"crossref","label":"Is 45:14","book":"Isa","chapter":45,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 49:23","book":"Isa","chapter":49,"verse":23,"letter":"b"},{"kind":"crossref","label":"Is 60:14","book":"Isa","chapter":60,"verse":14,"letter":"c"},{"kind":"crossref","label":"1Co 14:25","book":"1Co","chapter":14,"verse":25,"letter":"d"},{"kind":"text","text":" and they will know that I have loved you."},{"kind":"crossref","label":"Is 43:4","book":"Isa","chapter":43,"verse":4,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 45:14","book":"Isa","chapter":45,"verse":14},{"label":"Is 49:23","book":"Isa","chapter":49,"verse":23},{"label":"Is 60:14","book":"Isa","chapter":60,"verse":14},{"label":"1Co 14:25","book":"1Co","chapter":14,"verse":25},{"label":"Is 43:4","book":"Isa","chapter":43,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:10","parts":[{"kind":"text","text":"Because you have kept my command to endure, I will also keep you from the hour of testing"},{"kind":"crossref","label":"Lk 8:13","book":"Luk","chapter":8,"verse":13,"letter":"a"},{"kind":"crossref","label":"Heb 3:8","book":"Heb","chapter":3,"verse":8,"letter":"b"},{"kind":"crossref","label":"1Pt 4:12","book":"1Pe","chapter":4,"verse":12,"letter":"c"},{"kind":"text","text":" that is going to come on the whole world to test those who live on the earth."},{"kind":"crossref","label":"Rv 6:10","book":"Rev","chapter":6,"verse":10,"letter":"d"},{"kind":"crossref","label":"Rv 8:13","book":"Rev","chapter":8,"verse":13,"letter":"e"},{"kind":"crossref","label":"Rv 11:10","book":"Rev","chapter":11,"verse":10,"letter":"f"},{"kind":"crossref","label":"Rv 13:8","book":"Rev","chapter":13,"verse":8,"letter":"g"},{"kind":"crossref","label":"Rv 13:14","book":"Rev","chapter":13,"verse":14,"letter":"h"},{"kind":"crossref","label":"Rv 17:8","book":"Rev","chapter":17,"verse":8,"letter":"i"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 8:13","book":"Luk","chapter":8,"verse":13},{"label":"Heb 3:8","book":"Heb","chapter":3,"verse":8},{"label":"1Pt 4:12","book":"1Pe","chapter":4,"verse":12},{"label":"Rv 6:10","book":"Rev","chapter":6,"verse":10},{"label":"Rv 8:13","book":"Rev","chapter":8,"verse":13},{"label":"Rv 11:10","book":"Rev","chapter":11,"verse":10},{"label":"Rv 13:8","book":"Rev","chapter":13,"verse":8},{"label":"Rv 13:14","book":"Rev","chapter":13,"verse":14},{"label":"Rv 17:8","book":"Rev","chapter":17,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:11","parts":[{"kind":"text","text":"I am coming soon."},{"kind":"crossref","label":"Rv 22:7","book":"Rev","chapter":22,"verse":7,"letter":"a"},{"kind":"crossref","label":"Rv 22:12","book":"Rev","chapter":22,"verse":12,"letter":"b"},{"kind":"crossref","label":"Rv 22:20","book":"Rev","chapter":22,"verse":20,"letter":"c"},{"kind":"text","text":" Hold on to what you have,"},{"kind":"crossref","label":"Rv 2:25","book":"Rev","chapter":2,"verse":25,"letter":"d"},{"kind":"text","text":" so that no one takes your crown."},{"kind":"crossref","label":"1Co 9:25","book":"1Co","chapter":9,"verse":25,"letter":"e"},{"kind":"crossref","label":"1Th 2:19","book":"1Th","chapter":2,"verse":19,"letter":"f"},{"kind":"crossref","label":"2Tm 4:8","book":"2Ti","chapter":4,"verse":8,"letter":"g"},{"kind":"crossref","label":"Jms 1:12","book":"Jas","chapter":1,"verse":12,"letter":"h"},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"i"}],"crossRefs":[{"label":"Rv 22:7","book":"Rev","chapter":22,"verse":7},{"label":"Rv 22:12","book":"Rev","chapter":22,"verse":12},{"label":"Rv 22:20","book":"Rev","chapter":22,"verse":20},{"label":"Rv 2:25","book":"Rev","chapter":2,"verse":25},{"label":"1Co 9:25","book":"1Co","chapter":9,"verse":25},{"label":"1Th 2:19","book":"1Th","chapter":2,"verse":19},{"label":"2Tm 4:8","book":"2Ti","chapter":4,"verse":8},{"label":"Jms 1:12","book":"Jas","chapter":1,"verse":12},{"label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:12","parts":[{"kind":"text","text":"“The one who conquers I will make a pillar"},{"kind":"crossref","label":"1Kg 7:21","book":"1Ki","chapter":7,"verse":21,"letter":"a"},{"kind":"crossref","label":"2Ch 3:17","book":"2Ch","chapter":3,"verse":17,"letter":"b"},{"kind":"crossref","label":"Jr 1:18","book":"Jer","chapter":1,"verse":18,"letter":"c"},{"kind":"crossref","label":"Gl 2:9","book":"Gal","chapter":2,"verse":9,"letter":"d"},{"kind":"text","text":" in the temple of my God, and he will never go out again. I will write on him the name of my God and the name of the city of my God —the new Jerusalem,"},{"kind":"crossref","label":"Ezk 48:35","book":"Ezk","chapter":48,"verse":35,"letter":"e"},{"kind":"crossref","label":"Gl 4:26","book":"Gal","chapter":4,"verse":26,"letter":"f"},{"kind":"crossref","label":"Heb 12:22","book":"Heb","chapter":12,"verse":22,"letter":"g"},{"kind":"crossref","label":"Rv 21:2","book":"Rev","chapter":21,"verse":2,"letter":"h"},{"kind":"text","text":" which comes down out of heaven from my God —and my new name."},{"kind":"crossref","label":"Rv 2:17","book":"Rev","chapter":2,"verse":17,"letter":"i"},{"kind":"crossref","label":"Rv 7:3","book":"Rev","chapter":7,"verse":3,"letter":"j"},{"kind":"crossref","label":"Rv 14:1","book":"Rev","chapter":14,"verse":1,"letter":"k"},{"kind":"crossref","label":"Rv 22:4","book":"Rev","chapter":22,"verse":4,"letter":"l"}],"crossRefs":[{"label":"1Kg 7:21","book":"1Ki","chapter":7,"verse":21},{"label":"2Ch 3:17","book":"2Ch","chapter":3,"verse":17},{"label":"Jr 1:18","book":"Jer","chapter":1,"verse":18},{"label":"Gl 2:9","book":"Gal","chapter":2,"verse":9},{"label":"Ezk 48:35","book":"Ezk","chapter":48,"verse":35},{"label":"Gl 4:26","book":"Gal","chapter":4,"verse":26},{"label":"Heb 12:22","book":"Heb","chapter":12,"verse":22},{"label":"Rv 21:2","book":"Rev","chapter":21,"verse":2},{"label":"Rv 2:17","book":"Rev","chapter":2,"verse":17},{"label":"Rv 7:3","book":"Rev","chapter":7,"verse":3},{"label":"Rv 14:1","book":"Rev","chapter":14,"verse":1},{"label":"Rv 22:4","book":"Rev","chapter":22,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:13","parts":[{"kind":"text","text":"“Let anyone who has ears to hear listen to what the Spirit says to the churches."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:14","parts":[{"kind":"text","text":"“Write to the angel of the church in Laodicea: Thus says the Amen,"},{"kind":"crossref","label":"2Co 1:20","book":"2Co","chapter":1,"verse":20,"letter":"a"},{"kind":"text","text":" the faithful and true witness, the originator"},{"kind":"footnote","marker":1,"text":"Or beginning, or ruler"},{"kind":"crossref","label":"Mk 10:6","book":"Mrk","chapter":10,"verse":6,"letter":"b"},{"kind":"crossref","label":"Mk 13:19","book":"Mrk","chapter":13,"verse":19,"letter":"c"},{"kind":"crossref","label":"Jn 1:1–5","book":"Jhn","chapter":1,"verse":1,"letter":"d"},{"kind":"crossref","label":"Col 1:18","book":"Col","chapter":1,"verse":18,"letter":"e"},{"kind":"crossref","label":"2Pt 3:4","book":"2Pe","chapter":3,"verse":4,"letter":"f"},{"kind":"text","text":" of God’s creation: "}],"crossRefs":[{"label":"2Co 1:20","book":"2Co","chapter":1,"verse":20},{"label":"Mk 10:6","book":"Mrk","chapter":10,"verse":6},{"label":"Mk 13:19","book":"Mrk","chapter":13,"verse":19},{"label":"Jn 1:1–5","book":"Jhn","chapter":1,"verse":1},{"label":"Col 1:18","book":"Col","chapter":1,"verse":18},{"label":"2Pt 3:4","book":"2Pe","chapter":3,"verse":4}],"footnotes":[{"marker":1,"text":"Or beginning, or ruler"}]},{"verseId":"a556c5305ee15c3f-01:Rev:3:15","parts":[{"kind":"text","text":"I know your works, that you are neither cold nor hot. I wish that you were cold or hot. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:16","parts":[{"kind":"text","text":"So, because you are lukewarm, and neither hot nor cold, I am going to vomit"},{"kind":"footnote","marker":2,"text":"Or spit"},{"kind":"text","text":" you out of my mouth. "}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Or spit"}]},{"verseId":"a556c5305ee15c3f-01:Rev:3:17","parts":[{"kind":"text","text":"For you say, ‘I’m rich; I have become wealthy and need nothing,’"},{"kind":"crossref","label":"Hs 12:8","book":"Hos","chapter":12,"verse":8,"letter":"a"},{"kind":"crossref","label":"Zch 11:5","book":"Zec","chapter":11,"verse":5,"letter":"b"},{"kind":"crossref","label":"1Co 4:8","book":"1Co","chapter":4,"verse":8,"letter":"c"},{"kind":"text","text":" and you don’t realize that you are wretched, pitiful, poor, blind, and naked. "}],"crossRefs":[{"label":"Hs 12:8","book":"Hos","chapter":12,"verse":8},{"label":"Zch 11:5","book":"Zec","chapter":11,"verse":5},{"label":"1Co 4:8","book":"1Co","chapter":4,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:18","parts":[{"kind":"text","text":"I advise you to buy from me gold refined in the fire so that you may be rich,"},{"kind":"crossref","label":"Zch 13:9","book":"Zec","chapter":13,"verse":9,"letter":"a"},{"kind":"crossref","label":"1Pt 1:7","book":"1Pe","chapter":1,"verse":7,"letter":"b"},{"kind":"text","text":" white clothes so that you may be dressed and your shameful nakedness not be exposed,"},{"kind":"crossref","label":"Gn 2:25","book":"Gen","chapter":2,"verse":25,"letter":"c"},{"kind":"crossref","label":"Is 20:4","book":"Isa","chapter":20,"verse":4,"letter":"d"},{"kind":"crossref","label":"Ezk 23:29","book":"Ezk","chapter":23,"verse":29,"letter":"e"},{"kind":"crossref","label":"Rv 16:15","book":"Rev","chapter":16,"verse":15,"letter":"f"},{"kind":"text","text":" and ointment to spread on your eyes so that you may see. "}],"crossRefs":[{"label":"Zch 13:9","book":"Zec","chapter":13,"verse":9},{"label":"1Pt 1:7","book":"1Pe","chapter":1,"verse":7},{"label":"Gn 2:25","book":"Gen","chapter":2,"verse":25},{"label":"Is 20:4","book":"Isa","chapter":20,"verse":4},{"label":"Ezk 23:29","book":"Ezk","chapter":23,"verse":29},{"label":"Rv 16:15","book":"Rev","chapter":16,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:19","parts":[{"kind":"text","text":"As many as I love, I rebuke and discipline."},{"kind":"crossref","label":"Heb 12:26","book":"Heb","chapter":12,"verse":26,"letter":"a"},{"kind":"text","text":" So be zealous and repent. "}],"crossRefs":[{"label":"Heb 12:26","book":"Heb","chapter":12,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:20","parts":[{"kind":"text","text":"See! I stand at the door and knock. If anyone hears my voice and opens the door, I will come in to him and eat with him, and he with me."},{"kind":"crossref","label":"Lk 24:29–30","book":"Luk","chapter":24,"verse":29,"letter":"a"}],"crossRefs":[{"label":"Lk 24:29–30","book":"Luk","chapter":24,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:21","parts":[{"kind":"text","text":"“To the one who conquers I will give the right to sit with me on my throne,"},{"kind":"crossref","label":"Mt 19:28","book":"Mat","chapter":19,"verse":28,"letter":"a"},{"kind":"crossref","label":"2Tm 2:12","book":"2Ti","chapter":2,"verse":12,"letter":"b"},{"kind":"crossref","label":"Rv 20:4","book":"Rev","chapter":20,"verse":4,"letter":"c"},{"kind":"text","text":" just as I also conquered and sat down with my Father on his throne."}],"crossRefs":[{"label":"Mt 19:28","book":"Mat","chapter":19,"verse":28},{"label":"2Tm 2:12","book":"2Ti","chapter":2,"verse":12},{"label":"Rv 20:4","book":"Rev","chapter":20,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:3:22","parts":[{"kind":"text","text":"“Let anyone who has ears to hear listen to what the Spirit says to the churches.”"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279688366}