ook":"Rev","chapter":3,"verse":12,"letter":"h"},{"kind":"crossref","label":"Rv 3:21","book":"Rev","chapter":3,"verse":21,"letter":"i"},{"kind":"text","text":" will be dressed in white clothes,"},{"kind":"crossref","label":"Mt 17:2","book":"Mat","chapter":17,"verse":2,"letter":"j"},{"kind":"crossref","label":"Rv 3:18","book":"Rev","chapter":3,"verse":18,"letter":"k"},{"kind":"crossref","label":"Rv 4:4","book":"Rev","chapter":4,"verse":4,"letter":"l"},{"kind":"text","text":" and I will never erase his name from the book of life"},{"kind":"crossref","label":"Ex 32:32–33","book":"Exo","chapter":32,"verse":32,"letter":"m"},{"kind":"crossref","label":"Ps 69:28","book":"Psa","chapter":69,"verse":28,"letter":"n"},{"kind":"crossref","label":"Dn 12:1","book":"Dan","chapter":12,"verse":1,"letter":"o"},{"kind":"crossref","label":"Rv 13:8","book":"Rev","chapter":13,"verse":8,"letter":"p"},{"kind":"crossref","label":"Rv 17:8","book":"Rev","chapter":17,"verse":8,"letter":"q"},{"kind":"crossref","label":"Rv 20:12","book":"Rev","chapter":20,"verse":12,"letter":"r"},{"kind":"crossref","label":"Rv 20:15","book":"Rev","chapter":20,"verse":15,"letter":"s"},{"kind":"crossref","label":"Rv 21:27","book":"Rev","chapter":21,"verse":27,"letter":"t"},{"kind":"text","text":" but will acknowledge his name before my Father and before his angels."},{"kind":"crossref","label":"Mt 10:32","book":"Mat","chapter":10,"verse":32,"letter":"u"},{"kind":"crossref","label":"Lk 12:8","book":"Luk","chapter":12,"verse":8,"letter":"v"}],"crossRefs":[{"label":"1Jn 2:13–14","book":"1Jn","chapter":2,"verse":13},{"label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4},{"label":"1Jn 5:4–5","book":"1Jn","chapter":5,"verse":4},{"label":"Rv 2:7","book":"Rev","chapter":2,"verse":7},{"label":"Rv 2:11","book":"Rev","chapter":2,"verse":11},{"label":"Rv 2:17","book":"Rev","chapter":2,"verse":17},{"label":"Rv 2:26","book":"Rev","chapter":2,"verse":26},{"label":"Rv 3:12","book":"Rev","chapter":3,"verse":12},{"label":"Rv 3:21","b