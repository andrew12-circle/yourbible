bel":"Ps 121:2","book":"Psa","chapter":121,"verse":2},{"label":"Ps 124:8","book":"Psa","chapter":124,"verse":8},{"label":"Ps 134:3","book":"Psa","chapter":134,"verse":3},{"label":"Ps 146:6","book":"Psa","chapter":146,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:8","parts":[{"kind":"text","text":"And another, a second angel, followed, saying, “It has fallen, Babylon the Great "},{"kind":"crossref","label":"Dn 4:30","book":"Dan","chapter":4,"verse":30,"letter":"a"},{"kind":"crossref","label":"Rv 16:19","book":"Rev","chapter":16,"verse":19,"letter":"b"},{"kind":"crossref","label":"Rv 17:5","book":"Rev","chapter":17,"verse":5,"letter":"c"},{"kind":"crossref","label":"Rv 18:2","book":"Rev","chapter":18,"verse":2,"letter":"d"},{"kind":"text","text":" has fallen. "},{"kind":"footnote","marker":1,"text":"Other mss omit the second has fallen"},{"kind":"text","text":" She made all the nations drink the wine of her sexual immorality, "},{"kind":"footnote","marker":2,"text":"Or wine of her passionate immorality"},{"kind":"text","text":" which brings wrath.” "},{"kind":"crossref","label":"Is 21:9","book":"Isa","chapter":21,"verse":9,"letter":"e"},{"kind":"crossref","label":"Jr 51:7–8","book":"Jer","chapter":51,"verse":7,"letter":"f"},{"kind":"crossref","label":"Jr 51:49","book":"Jer","chapter":51,"verse":49,"letter":"g"},{"kind":"crossref","label":"Rv 17:2","book":"Rev","chapter":17,"verse":2,"letter":"h"},{"kind":"crossref","label":"Rv 17:4","book":"Rev","chapter":17,"verse":4,"letter":"i"},{"kind":"crossref","label":"Rv 18:2–3","book":"Rev","chapter":18,"verse":2,"letter":"j"}],"crossRefs":[{"label":"Dn 4:30","book":"Dan","chapter":4,"verse":30},{"label":"Rv 16:19","book":"Rev","chapter":16,"verse":19},{"label":"Rv 17:5","book":"Rev","chapter":17,"verse":5},{"label":"Rv 18:2","book":"Rev","chapter":18,"verse":2},{"label":"Is 21:9","book":"Isa","chapter":21,"verse":9},{"label":"Jr 51:7–8","book":"Jer","chapter":51,"verse":7},{"label":"Jr 51:49","book":"Jer","chapter":51,"verse":49},{"label":"Rv 17:2","book":"Rev","chapter":17,"verse":2},{"label":"Rv 17:4","book":"Rev","chapter":17,"verse":4},{"label":"Rv 18:2–3","book":"Rev","chapter":18,"verse":2}],"footnotes":[{"marker":1,"text":"Other mss omit the second has fallen"},{"marker":2,"text":"Or wine of her passionate immorality"}]},{"verseId":"a556c5305ee15c3f-01:Rev:14:9","parts":[{"kind":"text","text":"And another, a third angel, followed them and spoke with a loud voice: “If anyone worships the beast and its image and receives a mark on his forehead or on his hand, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:10","parts":[{"kind":"text","text":"he will also drink the wine of God’s wrath, which is poured full strength into the cup of his anger. "},{"kind":"crossref","label":"Ps 75:8","book":"Psa","chapter":75,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 51:17","book":"Isa","chapter":51,"verse":17,"letter":"b"},{"kind":"crossref","label":"Jr 25:15–17","book":"Jer","chapter":25,"verse":15,"letter":"c"},{"kind":"crossref","label":"Rv 17:2","book":"Rev","chapter":17,"verse":2,"letter":"d"},{"kind":"crossref","label":"Rv 17:4","book":"Rev","chapter":17,"verse":4,"letter":"e"},{"kind":"crossref","label":"Rv 18:2–3","book":"Rev","chapter":18,"verse":2,"letter":"f"},{"kind":"text","text":" He will be tormented with fire and sulfur "},{"kind":"crossref","label":"Lk 17:29","book":"Luk","chapter":17,"verse":29,"letter":"g"},{"kind":"crossref","label":"Rv 20:10","book":"Rev","chapter":20,"verse":10,"letter":"h"},{"kind":"crossref","label":"Rv 21:8","book":"Rev","chapter":21,"verse":8,"letter":"i"},{"kind":"text","text":" in the sight of the holy angels and in the sight of the Lamb, "}],"crossRefs":[{"label":"Ps 75:8","book":"Psa","chapter":75,"verse":8},{"label":"Is 51:17","book":"Isa","chapter":51,"verse":17},{"label":"Jr 25:15–17","book":"Jer","chapter":25,"verse":15},{"label":"Rv 17:2","book":"Rev","chapter":17,"verse":2},{"label":"Rv 17:4","book":"Rev","chapter":17,"verse":4},{"label":"Rv 18:2–3","book":"Rev","chapter":18,"verse":2},{"label":"Lk 17:29","book":"Luk","chapter":17,"verse":29},{"label":"Rv 20:10","book":"Rev","chapter":20,"verse":10},{"label":"Rv 21:8","book":"Rev","chapter":21,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:11","parts":[{"kind":"text","text":"and the smoke of their torment will go up forever and ever. "},{"kind":"crossref","label":"Is 1:31","book":"Isa","chapter":1,"verse":31,"letter":"a"},{"kind":"crossref","label":"Is 34:10","book":"Isa","chapter":34,"verse":10,"letter":"b"},{"kind":"crossref","label":"Is 66:24","book":"Isa","chapter":66,"verse":24,"letter":"c"},{"kind":"crossref","label":"Rv 19:3","book":"Rev","chapter":19,"verse":3,"letter":"d"},{"kind":"text","text":" There is no rest "},{"kind":"footnote","marker":1,"text":"Or They have no rest"},{"kind":"crossref","label":"Ps 22:2","book":"Psa","chapter":22,"verse":2,"letter":"e"},{"kind":"crossref","label":"Is 23:12","book":"Isa","chapter":23,"verse":12,"letter":"f"},{"kind":"crossref","label":"Is 62:6","book":"Isa","chapter":62,"verse":6,"letter":"g"},{"kind":"crossref","label":"Jr 45:3","book":"Jer","chapter":45,"verse":3,"letter":"h"},{"kind":"crossref","label":"Lm 2:18","book":"Lam","chapter":2,"verse":18,"letter":"i"},{"kind":"text","text":" day or night for those who worship the beast and its image, or anyone who receives the mark "},{"kind":"crossref","label":"Gn 4:15","book":"Gen","chapter":4,"verse":15,"letter":"j"},{"kind":"crossref","label":"Ex 12:13","book":"Exo","chapter":12,"verse":13,"letter":"k"},{"kind":"crossref","label":"Ezk 9:4","book":"Ezk","chapter":9,"verse":4,"letter":"l"},{"kind":"crossref","label":"Ezk 9:6","book":"Ezk","chapter":9,"verse":6,"letter":"m"},{"kind":"crossref","label":"Rv 13:16","book":"Rev","chapter":13,"verse":16,"letter":"n"},{"kind":"crossref","label":"Rv 16:2","book":"Rev","chapter":16,"verse":2,"letter":"o"},{"kind":"crossref","label":"Rv 19:20","book":"Rev","chapter":19,"verse":20,"letter":"p"},{"kind":"text","text":" of its name. "}],"crossRefs":[{"label":"Is 1:31","book":"Isa","chapter":1,"verse":31},{"label":"Is 34:10","book":"Isa","chapter":34,"verse":10},{"label":"Is 66:24","book":"Isa","chapter":66,"verse":24},{"label":"Rv 19:3","book":"Rev","chapter":19,"verse":3},{"label":"Ps 22:2","book":"Psa","chapter":22,"verse":2},{"label":"Is 23:12","book":"Isa","chapter":23,"verse":12},{"label":"Is 62:6","book":"Isa","chapter":62,"verse":6},{"label":"Jr 45:3","book":"Jer","chapter":45,"verse":3},{"label":"Lm 2:18","book":"Lam","chapter":2,"verse":18},{"label":"Gn 4:15","book":"Gen","chapter":4,"verse":15},{"label":"Ex 12:13","book":"Exo","chapter":12,"verse":13},{"label":"Ezk 9:4","book":"Ezk","chapter":9,"verse":4},{"label":"Ezk 9:6","book":"Ezk","chapter":9,"verse":6},{"label":"Rv 13:16","book":"Rev","chapter":13,"verse":16},{"label":"Rv 16:2","book":"Rev","chapter":16,"verse":2},{"label":"Rv 19:20","book":"Rev","chapter":19,"verse":20}],"footnotes":[{"marker":1,"text":"Or They have no rest"}]},{"verseId":"a556c5305ee15c3f-01:Rev:14:12","parts":[{"kind":"text","text":"This calls for endurance from the saints, "},{"kind":"crossref","label":"Rv 13:10","book":"Rev","chapter":13,"verse":10,"letter":"a"},{"kind":"text","text":" who keep God’s commands and their faith in Jesus.” "},{"kind":"footnote","marker":2,"text":"Or and the faith of Jesus, or and faithfulness to Jesus"}],"crossRefs":[{"label":"Rv 13:10","book":"Rev","chapter":13,"verse":10}],"footnotes":[{"marker":2,"text":"Or and the faith of Jesus, or and faithfulness to Jesus"}]},{"verseId":"a556c5305ee15c3f-01:Rev:14:13","parts":[{"kind":"text","text":"Then I heard a voice from heaven saying, “Write: Blessed are the dead who die in the Lord from now on.” "},{"kind":"crossref","label":"Rv 1:3","book":"Rev","chapter":1,"verse":3,"letter":"a"},{"kind":"crossref","label":"Rv 16:15","book":"Rev","chapter":16,"verse":15,"letter":"b"},{"kind":"crossref","label":"Rv 19:9","book":"Rev","chapter":19,"verse":9,"letter":"c"},{"kind":"crossref","label":"Rv 20:6","book":"Rev","chapter":20,"verse":6,"letter":"d"},{"kind":"crossref","label":"Rv 22:7","book":"Rev","chapter":22,"verse":7,"letter":"e"},{"kind":"crossref","label":"Rv 22:14","book":"Rev","chapter":22,"verse":14,"letter":"f"},{"kind":"text","text":" “Yes,” says the Spirit, “so they will rest from their labors, since their works follow them.”"}],"crossRefs":[{"label":"Rv 1:3","book":"Rev","chapter":1,"verse":3},{"label":"Rv 16:15","book":"Rev","chapter":16,"verse":15},{"label":"Rv 19:9","book":"Rev","chapter":19,"verse":9},{"label":"Rv 20:6","book":"Rev","chapter":20,"verse":6},{"label":"Rv 22:7","book":"Rev","chapter":22,"verse":7},{"label":"Rv 22:14","book":"Rev","chapter":22,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:14","parts":[{"kind":"text","text":"Then I looked, and there was a white cloud, and one like the Son of Man "},{"kind":"footnote","marker":1,"text":"Or like a son of man"},{"kind":"crossref","label":"Dn 7:13","book":"Dan","chapter":7,"verse":13,"letter":"a"},{"kind":"crossref","label":"Lk 21:27","book":"Luk","chapter":21,"verse":27,"letter":"b"},{"kind":"crossref","label":"Rv 1:13","book":"Rev","chapter":1,"verse":13,"letter":"c"},{"kind":"text","text":" was seated on the cloud, with a golden crown on his head and a sharp sickle in his hand. "}],"crossRefs":[{"label":"Dn 7:13","book":"Dan","chapter":7,"verse":13},{"label":"Lk 21:27","book":"Luk","chapter":21,"verse":27},{"label":"Rv 1:13","book":"Rev","chapter":1,"verse":13}],"footnotes":[{"marker":1,"text":"Or like a son of man"}]},{"verseId":"a556c5305ee15c3f-01:Rev:14:15","parts":[{"kind":"text","text":"Another angel came out of the temple, crying out in a loud voice to the one who was seated on the cloud, “Use your sickle and reap, for the time to reap has come, since the harvest of the earth is ripe.” "},{"kind":"crossref","label":"Jl 3:13","book":"Jol","chapter":3,"verse":13,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jl 3:13","book":"Jol","chapter":3,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:16","parts":[{"kind":"text","text":"So the one seated on the cloud swung his sickle over the earth, and the earth was harvested."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:17","parts":[{"kind":"text","text":"Then another angel who also had a sharp sickle came out of the temple in heaven. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:18","parts":[{"kind":"text","text":"Yet another angel, who had authority over fire, came from the altar, and he called with a loud voice to the one who had the sharp sickle, “Use your sharp sickle and gather the clusters of grapes from the vineyard of the earth, because its grapes have ripened.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:19","parts":[{"kind":"text","text":"So the angel swung his sickle at the earth and gathered the grapes from the vineyard of the earth, and he threw them into the great winepress of God’s wrath. "},{"kind":"crossref","label":"Rv 16:19","book":"Rev","chapter":16,"verse":19,"letter":"a"},{"kind":"crossref","label":"Rv 19:15","book":"Rev","chapter":19,"verse":15,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 16:19","book":"Rev","chapter":16,"verse":19},{"label":"Rv 19:15","book":"Rev","chapter":19,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:14:20","parts":[{"kind":"text","text":"Then the press was trampled outside the city, and blood flowed out of the press up to the horses’ bridles for about 180 miles. "},{"kind":"footnote","marker":1,"text":"Lit 1,600 stadia"},{"kind":"crossref","label":"Is 63:1–6","book":"Isa","chapter":63,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Is 63:1–6","book":"Isa","chapter":63,"verse":1}],"footnotes":[{"marker":1,"text":"Lit 1,600 stadia"}]}]},"cachedAt":1783279691691}