abel":"Ps 62:12","book":"Psa","chapter":62,"verse":12,"letter":"j"},{"kind":"crossref","label":"Jr 17:10","book":"Jer","chapter":17,"verse":10,"letter":"k"},{"kind":"crossref","label":"Rm 2:6","book":"Rom","chapter":2,"verse":6,"letter":"l"},{"kind":"crossref","label":"1Pt 1:17","book":"1Pe","chapter":1,"verse":17,"letter":"m"},{"kind":"text","text":" by what was written in the books. "}],"crossRefs":[{"label":"Dn 7:10","book":"Dan","chapter":7,"verse":10},{"label":"Is 4:3","book":"Isa","chapter":4,"verse":3},{"label":"Is 34:16","book":"Isa","chapter":34,"verse":16},{"label":"Dn 12:1","book":"Dan","chapter":12,"verse":1},{"label":"Rv 3:5","book":"Rev","chapter":3,"verse":5},{"label":"Rv 13:8","book":"Rev","chapter":13,"verse":8},{"label":"Rv 17:8","book":"Rev","chapter":17,"verse":8},{"label":"Rv 20:15","book":"Rev","chapter":20,"verse":15},{"label":"Rv 21:27","book":"Rev","chapter":21,"verse":27},{"label":"Ps 62:12","book":"Psa","chapter":62,"verse":12},{"label":"Jr 17:10","book":"Jer","chapter":17,"verse":10},{"label":"Rm 2:6","book":"Rom","chapter":2,"verse":6},{"label":"1Pt 1:17","book":"1Pe","chapter":1,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:20:13","parts":[{"kind":"text","text":"Then the sea gave up the dead that were in it, and death and Hades "},{"kind":"crossref","label":"Rv 1:18","book":"Rev","chapter":1,"verse":18,"letter":"a"},{"kind":"crossref","label":"Rv 6:8","book":"Rev","chapter":6,"verse":8,"letter":"b"},{"kind":"text","text":" gave up the dead that were in them; each one was judged according to their works. "}],"crossRefs":[{"label":"Rv 1:18","book":"Rev","chapter":1,"verse":18},{"label":"Rv 6:8","book":"Rev","chapter":6,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:20:14","parts":[{"kind":"text","text":"Death and Hades were thrown into the lake of fire. "},{"kind":"crossref","label":"Is 25:7–8","book":"Isa","chapter":25,"verse":7,"letter":"a"},{"kind":"crossref","label":"1Co 15:26","book":"1Co","chapter":15,"verse":26,"letter":"b"},{"kind":"text","text":" This is the second death, the lake of fire. "}],"crossRefs":[{"label":"Is 25:7–8","book":"Isa","chapter":25,"verse":7},{"label":"1Co 15:26","book":"1Co","chapter":15,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:20:15","parts":[{"kind":"text","text":"And anyone whose name was not found written in the book of life was thrown into the lake of fire."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099572161}