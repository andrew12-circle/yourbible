chapter":12,"verse":17,"letter":"a"},{"kind":"text","text":" It was also given authority "},{"kind":"crossref","label":"Jr 27:6","book":"Jer","chapter":27,"verse":6,"letter":"b"},{"kind":"crossref","label":"Dn 7:6","book":"Dan","chapter":7,"verse":6,"letter":"c"},{"kind":"crossref","label":"Dn 7:14","book":"Dan","chapter":7,"verse":14,"letter":"d"},{"kind":"crossref","label":"Lk 4:6","book":"Luk","chapter":4,"verse":6,"letter":"e"},{"kind":"crossref","label":"Jn 19:11","book":"Jhn","chapter":19,"verse":11,"letter":"f"},{"kind":"text","text":" over every tribe, people, language, and nation. "},{"kind":"crossref","label":"Rv 5:9","book":"Rev","chapter":5,"verse":9,"letter":"g"},{"kind":"crossref","label":"Rv 7:9","book":"Rev","chapter":7,"verse":9,"letter":"h"},{"kind":"crossref","label":"Rv 11:9","book":"Rev","chapter":11,"verse":9,"letter":"i"},{"kind":"crossref","label":"Rv 14:6","book":"Rev","chapter":14,"verse":6,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 12:17","book":"Rev","chapter":12,"verse":17},{"label":"Jr 27:6","book":"Jer","chapter":27,"verse":6},{"label":"Dn 7:6","book":"Dan","chapter":7,"verse":6},{"label":"Dn 7:14","book":"Dan","chapter":7,"verse":14},{"label":"Lk 4:6","book":"Luk","chapter":4,"verse":6},{"label":"Jn 19:11","book":"Jhn","chapter":19,"verse":11},{"label":"Rv 5:9","book":"Rev","chapter":5,"verse":9},{"label":"Rv 7:9","book":"Rev","chapter":7,"verse":9},{"label":"Rv 11:9","book":"Rev","chapter":11,"verse":9},{"label":"Rv 14:6","book":"Rev","chapter":14,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:13:8","parts":[{"kind":"text","text":"All those who live on the earth will worship it, everyone whose name was not written from the foundation of the world in the book "},{"kind":"footnote","marker":4,"text":"Or scroll"},{"kind":"text","text":" of life "},{"kind":"crossref","label":"Ex 32:32–33","book":"Exo","chapter":32,"verse":32,"letter":"a"},{"kind":"crossref","label":"Ps 69:28","book":"Psa","chapte