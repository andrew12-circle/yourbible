abel":"Dn 8:3","book":"Dan","chapter":8,"verse":3,"letter":"a"},{"kind":"text","text":" but it spoke like a dragon. "}],"crossRefs":[{"label":"Dn 8:3","book":"Dan","chapter":8,"verse":3}],"footnotes":[{"marker":1,"text":"Or ram"}]},{"verseId":"a556c5305ee15c3f-01:Rev:13:12","parts":[{"kind":"text","text":"It exercises all the authority of the first beast on its behalf and compels the earth and those who live on it to worship the first beast, whose fatal wound was healed. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:13:13","parts":[{"kind":"text","text":"It also performs great signs, "},{"kind":"crossref","label":"Dt 13:1","book":"Deu","chapter":13,"verse":1,"letter":"a"},{"kind":"crossref","label":"Mk 13:22","book":"Mrk","chapter":13,"verse":22,"letter":"b"},{"kind":"crossref","label":"2Th 2:9–11","book":"2Th","chapter":2,"verse":9,"letter":"c"},{"kind":"text","text":" even causing fire to come down from heaven to earth in front of people. "},{"kind":"crossref","label":"1Kg 18:38","book":"1Ki","chapter":18,"verse":38,"letter":"d"},{"kind":"crossref","label":"2Kg 1:10","book":"2Ki","chapter":1,"verse":10,"letter":"e"},{"kind":"crossref","label":"Lk 9:54","book":"Luk","chapter":9,"verse":54,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 13:1","book":"Deu","chapter":13,"verse":1},{"label":"Mk 13:22","book":"Mrk","chapter":13,"verse":22},{"label":"2Th 2:9–11","book":"2Th","chapter":2,"verse":9},{"label":"1Kg 18:38","book":"1Ki","chapter":18,"verse":38},{"label":"2Kg 1:10","book":"2Ki","chapter":1,"verse":10},{"label":"Lk 9:54","book":"Luk","chapter":9,"verse":54}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:13:14","parts":[{"kind":"text","text":"It deceives those who live on the earth "},{"kind":"crossref","label":"Rv 12:9","book":"Rev","chapter":12,"verse":9,"letter":"a"},{"kind":"text","text":" because of the signs that it is permitted to perform in the presence of the beast, "},{"kind":"crossref","label":"2Th 2:9–12","book":"2Th","chapter":2,"verse":9,"letter":"b"},{"kind":"crossref","label":"Rv 19:20","book":"Rev","chapter":19,"verse":20,"letter":"c"},{"kind":"text","text":" telling those who live on the earth to make an image "},{"kind":"footnote","marker":2,"text":"Or a statue, or a likeness"},{"kind":"text","text":" of the beast who was wounded by the sword and yet lived. "}],"crossRefs":[{"label":"Rv 12:9","book":"Rev","chapter":12,"verse":9},{"label":"2Th 2:9–12","book":"2Th","chapter":2,"verse":9},{"label":"Rv 19:20","book":"Rev","chapter":19,"verse":20}],"footnotes":[{"marker":2,"text":"Or a statue, or a likeness"}]},{"verseId":"a556c5305ee15c3f-01:Rev:13:15","parts":[{"kind":"text","text":"It was permitted to give breath "},{"kind":"footnote","marker":3,"text":"Or a spirit, or life"},{"kind":"text","text":" to the image of the beast, so that the image of the beast could both speak and cause whoever would not worship the image of the beast to be killed. "},{"kind":"crossref","label":"Dn 3:5","book":"Dan","chapter":3,"verse":5,"letter":"a"},{"kind":"crossref","label":"Rv 20:4","book":"Rev","chapter":20,"verse":4,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 3:5","book":"Dan","chapter":3,"verse":5},{"label":"Rv 20:4","book":"Rev","chapter":20,"verse":4}],"footnotes":[{"marker":3,"text":"Or a spirit, or life"}]},{"verseId":"a556c5305ee15c3f-01:Rev:13:16","parts":[{"kind":"text","text":"And it makes everyone —small and great, rich and poor, free and slave —to receive a mark on his right hand or on his forehead, "},{"kind":"crossref","label":"Rv 14:1","book":"Rev","chapter":14,"verse":1,"letter":"a"},{"kind":"crossref","label":"Rv 14:9","book":"Rev","chapter":14,"verse":9,"letter":"b"},{"kind":"crossref","label":"Rv 14:11","book":"Rev","chapter":14,"verse":11,"letter":"c"},{"kind":"crossref","label":"Rv 16:2","book":"Rev","chapter":16,"verse":2,"letter":"d"},{"kind":"crossref","label":"Rv 19:20","book":"Rev","chapter":19,"verse":20,"letter":"e"},{"k