4},{"label":"Is 60:20","book":"Isa","chapter":60,"verse":20},{"label":"Is 42:9","book":"Isa","chapter":42,"verse":9},{"label":"2Co 5:17","book":"2Co","chapter":5,"verse":17}],"footnotes":[{"marker":5,"text":"Or the first things"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:5","parts":[{"kind":"text","text":"Then the one seated on the throne said, “Look, I am making everything new.” He also said, “Write, because these words "},{"kind":"footnote","marker":1,"text":"Other mss add of God"},{"kind":"text","text":" are faithful and true.” "},{"kind":"crossref","label":"Rv 3:14","book":"Rev","chapter":3,"verse":14,"letter":"a"},{"kind":"crossref","label":"Rv 19:11","book":"Rev","chapter":19,"verse":11,"letter":"b"},{"kind":"crossref","label":"Rv 22:6","book":"Rev","chapter":22,"verse":6,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 3:14","book":"Rev","chapter":3,"verse":14},{"label":"Rv 19:11","book":"Rev","chapter":19,"verse":11},{"label":"Rv 22:6","book":"Rev","chapter":22,"verse":6}],"footnotes":[{"marker":1,"text":"Other mss add of God"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:6","parts":[{"kind":"text","text":"Then he said to me, “It is done! "},{"kind":"crossref","label":"Rv 16:17","book":"Rev","chapter":16,"verse":17,"letter":"a"},{"kind":"text","text":" I am the Alpha and the Omega, "},{"kind":"crossref","label":"Rv 1:8","book":"Rev","chapter":1,"verse":8,"letter":"b"},{"kind":"crossref","label":"Rv 22:13","book":"Rev","chapter":22,"verse":13,"letter":"c"},{"kind":"text","text":" the beginning and the end. "},{"kind":"crossref","label":"Is 44:6","book":"Isa","chapter":44,"verse":6,"letter":"d"},{"kind":"crossref","label":"Is 48:12","book":"Isa","chapter":48,"verse":12,"letter":"e"},{"kind":"text","text":" I will freely give to the thirsty "},{"kind":"crossref","label":"Ps 42:1–2","book":"Psa","chapter":42,"verse":1,"letter":"f"},{"kind":"crossref","label":"Is 41:17","book":"Isa","chapter":41,"verse":17,"letter":"g"},{"kind":"crossref","label":"Is 44:3","book":"Isa","chapter":44,"verse":3,"letter":"h"},{"kind":"crossref","label":"Is 55:1","book":"Isa","chapter":55,"verse":1,"letter":"i"},{"kind":"crossref","label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14,"letter":"j"},{"kind":"crossref","label":"Jn 7:37","book":"Jhn","chapter":7,"verse":37,"letter":"k"},{"kind":"text","text":" from the spring of the water of life. "},{"kind":"crossref","label":"Ps 36:9","book":"Psa","chapter":36,"verse":9,"letter":"l"},{"kind":"crossref","label":"Jr 2:13","book":"Jer","chapter":2,"verse":13,"letter":"m"},{"kind":"crossref","label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14,"letter":"n"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 16:17","book":"Rev","chapter":16,"verse":17},{"label":"Rv 1:8","book":"Rev","chapter":1,"verse":8},{"label":"Rv 22:13","book":"Rev","chapter":22,"verse":13},{"label":"Is 44:6","book":"Isa","chapter":44,"verse":6},{"label":"Is 48:12","book":"Isa","chapter":48,"verse":12},{"label":"Ps 42:1–2","book":"Psa","chapter":42,"verse":1},{"label":"Is 41:17","book":"Isa","chapter":41,"verse":17},{"label":"Is 44:3","book":"Isa","chapter":44,"verse":3},{"label":"Is 55:1","book":"Isa","chapter":55,"verse":1},{"label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14},{"label":"Jn 7:37","book":"Jhn","chapter":7,"verse":37},{"label":"Ps 36:9","book":"Psa","chapter":36,"verse":9},{"label":"Jr 2:13","book":"Jer","chapter":2,"verse":13},{"label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:7","parts":[{"kind":"text","text":"The one who conquers "},{"kind":"crossref","label":"Rv 2:7","book":"Rev","chapter":2,"verse":7,"letter":"a"},{"kind":"text","text":" will inherit these things, and I will be his God, and he will be my son. "},{"kind":"crossref","label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 2:7","book":"Rev","chapter":2,"verse":7},{"label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:8","parts":[{"kind":"text","text":"But the cowards, faithless, "},{"kind":"footnote","marker":2,"text":"Other mss add the sinful,"},{"kind":"text","text":" detestable, murderers, sexually immoral, sorcerers, idolaters, and all liars "},{"kind":"crossref","label":"Rm 1:28–32","book":"Rom","chapter":1,"verse":28,"letter":"a"},{"kind":"crossref","label":"1Co 6:9–10","book":"1Co","chapter":6,"verse":9,"letter":"b"},{"kind":"crossref","label":"Rv 22:15","book":"Rev","chapter":22,"verse":15,"letter":"c"},{"kind":"text","text":" —their share will be in the lake that burns with fire and sulfur, "},{"kind":"crossref","label":"Rv 19:20","book":"Rev","chapter":19,"verse":20,"letter":"d"},{"kind":"text","text":" which is the second death.” "},{"kind":"crossref","label":"Rv 20:6","book":"Rev","chapter":20,"verse":6,"letter":"e"}],"crossRefs":[{"label":"Rm 1:28–32","book":"Rom","chapter":1,"verse":28},{"label":"1Co 6:9–10","book":"1Co","chapter":6,"verse":9},{"label":"Rv 22:15","book":"Rev","chapter":22,"verse":15},{"label":"Rv 19:20","book":"Rev","chapter":19,"verse":20},{"label":"Rv 20:6","book":"Rev","chapter":20,"verse":6}],"footnotes":[{"marker":2,"text":"Other mss add the sinful,"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:9","parts":[{"kind":"text","text":"Then one of the seven angels, who had held the seven bowls filled with the seven last plagues, "},{"kind":"crossref","label":"Rv 16:1","book":"Rev","chapter":16,"verse":1,"letter":"a"},{"kind":"text","text":" came and spoke with me: “Come, I will show you the bride, the wife of the Lamb.” "}],"crossRefs":[{"label":"Rv 16:1","book":"Rev","chapter":16,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:10","parts":[{"kind":"text","text":"He then carried me away in the Spirit "},{"kind":"footnote","marker":1,"text":"Or in spirit"},{"kind":"crossref","label":"Rv 1:10","book":"Rev","chapter":1,"verse":10,"letter":"a"},{"kind":"crossref","label":"Rv 4:2","book":"Rev","chapter":4,"verse":2,"letter":"b"},{"kind":"crossref","label":"Rv 17:3","book":"Rev","chapter":17,"verse":3,"letter":"c"},{"kind":"text","text":" to a great, high mountain "},{"kind":"crossref","label":"Ezk 40:2","book":"Ezk","chapter":40,"verse":2,"letter":"d"},{"kind":"text","text":" and showed me the holy city, Jerusalem, coming down out of heaven from God, "}],"crossRefs":[{"label":"Rv 1:10","book":"Rev","chapter":1,"verse":10},{"label":"Rv 4:2","book":"Rev","chapter":4,"verse":2},{"label":"Rv 17:3","book":"Rev","chapter":17,"verse":3},{"label":"Ezk 40:2","book":"Ezk","chapter":40,"verse":2}],"footnotes":[{"marker":1,"text":"Or in spirit"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:11","parts":[{"kind":"text","text":"arrayed with God’s glory. "},{"kind":"crossref","label":"Is 60:1–2","book":"Isa","chapter":60,"verse":1,"letter":"a"},{"kind":"text","text":" Her radiance was like a precious jewel, like a jasper stone, clear as crystal. "}],"crossRefs":[{"label":"Is 60:1–2","book":"Isa","chapter":60,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:12","parts":[{"kind":"text","text":"The city had a massive high wall, with twelve gates. Twelve angels were at the gates; the names of the twelve tribes of Israel’s sons were inscribed on the gates. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:13","parts":[{"kind":"text","text":"There were three gates on the east, three gates on the north, three gates on the south, and three gates on the west. "},{"kind":"crossref","label":"Ezk 48:30–34","book":"Ezk","chapter":48,"verse":30,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 48:30–34","book":"Ezk","chapter":48,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:14","parts":[{"kind":"text","text":"The city wall had twelve foundations, and the twelve names of the twelve apostles of the Lamb were on the foundations."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:15","parts":[{"kind":"text","text":"The one who spoke with me had a golden measuring rod "},{"kind":"crossref","label":"Rv 11:1","book":"Rev","chapter":11,"verse":1,"letter":"a"},{"kind":"text","text":" to measure the city, its gates, and its wall. "},{"kind":"crossref","label":"Ezk 40:3","book":"Ezk","chapter":40,"verse":3,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 11:1","book":"Rev","chapter":11,"verse":1},{"label":"Ezk 40:3","book":"Ezk","chapter":40,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:16","parts":[{"kind":"text","text":"The city is laid out in a square; its length and width are the same. He measured the city with the rod at 12,000 stadia. "},{"kind":"footnote","marker":1,"text":"A stadion (sg) = about 600 feet; 12,000 stadia = 1,400 miles."},{"kind":"text","text":" Its length, width, and height are equal. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"A stadion (sg) = about 600 feet; 12,000 stadia = 1,400 miles."}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:17","parts":[{"kind":"text","text":"Then he measured its wall, 144 cubits according to human measurement, which the angel used. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:18","parts":[{"kind":"text","text":"The building material of its wall was jasper, and the city was pure gold clear as glass. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:19","parts":[{"kind":"text","text":"The foundations of the city wall were adorned with every kind of jewel: "},{"kind":"crossref","label":"Ex 28:15–21","book":"Exo","chapter":28,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 54:11","book":"Isa","chapter":54,"verse":11,"letter":"b"},{"kind":"text","text":" the first foundation is jasper, the second sapphire, the third chalcedony, the fourth emerald, "}],"crossRefs":[{"label":"Ex 28:15–21","book":"Exo","chapter":28,"verse":15},{"label":"Is 54:11","book":"Isa","chapter":54,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:20","parts":[{"kind":"text","text":"the fifth sardonyx, the sixth carnelian, the seventh chrysolite, the eighth beryl, the ninth topaz, the tenth chrysoprase, the eleventh jacinth, the twelfth amethyst. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:21","parts":[{"kind":"text","text":"The twelve gates are twelve pearls; each individual gate was made of a single pearl. The main street "},{"kind":"footnote","marker":2,"text":"Or The public square"},{"kind":"text","text":" of the city was pure gold, transparent as glass."}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Or The public square"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:22","parts":[{"kind":"text","text":"I did not see a temple in it, because the Lord God the Almighty and the Lamb are its temple. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:23","parts":[{"kind":"text","text":"The city does not need the sun or the moon to shine on it, because the glory of God illuminates it, and its lamp is the Lamb. "},{"kind":"crossref","label":"Is 24:23","book":"Isa","chapter":24,"verse":23,"letter":"a"},{"kind":"crossref","label":"Is 30:26","book":"Isa","chapter":30,"verse":26,"letter":"b"},{"kind":"crossref","label":"Is 60:19–20","book":"Isa","chapter":60,"verse":19,"letter":"c"},{"kind":"crossref","label":"Zch 14:6","book":"Zec","chapter":14,"verse":6,"letter":"d"},{"kind":"crossref","label":"Rv 22:5","book":"Rev","chapter":22,"verse":5,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 24:23","book":"Isa","chapter":24,"verse":23},{"label":"Is 30:26","book":"Isa","chapter":30,"verse":26},{"label":"Is 60:19–20","book":"Isa","chapter":60,"verse":19},{"label":"Zch 14:6","book":"Zec","chapter":14,"verse":6},{"label":"Rv 22:5","book":"Rev","chapter":22,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:24","parts":[{"kind":"text","text":"The nations will walk by its light, "},{"kind":"crossref","label":"Is 42:6","book":"Isa","chapter":42,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 49:6","book":"Isa","chapter":49,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 60:3","book":"Isa","chapter":60,"verse":3,"letter":"c"},{"kind":"crossref","label":"Is 60:5","book":"Isa","chapter":60,"verse":5,"letter":"d"},{"kind":"text","text":" and the kings of the earth will bring their glory into it. "},{"kind":"footnote","marker":1,"text":"Other mss read will bring to him the nations’ glory and honor"},{"kind":"crossref","label":"Is 49:7","book":"Isa","chapter":49,"verse":7,"letter":"e"},{"kind":"crossref","label":"Is 49:23","book":"Isa","chapter":49,"verse":23,"letter":"f"},{"kind":"crossref","label":"Is 60:10","book":"Isa","chapter":60,"verse":10,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 42:6","book":"Isa","chapter":42,"verse":6},{"label":"Is 49:6","book":"Isa","chapter":49,"verse":6},{"label":"Is 60:3","book":"Isa","chapter":60,"verse":3},{"label":"Is 60:5","book":"Isa","chapter":60,"verse":5},{"label":"Is 49:7","book":"Isa","chapter":49,"verse":7},{"label":"Is 49:23","book":"Isa","chapter":49,"verse":23},{"label":"Is 60:10","book":"Isa","chapter":60,"verse":10}],"footnotes":[{"marker":1,"text":"Other mss read will bring to him the nations’ glory and honor"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:25","parts":[{"kind":"text","text":"Its gates will never close by day because it will never be night there. "},{"kind":"crossref","label":"Neh 7:3","book":"Neh","chapter":7,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Neh 7:3","book":"Neh","chapter":7,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:21:26","parts":[{"kind":"text","text":"They will bring the glory and honor of the nations into it. "},{"kind":"footnote","marker":2,"text":"Other mss add in order that they might go in"},{"kind":"crossref","label":"Is 60:11","book":"Isa","chapter":60,"verse":11,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 60:11","book":"Isa","chapter":60,"verse":11}],"footnotes":[{"marker":2,"text":"Other mss add in order that they might go in"}]},{"verseId":"a556c5305ee15c3f-01:Rev:21:27","parts":[{"kind":"text","text":"Nothing unclean will ever enter it, "},{"kind":"crossref","label":"Is 35:8","book":"Isa","chapter":35,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 52:1","book":"Isa","chapter":52,"verse":1,"letter":"b"},{"kind":"text","text":" nor anyone who does what is detestable or false, but only those written in the Lamb’s book of life. "},{"kind":"crossref","label":"Rv 3:5","book":"Rev","chapter":3,"verse":5,"letter":"c"},{"kind":"crossref","label":"Rv 13:8","book":"Rev","chapter":13,"verse":8,"letter":"d"},{"kind":"crossref","label":"Rv 17:8","book":"Rev","chapter":17,"verse":8,"letter":"e"},{"kind":"crossref","label":"Rv 20:12","book":"Rev","chapter":20,"verse":12,"letter":"f"},{"kind":"crossref","label":"Rv 20:15","book":"Rev","chapter":20,"verse":15,"letter":"g"}],"crossRefs":[{"label":"Is 35:8","book":"Isa","chapter":35,"verse":8},{"label":"Is 52:1","book":"Isa","chapter":52,"verse":1},{"label":"Rv 3:5","book":"Rev","chapter":3,"verse":5},{"label":"Rv 13:8","book":"Rev","chapter":13,"verse":8},{"label":"Rv 17:8","book":"Rev","chapter":17,"verse":8},{"label":"Rv 20:12","book":"Rev","chapter":20,"verse":12},{"label":"Rv 20:15","book":"Rev","chapter":20,"verse":15}],"footnotes":[]}]},"cachedAt":1783280290112}