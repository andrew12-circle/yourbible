"marker":1,"text":"Or sovereignty"},{"kind":"text","text":" to the beast until the words of God are fulfilled. "},{"kind":"crossref","label":"Jr 51:12","book":"Jer","chapter":51,"verse":12,"letter":"b"},{"kind":"crossref","label":"Rv 10:7","book":"Rev","chapter":10,"verse":7,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 50:20","book":"Gen","chapter":50,"verse":20},{"label":"Jr 51:12","book":"Jer","chapter":51,"verse":12},{"label":"Rv 10:7","book":"Rev","chapter":10,"verse":7}],"footnotes":[{"marker":1,"text":"Or sovereignty"}]},{"verseId":"a556c5305ee15c3f-01:Rev:17:18","parts":[{"kind":"text","text":"And the woman you saw is the great city that has royal power over the kings of the earth.”"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099571249}