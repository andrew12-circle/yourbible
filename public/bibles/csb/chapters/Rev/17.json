seId":"a556c5305ee15c3f-01:Rev:17:11","parts":[{"kind":"text","text":"The beast that was and is not, is itself an eighth king, but it belongs to the seven and is going to destruction. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:17:12","parts":[{"kind":"text","text":"The ten horns you saw are ten kings "},{"kind":"crossref","label":"Dn 7:24","book":"Dan","chapter":7,"verse":24,"letter":"a"},{"kind":"crossref","label":"Rv 13:1","book":"Rev","chapter":13,"verse":1,"letter":"b"},{"kind":"text","text":" who have not yet received a kingdom, but they will receive authority as kings with the beast for one hour. "},{"kind":"crossref","label":"Rv 18:10","book":"Rev","chapter":18,"verse":10,"letter":"c"},{"kind":"crossref","label":"Rv 18:17","book":"Rev","chapter":18,"verse":17,"letter":"d"},{"kind":"crossref","label":"Rv 18:19","book":"Rev","chapter":18,"verse":19,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 7:24","book":"Dan","chapter":7,"verse":24},{"label":"Rv 13:1","book":"Rev","chapter":13,"verse":1},{"label":"Rv 18:10","book":"Rev","chapter":18,"verse":10},{"label":"Rv 18:17","book":"Rev","chapter":18,"verse":17},{"label":"Rv 18:19","book":"Rev","chapter":18,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:17:13","parts":[{"kind":"text","text":"These have one purpose, and they give their power and authority to the beast. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:17:14","parts":[{"kind":"text","text":"These will make war against the Lamb, but the Lamb will conquer them because he is Lord of lords and King of kings. "},{"kind":"crossref","label":"Dt 10:17","book":"Deu","chapter":10,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ps 136:2–3","book":"Psa","chapter":136,"verse":2,"letter":"b"},{"kind":"crossref","label":"Dn 2:47","book":"Dan","chapter":2,"verse":47,"letter":"c"},{"kind":"crossref","label":"1Tm 6:15","book":"1Ti","chapter":6,"verse":15,"letter":"d"},{"kind":"crossref","label":"Rv 1:5","book":"Rev","chapter":1,"verse":5,"letter":"e"},{"kind":"crossref","label":"Rv 19:11–21","book":"Rev","chapter":19,"verse":11,"letter":"f"},{"kind":"text","text":" Those with him are called, chosen, and faithful.” "},{"kind":"crossref","label":"Rv 12:11","book":"Rev","chapter":12,"verse":11,"letter":"g"},{"kind":"crossref","label":"Rv 13:8","book":"Rev","chapter":13,"verse":8,"letter":"h"}],"crossRefs":[{"label":"Dt 10:17","book":"Deu","chapter":10,"verse":17},{"label":"Ps 136:2–3","book":"Psa","chapter":136,"verse":2},{"label":"Dn 2:47","book":"Dan","chapter":2,"verse":47},{"label":"1Tm 6:15","book":"1Ti","chapter":6,"verse":15},{"label":"Rv 1:5","book":"Rev","chapter":1,"verse":5},{"label":"Rv 19:11–21","book":"Rev","chapter":19,"verse":11},{"label":"Rv 12:11","book":"Rev","chapter":12,"verse":11},{"label":"Rv 13:8","book":"Rev","chapter":13,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Rev:17:15","parts":[{"kind":"text","text":"He also said to me, “The waters you saw, "},{"kind":"crossref","label":"Jr 51:13","book":"Jer","chapter":51,"verse":13,"letter":"a"},{"kind":"text","text":" where the prostitute was seated, are peoples, multitudes, nations, and languages. "},{"kind":"crossref","label":"Is 17:12","book":"Isa","chapter":17,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jr 51:58","book":"Jer","chapter":51,"verse":58,"letter":"c"},{"kind":"crossref","label":"Dn 5:19","book":"Dan","chapter":5,"verse":19,"letter":"d"},{"kind":"crossref","label":"Hab 2:8","book":"Hab","chapter":2,"verse":8,"letter":"e"},{"kind":"crossref","label":"Rv 5:9","book":"Rev","chapter":5,"verse":9,"letter":"f"},{"kind":"crossref","label":"Rv 7:9","book":"Rev","chapter":7,"verse":9,"letter":"g"},{"kind":"crossref","label":"Rv 10:11","book":"Rev","chapter":10,"verse":11,"letter":"h"},{"kind":"crossref","label":"Rv 11:9","book":"Rev","chapter":11,"verse":9,"letter":"i"},{"kind":"crossref","label":"Rv 13:7","book":"Rev","chapter":13,"verse":7,"le