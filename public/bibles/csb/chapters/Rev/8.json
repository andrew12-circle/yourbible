 12:12","book":"Rev","chapter":12,"verse":12,"letter":"c"},{"kind":"text","text":" Woe! Woe to those who live on the earth, because of the remaining trumpet blasts that the three angels are about to sound!”"}],"crossRefs":[{"label":"Rv 9:12","book":"Rev","chapter":9,"verse":12},{"label":"Rv 11:14","book":"Rev","chapter":11,"verse":14},{"label":"Rv 12:12","book":"Rev","chapter":12,"verse":12}],"footnotes":[{"marker":1,"text":"Other mss read angel"}]}]},"cachedAt":1783099568696}