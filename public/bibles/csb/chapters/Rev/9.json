ns "},{"kind":"crossref","label":"1Co 10:20","book":"1Co","chapter":10,"verse":20,"letter":"g"},{"kind":"text","text":" and idols of gold, silver, bronze, stone, and wood, "},{"kind":"crossref","label":"Dt 29:17","book":"Deu","chapter":29,"verse":17,"letter":"h"},{"kind":"crossref","label":"Dn 2:32","book":"Dan","chapter":2,"verse":32,"letter":"i"},{"kind":"crossref","label":"Dn 2:35","book":"Dan","chapter":2,"verse":35,"letter":"j"},{"kind":"crossref","label":"Dn 2:45","book":"Dan","chapter":2,"verse":45,"letter":"k"},{"kind":"crossref","label":"Hab 2:19","book":"Hab","chapter":2,"verse":19,"letter":"l"},{"kind":"crossref","label":"Ac 17:29","book":"Act","chapter":17,"verse":29,"letter":"m"},{"kind":"text","text":" which cannot see, hear, or walk. "},{"kind":"crossref","label":"Dt 4:28","book":"Deu","chapter":4,"verse":28,"letter":"n"},{"kind":"crossref","label":"Ps 115:4–7","book":"Psa","chapter":115,"verse":4,"letter":"o"},{"kind":"crossref","label":"Ps 135:15–17","book":"Psa","chapter":135,"verse":15,"letter":"p"},{"kind":"crossref","label":"Dn 5:23","book":"Dan","chapter":5,"verse":23,"letter":"q"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Kg 13:33","book":"1Ki","chapter":13,"verse":33},{"label":"2Ch 34:25","book":"2Ch","chapter":34,"verse":25},{"label":"Ps 7:12","book":"Psa","chapter":7,"verse":12},{"label":"Jr 1:16","book":"Jer","chapter":1,"verse":16},{"label":"Rv 16:9","book":"Rev","chapter":16,"verse":9},{"label":"Rv 16:11","book":"Rev","chapter":16,"verse":11},{"label":"1Co 10:20","book":"1Co","chapter":10,"verse":20},{"label":"Dt 29:17","book":"Deu","chapter":29,"verse":17},{"label":"Dn 2:32","book":"Dan","chapter":2,"verse":32},{"label":"Dn 2:35","book":"Dan","chapter":2,"verse":35},{"label":"Dn 2:45","book":"Dan","chapter":2,"verse":45},{"label":"Hab 2:19","book":"Hab","chapter":2,"verse":19},{"label":"Ac 17:29","book":"Act","chapter":17,"verse":29},{"label":"Dt 4:28","book":"Deu","chapter":4,"verse":28},{"label":"Ps 115:4–7","book":"Psa","ch