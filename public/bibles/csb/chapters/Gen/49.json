24"},{"verseId":"a556c5305ee15c3f-01:Gen:49:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":19,"text":"Gad will be attacked by raiders,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":20,"text":"Asher’s food will be rich,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":21,"text":"Naphtali is a doe set free","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":22,"text":"Joseph is a fruitful vine,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":23,"text":"The archers attacked him,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":24,"text":"Yet his bow remained steady,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":25,"text":"by the God of your father who helps you,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":26,"text":"The blessings of your father excel","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":27,"text":"Benjamin is a wolf; he tears his prey.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Gen:49:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Gen","bookOrder":0,"chapter":49,"verse":