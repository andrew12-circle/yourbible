kind":"text","text":" as one of the tribes of Israel."}],"crossRefs":[{"label":"Dt 33:22","book":"Deu","chapter":33,"verse":22},{"label":"Jdg 13:2","book":"Jdg","chapter":13,"verse":2},{"label":"Jdg 13:25","book":"Jdg","chapter":13,"verse":25},{"label":"Jdg 18:25–27","book":"Jdg","chapter":18,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:17","parts":[{"kind":"text","text":"Dan will be a snake by the road,"},{"kind":"text","text":" a viper beside the path,"},{"kind":"text","text":" that bites the horse’s heels"},{"kind":"text","text":" so that its rider falls backward."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:18","parts":[{"kind":"text","text":"I wait for your salvation, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:19","parts":[{"kind":"text","text":"Gad will be attacked by raiders,"},{"kind":"text","text":" but he will attack their heels. "},{"kind":"crossref","label":"Dt 33:20","book":"Deu","chapter":33,"verse":20,"letter":"a"},{"kind":"crossref","label":"1Ch 5:18–22","book":"1Ch","chapter":5,"verse":18,"letter":"b"},{"kind":"crossref","label":"Jr 49:1","book":"Jer","chapter":49,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Dt 33:20","book":"Deu","chapter":33,"verse":20},{"label":"1Ch 5:18–22","book":"1Ch","chapter":5,"verse":18},{"label":"Jr 49:1","book":"Jer","chapter":49,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:20","parts":[{"kind":"text","text":"Asher’s "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Vg; MT reads their heel. From Asher"},{"kind":"text","text":" food will be rich,"},{"kind":"text","text":" and he will produce royal delicacies. "},{"kind":"crossref","label":"Dt 33:24","book":"Deu","chapter":33,"verse":24,"letter":"a"},{"kind":"crossref","label":"Jos 19:24–31","book":"Jos","chapter":19,"verse":24,"letter":"b"},{"kind":"crossref","label":"Jdg 5:17","book":"Jdg","chapter":5,"verse":17,"letter":"c"},{"kind":"crossref","label":"1Kg 4:7","book":"1Ki","chapter":4,"verse":7,"letter":"d"}],"crossRefs":[{"label":"Dt 33:24","book":"Deu","chapter":33,"verse":24},{"label":"Jos 19:24–31","book":"Jos","chapter":19,"verse":24},{"label":"Jdg 5:17","book":"Jdg","chapter":5,"verse":17},{"label":"1Kg 4:7","book":"1Ki","chapter":4,"verse":7}],"footnotes":[{"marker":1,"text":"LXX, Syr, Vg; MT reads their heel. From Asher"}]},{"verseId":"a556c5305ee15c3f-01:Gen:49:21","parts":[{"kind":"text","text":"Naphtali is a doe set free"},{"kind":"text","text":" that bears beautiful fawns. "},{"kind":"crossref","label":"Jos 19:32–39","book":"Jos","chapter":19,"verse":32,"letter":"a"}],"crossRefs":[{"label":"Jos 19:32–39","book":"Jos","chapter":19,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:22","parts":[{"kind":"text","text":"Joseph is a fruitful vine,"},{"kind":"text","text":" a fruitful vine beside a spring;"},{"kind":"text","text":" its branches "},{"kind":"footnote","marker":1,"text":"Lit daughters"},{"kind":"text","text":" climb over the wall. "},{"kind":"footnote","marker":2,"text":"Hb obscure"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit daughters"},{"marker":2,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Gen:49:23","parts":[{"kind":"text","text":"The archers attacked him,"},{"kind":"text","text":" shot at him, and were hostile toward him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:24","parts":[{"kind":"text","text":"Yet his bow remained steady,"},{"kind":"text","text":" and his strong arms were made agile"},{"kind":"text","text":" by the hands of the Mighty One of Jacob, "},{"kind":"crossref","label":"Gn 31:42","book":"Gen","chapter":31,"verse":42,"letter":"a"},{"kind":"crossref","label":"Ps 132:2","book":"Psa","chapter":132,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ps 132:5","book":"Psa","chapter":132,"verse":5,"letter":"c"},{"kind":"crossref","label":"Is 1:24","book":"Isa","chapter":1,"verse":24,"letter":"d"},{"kind":"crossref","label":"Is 49:26","book":"Isa","chapter":49,"verse":26,"letter":"e"},{"kind":"text","text":" by the name of "},{"kind":"footnote","marker":1,"text":"Syr, Tg; MT reads Jacob, from there"},{"kind":"text","text":" the Shepherd, "},{"kind":"crossref","label":"Gn 48:15","book":"Gen","chapter":48,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ps 23:1","book":"Psa","chapter":23,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jr 31:10","book":"Jer","chapter":31,"verse":10,"letter":"c"},{"kind":"text","text":" the Rock of Israel, "},{"kind":"crossref","label":"Ps 118:22","book":"Psa","chapter":118,"verse":22,"letter":"d"},{"kind":"crossref","label":"Is 28:16","book":"Isa","chapter":28,"verse":16,"letter":"e"},{"kind":"crossref","label":"1Pt 2:6","book":"1Pe","chapter":2,"verse":6,"letter":"f"}],"crossRefs":[{"label":"Gn 31:42","book":"Gen","chapter":31,"verse":42},{"label":"Ps 132:2","book":"Psa","chapter":132,"verse":2},{"label":"Ps 132:5","book":"Psa","chapter":132,"verse":5},{"label":"Is 1:24","book":"Isa","chapter":1,"verse":24},{"label":"Is 49:26","book":"Isa","chapter":49,"verse":26},{"label":"Gn 48:15","book":"Gen","chapter":48,"verse":15},{"label":"Ps 23:1","book":"Psa","chapter":23,"verse":1},{"label":"Jr 31:10","book":"Jer","chapter":31,"verse":10},{"label":"Ps 118:22","book":"Psa","chapter":118,"verse":22},{"label":"Is 28:16","book":"Isa","chapter":28,"verse":16},{"label":"1Pt 2:6","book":"1Pe","chapter":2,"verse":6}],"footnotes":[{"marker":1,"text":"Syr, Tg; MT reads Jacob, from there"}]},{"verseId":"a556c5305ee15c3f-01:Gen:49:25","parts":[{"kind":"text","text":"by the God of your father who helps you,"},{"kind":"text","text":" and by the Almighty who blesses you"},{"kind":"text","text":" with blessings of the heavens above,"},{"kind":"text","text":" blessings of the deep that lies below,"},{"kind":"text","text":" and blessings of the breasts and the womb."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:26","parts":[{"kind":"text","text":"The blessings of your father excel"},{"kind":"text","text":" the blessings of my ancestors "},{"kind":"footnote","marker":1,"text":"Or of the mountains"},{"kind":"text","text":" and "},{"kind":"footnote","marker":1,"text":"Lit to"},{"kind":"text","text":" the bounty of the ancient hills. "},{"kind":"footnote","marker":2,"text":"Hb obscure"},{"kind":"crossref","label":"Dt 33:15","book":"Deu","chapter":33,"verse":15,"letter":"a"},{"kind":"text","text":" May they rest on the head of Joseph,"},{"kind":"text","text":" on the brow of the prince of his brothers."}],"crossRefs":[{"label":"Dt 33:15","book":"Deu","chapter":33,"verse":15}],"footnotes":[{"marker":1,"text":"Or of the mountains"},{"marker":1,"text":"Lit to"},{"marker":2,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Gen:49:27","parts":[{"kind":"text","text":"Benjamin is a wolf; he tears his prey."},{"kind":"text","text":" In the morning he devours the prey,"},{"kind":"text","text":" and in the evening he divides the plunder.” "},{"kind":"crossref","label":"Jdg 5:14","book":"Jdg","chapter":5,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jdg 20:21","book":"Jdg","chapter":20,"verse":21,"letter":"b"},{"kind":"crossref","label":"1Sm 14:47","book":"1Sa","chapter":14,"verse":47,"letter":"c"}],"crossRefs":[{"label":"Jdg 5:14","book":"Jdg","chapter":5,"verse":14},{"label":"Jdg 20:21","book":"Jdg","chapter":20,"verse":21},{"label":"1Sm 14:47","book":"1Sa","chapter":14,"verse":47}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:28","parts":[{"kind":"text","text":"These are the tribes of Israel, twelve in all, and this is what their father said to them. He blessed them, and he blessed each one with a suitable blessing."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:29","parts":[{"kind":"text","text":"Then he commanded them, “I am about to be gathered to my people. "},{"kind":"crossref","label":"Gn 25:8","book":"Gen","chapter":25,"verse":8,"letter":"a"},{"kind":"text","text":" Bury me with my ancestors "},{"kind":"crossref","label":"Gn 47:30","book":"Gen","chapter":47,"verse":30,"letter":"b"},{"kind":"text","text":" in the cave in the field of Ephron the Hethite. "},{"kind":"crossref","label":"Gn 23:16–20","book":"Gen","chapter":23,"verse":16,"letter":"c"},{"kind":"crossref","label":"Gn 50:13","book":"Gen","chapter":50,"verse":13,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 25:8","book":"Gen","chapter":25,"verse":8},{"label":"Gn 47:30","book":"Gen","chapter":47,"verse":30},{"label":"Gn 23:16–20","book":"Gen","chapter":23,"verse":16},{"label":"Gn 50:13","book":"Gen","chapter":50,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:30","parts":[{"kind":"text","text":"The cave is in the field of Machpelah near Mamre, in the land of Canaan. This is the field Abraham purchased from Ephron the Hethite as burial property. "},{"kind":"crossref","label":"Gn 23:3–20","book":"Gen","chapter":23,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 23:3–20","book":"Gen","chapter":23,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:31","parts":[{"kind":"text","text":"Abraham and his wife Sarah are buried there, "},{"kind":"crossref","label":"Gn 23:19","book":"Gen","chapter":23,"verse":19,"letter":"a"},{"kind":"crossref","label":"Gn 25:9","book":"Gen","chapter":25,"verse":9,"letter":"b"},{"kind":"text","text":" Isaac and his wife Rebekah are buried there, "},{"kind":"crossref","label":"Gn 35:29","book":"Gen","chapter":35,"verse":29,"letter":"c"},{"kind":"text","text":" and I buried Leah there. "},{"kind":"crossref","label":"Gn 48:7","book":"Gen","chapter":48,"verse":7,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 23:19","book":"Gen","chapter":23,"verse":19},{"label":"Gn 25:9","book":"Gen","chapter":25,"verse":9},{"label":"Gn 35:29","book":"Gen","chapter":35,"verse":29},{"label":"Gn 48:7","book":"Gen","chapter":48,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:32","parts":[{"kind":"text","text":"The field and the cave in it were purchased from the Hethites.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:49:33","parts":[{"kind":"text","text":"When Jacob had finished giving charges to his sons, he drew his feet into the bed, took his last breath, and was gathered to his people."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279315521}