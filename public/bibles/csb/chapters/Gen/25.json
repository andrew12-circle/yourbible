:"Gal","chapter":4,"verse":27},{"label":"Heb 11:11","book":"Heb","chapter":11,"verse":11},{"label":"1Sm 1:17","book":"1Sa","chapter":1,"verse":17},{"label":"1Ch 5:20","book":"1Ch","chapter":5,"verse":20},{"label":"2Ch 33:13","book":"2Ch","chapter":33,"verse":13},{"label":"Ezr 8:23","book":"Ezr","chapter":8,"verse":23},{"label":"Ps 127:3","book":"Psa","chapter":127,"verse":3},{"label":"Rm 9:10","book":"Rom","chapter":9,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:22","parts":[{"kind":"text","text":"But the children inside her struggled with each other, and she said, “Why is this happening to me?” "},{"kind":"footnote","marker":1,"text":"Lit said, “If thus, why this I?”"},{"kind":"text","text":" So she went to inquire of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"1Sm 9:9","book":"1Sa","chapter":9,"verse":9,"letter":"a"},{"kind":"crossref","label":"1Sm 10:22","book":"1Sa","chapter":10,"verse":22,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Sm 9:9","book":"1Sa","chapter":9,"verse":9},{"label":"1Sm 10:22","book":"1Sa","chapter":10,"verse":22}],"footnotes":[{"marker":1,"text":"Lit said, “If thus, why this I?”"}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:23","parts":[{"kind":"text","text":"And the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said to her:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:24","parts":[{"kind":"text","text":"When her time came to give birth, there were indeed twins in her womb. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:25","parts":[{"kind":"text","text":"The first one came out red-looking, "},{"kind":"footnote","marker":1,"text":"In Hb, red-looking sounds like “Edom”; Gn 32:3."},{"kind":"text","text":" covered with hair "},{"kind":"footnote","marker":2,"text":"In Hb, hair sounds like “Seir”; Gn 32:3."},{"kind":"text","text":" like a fur coat, and they named him Esau. "},{"kind":"crossref","label":"Gn 27:11","book":"Gen","chapter":27,"verse":11,"letter":"a"},{"kind":"crossref","label":"Gn 27:16","book":"Gen","chapter":27,"verse":16,"letter":"b"},{"kind":"crossref","label":"Gn 27:23","book":"Gen","chapter":27,"verse":23,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 27:11","book":"Gen","chapter":27,"verse":11},{"label":"Gn 27:16","book":"Gen","chapter":27,"verse":16},{"label":"Gn 27:23","book":"Gen","chapter":27,"verse":23}],"footnotes":[{"marker":1,"text":"In Hb, red-looking sounds like “Edom”; Gn 32:3."},{"marker":2,"text":"In Hb, hair sounds like “Seir”; Gn 32:3."}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:26","parts":[{"kind":"text","text":"After this, his brother came out grasping Esau’s heel with his hand. "},{"kind":"crossref","label":"Hs 12:3","book":"Hos","chapter":12,"verse":3,"letter":"a"},{"kind":"text","text":" So he was named Jacob. "},{"kind":"footnote","marker":3,"text":"= He Grasps the Heel"},{"kind":"crossref","label":"Gn 27:36","book":"Gen","chapter":27,"verse":36,"letter":"b"},{"kind":"text","text":" Isaac was sixty years old when they were born."}],"crossRefs":[{"label":"Hs 12:3","book":"Hos","chapter":12,"verse":3},{"label":"Gn 27:36","book":"Gen","chapter":27,"verse":36}],"footnotes":[{"marker":3,"text":"= He Grasps the Heel"}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:27","parts":[{"kind":"text","text":"When the boys grew up, Esau became an expert hunter, an outdoorsman, "},{"kind":"footnote","marker":1,"text":"Lit a man of the field"},{"kind":"text","text":" but Jacob was a quiet man who stayed at home. "},{"kind":"footnote","marker":2,"text":"Lit man living in tents"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit a man of the field"},{"marker":2,"text":"Lit man living in tents"}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:28","parts":[{"kind":"text","text":"Isaac loved Esau because he had a taste for wild game, but Rebekah loved Jacob. "},{"kind":"crossref","label":"Gn 27:4–9","book":"Gen","chapter":27,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Gn 27:4–9","book":"Gen","chapter":27,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:29","parts":[{"kind":"text","text":"Once when Jacob was cooking a stew, Esau came in from the field exhausted. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:30","parts":[{"kind":"text","text":"He said to Jacob, “Let me eat some of that red stuff, because I’m exhausted.” That is why he was also named Edom. "},{"kind":"footnote","marker":1,"text":"= Red"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"= Red"}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:31","parts":[{"kind":"text","text":"Jacob replied, “First sell me your birthright.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:32","parts":[{"kind":"text","text":"“Look,” said Esau, “I’m about to die, so what good is a birthright to me?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:33","parts":[{"kind":"text","text":"Jacob said, “Swear to me first.” So he swore to Jacob and sold his birthright to him. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:34","parts":[{"kind":"text","text":"Then Jacob gave bread and lentil stew to Esau; he ate, drank, got up, and went away. So Esau despised his birthright. "},{"kind":"crossref","label":"Heb 12:16–17","book":"Heb","chapter":12,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Heb 12:16–17","book":"Heb","chapter":12,"verse":16}],"footnotes":[]}]},"cachedAt":1783099219926}