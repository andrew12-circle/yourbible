},{"marker":6,"text":"= Ishmael and his descendants"},{"marker":7,"text":"Or He settled down alongside of"}]},{"verseId":"a556c5305ee15c3f-01:Gen:25:19","parts":[{"kind":"text","text":"These are the family records of Isaac son of Abraham. Abraham fathered Isaac. "},{"kind":"crossref","label":"Mt 1:2","book":"Mat","chapter":1,"verse":2,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 1:2","book":"Mat","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:20","parts":[{"kind":"text","text":"Isaac was forty years old when he took as his wife Rebekah "},{"kind":"crossref","label":"Gn 24:15","book":"Gen","chapter":24,"verse":15,"letter":"a"},{"kind":"crossref","label":"Gn 24:29","book":"Gen","chapter":24,"verse":29,"letter":"b"},{"kind":"crossref","label":"Gn 24:67","book":"Gen","chapter":24,"verse":67,"letter":"c"},{"kind":"text","text":" daughter of Bethuel the Aramean from Paddan-aram "},{"kind":"crossref","label":"Gn 22:23","book":"Gen","chapter":22,"verse":23,"letter":"d"},{"kind":"text","text":" and sister of Laban the Aramean. "},{"kind":"crossref","label":"Gn 24:29","book":"Gen","chapter":24,"verse":29,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 24:15","book":"Gen","chapter":24,"verse":15},{"label":"Gn 24:29","book":"Gen","chapter":24,"verse":29},{"label":"Gn 24:67","book":"Gen","chapter":24,"verse":67},{"label":"Gn 22:23","book":"Gen","chapter":22,"verse":23},{"label":"Gn 24:29","book":"Gen","chapter":24,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:25:21","parts":[{"kind":"text","text":"Isaac prayed to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" on behalf of his wife because she was childless. "},{"kind":"crossref","label":"Gn 11:30","book":"Gen","chapter":11,"verse":30,"letter":"a"},{"kind":"crossref","label":"Gn 29:31","book":"Gen","chapter":29,"verse":31,"letter":"b"},{"kind":"crossref","label":"Ex 23:26","book":"Exo","chapter":23,"verse":