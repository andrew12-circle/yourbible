etter":"b"},{"kind":"crossref","label":"1Tm 2:13","book":"1Ti","chapter":2,"verse":13,"letter":"c"},{"kind":"text","text":" to him.” "}],"crossRefs":[{"label":"Pr 31:11–12","book":"Pro","chapter":31,"verse":11},{"label":"1Co 11:9","book":"1Co","chapter":11,"verse":9},{"label":"1Tm 2:13","book":"1Ti","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:19","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" God formed out of the ground every wild animal and every bird of the sky, and brought each to the man to see what he would call it. "},{"kind":"crossref","label":"Ps 8:6","book":"Psa","chapter":8,"verse":6,"letter":"a"},{"kind":"text","text":" And whatever the man called a living creature, that was its name. "}],"crossRefs":[{"label":"Ps 8:6","book":"Psa","chapter":8,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:20","parts":[{"kind":"text","text":"The man gave names to all the livestock, to the birds of the sky, and to every wild animal; but for the man "},{"kind":"footnote","marker":1,"text":"Or for Adam"},{"kind":"text","text":" no helper was found corresponding to him. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or for Adam"}]},{"verseId":"a556c5305ee15c3f-01:Gen:2:21","parts":[{"kind":"text","text":"So the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" God caused a deep sleep to come over the man, "},{"kind":"crossref","label":"Gn 15:12","book":"Gen","chapter":15,"verse":12,"letter":"a"},{"kind":"text","text":" and he slept. God took one of his ribs and closed the flesh at that place. "}],"crossRefs":[{"label":"Gn 15:12","book":"Gen","chapter":15,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:22","parts":[{"kind":"text","text":"Then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" God made the rib he had taken from the man into a woman and brought her to the man. "},{"kind":"crossref","label":"1Co 11:8","book":"1Co","chapter":11,"verse":8,"letter":"a"},{"kind":"crossref","label":"1Co 11:12","book":"1Co","chapter":11,"verse":12,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Co 11:8","book":"1Co","chapter":11,"verse":8},{"label":"1Co 11:12","book":"1Co","chapter":11,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:23","parts":[{"kind":"text","text":"And the man said:"},{"kind":"text","text":" This one, at last, is bone of my bone"},{"kind":"text","text":" and flesh of my flesh;"},{"kind":"text","text":" this one will be called “woman,”"},{"kind":"text","text":" for she was taken from man. "},{"kind":"crossref","label":"Eph 5:28–30","book":"Eph","chapter":5,"verse":28,"letter":"a"}],"crossRefs":[{"label":"Eph 5:28–30","book":"Eph","chapter":5,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:24","parts":[{"kind":"text","text":"This is why a man leaves his father and mother and bonds with his wife, and they become one flesh. "},{"kind":"crossref","label":"Mal 2:15","book":"Mal","chapter":2,"verse":15,"letter":"a"},{"kind":"crossref","label":"Mt 19:5","book":"Mat","chapter":19,"verse":5,"letter":"b"},{"kind":"crossref","label":"Mk 10:7–8","book":"Mrk","chapter":10,"verse":7,"letter":"c"},{"kind":"crossref","label":"1Co 6:16","book":"1Co","chapter":6,"verse":16,"letter":"d"},{"kind":"crossref","label":"Eph 5:31","book":"Eph","chapter":5,"verse":31,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mal 2:15","book":"Mal","chapter":2,"verse":15},{"label":"Mt 19:5","book":"Mat","chapter":19,"verse":5},{"label":"Mk 10:7–8","book":"Mrk","chapter":10,"verse":7},{"label":"1Co 6:16","book":"1Co","chapter":6,"verse":16},{"label":"Eph 5:31","book":"Eph","chapter":5,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gen:2:25","parts":[{"kind":"text","text":"Both the man and his wife were naked, yet felt no shame."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279300899}