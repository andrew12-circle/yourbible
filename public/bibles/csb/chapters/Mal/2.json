ate us? "},{"kind":"crossref","label":"Dt 32:6","book":"Deu","chapter":32,"verse":6,"letter":"f"},{"kind":"crossref","label":"Is 43:1–7","book":"Isa","chapter":43,"verse":1,"letter":"g"},{"kind":"crossref","label":"Is 64:8","book":"Isa","chapter":64,"verse":8,"letter":"h"},{"kind":"text","text":" Why then do we act treacherously against one another, "},{"kind":"crossref","label":"Ex 21:8","book":"Exo","chapter":21,"verse":8,"letter":"i"},{"kind":"crossref","label":"Jdg 9:23","book":"Jdg","chapter":9,"verse":23,"letter":"j"},{"kind":"crossref","label":"Jb 6:15","book":"Job","chapter":6,"verse":15,"letter":"k"},{"kind":"crossref","label":"Is 21:2","book":"Isa","chapter":21,"verse":2,"letter":"l"},{"kind":"crossref","label":"Jr 3:20","book":"Jer","chapter":3,"verse":20,"letter":"m"},{"kind":"text","text":" profaning "},{"kind":"crossref","label":"Nm 30:2","book":"Num","chapter":30,"verse":2,"letter":"n"},{"kind":"crossref","label":"Ps 55:20","book":"Psa","chapter":55,"verse":20,"letter":"o"},{"kind":"crossref","label":"Ps 89:34","book":"Psa","chapter":89,"verse":34,"letter":"p"},{"kind":"crossref","label":"Mal 1:12","book":"Mal","chapter":1,"verse":12,"letter":"q"},{"kind":"text","text":" the covenant of our ancestors? "},{"kind":"crossref","label":"1Kg 8:21","book":"1Ki","chapter":8,"verse":21,"letter":"r"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 4:22–23","book":"Exo","chapter":4,"verse":22},{"label":"Is 63:16","book":"Isa","chapter":63,"verse":16},{"label":"Hs 11:1","book":"Hos","chapter":11,"verse":1},{"label":"Mal 1:6","book":"Mal","chapter":1,"verse":6},{"label":"Jn 8:41","book":"Jhn","chapter":8,"verse":41},{"label":"Dt 32:6","book":"Deu","chapter":32,"verse":6},{"label":"Is 43:1–7","book":"Isa","chapter":43,"verse":1},{"label":"Is 64:8","book":"Isa","chapter":64,"verse":8},{"label":"Ex 21:8","book":"Exo","chapter":21,"verse":8},{"label":"Jdg 9:23","book":"Jdg","chapter":9,"verse":23},{"label":"Jb 6:15","book":"Job","chapter":6,"verse":15},{"label":