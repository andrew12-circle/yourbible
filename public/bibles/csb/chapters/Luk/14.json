","chapter":21,"verse":33,"letter":"a"},{"kind":"crossref","label":"Dt 22:4","book":"Deu","chapter":22,"verse":4,"letter":"b"},{"kind":"crossref","label":"Mt 12:11","book":"Mat","chapter":12,"verse":11,"letter":"c"},{"kind":"crossref","label":"Lk 13:15","book":"Luk","chapter":13,"verse":15,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 21:33","book":"Exo","chapter":21,"verse":33},{"label":"Dt 22:4","book":"Deu","chapter":22,"verse":4},{"label":"Mt 12:11","book":"Mat","chapter":12,"verse":11},{"label":"Lk 13:15","book":"Luk","chapter":13,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:6","parts":[{"kind":"text","text":"They could find no answer to these things."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:7","parts":[{"kind":"text","text":"He told a parable "},{"kind":"crossref","label":"Lk 5:36","book":"Luk","chapter":5,"verse":36,"letter":"a"},{"kind":"crossref","label":"Lk 13:6","book":"Luk","chapter":13,"verse":6,"letter":"b"},{"kind":"text","text":" to those who were invited, when he noticed how they would choose the best places "},{"kind":"crossref","label":"Lk 11:43","book":"Luk","chapter":11,"verse":43,"letter":"c"},{"kind":"text","text":" for themselves: "}],"crossRefs":[{"label":"Lk 5:36","book":"Luk","chapter":5,"verse":36},{"label":"Lk 13:6","book":"Luk","chapter":13,"verse":6},{"label":"Lk 11:43","book":"Luk","chapter":11,"verse":43}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:8","parts":[{"kind":"text","text":"“When you are invited by someone to a wedding banquet, don’t sit in the place of honor, because a more distinguished person"},{"kind":"crossref","label":"Lk 7:2","book":"Luk","chapter":7,"verse":2,"letter":"a"},{"kind":"crossref","label":"Php 2:29","book":"Php","chapter":2,"verse":29,"letter":"b"},{"kind":"crossref","label":"1Pt 2:4","book":"1Pe","chapter":2,"verse":4,"letter":"c"},{"kind":"text","text":" than you may have been invited by your host. "}],"crossRefs":[{"label":"Lk 7:2","book":"Luk","chapter":7,"verse":2},{"label":"Php 2:29","book":"Php","chapter":2,"verse":29},{"label":"1Pt 2:4","book":"1Pe","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:9","parts":[{"kind":"text","text":"The one who invited both of you may come and say to you, ‘Give your place to this man,’ and then in humiliation, you will proceed to take the lowest place."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:10","parts":[{"kind":"text","text":"“But when you are invited, go and sit in the lowest place, so that when the one who invited you comes, he will say to you, ‘Friend, move up higher.’ You will then be honored"},{"kind":"crossref","label":"Jn 5:44","book":"Jhn","chapter":5,"verse":44,"letter":"a"},{"kind":"crossref","label":"Jn 7:18","book":"Jhn","chapter":7,"verse":18,"letter":"b"},{"kind":"crossref","label":"Rm 2:7","book":"Rom","chapter":2,"verse":7,"letter":"c"},{"kind":"text","text":" in the presence of all the other guests."},{"kind":"crossref","label":"Pr 25:6–7","book":"Pro","chapter":25,"verse":6,"letter":"d"},{"kind":"crossref","label":"Pr 29:23","book":"Pro","chapter":29,"verse":23,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 5:44","book":"Jhn","chapter":5,"verse":44},{"label":"Jn 7:18","book":"Jhn","chapter":7,"verse":18},{"label":"Rm 2:7","book":"Rom","chapter":2,"verse":7},{"label":"Pr 25:6–7","book":"Pro","chapter":25,"verse":6},{"label":"Pr 29:23","book":"Pro","chapter":29,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:11","parts":[{"kind":"text","text":"For everyone who exalts himself will be humbled, and the one who humbles himself will be exalted.”"},{"kind":"crossref","label":"Ezk 21:26","book":"Ezk","chapter":21,"verse":26,"letter":"a"},{"kind":"crossref","label":"Mt 18:4","book":"Mat","chapter":18,"verse":4,"letter":"b"},{"kind":"crossref","label":"Mt 23:12","book":"Mat","chapter":23,"verse":12,"letter":"c"},{"kind":"crossref","label":"Lk 1:51","book":"Luk","chapter":1,"verse":51,"letter":"d"},{"kind":"crossref","label":"Lk 3:5","book":"Luk","chapter":3,"verse":5,"letter":"e"},{"kind":"crossref","label":"Lk 18:14","book":"Luk","chapter":18,"verse":14,"letter":"f"},{"kind":"crossref","label":"Jms 4:10","book":"Jas","chapter":4,"verse":10,"letter":"g"},{"kind":"crossref","label":"1Pt 5:5","book":"1Pe","chapter":5,"verse":5,"letter":"h"}],"crossRefs":[{"label":"Ezk 21:26","book":"Ezk","chapter":21,"verse":26},{"label":"Mt 18:4","book":"Mat","chapter":18,"verse":4},{"label":"Mt 23:12","book":"Mat","chapter":23,"verse":12},{"label":"Lk 1:51","book":"Luk","chapter":1,"verse":51},{"label":"Lk 3:5","book":"Luk","chapter":3,"verse":5},{"label":"Lk 18:14","book":"Luk","chapter":18,"verse":14},{"label":"Jms 4:10","book":"Jas","chapter":4,"verse":10},{"label":"1Pt 5:5","book":"1Pe","chapter":5,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:12","parts":[{"kind":"text","text":"He also said to the one who had invited him, “When you give a lunch or a dinner, don’t invite your friends, your brothers or sisters, your relatives, or your rich neighbors, because they might invite you back, and you would be repaid. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:13","parts":[{"kind":"text","text":"On the contrary, when you host a banquet,"},{"kind":"crossref","label":"Lk 5:29","book":"Luk","chapter":5,"verse":29,"letter":"a"},{"kind":"text","text":" invite those who are poor, maimed, lame, or blind."},{"kind":"crossref","label":"Lv 22:22","book":"Lev","chapter":22,"verse":22,"letter":"b"},{"kind":"crossref","label":"Lk 14:21","book":"Luk","chapter":14,"verse":21,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 5:29","book":"Luk","chapter":5,"verse":29},{"label":"Lv 22:22","book":"Lev","chapter":22,"verse":22},{"label":"Lk 14:21","book":"Luk","chapter":14,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:14","parts":[{"kind":"text","text":"And you will be blessed, because they cannot repay you; for you will be repaid"},{"kind":"crossref","label":"Rm 11:35","book":"Rom","chapter":11,"verse":35,"letter":"a"},{"kind":"crossref","label":"Rm 12:19","book":"Rom","chapter":12,"verse":19,"letter":"b"},{"kind":"crossref","label":"1Th 3:9","book":"1Th","chapter":3,"verse":9,"letter":"c"},{"kind":"crossref","label":"2Th 1:6","book":"2Th","chapter":1,"verse":6,"letter":"d"},{"kind":"crossref","label":"Heb 10:30","book":"Heb","chapter":10,"verse":30,"letter":"e"},{"kind":"text","text":" at the resurrection of the righteous.”"},{"kind":"crossref","label":"Ac 24:15","book":"Act","chapter":24,"verse":15,"letter":"f"}],"crossRefs":[{"label":"Rm 11:35","book":"Rom","chapter":11,"verse":35},{"label":"Rm 12:19","book":"Rom","chapter":12,"verse":19},{"label":"1Th 3:9","book":"1Th","chapter":3,"verse":9},{"label":"2Th 1:6","book":"2Th","chapter":1,"verse":6},{"label":"Heb 10:30","book":"Heb","chapter":10,"verse":30},{"label":"Ac 24:15","book":"Act","chapter":24,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:15","parts":[{"kind":"text","text":"When "},{"kind":"crossref","label":"Mt 22:1–14","book":"Mat","chapter":22,"verse":1,"letter":"a"},{"kind":"text","text":" one of those who reclined at the table with him heard these things, he said to him, “Blessed is the one who will eat bread in the kingdom of God!” "},{"kind":"crossref","label":"Lk 13:29","book":"Luk","chapter":13,"verse":29,"letter":"b"},{"kind":"crossref","label":"Lk 22:16","book":"Luk","chapter":22,"verse":16,"letter":"c"},{"kind":"crossref","label":"Lk 22:30","book":"Luk","chapter":22,"verse":30,"letter":"d"},{"kind":"crossref","label":"Rv 19:9","book":"Rev","chapter":19,"verse":9,"letter":"e"}],"crossRefs":[{"label":"Mt 22:1–14","book":"Mat","chapter":22,"verse":1},{"label":"Lk 13:29","book":"Luk","chapter":13,"verse":29},{"label":"Lk 22:16","book":"Luk","chapter":22,"verse":16},{"label":"Lk 22:30","book":"Luk","chapter":22,"verse":30},{"label":"Rv 19:9","book":"Rev","chapter":19,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:16","parts":[{"kind":"text","text":"Then he told him, “A man was giving a large banquet and invited many. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:17","parts":[{"kind":"text","text":"At the time of the banquet, he sent his servant to tell those who were invited, ‘Come, because everything is now ready.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:18","parts":[{"kind":"text","text":"“But without exception"},{"kind":"footnote","marker":1,"text":"Lit “And from one (voice)"},{"kind":"text","text":" they all began to make excuses. The first one said to him, ‘I have bought a field, and I must go out and see it. I ask you to excuse me.’"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit “And from one (voice)"}]},{"verseId":"a556c5305ee15c3f-01:Luk:14:19","parts":[{"kind":"text","text":"“Another said, ‘I have bought five yoke of oxen, and I’m going to try them out. I ask you to excuse me.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:20","parts":[{"kind":"text","text":"“And another said, ‘I just got married,"},{"kind":"crossref","label":"Dt 24:5","book":"Deu","chapter":24,"verse":5,"letter":"a"},{"kind":"text","text":" and therefore I’m unable to come.’"}],"crossRefs":[{"label":"Dt 24:5","book":"Deu","chapter":24,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:21","parts":[{"kind":"text","text":"“So the servant came back and reported these things to his master. Then in anger, the master of the house told his servant, ‘Go out quickly into the streets and alleys of the city, and bring in here the poor, maimed, blind, and lame.’"},{"kind":"crossref","label":"Lk 14:13","book":"Luk","chapter":14,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Lk 14:13","book":"Luk","chapter":14,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:22","parts":[{"kind":"text","text":"“ ‘Master,’ the servant said, ‘what you ordered has been done, and there’s still room.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:23","parts":[{"kind":"text","text":"“Then the master told the servant, ‘Go out into the highways and hedges and make them come in, so that my house may be filled. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:24","parts":[{"kind":"text","text":"For I tell you, not one of those people who were invited will enjoy my banquet.’”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:25","parts":[{"kind":"text","text":"Now "},{"kind":"crossref","label":"Mt 10:37–38","book":"Mat","chapter":10,"verse":37,"letter":"a"},{"kind":"text","text":" great crowds were traveling with him. So he turned and said to them, "}],"crossRefs":[{"label":"Mt 10:37–38","book":"Mat","chapter":10,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:26","parts":[{"kind":"text","text":"“If anyone comes to me"},{"kind":"crossref","label":"Mt 11:28","book":"Mat","chapter":11,"verse":28,"letter":"a"},{"kind":"crossref","label":"Mk 10:14","book":"Mrk","chapter":10,"verse":14,"letter":"b"},{"kind":"crossref","label":"Lk 6:47","book":"Luk","chapter":6,"verse":47,"letter":"c"},{"kind":"crossref","label":"Jn 5:40","book":"Jhn","chapter":5,"verse":40,"letter":"d"},{"kind":"text","text":" and does not hate"},{"kind":"crossref","label":"Dt 21:15","book":"Deu","chapter":21,"verse":15,"letter":"e"},{"kind":"crossref","label":"Dt 22:13","book":"Deu","chapter":22,"verse":13,"letter":"f"},{"kind":"crossref","label":"Dt 24:3","book":"Deu","chapter":24,"verse":3,"letter":"g"},{"kind":"crossref","label":"Lk 16:13","book":"Luk","chapter":16,"verse":13,"letter":"h"},{"kind":"text","text":" his own father and mother, wife and children, brothers and sisters —yes, and even his own life —he cannot be my disciple. "}],"crossRefs":[{"label":"Mt 11:28","book":"Mat","chapter":11,"verse":28},{"label":"Mk 10:14","book":"Mrk","chapter":10,"verse":14},{"label":"Lk 6:47","book":"Luk","chapter":6,"verse":47},{"label":"Jn 5:40","book":"Jhn","chapter":5,"verse":40},{"label":"Dt 21:15","book":"Deu","chapter":21,"verse":15},{"label":"Dt 22:13","book":"Deu","chapter":22,"verse":13},{"label":"Dt 24:3","book":"Deu","chapter":24,"verse":3},{"label":"Lk 16:13","book":"Luk","chapter":16,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:27","parts":[{"kind":"text","text":"Whoever does not bear his own cross"},{"kind":"crossref","label":"Jn 19:17","book":"Jhn","chapter":19,"verse":17,"letter":"a"},{"kind":"text","text":" and come after me cannot be my disciple."}],"crossRefs":[{"label":"Jn 19:17","book":"Jhn","chapter":19,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:28","parts":[{"kind":"text","text":"“For which of you, wanting to build a tower, doesn’t first sit down and calculate the cost"},{"kind":"crossref","label":"Pr 24:27","book":"Pro","chapter":24,"verse":27,"letter":"a"},{"kind":"text","text":" to see if he has enough to complete it? "}],"crossRefs":[{"label":"Pr 24:27","book":"Pro","chapter":24,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:29","parts":[{"kind":"text","text":"Otherwise, after he has laid the foundation and cannot finish it, all the onlookers will begin to ridicule him, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:30","parts":[{"kind":"text","text":"saying, ‘This man started to build and wasn’t able to finish.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:31","parts":[{"kind":"text","text":"“Or what king, going to war against another king, will not first sit down and decide if he is able with ten thousand to oppose the one who comes against him with twenty thousand? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:32","parts":[{"kind":"text","text":"If not, while the other is still far off, he sends a delegation and asks for terms of peace. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:33","parts":[{"kind":"text","text":"In the same way, therefore, every one of you who does not renounce"},{"kind":"footnote","marker":1,"text":"Or leave"},{"kind":"text","text":" all his possessions"},{"kind":"crossref","label":"Mt 19:21","book":"Mat","chapter":19,"verse":21,"letter":"a"},{"kind":"crossref","label":"Php 3:7","book":"Php","chapter":3,"verse":7,"letter":"b"},{"kind":"crossref","label":"Heb 11:26","book":"Heb","chapter":11,"verse":26,"letter":"c"},{"kind":"text","text":" cannot be my disciple."}],"crossRefs":[{"label":"Mt 19:21","book":"Mat","chapter":19,"verse":21},{"label":"Php 3:7","book":"Php","chapter":3,"verse":7},{"label":"Heb 11:26","book":"Heb","chapter":11,"verse":26}],"footnotes":[{"marker":1,"text":"Or leave"}]},{"verseId":"a556c5305ee15c3f-01:Luk:14:34","parts":[{"kind":"text","text":"“Now,"},{"kind":"crossref","label":"Mt 5:13","book":"Mat","chapter":5,"verse":13,"letter":"a"},{"kind":"crossref","label":"Mk 9:49–50","book":"Mrk","chapter":9,"verse":49,"letter":"b"},{"kind":"text","text":" salt"},{"kind":"crossref","label":"Jdg 9:45","book":"Jdg","chapter":9,"verse":45,"letter":"c"},{"kind":"crossref","label":"Mk 9:50","book":"Mrk","chapter":9,"verse":50,"letter":"d"},{"kind":"text","text":" is good, but if salt should lose its taste, how will it be made salty? "}],"crossRefs":[{"label":"Mt 5:13","book":"Mat","chapter":5,"verse":13},{"label":"Mk 9:49–50","book":"Mrk","chapter":9,"verse":49},{"label":"Jdg 9:45","book":"Jdg","chapter":9,"verse":45},{"label":"Mk 9:50","book":"Mrk","chapter":9,"verse":50}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:14:35","parts":[{"kind":"text","text":"It isn’t fit for the soil or for the manure pile; they throw it out. Let anyone who has ears to hear listen.”"},{"kind":"crossref","label":"Mt 11:15","book":"Mat","chapter":11,"verse":15,"letter":"a"},{"kind":"crossref","label":"Mt 13:9","book":"Mat","chapter":13,"verse":9,"letter":"b"},{"kind":"crossref","label":"Mk 4:9","book":"Mrk","chapter":4,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Mt 11:15","book":"Mat","chapter":11,"verse":15},{"label":"Mt 13:9","book":"Mat","chapter":13,"verse":9},{"label":"Mk 4:9","book":"Mrk","chapter":4,"verse":9}],"footnotes":[]}]},"cachedAt":1783099512615}