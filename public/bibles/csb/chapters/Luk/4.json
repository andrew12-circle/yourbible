xo","chapter":34,"verse":28},{"label":"Dt 9:9","book":"Deu","chapter":9,"verse":9},{"label":"Dt 9:11","book":"Deu","chapter":9,"verse":11},{"label":"Dt 9:18","book":"Deu","chapter":9,"verse":18},{"label":"Dt 9:25","book":"Deu","chapter":9,"verse":25},{"label":"Dt 10:10","book":"Deu","chapter":10,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:3","parts":[{"kind":"text","text":"The devil said to him, “If you are the Son of God, tell this stone to become bread.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:4","parts":[{"kind":"text","text":"But Jesus answered him, “It is written: Man must not live on bread alone.”"},{"kind":"footnote","marker":1,"text":"Other mss add but on every word of God"},{"kind":"crossref","label":"Dt 8:3","book":"Deu","chapter":8,"verse":3,"letter":"a"},{"kind":"crossref","label":"Dt 8:3","book":"Deu","chapter":8,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Dt 8:3","book":"Deu","chapter":8,"verse":3},{"label":"Dt 8:3","book":"Deu","chapter":8,"verse":3}],"footnotes":[{"marker":1,"text":"Other mss add but on every word of God"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:5","parts":[{"kind":"text","text":"So he took him up "},{"kind":"footnote","marker":1,"text":"Other mss read So the devil took him up on a high mountain"},{"kind":"text","text":" and showed him all the kingdoms of the world "},{"kind":"crossref","label":"Is 23:17","book":"Isa","chapter":23,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jr 25:26","book":"Jer","chapter":25,"verse":26,"letter":"b"},{"kind":"text","text":" in a moment of time. "}],"crossRefs":[{"label":"Is 23:17","book":"Isa","chapter":23,"verse":17},{"label":"Jr 25:26","book":"Jer","chapter":25,"verse":26}],"footnotes":[{"marker":1,"text":"Other mss read So the devil took him up on a high mountain"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:6","parts":[{"kind":"text","text":"The devil said to him, “I will give you their splendor and all this authority, because it has been given over to me, "},{"kind":"crossref","label":"1Jn 5:19","book":"1Jn","chapter":5,"verse":19,"letter":"a"},{"kind":"text","text":" and I can give it to anyone I want. "}],"crossRefs":[{"label":"1Jn 5:19","book":"1Jn","chapter":5,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:7","parts":[{"kind":"text","text":"If you, then, will worship me, "},{"kind":"footnote","marker":2,"text":"Lit will fall down before me"},{"kind":"text","text":" all will be yours.”"}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Lit will fall down before me"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:8","parts":[{"kind":"text","text":"And Jesus answered him, "},{"kind":"footnote","marker":1,"text":"Other mss add “Get behind me, Satan!"},{"kind":"text","text":" “It is written: Worship the Lord your God, and serve"},{"kind":"crossref","label":"Dt 6:13","book":"Deu","chapter":6,"verse":13,"letter":"a"},{"kind":"text","text":" him only.”"},{"kind":"crossref","label":"Dt 6:13","book":"Deu","chapter":6,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Dt 6:13","book":"Deu","chapter":6,"verse":13},{"label":"Dt 6:13","book":"Deu","chapter":6,"verse":13}],"footnotes":[{"marker":1,"text":"Other mss add “Get behind me, Satan!"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:9","parts":[{"kind":"text","text":"So he took him to Jerusalem, had him stand on the pinnacle of the temple, and said to him, “If you are the Son of God, throw yourself down from here. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:10","parts":[{"kind":"text","text":"For it is written:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:11","parts":[{"kind":"text","text":"and"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:12","parts":[{"kind":"text","text":"And Jesus answered him, “It is said: Do not test the Lord your God.”"},{"kind":"crossref","label":"Dt 6:16","book":"Deu","chapter":6,"verse":16,"letter":"a"},{"kind":"crossref","label":"Dt 6:16","book":"Deu","chapter":6,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Dt 6:16","book":"Deu","chapter":6,"verse":16},{"label":"Dt 6:16","book":"Deu","chapter":6,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:13","parts":[{"kind":"text","text":"After the devil had finished every temptation, he departed from him for a time."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:14","parts":[{"kind":"text","text":"Then Jesus returned to Galilee in the power of the Spirit, "},{"kind":"crossref","label":"Mt 4:12","book":"Mat","chapter":4,"verse":12,"letter":"a"},{"kind":"text","text":" and news about him spread throughout the entire vicinity. "},{"kind":"crossref","label":"Mt 4:24","book":"Mat","chapter":4,"verse":24,"letter":"b"},{"kind":"crossref","label":"Mt 9:26","book":"Mat","chapter":9,"verse":26,"letter":"c"},{"kind":"crossref","label":"Mt 9:31","book":"Mat","chapter":9,"verse":31,"letter":"d"},{"kind":"crossref","label":"Mk 1:28","book":"Mrk","chapter":1,"verse":28,"letter":"e"},{"kind":"crossref","label":"Mk 1:45","book":"Mrk","chapter":1,"verse":45,"letter":"f"},{"kind":"crossref","label":"Lk 4:37","book":"Luk","chapter":4,"verse":37,"letter":"g"},{"kind":"crossref","label":"Lk 5:15","book":"Luk","chapter":5,"verse":15,"letter":"h"},{"kind":"crossref","label":"Lk 9:60","book":"Luk","chapter":9,"verse":60,"letter":"i"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 4:12","book":"Mat","chapter":4,"verse":12},{"label":"Mt 4:24","book":"Mat","chapter":4,"verse":24},{"label":"Mt 9:26","book":"Mat","chapter":9,"verse":26},{"label":"Mt 9:31","book":"Mat","chapter":9,"verse":31},{"label":"Mk 1:28","book":"Mrk","chapter":1,"verse":28},{"label":"Mk 1:45","book":"Mrk","chapter":1,"verse":45},{"label":"Lk 4:37","book":"Luk","chapter":4,"verse":37},{"label":"Lk 5:15","book":"Luk","chapter":5,"verse":15},{"label":"Lk 9:60","book":"Luk","chapter":9,"verse":60}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:15","parts":[{"kind":"text","text":"He was teaching in their synagogues, "},{"kind":"crossref","label":"Mt 4:23","book":"Mat","chapter":4,"verse":23,"letter":"a"},{"kind":"crossref","label":"Mt 9:35","book":"Mat","chapter":9,"verse":35,"letter":"b"},{"kind":"crossref","label":"Lk 4:44","book":"Luk","chapter":4,"verse":44,"letter":"c"},{"kind":"crossref","label":"Lk 13:10","book":"Luk","chapter":13,"verse":10,"letter":"d"},{"kind":"crossref","label":"Ac 9:20","book":"Act","chapter":9,"verse":20,"letter":"e"},{"kind":"crossref","label":"Ac 13:5","book":"Act","chapter":13,"verse":5,"letter":"f"},{"kind":"text","text":" being praised "},{"kind":"footnote","marker":1,"text":"Or glorified"},{"kind":"text","text":" by everyone."}],"crossRefs":[{"label":"Mt 4:23","book":"Mat","chapter":4,"verse":23},{"label":"Mt 9:35","book":"Mat","chapter":9,"verse":35},{"label":"Lk 4:44","book":"Luk","chapter":4,"verse":44},{"label":"Lk 13:10","book":"Luk","chapter":13,"verse":10},{"label":"Ac 9:20","book":"Act","chapter":9,"verse":20},{"label":"Ac 13:5","book":"Act","chapter":13,"verse":5}],"footnotes":[{"marker":1,"text":"Or glorified"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:16","parts":[{"kind":"text","text":"He came to Nazareth, where he had been brought up. "},{"kind":"crossref","label":"Lk 2:39","book":"Luk","chapter":2,"verse":39,"letter":"a"},{"kind":"crossref","label":"Lk 2:51","book":"Luk","chapter":2,"verse":51,"letter":"b"},{"kind":"text","text":" As usual, he entered the synagogue on the Sabbath day "},{"kind":"crossref","label":"Mt 13:54","book":"Mat","chapter":13,"verse":54,"letter":"c"},{"kind":"crossref","label":"Mk 6:1–2","book":"Mrk","chapter":6,"verse":1,"letter":"d"},{"kind":"text","text":" and stood up to read. "},{"kind":"crossref","label":"Ac 13:14–16","book":"Act","chapter":13,"verse":14,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 2:39","book":"Luk","chapter":2,"verse":39},{"label":"Lk 2:51","book":"Luk","chapter":2,"verse":51},{"label":"Mt 13:54","book":"Mat","chapter":13,"verse":54},{"label":"Mk 6:1–2","book":"Mrk","chapter":6,"verse":1},{"label":"Ac 13:14–16","book":"Act","chapter":13,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:17","parts":[{"kind":"text","text":"The scroll of the prophet Isaiah was given to him, and unrolling the scroll, he found the place where it was written:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:18","parts":[{"kind":"text","text":"The Spirit of the Lord is on me,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:19","parts":[{"kind":"text","text":"to proclaim the year of the Lord’s favor."},{"kind":"crossref","label":"Is 61:1–2","book":"Isa","chapter":61,"verse":1,"letter":"a"},{"kind":"crossref","label":"Is 61:1–2","book":"Isa","chapter":61,"verse":1,"letter":"b"},{"kind":"crossref","label":"Mt 11:5","book":"Mat","chapter":11,"verse":5,"letter":"c"},{"kind":"crossref","label":"Mt 12:18","book":"Mat","chapter":12,"verse":18,"letter":"d"},{"kind":"crossref","label":"Jn 3:34","book":"Jhn","chapter":3,"verse":34,"letter":"e"}],"crossRefs":[{"label":"Is 61:1–2","book":"Isa","chapter":61,"verse":1},{"label":"Is 61:1–2","book":"Isa","chapter":61,"verse":1},{"label":"Mt 11:5","book":"Mat","chapter":11,"verse":5},{"label":"Mt 12:18","book":"Mat","chapter":12,"verse":18},{"label":"Jn 3:34","book":"Jhn","chapter":3,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:20","parts":[{"kind":"text","text":"He then rolled up the scroll, gave it back to the attendant, and sat down. "},{"kind":"crossref","label":"Mt 26:55","book":"Mat","chapter":26,"verse":55,"letter":"a"},{"kind":"text","text":" And the eyes of everyone in the synagogue were fixed on him. "}],"crossRefs":[{"label":"Mt 26:55","book":"Mat","chapter":26,"verse":55}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:21","parts":[{"kind":"text","text":"He began by saying to them, “Today as you listen, this Scripture has been fulfilled.”"},{"kind":"crossref","label":"Jn 13:18","book":"Jhn","chapter":13,"verse":18,"letter":"a"},{"kind":"crossref","label":"Jn 15:25","book":"Jhn","chapter":15,"verse":25,"letter":"b"},{"kind":"crossref","label":"Jn 17:12","book":"Jhn","chapter":17,"verse":12,"letter":"c"},{"kind":"crossref","label":"Jn 19:28","book":"Jhn","chapter":19,"verse":28,"letter":"d"},{"kind":"crossref","label":"Jn 19:36","book":"Jhn","chapter":19,"verse":36,"letter":"e"},{"kind":"crossref","label":"Ac 1:16","book":"Act","chapter":1,"verse":16,"letter":"f"},{"kind":"crossref","label":"Jms 2:23","book":"Jas","chapter":2,"verse":23,"letter":"g"}],"crossRefs":[{"label":"Jn 13:18","book":"Jhn","chapter":13,"verse":18},{"label":"Jn 15:25","book":"Jhn","chapter":15,"verse":25},{"label":"Jn 17:12","book":"Jhn","chapter":17,"verse":12},{"label":"Jn 19:28","book":"Jhn","chapter":19,"verse":28},{"label":"Jn 19:36","book":"Jhn","chapter":19,"verse":36},{"label":"Ac 1:16","book":"Act","chapter":1,"verse":16},{"label":"Jms 2:23","book":"Jas","chapter":2,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:22","parts":[{"kind":"text","text":"They were all speaking well of him "},{"kind":"footnote","marker":1,"text":"Or They were testifying against him"},{"kind":"text","text":" and were amazed by the gracious words that came from his mouth; yet they said, “Isn’t this Joseph’s son?” "},{"kind":"crossref","label":"Mt 13:55","book":"Mat","chapter":13,"verse":55,"letter":"a"},{"kind":"crossref","label":"Mk 6:3","book":"Mrk","chapter":6,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jn 6:42","book":"Jhn","chapter":6,"verse":42,"letter":"c"}],"crossRefs":[{"label":"Mt 13:55","book":"Mat","chapter":13,"verse":55},{"label":"Mk 6:3","book":"Mrk","chapter":6,"verse":3},{"label":"Jn 6:42","book":"Jhn","chapter":6,"verse":42}],"footnotes":[{"marker":1,"text":"Or They were testifying against him"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:23","parts":[{"kind":"text","text":"Then he said to them, “No doubt you will quote this proverb"},{"kind":"footnote","marker":1,"text":"Or parable"},{"kind":"text","text":" to me: ‘Doctor, heal yourself. What we’ve heard that took place in Capernaum,"},{"kind":"crossref","label":"Mt 11:23","book":"Mat","chapter":11,"verse":23,"letter":"a"},{"kind":"crossref","label":"Mk 2:1–12","book":"Mrk","chapter":2,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jn 4:46–53","book":"Jhn","chapter":4,"verse":46,"letter":"c"},{"kind":"text","text":" do here in your hometown also.’”"}],"crossRefs":[{"label":"Mt 11:23","book":"Mat","chapter":11,"verse":23},{"label":"Mk 2:1–12","book":"Mrk","chapter":2,"verse":1},{"label":"Jn 4:46–53","book":"Jhn","chapter":4,"verse":46}],"footnotes":[{"marker":1,"text":"Or parable"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:24","parts":[{"kind":"text","text":"He also said, “Truly I tell you, no prophet is accepted in his hometown."},{"kind":"crossref","label":"Mt 13:57","book":"Mat","chapter":13,"verse":57,"letter":"a"},{"kind":"crossref","label":"Mk 6:4","book":"Mrk","chapter":6,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jn 4:44","book":"Jhn","chapter":4,"verse":44,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 13:57","book":"Mat","chapter":13,"verse":57},{"label":"Mk 6:4","book":"Mrk","chapter":6,"verse":4},{"label":"Jn 4:44","book":"Jhn","chapter":4,"verse":44}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:25","parts":[{"kind":"text","text":"But I say to you, there were certainly many widows in Israel in Elijah’s days,"},{"kind":"crossref","label":"1Kg 17:1","book":"1Ki","chapter":17,"verse":1,"letter":"a"},{"kind":"crossref","label":"1Kg 18:1","book":"1Ki","chapter":18,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jms 5:17","book":"Jas","chapter":5,"verse":17,"letter":"c"},{"kind":"text","text":" when the sky was shut up for three years and six months while a great famine came over all the land. "}],"crossRefs":[{"label":"1Kg 17:1","book":"1Ki","chapter":17,"verse":1},{"label":"1Kg 18:1","book":"1Ki","chapter":18,"verse":1},{"label":"Jms 5:17","book":"Jas","chapter":5,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:26","parts":[{"kind":"text","text":"Yet Elijah was not sent to any of them except a widow at Zarephath in Sidon."},{"kind":"crossref","label":"1Kg 17:8","book":"1Ki","chapter":17,"verse":8,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Kg 17:8","book":"1Ki","chapter":17,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:27","parts":[{"kind":"text","text":"And in the prophet Elisha’s time, there were many in Israel who had leprosy,"},{"kind":"footnote","marker":1,"text":"Gk lepros; a term for various skin diseases; see Lv 13–14"},{"kind":"text","text":" and yet not one of them was cleansed except Naaman the Syrian.”"},{"kind":"crossref","label":"2Kg 5:1","book":"2Ki","chapter":5,"verse":1,"letter":"a"}],"crossRefs":[{"label":"2Kg 5:1","book":"2Ki","chapter":5,"verse":1}],"footnotes":[{"marker":1,"text":"Gk lepros; a term for various skin diseases; see Lv 13–14"}]},{"verseId":"a556c5305ee15c3f-01:Luk:4:28","parts":[{"kind":"text","text":"When they heard this, everyone in the synagogue was enraged. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:29","parts":[{"kind":"text","text":"They got up, drove him out of town, "},{"kind":"crossref","label":"Nm 15:35","book":"Num","chapter":15,"verse":35,"letter":"a"},{"kind":"crossref","label":"Ac 7:58","book":"Act","chapter":7,"verse":58,"letter":"b"},{"kind":"crossref","label":"Heb 13:12","book":"Heb","chapter":13,"verse":12,"letter":"c"},{"kind":"text","text":" and brought him to the edge of the hill that their town was built on, intending to hurl him over the cliff. "}],"crossRefs":[{"label":"Nm 15:35","book":"Num","chapter":15,"verse":35},{"label":"Ac 7:58","book":"Act","chapter":7,"verse":58},{"label":"Heb 13:12","book":"Heb","chapter":13,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:30","parts":[{"kind":"text","text":"But he passed right through the crowd and went on his way. "},{"kind":"crossref","label":"Jn 10:39","book":"Jhn","chapter":10,"verse":39,"letter":"a"}],"crossRefs":[{"label":"Jn 10:39","book":"Jhn","chapter":10,"verse":39}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:31","parts":[{"kind":"text","text":"Then he went down to Capernaum, "},{"kind":"crossref","label":"Mk 1:21–28","book":"Mrk","chapter":1,"verse":21,"letter":"a"},{"kind":"text","text":" a town in Galilee, and was teaching them on the Sabbath. "}],"crossRefs":[{"label":"Mk 1:21–28","book":"Mrk","chapter":1,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:32","parts":[{"kind":"text","text":"They were astonished at his teaching because his message had authority. "},{"kind":"crossref","label":"Mt 7:28–29","book":"Mat","chapter":7,"verse":28,"letter":"a"},{"kind":"crossref","label":"Mk 1:22","book":"Mrk","chapter":1,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jn 7:46","book":"Jhn","chapter":7,"verse":46,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 7:28–29","book":"Mat","chapter":7,"verse":28},{"label":"Mk 1:22","book":"Mrk","chapter":1,"verse":22},{"label":"Jn 7:46","book":"Jhn","chapter":7,"verse":46}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:33","parts":[{"kind":"text","text":"In the synagogue there was a man with an unclean demonic spirit who cried out with a loud voice, "},{"kind":"crossref","label":"Mk 1:23–28","book":"Mrk","chapter":1,"verse":23,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 1:23–28","book":"Mrk","chapter":1,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:34","parts":[{"kind":"text","text":"“Leave us alone! What do you have to do with us, Jesus of Nazareth? Have you come to destroy us? I know who you are —the Holy One of God!” "},{"kind":"crossref","label":"Mk 1:24","book":"Mrk","chapter":1,"verse":24,"letter":"a"},{"kind":"crossref","label":"Jn 6:69","book":"Jhn","chapter":6,"verse":69,"letter":"b"}],"crossRefs":[{"label":"Mk 1:24","book":"Mrk","chapter":1,"verse":24},{"label":"Jn 6:69","book":"Jhn","chapter":6,"verse":69}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:35","parts":[{"kind":"text","text":"But Jesus rebuked him "},{"kind":"crossref","label":"Mt 8:26","book":"Mat","chapter":8,"verse":26,"letter":"a"},{"kind":"crossref","label":"Mk 4:39","book":"Mrk","chapter":4,"verse":39,"letter":"b"},{"kind":"crossref","label":"Lk 4:39","book":"Luk","chapter":4,"verse":39,"letter":"c"},{"kind":"crossref","label":"Lk 4:41","book":"Luk","chapter":4,"verse":41,"letter":"d"},{"kind":"crossref","label":"Lk 8:24","book":"Luk","chapter":8,"verse":24,"letter":"e"},{"kind":"text","text":" and said, “Be silent and come out of him!”"},{"kind":"crossref","label":"Mk 1:25","book":"Mrk","chapter":1,"verse":25,"letter":"f"},{"kind":"crossref","label":"Mk 9:25","book":"Mrk","chapter":9,"verse":25,"letter":"g"},{"kind":"text","text":" And throwing him down before them, the demon came out of him without hurting him at all."}],"crossRefs":[{"label":"Mt 8:26","book":"Mat","chapter":8,"verse":26},{"label":"Mk 4:39","book":"Mrk","chapter":4,"verse":39},{"label":"Lk 4:39","book":"Luk","chapter":4,"verse":39},{"label":"Lk 4:41","book":"Luk","chapter":4,"verse":41},{"label":"Lk 8:24","book":"Luk","chapter":8,"verse":24},{"label":"Mk 1:25","book":"Mrk","chapter":1,"verse":25},{"label":"Mk 9:25","book":"Mrk","chapter":9,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:36","parts":[{"kind":"text","text":"Amazement came over them all, and they were saying to one another, “What is this message? For he commands the unclean spirits with authority and power, and they come out!” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:37","parts":[{"kind":"text","text":"And news about him began to go out to every place in the vicinity."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:38","parts":[{"kind":"text","text":"After he left the synagogue, he entered Simon’s house. "},{"kind":"crossref","label":"Mt 8:14–17","book":"Mat","chapter":8,"verse":14,"letter":"a"},{"kind":"crossref","label":"Mk 1:29–34","book":"Mrk","chapter":1,"verse":29,"letter":"b"},{"kind":"text","text":" Simon’s mother-in-law was suffering from a high fever, and they asked him about her. "},{"kind":"crossref","label":"1Co 9:5","book":"1Co","chapter":9,"verse":5,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 8:14–17","book":"Mat","chapter":8,"verse":14},{"label":"Mk 1:29–34","book":"Mrk","chapter":1,"verse":29},{"label":"1Co 9:5","book":"1Co","chapter":9,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:39","parts":[{"kind":"text","text":"So he stood over her and rebuked the fever, and it left her. She got up immediately "},{"kind":"crossref","label":"Mt 8:3","book":"Mat","chapter":8,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mt 14:31","book":"Mat","chapter":14,"verse":31,"letter":"b"},{"kind":"crossref","label":"Mt 20:34","book":"Mat","chapter":20,"verse":34,"letter":"c"},{"kind":"crossref","label":"Mk 5:42","book":"Mrk","chapter":5,"verse":42,"letter":"d"},{"kind":"crossref","label":"Mk 10:52","book":"Mrk","chapter":10,"verse":52,"letter":"e"},{"kind":"crossref","label":"Lk 1:64","book":"Luk","chapter":1,"verse":64,"letter":"f"},{"kind":"crossref","label":"Lk 5:13","book":"Luk","chapter":5,"verse":13,"letter":"g"},{"kind":"crossref","label":"Lk 5:25","book":"Luk","chapter":5,"verse":25,"letter":"h"},{"kind":"crossref","label":"Ac 9:34","book":"Act","chapter":9,"verse":34,"letter":"i"},{"kind":"text","text":" and began to serve them."}],"crossRefs":[{"label":"Mt 8:3","book":"Mat","chapter":8,"verse":3},{"label":"Mt 14:31","book":"Mat","chapter":14,"verse":31},{"label":"Mt 20:34","book":"Mat","chapter":20,"verse":34},{"label":"Mk 5:42","book":"Mrk","chapter":5,"verse":42},{"label":"Mk 10:52","book":"Mrk","chapter":10,"verse":52},{"label":"Lk 1:64","book":"Luk","chapter":1,"verse":64},{"label":"Lk 5:13","book":"Luk","chapter":5,"verse":13},{"label":"Lk 5:25","book":"Luk","chapter":5,"verse":25},{"label":"Ac 9:34","book":"Act","chapter":9,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:40","parts":[{"kind":"text","text":"When the sun was setting, all those who had anyone sick with various diseases brought them to him. As he laid his hands on each one of them, he healed them. "},{"kind":"crossref","label":"Mt 4:23","book":"Mat","chapter":4,"verse":23,"letter":"a"},{"kind":"crossref","label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 4:23","book":"Mat","chapter":4,"verse":23},{"label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:41","parts":[{"kind":"text","text":"Also, demons were coming out of many, shouting and saying, “You are the Son of God!” "},{"kind":"crossref","label":"Mt 4:3","book":"Mat","chapter":4,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mt 8:29","book":"Mat","chapter":8,"verse":29,"letter":"b"},{"kind":"crossref","label":"Mk 3:11","book":"Mrk","chapter":3,"verse":11,"letter":"c"},{"kind":"text","text":" But he rebuked them and would not allow them to speak, because they knew he was the Messiah. "},{"kind":"crossref","label":"Mt 8:16","book":"Mat","chapter":8,"verse":16,"letter":"d"},{"kind":"crossref","label":"Mk 1:34","book":"Mrk","chapter":1,"verse":34,"letter":"e"},{"kind":"crossref","label":"Mk 3:11–12","book":"Mrk","chapter":3,"verse":11,"letter":"f"}],"crossRefs":[{"label":"Mt 4:3","book":"Mat","chapter":4,"verse":3},{"label":"Mt 8:29","book":"Mat","chapter":8,"verse":29},{"label":"Mk 3:11","book":"Mrk","chapter":3,"verse":11},{"label":"Mt 8:16","book":"Mat","chapter":8,"verse":16},{"label":"Mk 1:34","book":"Mrk","chapter":1,"verse":34},{"label":"Mk 3:11–12","book":"Mrk","chapter":3,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:42","parts":[{"kind":"text","text":"When it was day, he went out and made his way to a deserted place. "},{"kind":"crossref","label":"Mt 14:13","book":"Mat","chapter":14,"verse":13,"letter":"a"},{"kind":"crossref","label":"Mk 1:35–38","book":"Mrk","chapter":1,"verse":35,"letter":"b"},{"kind":"crossref","label":"Mk 1:45","book":"Mrk","chapter":1,"verse":45,"letter":"c"},{"kind":"crossref","label":"Mk 6:31–32","book":"Mrk","chapter":6,"verse":31,"letter":"d"},{"kind":"crossref","label":"Lk 9:12","book":"Luk","chapter":9,"verse":12,"letter":"e"},{"kind":"text","text":" But the crowds were searching for him. They came to him and tried to keep him from leaving them. "}],"crossRefs":[{"label":"Mt 14:13","book":"Mat","chapter":14,"verse":13},{"label":"Mk 1:35–38","book":"Mrk","chapter":1,"verse":35},{"label":"Mk 1:45","book":"Mrk","chapter":1,"verse":45},{"label":"Mk 6:31–32","book":"Mrk","chapter":6,"verse":31},{"label":"Lk 9:12","book":"Luk","chapter":9,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:43","parts":[{"kind":"text","text":"But he said to them, “It is necessary for me to proclaim the good news about the kingdom of God to the other towns also, because I was sent for this purpose.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:4:44","parts":[{"kind":"text","text":"And he was preaching in the synagogues of Judea. "},{"kind":"footnote","marker":1,"text":"Other mss read Galilee"},{"kind":"crossref","label":"Mt 4:23","book":"Mat","chapter":4,"verse":23,"letter":"a"},{"kind":"crossref","label":"Mk 1:39","book":"Mrk","chapter":1,"verse":39,"letter":"b"}],"crossRefs":[{"label":"Mt 4:23","book":"Mat","chapter":4,"verse":23},{"label":"Mk 1:39","book":"Mrk","chapter":1,"verse":39}],"footnotes":[{"marker":1,"text":"Other mss read Galilee"}]}]},"cachedAt":1783099509444}