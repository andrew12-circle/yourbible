ruin my reputation"}]},{"verseId":"a556c5305ee15c3f-01:Luk:18:6","parts":[{"kind":"text","text":"Then the Lord said, “Listen to what the unjust judge says. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:18:7","parts":[{"kind":"text","text":"Will not God grant justice"},{"kind":"crossref","label":"Is 63:4","book":"Isa","chapter":63,"verse":4,"letter":"a"},{"kind":"crossref","label":"Rv 6:10","book":"Rev","chapter":6,"verse":10,"letter":"b"},{"kind":"text","text":" to his elect"},{"kind":"crossref","label":"Mt 24:22","book":"Mat","chapter":24,"verse":22,"letter":"c"},{"kind":"crossref","label":"Rm 8:33","book":"Rom","chapter":8,"verse":33,"letter":"d"},{"kind":"crossref","label":"2Tm 2:10","book":"2Ti","chapter":2,"verse":10,"letter":"e"},{"kind":"crossref","label":"Ti 1:1","book":"Tit","chapter":1,"verse":1,"letter":"f"},{"kind":"text","text":" who cry out to him day and night?"},{"kind":"crossref","label":"Ps 88:1","book":"Psa","chapter":88,"verse":1,"letter":"g"},{"kind":"text","text":" Will he delay"},{"kind":"crossref","label":"2Pt 3:9","book":"2Pe","chapter":3,"verse":9,"letter":"h"},{"kind":"text","text":" helping them?"},{"kind":"footnote","marker":1,"text":"Or Will he put up with them?"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 63:4","book":"Isa","chapter":63,"verse":4},{"label":"Rv 6:10","book":"Rev","chapter":6,"verse":10},{"label":"Mt 24:22","book":"Mat","chapter":24,"verse":22},{"label":"Rm 8:33","book":"Rom","chapter":8,"verse":33},{"label":"2Tm 2:10","book":"2Ti","chapter":2,"verse":10},{"label":"Ti 1:1","book":"Tit","chapter":1,"verse":1},{"label":"Ps 88:1","book":"Psa","chapter":88,"verse":1},{"label":"2Pt 3:9","book":"2Pe","chapter":3,"verse":9}],"footnotes":[{"marker":1,"text":"Or Will he put up with them?"}]},{"verseId":"a556c5305ee15c3f-01:Luk:18:8","parts":[{"kind":"text","text":"I tell you that he will swiftly grant them justice. Nevertheless, when the Son of Man comes,"},{"kind":"crossref","label":"Dn 7:13",