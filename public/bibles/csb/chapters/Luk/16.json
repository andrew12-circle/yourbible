seId":"a556c5305ee15c3f-01:Luk:16:28","parts":[{"kind":"text","text":"because I have five brothers —to warn"},{"kind":"crossref","label":"Ac 2:40","book":"Act","chapter":2,"verse":40,"letter":"a"},{"kind":"crossref","label":"Ac 8:25","book":"Act","chapter":8,"verse":25,"letter":"b"},{"kind":"text","text":" them, so that they won’t also come to this place of torment.’"}],"crossRefs":[{"label":"Ac 2:40","book":"Act","chapter":2,"verse":40},{"label":"Ac 8:25","book":"Act","chapter":8,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:16:29","parts":[{"kind":"text","text":"“But Abraham said, ‘They have Moses and the prophets;"},{"kind":"crossref","label":"Lk 24:27","book":"Luk","chapter":24,"verse":27,"letter":"a"},{"kind":"crossref","label":"Lk 24:44","book":"Luk","chapter":24,"verse":44,"letter":"b"},{"kind":"crossref","label":"Jn 1:45","book":"Jhn","chapter":1,"verse":45,"letter":"c"},{"kind":"crossref","label":"Ac 26:22","book":"Act","chapter":26,"verse":22,"letter":"d"},{"kind":"crossref","label":"Ac 28:23","book":"Act","chapter":28,"verse":23,"letter":"e"},{"kind":"text","text":" they should listen to them.’"}],"crossRefs":[{"label":"Lk 24:27","book":"Luk","chapter":24,"verse":27},{"label":"Lk 24:44","book":"Luk","chapter":24,"verse":44},{"label":"Jn 1:45","book":"Jhn","chapter":1,"verse":45},{"label":"Ac 26:22","book":"Act","chapter":26,"verse":22},{"label":"Ac 28:23","book":"Act","chapter":28,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:16:30","parts":[{"kind":"text","text":"“ ‘No, father Abraham,’ he said. ‘But if someone from the dead goes to them, they will repent.’"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Luk:16:31","parts":[{"kind":"text","text":"“But he told him, ‘If they don’t listen to Moses and the prophets, they will not be persuaded if someone rises from the dead.’”"},{"kind":"crossref","label":"Mt 28:11–15","book":"Mat","chapter":28,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 12:10–11","book":"Jhn","chapter":12,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Mt 28:11–15","book":"Mat","chapter":28,"verse":11},{"label":"Jn 12:10–11","book":"Jhn","chapter":12,"verse":10}],"footnotes":[]}]},"cachedAt":1783279633435}