hapter":4,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:17","parts":[{"kind":"text","text":"although he did not leave himself without a witness, "},{"kind":"crossref","label":"Ac 17:26–27","book":"Act","chapter":17,"verse":26,"letter":"a"},{"kind":"crossref","label":"Rm 1:19–20","book":"Rom","chapter":1,"verse":19,"letter":"b"},{"kind":"text","text":" since he did what is good by giving you rain from heaven and fruitful seasons "},{"kind":"crossref","label":"Lv 26:4","book":"Lev","chapter":26,"verse":4,"letter":"c"},{"kind":"crossref","label":"Dt 11:14","book":"Deu","chapter":11,"verse":14,"letter":"d"},{"kind":"crossref","label":"Dt 28:12","book":"Deu","chapter":28,"verse":12,"letter":"e"},{"kind":"crossref","label":"Jb 5:10","book":"Job","chapter":5,"verse":10,"letter":"f"},{"kind":"crossref","label":"Ps 65:10","book":"Psa","chapter":65,"verse":10,"letter":"g"},{"kind":"crossref","label":"Ps 147:8","book":"Psa","chapter":147,"verse":8,"letter":"h"},{"kind":"crossref","label":"Ezk 34:26","book":"Ezk","chapter":34,"verse":26,"letter":"i"},{"kind":"crossref","label":"Jl 2:23","book":"Jol","chapter":2,"verse":23,"letter":"j"},{"kind":"text","text":" and filling you with food and your hearts with joy.” "}],"crossRefs":[{"label":"Ac 17:26–27","book":"Act","chapter":17,"verse":26},{"label":"Rm 1:19–20","book":"Rom","chapter":1,"verse":19},{"label":"Lv 26:4","book":"Lev","chapter":26,"verse":4},{"label":"Dt 11:14","book":"Deu","chapter":11,"verse":14},{"label":"Dt 28:12","book":"Deu","chapter":28,"verse":12},{"label":"Jb 5:10","book":"Job","chapter":5,"verse":10},{"label":"Ps 65:10","book":"Psa","chapter":65,"verse":10},{"label":"Ps 147:8","book":"Psa","chapter":147,"verse":8},{"label":"Ezk 34:26","book":"Ezk","chapter":34,"verse":26},{"label":"Jl 2:23","book":"Jol","chapter":2,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:18","parts":[{"kind":"text","text":"Even though they said these things, they barely stopped the crowds from sacrificing to them."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:19","parts":[{"kind":"text","text":"Some Jews came from Antioch and Iconium, and when they won over the crowds, they stoned Paul and dragged him out of the city, thinking he was dead. "},{"kind":"crossref","label":"Ac 13:45","book":"Act","chapter":13,"verse":45,"letter":"a"},{"kind":"crossref","label":"Ac 13:51","book":"Act","chapter":13,"verse":51,"letter":"b"},{"kind":"crossref","label":"2Co 11:25","book":"2Co","chapter":11,"verse":25,"letter":"c"},{"kind":"crossref","label":"2Tm 3:11","book":"2Ti","chapter":3,"verse":11,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 13:45","book":"Act","chapter":13,"verse":45},{"label":"Ac 13:51","book":"Act","chapter":13,"verse":51},{"label":"2Co 11:25","book":"2Co","chapter":11,"verse":25},{"label":"2Tm 3:11","book":"2Ti","chapter":3,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:20","parts":[{"kind":"text","text":"After the disciples gathered around him, he got up and went into the town. The next day he left with Barnabas for Derbe. "},{"kind":"crossref","label":"Ac 11:26","book":"Act","chapter":11,"verse":26,"letter":"a"},{"kind":"crossref","label":"Ac 14:22","book":"Act","chapter":14,"verse":22,"letter":"b"},{"kind":"crossref","label":"Ac 14:28","book":"Act","chapter":14,"verse":28,"letter":"c"}],"crossRefs":[{"label":"Ac 11:26","book":"Act","chapter":11,"verse":26},{"label":"Ac 14:22","book":"Act","chapter":14,"verse":22},{"label":"Ac 14:28","book":"Act","chapter":14,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:21","parts":[{"kind":"text","text":"After they had preached the gospel in that town and made many disciples, they returned to Lystra, to Iconium, and to Antioch, "},{"kind":"crossref","label":"Mt 28:19","book":"Mat","chapter":28,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ac 13:51","book":"Act","chapter":13,"verse":51,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 28:19","book":"Mat","chapter":28,"verse":19},{"label":"Ac 13:51","book":"Act","chapter":13,"verse":51}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:22","parts":[{"kind":"text","text":"strengthening the "},{"kind":"footnote","marker":1,"text":"Lit the souls of the"},{"kind":"text","text":" disciples by encouraging them to continue in the faith "},{"kind":"crossref","label":"Ac 11:23","book":"Act","chapter":11,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ac 13:43","book":"Act","chapter":13,"verse":43,"letter":"b"},{"kind":"text","text":" and by telling them, “It is necessary to go through many hardships "},{"kind":"crossref","label":"Lk 22:48","book":"Luk","chapter":22,"verse":48,"letter":"c"},{"kind":"crossref","label":"Jn 15:20","book":"Jhn","chapter":15,"verse":20,"letter":"d"},{"kind":"crossref","label":"Jn 16:33","book":"Jhn","chapter":16,"verse":33,"letter":"e"},{"kind":"crossref","label":"Ac 9:16","book":"Act","chapter":9,"verse":16,"letter":"f"},{"kind":"crossref","label":"Rm 8:17","book":"Rom","chapter":8,"verse":17,"letter":"g"},{"kind":"crossref","label":"1Th 3:3","book":"1Th","chapter":3,"verse":3,"letter":"h"},{"kind":"crossref","label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12,"letter":"i"},{"kind":"text","text":" to enter the kingdom of God.” "}],"crossRefs":[{"label":"Ac 11:23","book":"Act","chapter":11,"verse":23},{"label":"Ac 13:43","book":"Act","chapter":13,"verse":43},{"label":"Lk 22:48","book":"Luk","chapter":22,"verse":48},{"label":"Jn 15:20","book":"Jhn","chapter":15,"verse":20},{"label":"Jn 16:33","book":"Jhn","chapter":16,"verse":33},{"label":"Ac 9:16","book":"Act","chapter":9,"verse":16},{"label":"Rm 8:17","book":"Rom","chapter":8,"verse":17},{"label":"1Th 3:3","book":"1Th","chapter":3,"verse":3},{"label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12}],"footnotes":[{"marker":1,"text":"Lit the souls of the"}]},{"verseId":"a556c5305ee15c3f-01:Act:14:23","parts":[{"kind":"text","text":"When they had appointed elders "},{"kind":"crossref","label":"Ac 11:30","book":"Act","chapter":11,"verse":30,"letter":"a"},{"kind":"crossref","label":"Ac 13:3","book":"Act","chapter":13,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ac 20:32","book":"Act","chapter":20,"verse":32,"letter":"c"},{"kind":"crossref","label":"Ti 1:5","book":"Tit","chapter":1,"verse":5,"letter":"d"},{"kind":"text","text":" for them in every church and prayed with fasting, they committed them to the Lord in whom they had believed."}],"crossRefs":[{"label":"Ac 11:30","book":"Act","chapter":11,"verse":30},{"label":"Ac 13:3","book":"Act","chapter":13,"verse":3},{"label":"Ac 20:32","book":"Act","chapter":20,"verse":32},{"label":"Ti 1:5","book":"Tit","chapter":1,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:24","parts":[{"kind":"text","text":"They passed through Pisidia and came to Pamphylia. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:25","parts":[{"kind":"text","text":"After they had spoken the word in Perga, they went down to Attalia. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:26","parts":[{"kind":"text","text":"From there they sailed back to Antioch where they had been commended to the grace of God for the work they had now completed. "},{"kind":"crossref","label":"Ac 11:19","book":"Act","chapter":11,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ac 13:3","book":"Act","chapter":13,"verse":3,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 11:19","book":"Act","chapter":11,"verse":19},{"label":"Ac 13:3","book":"Act","chapter":13,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:27","parts":[{"kind":"text","text":"After they arrived and gathered the church together, they reported everything God had done with them "},{"kind":"crossref","label":"Ac 15:12","book":"Act","chapter":15,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ac 21:19","book":"Act","chapter":21,"verse":19,"letter":"b"},{"kind":"text","text":" and that he had opened the door "},{"kind":"crossref","label":"1Co 16:9","book":"1Co","chapter":16,"verse":9,"letter":"c"},{"kind":"crossref","label":"2Co 2:12","book":"2Co","chapter":2,"verse":12,"letter":"d"},{"kind":"crossref","label":"Col 4:3","book":"Col","chapter":4,"verse":3,"letter":"e"},{"kind":"crossref","label":"Rv 3:8","book":"Rev","chapter":3,"verse":8,"letter":"f"},{"kind":"text","text":" of faith to the Gentiles. "}],"crossRefs":[{"label":"Ac 15:12","book":"Act","chapter":15,"verse":12},{"label":"Ac 21:19","book":"Act","chapter":21,"verse":19},{"label":"1Co 16:9","book":"1Co","chapter":16,"verse":9},{"label":"2Co 2:12","book":"2Co","chapter":2,"verse":12},{"label":"Col 4:3","book":"Col","chapter":4,"verse":3},{"label":"Rv 3:8","book":"Rev","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:14:28","parts":[{"kind":"text","text":"And they spent a considerable time with the disciples."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279647135}