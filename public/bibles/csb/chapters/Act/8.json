:"Ac 8:1","book":"Act","chapter":8,"verse":1,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 22:8","book":"Luk","chapter":22,"verse":8},{"label":"Ac 8:1","book":"Act","chapter":8,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:15","parts":[{"kind":"text","text":"After they went down there, they prayed for them so that the Samaritans might receive the Holy Spirit because he had not yet come down on any of them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:16","parts":[{"kind":"text","text":"(They had only been baptized in the name of the Lord Jesus. "},{"kind":"crossref","label":"Mt 28:19","book":"Mat","chapter":28,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ac 2:38","book":"Act","chapter":2,"verse":38,"letter":"b"},{"kind":"crossref","label":"Ac 10:48","book":"Act","chapter":10,"verse":48,"letter":"c"},{"kind":"crossref","label":"Ac 19:2","book":"Act","chapter":19,"verse":2,"letter":"d"},{"kind":"text","text":") "}],"crossRefs":[{"label":"Mt 28:19","book":"Mat","chapter":28,"verse":19},{"label":"Ac 2:38","book":"Act","chapter":2,"verse":38},{"label":"Ac 10:48","book":"Act","chapter":10,"verse":48},{"label":"Ac 19:2","book":"Act","chapter":19,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:17","parts":[{"kind":"text","text":"Then Peter and John laid their hands on them, and they received the Holy Spirit."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:18","parts":[{"kind":"text","text":"When Simon saw that the Spirit "},{"kind":"footnote","marker":1,"text":"Other mss add Holy"},{"kind":"text","text":" was given through the laying on of the apostles’ hands, he offered them money, "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss add Holy"}]},{"verseId":"a556c5305ee15c3f-01:Act:8:19","parts":[{"kind":"text","text":"saying, “Give me this power also so that anyone I lay hands on may receive the Holy Spirit.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:20","parts":[{"kind":"text","text":"But Peter told him, “May your silver be destroyed with you, because you thought you could obtain the gift of God with money! "},{"kind":"crossref","label":"2Kg 5:16","book":"2Ki","chapter":5,"verse":16,"letter":"a"},{"kind":"crossref","label":"Is 55:1","book":"Isa","chapter":55,"verse":1,"letter":"b"},{"kind":"crossref","label":"Dn 5:17","book":"Dan","chapter":5,"verse":17,"letter":"c"},{"kind":"crossref","label":"Mt 10:8","book":"Mat","chapter":10,"verse":8,"letter":"d"},{"kind":"crossref","label":"Ac 2:38","book":"Act","chapter":2,"verse":38,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Kg 5:16","book":"2Ki","chapter":5,"verse":16},{"label":"Is 55:1","book":"Isa","chapter":55,"verse":1},{"label":"Dn 5:17","book":"Dan","chapter":5,"verse":17},{"label":"Mt 10:8","book":"Mat","chapter":10,"verse":8},{"label":"Ac 2:38","book":"Act","chapter":2,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:21","parts":[{"kind":"text","text":"You have no part or share in this matter, because your heart is not right before God. "},{"kind":"crossref","label":"2Kg 10:15","book":"2Ki","chapter":10,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ps 78:37","book":"Psa","chapter":78,"verse":37,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Kg 10:15","book":"2Ki","chapter":10,"verse":15},{"label":"Ps 78:37","book":"Psa","chapter":78,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:22","parts":[{"kind":"text","text":"Therefore repent of this wickedness of yours, and pray to the Lord that, if possible, your heart’s intent may be forgiven. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:23","parts":[{"kind":"text","text":"For I see you are poisoned by bitterness and bound by wickedness.” "},{"kind":"crossref","label":"Is 55:6–7","book":"Isa","chapter":55,"verse":6,"letter":"a"},{"kind":"crossref","label":"Dn 4:27","book":"Dan","chapter":4,"verse":27,"letter":"b"},{"kind":"crossref","label":"2Tm 2:25","book":"2Ti","chapter":2,"verse":25,"letter":"c"},{"kind":"crossref","label":"Heb 12:15","book":"Heb","chapter":12,"verse":15,"letter":"d"}],"crossRefs":[{"label":"Is 55:6–7","book":"Isa","chapter":55,"verse":6},{"label":"Dn 4:27","book":"Dan","chapter":4,"verse":27},{"label":"2Tm 2:25","book":"2Ti","chapter":2,"verse":25},{"label":"Heb 12:15","book":"Heb","chapter":12,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:24","parts":[{"kind":"text","text":"“Pray to the Lord for me,” Simon replied, “so that nothing you have said may happen to me.” "},{"kind":"crossref","label":"Gn 20:7","book":"Gen","chapter":20,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ex 8:8","book":"Exo","chapter":8,"verse":8,"letter":"b"},{"kind":"crossref","label":"Nm 21:7","book":"Num","chapter":21,"verse":7,"letter":"c"},{"kind":"crossref","label":"Jms 5:16","book":"Jas","chapter":5,"verse":16,"letter":"d"}],"crossRefs":[{"label":"Gn 20:7","book":"Gen","chapter":20,"verse":7},{"label":"Ex 8:8","book":"Exo","chapter":8,"verse":8},{"label":"Nm 21:7","book":"Num","chapter":21,"verse":7},{"label":"Jms 5:16","book":"Jas","chapter":5,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:25","parts":[{"kind":"text","text":"So, after they had testified and spoken the word of the Lord, they traveled back to Jerusalem, preaching the gospel in many villages of the Samaritans."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:26","parts":[{"kind":"text","text":"An angel of the Lord spoke to Philip: “Get up and go south to the road that goes down from Jerusalem to Gaza.” (This is the desert road. "},{"kind":"footnote","marker":1,"text":"Or is a desert place"},{"kind":"crossref","label":"Ac 5:19","book":"Act","chapter":5,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ac 8:29","book":"Act","chapter":8,"verse":29,"letter":"b"},{"kind":"text","text":") "}],"crossRefs":[{"label":"Ac 5:19","book":"Act","chapter":5,"verse":19},{"label":"Ac 8:29","book":"Act","chapter":8,"verse":29}],"footnotes":[{"marker":1,"text":"Or is a desert place"}]},{"verseId":"a556c5305ee15c3f-01:Act:8:27","parts":[{"kind":"text","text":"So he got up and went. There was an Ethiopian man, a eunuch "},{"kind":"crossref","label":"Ps 68:31","book":"Psa","chapter":68,"verse":31,"letter":"a"},{"kind":"crossref","label":"Ps 87:4","book":"Psa","chapter":87,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 56:3","book":"Isa","chapter":56,"verse":3,"letter":"c"},{"kind":"crossref","label":"Zp 3:10","book":"Zep","chapter":3,"verse":10,"letter":"d"},{"kind":"text","text":" and high official of Candace, queen of the Ethiopians, who was in charge of her entire treasury. He had come to worship in Jerusalem "},{"kind":"crossref","label":"1Kg 8:41","book":"1Ki","chapter":8,"verse":41,"letter":"e"},{"kind":"crossref","label":"Jn 12:20","book":"Jhn","chapter":12,"verse":20,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 68:31","book":"Psa","chapter":68,"verse":31},{"label":"Ps 87:4","book":"Psa","chapter":87,"verse":4},{"label":"Is 56:3","book":"Isa","chapter":56,"verse":3},{"label":"Zp 3:10","book":"Zep","chapter":3,"verse":10},{"label":"1Kg 8:41","book":"1Ki","chapter":8,"verse":41},{"label":"Jn 12:20","book":"Jhn","chapter":12,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:28","parts":[{"kind":"text","text":"and was sitting in his chariot on his way home, reading the prophet Isaiah aloud."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:29","parts":[{"kind":"text","text":"The Spirit told Philip, “Go and join that chariot.” "},{"kind":"crossref","label":"Ac 10:19","book":"Act","chapter":10,"verse":19,"letter":"a"},{"kind":"crossref","label":"Ac 11:12","book":"Act","chapter":11,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ac 13:2","book":"Act","chapter":13,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ac 20:23","book":"Act","chapter":20,"verse":23,"letter":"d"},{"kind":"crossref","label":"Ac 21:11","book":"Act","chapter":21,"verse":11,"letter":"e"}],"crossRefs":[{"label":"Ac 10:19","book":"Act","chapter":10,"verse":19},{"label":"Ac 11:12","book":"Act","chapter":11,"verse":12},{"label":"Ac 13:2","book":"Act","chapter":13,"verse":2},{"label":"Ac 20:23","book":"Act","chapter":20,"verse":23},{"label":"Ac 21:11","book":"Act","chapter":21,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:30","parts":[{"kind":"text","text":"When Philip ran up to it, he heard him reading the prophet Isaiah, and said, “Do you understand what you’re reading?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:31","parts":[{"kind":"text","text":"“How can I,” he said, “unless someone guides me?” So he invited Philip to come up and sit with him. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:32","parts":[{"kind":"text","text":"Now the Scripture passage he was reading was this:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:33","parts":[{"kind":"text","text":"In his humiliation justice was denied him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:34","parts":[{"kind":"text","text":"The eunuch said to Philip, “I ask you, who is the prophet saying this about —himself or someone else?” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:35","parts":[{"kind":"text","text":"Philip proceeded to tell him the good news about Jesus, beginning with that Scripture. "},{"kind":"crossref","label":"Lk 24:27","book":"Luk","chapter":24,"verse":27,"letter":"a"},{"kind":"crossref","label":"Ac 17:2","book":"Act","chapter":17,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ac 18:28","book":"Act","chapter":18,"verse":28,"letter":"c"}],"crossRefs":[{"label":"Lk 24:27","book":"Luk","chapter":24,"verse":27},{"label":"Ac 17:2","book":"Act","chapter":17,"verse":2},{"label":"Ac 18:28","book":"Act","chapter":18,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:36","parts":[{"kind":"text","text":"As they were traveling down the road, they came to some water. The eunuch said, “Look, there’s water. What would keep me from being baptized?” "},{"kind":"footnote","marker":1,"text":"Some mss include v. 37: Philip said, “If you believe with all your heart you may.” And he replied, “I believe that Jesus Christ is the Son of God.”"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Some mss include v. 37: Philip said, “If you believe with all your heart you may.” And he replied, “I believe that Jesus Christ is the Son of God.”"}]},{"verseId":"a556c5305ee15c3f-01:Act:8:38","parts":[{"kind":"text","text":"So he ordered the chariot to stop, and both Philip and the eunuch went down into the water, and he baptized him. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:39","parts":[{"kind":"text","text":"When they came up out of the water, the Spirit of the Lord "},{"kind":"crossref","label":"1Kg 18:12","book":"1Ki","chapter":18,"verse":12,"letter":"a"},{"kind":"crossref","label":"2Kg 2:16","book":"2Ki","chapter":2,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ezk 3:12","book":"Ezk","chapter":3,"verse":12,"letter":"c"},{"kind":"crossref","label":"Ezk 3:14","book":"Ezk","chapter":3,"verse":14,"letter":"d"},{"kind":"crossref","label":"Ezk 8:3","book":"Ezk","chapter":8,"verse":3,"letter":"e"},{"kind":"crossref","label":"Ezk 11:1","book":"Ezk","chapter":11,"verse":1,"letter":"f"},{"kind":"crossref","label":"Ezk 11:24","book":"Ezk","chapter":11,"verse":24,"letter":"g"},{"kind":"crossref","label":"Ezk 43:5","book":"Ezk","chapter":43,"verse":5,"letter":"h"},{"kind":"text","text":" carried Philip away, and the eunuch did not see him any longer but went on his way rejoicing. "}],"crossRefs":[{"label":"1Kg 18:12","book":"1Ki","chapter":18,"verse":12},{"label":"2Kg 2:16","book":"2Ki","chapter":2,"verse":16},{"label":"Ezk 3:12","book":"Ezk","chapter":3,"verse":12},{"label":"Ezk 3:14","book":"Ezk","chapter":3,"verse":14},{"label":"Ezk 8:3","book":"Ezk","chapter":8,"verse":3},{"label":"Ezk 11:1","book":"Ezk","chapter":11,"verse":1},{"label":"Ezk 11:24","book":"Ezk","chapter":11,"verse":24},{"label":"Ezk 43:5","book":"Ezk","chapter":43,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:8:40","parts":[{"kind":"text","text":"Philip appeared in "},{"kind":"footnote","marker":2,"text":"Or Philip was found at, or Philip found himself in"},{"kind":"text","text":" Azotus, "},{"kind":"footnote","marker":3,"text":"Or Ashdod"},{"kind":"text","text":" and he was traveling and preaching the gospel in all the towns until he came to Caesarea. "},{"kind":"crossref","label":"Ac 10:1","book":"Act","chapter":10,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ac 10:24","book":"Act","chapter":10,"verse":24,"letter":"b"},{"kind":"crossref","label":"Ac 12:19","book":"Act","chapter":12,"verse":19,"letter":"c"},{"kind":"crossref","label":"Ac 21:8","book":"Act","chapter":21,"verse":8,"letter":"d"},{"kind":"crossref","label":"Ac 21:16","book":"Act","chapter":21,"verse":16,"letter":"e"},{"kind":"crossref","label":"Ac 23:23","book":"Act","chapter":23,"verse":23,"letter":"f"},{"kind":"crossref","label":"Ac 23:33","book":"Act","chapter":23,"verse":33,"letter":"g"},{"kind":"crossref","label":"Ac 25:1","book":"Act","chapter":25,"verse":1,"letter":"h"},{"kind":"crossref","label":"Ac 25:4","book":"Act","chapter":25,"verse":4,"letter":"i"},{"kind":"crossref","label":"Ac 25:6","book":"Act","chapter":25,"verse":6,"letter":"j"},{"kind":"crossref","label":"Ac 25:13","book":"Act","chapter":25,"verse":13,"letter":"k"}],"crossRefs":[{"label":"Ac 10:1","book":"Act","chapter":10,"verse":1},{"label":"Ac 10:24","book":"Act","chapter":10,"verse":24},{"label":"Ac 12:19","book":"Act","chapter":12,"verse":19},{"label":"Ac 21:8","book":"Act","chapter":21,"verse":8},{"label":"Ac 21:16","b