ook":"Jhn","chapter":11,"verse":47},{"label":"Ac 3:9–10","book":"Act","chapter":3,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:17","parts":[{"kind":"text","text":"But so that this does not spread any further among the people, let’s threaten them against speaking to anyone in this name again.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:18","parts":[{"kind":"text","text":"So they called for them and ordered them not to speak or teach at all in the name of Jesus."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:19","parts":[{"kind":"text","text":"Peter and John answered them, “Whether it’s right in the sight of God for us to listen to you rather than to God, you decide; "},{"kind":"crossref","label":"Ac 4:13","book":"Act","chapter":4,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ac 5:28","book":"Act","chapter":5,"verse":28,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 4:13","book":"Act","chapter":4,"verse":13},{"label":"Ac 5:28","book":"Act","chapter":5,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:20","parts":[{"kind":"text","text":"for we are unable to stop speaking about what we have seen and heard.” "},{"kind":"crossref","label":"Ac 22:15","book":"Act","chapter":22,"verse":15,"letter":"a"},{"kind":"crossref","label":"1Co 9:16","book":"1Co","chapter":9,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Jn 1:1","book":"1Jn","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Jn 1:3","book":"1Jn","chapter":1,"verse":3,"letter":"d"}],"crossRefs":[{"label":"Ac 22:15","book":"Act","chapter":22,"verse":15},{"label":"1Co 9:16","book":"1Co","chapter":9,"verse":16},{"label":"1Jn 1:1","book":"1Jn","chapter":1,"verse":1},{"label":"1Jn 1:3","book":"1Jn","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:21","parts":[{"kind":"text","text":"After threatening them further, they released them. They found no way to punish them because the people were all giving glory to God over what had been done. "},{"kind":"crossref","label":"Mt 9:8","book":"Mat","chapter":9,"verse":8,"letter":"a"},{"kind":"crossref","label":"Mt 21:26","book":"Mat","chapter":21,"verse":26,"letter":"b"},{"kind":"crossref","label":"Lk 20:6","book":"Luk","chapter":20,"verse":6,"letter":"c"},{"kind":"crossref","label":"Lk 20:19","book":"Luk","chapter":20,"verse":19,"letter":"d"},{"kind":"crossref","label":"Lk 22:2","book":"Luk","chapter":22,"verse":2,"letter":"e"},{"kind":"crossref","label":"Ac 5:26","book":"Act","chapter":5,"verse":26,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 9:8","book":"Mat","chapter":9,"verse":8},{"label":"Mt 21:26","book":"Mat","chapter":21,"verse":26},{"label":"Lk 20:6","book":"Luk","chapter":20,"verse":6},{"label":"Lk 20:19","book":"Luk","chapter":20,"verse":19},{"label":"Lk 22:2","book":"Luk","chapter":22,"verse":2},{"label":"Ac 5:26","book":"Act","chapter":5,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:22","parts":[{"kind":"text","text":"For this sign of healing had been performed on a man over forty years old."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:23","parts":[{"kind":"text","text":"After they were released, they went to their own people and reported everything the chief priests and the elders had said to them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:24","parts":[{"kind":"text","text":"When they heard this, they raised their voices together to God and said, “Master, you are the one who made the heaven, the earth, and the sea, and everything in them. "},{"kind":"crossref","label":"Ex 20:11","book":"Exo","chapter":20,"verse":11,"letter":"a"},{"kind":"crossref","label":"2Ch 2:12","book":"2Ch","chapter":2,"verse":12,"letter":"b"},{"kind":"crossref","label":"Neh 9:6","book":"Neh","chapter":9,"verse":6,"letter":"c"},{"kind":"crossref","label":"Ps 102:25","book":"Psa","chapter":102,"verse":25,"letter":"d"},{"kind":"crossref","label":"Ps 124:8","book":"Psa","chapter":124,"verse":8,"letter":"e"},{"kind":"crossref","label":"Ps 134:3","book":"Psa","chapter":134,"verse":3,"letter":"f"},{"kind":"crossref","label":"Ps 146:6","book":"Psa","chapter":146,"verse":6,"letter":"g"},{"kind":"crossref","label":"Is 37:16","book":"Isa","chapter":37,"verse":16,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 20:11","book":"Exo","chapter":20,"verse":11},{"label":"2Ch 2:12","book":"2Ch","chapter":2,"verse":12},{"label":"Neh 9:6","book":"Neh","chapter":9,"verse":6},{"label":"Ps 102:25","book":"Psa","chapter":102,"verse":25},{"label":"Ps 124:8","book":"Psa","chapter":124,"verse":8},{"label":"Ps 134:3","book":"Psa","chapter":134,"verse":3},{"label":"Ps 146:6","book":"Psa","chapter":146,"verse":6},{"label":"Is 37:16","book":"Isa","chapter":37,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:25","parts":[{"kind":"text","text":"You said through the Holy Spirit, by the mouth of our father David your servant: "},{"kind":"footnote","marker":1,"text":"Other mss read through the mouth of David your servant"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss read through the mouth of David your servant"}]},{"verseId":"a556c5305ee15c3f-01:Act:4:26","parts":[{"kind":"text","text":"The kings of the earth take their stand"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:27","parts":[{"kind":"text","text":"“For, in fact, in this city both Herod and Pontius Pilate, with the Gentiles and the people of Israel, assembled together against your holy servant Jesus, whom you anointed, "},{"kind":"crossref","label":"Mt 14:1","book":"Mat","chapter":14,"verse":1,"letter":"a"},{"kind":"crossref","label":"Mt 27:2","book":"Mat","chapter":27,"verse":2,"letter":"b"},{"kind":"crossref","label":"Lk 23:1","book":"Luk","chapter":23,"verse":1,"letter":"c"},{"kind":"crossref","label":"Lk 23:12","book":"Luk","chapter":23,"verse":12,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 14:1","book":"Mat","chapter":14,"verse":1},{"label":"Mt 27:2","book":"Mat","chapter":27,"verse":2},{"label":"Lk 23:1","book":"Luk","chapter":23,"verse":1},{"label":"Lk 23:12","book":"Luk","chapter":23,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:28","parts":[{"kind":"text","text":"to do whatever your hand and your will had predestined to take place. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:29","parts":[{"kind":"text","text":"And now, Lord, consider their threats, and grant that your servants may speak your word with all boldness, "},{"kind":"crossref","label":"Ac 9:27","book":"Act","chapter":9,"verse":27,"letter":"a"},{"kind":"crossref","label":"Ac 13:46","book":"Act","chapter":13,"verse":46,"letter":"b"},{"kind":"crossref","label":"Ac 14:3","book":"Act","chapter":14,"verse":3,"letter":"c"},{"kind":"crossref","label":"Ac 19:8","book":"Act","chapter":19,"verse":8,"letter":"d"},{"kind":"crossref","label":"Php 1:14","book":"Php","chapter":1,"verse":14,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 9:27","book":"Act","chapter":9,"verse":27},{"label":"Ac 13:46","book":"Act","chapter":13,"verse":46},{"label":"Ac 14:3","book":"Act","chapter":14,"verse":3},{"label":"Ac 19:8","book":"Act","chapter":19,"verse":8},{"label":"Php 1:14","book":"Php","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:30","parts":[{"kind":"text","text":"while you stretch out your hand for healing, and signs and wonders "},{"kind":"crossref","label":"Jn 4:48","book":"Jhn","chapter":4,"verse":48,"letter":"a"},{"kind":"crossref","label":"Ac 3:6","book":"Act","chapter":3,"verse":6,"letter":"b"},{"kind":"text","text":" are performed through the name of your holy servant Jesus.” "}],"crossRefs":[{"label":"Jn 4:48","book":"Jhn","chapter":4,"verse":48},{"label":"Ac 3:6","book":"Act","chapter":3,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:31","parts":[{"kind":"text","text":"When they had prayed, the place where they were assembled was shaken, and they were all filled with the Holy Spirit and began to speak the word of God boldly. "},{"kind":"crossref","label":"Ac 2:2","book":"Act","chapter":2,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ac 2:4","book":"Act","chapter":2,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ac 16:26","book":"Act","chapter":16,"verse":26,"letter":"c"},{"kind":"crossref","label":"Php 1:14","book":"Php","chapter":1,"verse":14,"letter":"d"}],"crossRefs":[{"label":"Ac 2:2","book":"Act","chapter":2,"verse":2},{"label":"Ac 2:4","book":"Act","chapter":2,"verse":4},{"label":"Ac 16:26","book":"Act","chapter":16,"verse":26},{"label":"Php 1:14","book":"Php","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:32","parts":[{"kind":"text","text":"Now the entire group of those who believed were of one heart and mind, and no one claimed that any of his possessions was his own, but instead they held everything in common. "},{"kind":"crossref","label":"Ac 2:44","book":"Act","chapter":2,"verse":44,"letter":"a"},{"kind":"crossref","label":"Php 1:27","book":"Php","chapter":1,"verse":27,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 2:44","book":"Act","chapter":2,"verse":44},{"label":"Php 1:27","book":"Php","chapter":1,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:33","parts":[{"kind":"text","text":"With great power the apostles were giving testimony to the resurrection of the Lord Jesus, and great grace was on all of them. "},{"kind":"crossref","label":"Lk 24:48","book":"Luk","chapter":24,"verse":48,"letter":"a"},{"kind":"crossref","label":"Ac 1:8","book":"Act","chapter":1,"verse":8,"letter":"b"},{"kind":"crossref","label":"Ac 1:22","book":"Act","chapter":1,"verse":22,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 24:48","book":"Luk","chapter":24,"verse":48},{"label":"Ac 1:8","book":"Act","chapter":1,"verse":8},{"label":"Ac 1:22","book":"Act","chapter":1,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:34","parts":[{"kind":"text","text":"For there was not a needy person among them because all those who owned lands or houses sold them, brought the proceeds of what was sold, "},{"kind":"crossref","label":"Mt 19:21","book":"Mat","chapter":19,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ac 2:45","book":"Act","chapter":2,"verse":45,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 19:21","book":"Mat","chapter":19,"verse":21},{"label":"Ac 2:45","book":"Act","chapter":2,"verse":45}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:35","parts":[{"kind":"text","text":"and laid them at the apostles’ feet. This was then distributed to each person as any had need. "},{"kind":"crossref","label":"Ac 2:45","book":"Act","chapter":2,"verse":45,"letter":"a"},{"kind":"crossref","label":"Ac 4:37","book":"Act","chapter":4,"verse":37,"letter":"b"},{"kind":"crossref","label":"Ac 5:2","book":"Act","chapter":5,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ac 6:1","book":"Act","chapter":6,"verse":1,"letter":"d"}],"crossRefs":[{"label":"Ac 2:45","book":"Act","chapter":2,"verse":45},{"label":"Ac 4:37","book":"Act","chapter":4,"verse":37},{"label":"Ac 5:2","book":"Act","chapter":5,"verse":2},{"label":"Ac 6:1","book":"Act","chapter":6,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:36","parts":[{"kind":"text","text":"Joseph, a Levite from Cyprus by birth, the one the apostles called Barnabas (which is translated Son of Encouragement), "},{"kind":"crossref","label":"Ac 9:27","book":"Act","chapter":9,"verse":27,"letter":"a"},{"kind":"crossref","label":"1Co 9:6","book":"1Co","chapter":9,"verse":6,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 9:27","book":"Act","chapter":9,"verse":27},{"label":"1Co 9:6","book":"1Co","chapter":9,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:4:37","parts":[{"kind":"text","text":"sold a field he owned, brought the money, and laid it at the apostles’ feet. "},{"kind":"crossref","label":"Ac 4:35","book":"Act","chapter":4,"verse":35,"letter":"a"},{"kind":"crossref","label":"Ac 5:2","book":"Act","chapter":5,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Ac 4:35","book":"Act","chapter":4,"verse":35},{"label":"Ac 5:2","book":"Act","chapter":5,"verse":2}],"footnotes":[]}]},"cachedAt":1783279643836}