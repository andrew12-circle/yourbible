:14","book":"Act","chapter":24,"verse":14},{"label":"Ac 24:22","book":"Act","chapter":24,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:3","parts":[{"kind":"text","text":"As "},{"kind":"crossref","label":"Ac 22:6–11","book":"Act","chapter":22,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ac 26:12–18","book":"Act","chapter":26,"verse":12,"letter":"b"},{"kind":"crossref","label":"1Co 15:8","book":"1Co","chapter":15,"verse":8,"letter":"c"},{"kind":"text","text":" he traveled and was nearing Damascus, a light from heaven suddenly flashed around him. "}],"crossRefs":[{"label":"Ac 22:6–11","book":"Act","chapter":22,"verse":6},{"label":"Ac 26:12–18","book":"Act","chapter":26,"verse":12},{"label":"1Co 15:8","book":"1Co","chapter":15,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:4","parts":[{"kind":"text","text":"Falling to the ground, he heard a voice saying to him, “Saul, Saul, why are you persecuting me?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:5","parts":[{"kind":"text","text":"“Who are you, Lord?” Saul said."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:6","parts":[{"kind":"text","text":"“But get up and go into the city, and you will be told what you must do.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:7","parts":[{"kind":"text","text":"The men who were traveling with him stood speechless, hearing the sound but seeing no one. "},{"kind":"crossref","label":"Dn 10:7","book":"Dan","chapter":10,"verse":7,"letter":"a"},{"kind":"crossref","label":"Jn 12:29","book":"Jhn","chapter":12,"verse":29,"letter":"b"},{"kind":"crossref","label":"Ac 22:9","book":"Act","chapter":22,"verse":9,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 10:7","book":"Dan","chapter":10,"verse":7},{"label":"Jn 12:29","book":"Jhn","chapter":12,"verse":29},{"label":"Ac 22:9","book":"Act","chapter":22,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:8","parts":[{"kind":"text","text":"Saul got up from the ground, and though his eyes were open, he could see nothing. So they took him by the hand and led him into Damascus. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:9","parts":[{"kind":"text","text":"He was unable to see for three days and did not eat or drink."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:10","parts":[{"kind":"text","text":"There was a disciple in Damascus named Ananias, and the Lord said to him in a vision, “Ananias.”"},{"kind":"text","text":" “Here I am, Lord,” he replied. "},{"kind":"crossref","label":"Ac 10:3","book":"Act","chapter":10,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ac 10:17","book":"Act","chapter":10,"verse":17,"letter":"b"},{"kind":"crossref","label":"Ac 10:19","book":"Act","chapter":10,"verse":19,"letter":"c"},{"kind":"crossref","label":"Ac 22:12","book":"Act","chapter":22,"verse":12,"letter":"d"}],"crossRefs":[{"label":"Ac 10:3","book":"Act","chapter":10,"verse":3},{"label":"Ac 10:17","book":"Act","chapter":10,"verse":17},{"label":"Ac 10:19","book":"Act","chapter":10,"verse":19},{"label":"Ac 22:12","book":"Act","chapter":22,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:11","parts":[{"kind":"text","text":"“Get up and go to the street called Straight,” the Lord said to him, “to the house of Judas, and ask for a man from Tarsus"},{"kind":"crossref","label":"Ac 9:30","book":"Act","chapter":9,"verse":30,"letter":"a"},{"kind":"crossref","label":"Ac 11:25","book":"Act","chapter":11,"verse":25,"letter":"b"},{"kind":"crossref","label":"Ac 21:39","book":"Act","chapter":21,"verse":39,"letter":"c"},{"kind":"crossref","label":"Ac 22:3","book":"Act","chapter":22,"verse":3,"letter":"d"},{"kind":"text","text":" named Saul, since he is praying there. "}],"crossRefs":[{"label":"Ac 9:30","book":"Act","chapter":9,"verse":30},{"label":"Ac 11:25","book":"Act","chapter":11,"verse":25},{"label":"Ac 21:39","book":"Act","chapter":21,"verse":39},{"label":"Ac 22:3","book":"Act","chapter":22,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:12","parts":[{"kind":"text","text":"In a vision"},{"kind":"footnote","marker":1,"text":"Other mss omit In a vision"},{"kind":"text","text":" he has seen a man named Ananias coming in and placing his hands on him so that he may regain his sight.”"},{"kind":"crossref","label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ac 9:17","book":"Act","chapter":9,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23},{"label":"Ac 9:17","book":"Act","chapter":9,"verse":17}],"footnotes":[{"marker":1,"text":"Other mss omit In a vision"}]},{"verseId":"a556c5305ee15c3f-01:Act:9:13","parts":[{"kind":"text","text":"“Lord,” Ananias answered, “I have heard from many people about this man, how much harm he has done to your saints in Jerusalem. "},{"kind":"crossref","label":"Ac 8:3","book":"Act","chapter":8,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ac 9:32","book":"Act","chapter":9,"verse":32,"letter":"b"},{"kind":"crossref","label":"Rm 1:7","book":"Rom","chapter":1,"verse":7,"letter":"c"},{"kind":"crossref","label":"Rm 15:25–26","book":"Rom","chapter":15,"verse":25,"letter":"d"},{"kind":"crossref","label":"Rm 15:31","book":"Rom","chapter":15,"verse":31,"letter":"e"},{"kind":"crossref","label":"Rm 16:2","book":"Rom","chapter":16,"verse":2,"letter":"f"},{"kind":"crossref","label":"Rm 16:15","book":"Rom","chapter":16,"verse":15,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 8:3","book":"Act","chapter":8,"verse":3},{"label":"Ac 9:32","book":"Act","chapter":9,"verse":32},{"label":"Rm 1:7","book":"Rom","chapter":1,"verse":7},{"label":"Rm 15:25–26","book":"Rom","chapter":15,"verse":25},{"label":"Rm 15:31","book":"Rom","chapter":15,"verse":31},{"label":"Rm 16:2","book":"Rom","chapter":16,"verse":2},{"label":"Rm 16:15","book":"Rom","chapter":16,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:14","parts":[{"kind":"text","text":"And he has authority here from the chief priests to arrest all who call on your name.” "},{"kind":"crossref","label":"Ac 7:59","book":"Act","chapter":7,"verse":59,"letter":"a"},{"kind":"crossref","label":"1Co 1:2","book":"1Co","chapter":1,"verse":2,"letter":"b"},{"kind":"crossref","label":"2Tm 2:22","book":"2Ti","chapter":2,"verse":22,"letter":"c"}],"crossRefs":[{"label":"Ac 7:59","book":"Act","chapter":7,"verse":59},{"label":"1Co 1:2","book":"1Co","chapter":1,"verse":2},{"label":"2Tm 2:22","book":"2Ti","chapter":2,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:15","parts":[{"kind":"text","text":"But the Lord said to him, “Go, for this man is my chosen instrument"},{"kind":"crossref","label":"Ac 13:2","book":"Act","chapter":13,"verse":2,"letter":"a"},{"kind":"crossref","label":"Rm 1:1","book":"Rom","chapter":1,"verse":1,"letter":"b"},{"kind":"crossref","label":"Gl 1:15","book":"Gal","chapter":1,"verse":15,"letter":"c"},{"kind":"text","text":" to take my name to Gentiles,"},{"kind":"crossref","label":"Mt 28:19","book":"Mat","chapter":28,"verse":19,"letter":"d"},{"kind":"crossref","label":"Rm 1:5","book":"Rom","chapter":1,"verse":5,"letter":"e"},{"kind":"crossref","label":"Gl 1:16","book":"Gal","chapter":1,"verse":16,"letter":"f"},{"kind":"text","text":" kings, and Israelites."},{"kind":"crossref","label":"Ac 25:22","book":"Act","chapter":25,"verse":22,"letter":"g"},{"kind":"crossref","label":"Ac 26:1","book":"Act","chapter":26,"verse":1,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 13:2","book":"Act","chapter":13,"verse":2},{"label":"Rm 1:1","book":"Rom","chapter":1,"verse":1},{"label":"Gl 1:15","book":"Gal","chapter":1,"verse":15},{"label":"Mt 28:19","book":"Mat","chapter":28,"verse":19},{"label":"Rm 1:5","book":"Rom","chapter":1,"verse":5},{"label":"Gl 1:16","book":"Gal","chapter":1,"verse":16},{"label":"Ac 25:22","book":"Act","chapter":25,"verse":22},{"label":"Ac 26:1","book":"Act","chapter":26,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:16","parts":[{"kind":"text","text":"I will show him how much he must suffer for my name.”"},{"kind":"crossref","label":"Ac 20:23","book":"Act","chapter":20,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ac 21:4","book":"Act","chapter":21,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ac 21:11","book":"Act","chapter":21,"verse":11,"letter":"c"},{"kind":"crossref","label":"2Co 6:4–5","book":"2Co","chapter":6,"verse":4,"letter":"d"},{"kind":"crossref","label":"2Co 11:23–27","book":"2Co","chapter":11,"verse":23,"letter":"e"},{"kind":"crossref","label":"1Th 3:3","book":"1Th","chapter":3,"verse":3,"letter":"f"}],"crossRefs":[{"label":"Ac 20:23","book":"Act","chapter":20,"verse":23},{"label":"Ac 21:4","book":"Act","chapter":21,"verse":4},{"label":"Ac 21:11","book":"Act","chapter":21,"verse":11},{"label":"2Co 6:4–5","book":"2Co","chapter":6,"verse":4},{"label":"2Co 11:23–27","book":"2Co","chapter":11,"verse":23},{"label":"1Th 3:3","book":"1Th","chapter":3,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:17","parts":[{"kind":"text","text":"Ananias went and entered the house. He placed his hands on him and said, “Brother Saul, the Lord Jesus, who appeared to you on the road you were traveling, has sent me so that you may regain your sight and be filled with the Holy Spirit.” "},{"kind":"crossref","label":"Ac 6:6","book":"Act","chapter":6,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ac 22:13","book":"Act","chapter":22,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Ac 6:6","book":"Act","chapter":6,"verse":6},{"label":"Ac 22:13","book":"Act","chapter":22,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:18","parts":[{"kind":"text","text":"At once something like scales fell from his eyes, and he regained his sight. Then he got up and was baptized. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:19","parts":[{"kind":"text","text":"And after taking some food, he regained his strength. "},{"kind":"crossref","label":"Ac 11:26","book":"Act","chapter":11,"verse":26,"letter":"a"},{"kind":"crossref","label":"Ac 26:20","book":"Act","chapter":26,"verse":20,"letter":"b"}],"crossRefs":[{"label":"Ac 11:26","book":"Act","chapter":11,"verse":26},{"label":"Ac 26:20","book":"Act","chapter":26,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:20","parts":[{"kind":"text","text":"Immediately he began proclaiming Jesus in the synagogues: “He is the Son of God.” "},{"kind":"crossref","label":"Mt 4:3","book":"Mat","chapter":4,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ac 13:5","book":"Act","chapter":13,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ac 13:14","book":"Act","chapter":13,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Mt 4:3","book":"Mat","chapter":4,"verse":3},{"label":"Ac 13:5","book":"Act","chapter":13,"verse":5},{"label":"Ac 13:14","book":"Act","chapter":13,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:21","parts":[{"kind":"text","text":"All who heard him were astounded and said, “Isn’t this the man in Jerusalem who was causing havoc for those who called on this name and came here for the purpose of taking them as prisoners to the chief priests?” "},{"kind":"crossref","label":"Ac 8:3","book":"Act","chapter":8,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ac 9:13–14","book":"Act","chapter":9,"verse":13,"letter":"b"},{"kind":"crossref","label":"Gl 1:13","book":"Gal","chapter":1,"verse":13,"letter":"c"},{"kind":"crossref","label":"Gl 1:23","book":"Gal","chapter":1,"verse":23,"letter":"d"}],"crossRefs":[{"label":"Ac 8:3","book":"Act","chapter":8,"verse":3},{"label":"Ac 9:13–14","book":"Act","chapter":9,"verse":13},{"label":"Gl 1:13","book":"Gal","chapter":1,"verse":13},{"label":"Gl 1:23","book":"Gal","chapter":1,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:22","parts":[{"kind":"text","text":"But Saul grew stronger and kept confounding the Jews who lived in Damascus by proving that Jesus is the Messiah."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:23","parts":[{"kind":"text","text":"After many days had passed, the Jews conspired to kill him, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:24","parts":[{"kind":"text","text":"but Saul learned of their plot. So they were watching the gates day and night intending to kill him, "},{"kind":"crossref","label":"Ac 20:3","book":"Act","chapter":20,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ac 20:19","book":"Act","chapter":20,"verse":19,"letter":"b"},{"kind":"crossref","label":"Ac 23:12","book":"Act","chapter":23,"verse":12,"letter":"c"},{"kind":"crossref","label":"Ac 23:30","book":"Act","chapter":23,"verse":30,"letter":"d"},{"kind":"crossref","label":"Ac 25:3","book":"Act","chapter":25,"verse":3,"letter":"e"},{"kind":"crossref","label":"2Co 11:26","book":"2Co","chapter":11,"verse":26,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 20:3","book":"Act","chapter":20,"verse":3},{"label":"Ac 20:19","book":"Act","chapter":20,"verse":19},{"label":"Ac 23:12","book":"Act","chapter":23,"verse":12},{"label":"Ac 23:30","book":"Act","chapter":23,"verse":30},{"label":"Ac 25:3","book":"Act","chapter":25,"verse":3},{"label":"2Co 11:26","book":"2Co","chapter":11,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:25","parts":[{"kind":"text","text":"but his disciples took him by night and lowered him in a large basket through an opening in the wall. "},{"kind":"crossref","label":"Jos 2:15","book":"Jos","chapter":2,"verse":15,"letter":"a"},{"kind":"crossref","label":"1Sm 19:12","book":"1Sa","chapter":19,"verse":12,"letter":"b"},{"kind":"crossref","label":"2Co 11:33","book":"2Co","chapter":11,"verse":33,"letter":"c"}],"crossRefs":[{"label":"Jos 2:15","book":"Jos","chapter":2,"verse":15},{"label":"1Sm 19:12","book":"1Sa","chapter":19,"verse":12},{"label":"2Co 11:33","book":"2Co","chapter":11,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:26","parts":[{"kind":"text","text":"When he arrived in Jerusalem, "},{"kind":"crossref","label":"Ac 22:17","book":"Act","chapter":22,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ac 26:20","book":"Act","chapter":26,"verse":20,"letter":"b"},{"kind":"crossref","label":"Gl 1:17","book":"Gal","chapter":1,"verse":17,"letter":"c"},{"kind":"text","text":" he tried to join the disciples, but they were all afraid of him, since they did not believe he was a disciple. "}],"crossRefs":[{"label":"Ac 22:17","book":"Act","chapter":22,"verse":17},{"label":"Ac 26:20","book":"Act","chapter":26,"verse":20},{"label":"Gl 1:17","book":"Gal","chapter":1,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:27","parts":[{"kind":"text","text":"Barnabas, however, took him and brought him to the apostles and explained to them how Saul had seen the Lord on the road and that the Lord had talked to him, and how in Damascus he had spoken boldly "},{"kind":"crossref","label":"Ac 13:46","book":"Act","chapter":13,"verse":46,"letter":"a"},{"kind":"crossref","label":"Ac 14:3","book":"Act","chapter":14,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ac 18:26","book":"Act","chapter":18,"verse":26,"letter":"c"},{"kind":"crossref","label":"Ac 19:8","book":"Act","chapter":19,"verse":8,"letter":"d"},{"kind":"crossref","label":"Ac 26:26","book":"Act","chapter":26,"verse":26,"letter":"e"},{"kind":"crossref","label":"Eph 6:20","book":"Eph","chapter":6,"verse":20,"letter":"f"},{"kind":"crossref","label":"1Th 2:2","book":"1Th","chapter":2,"verse":2,"letter":"g"},{"kind":"text","text":" in the name of Jesus. "},{"kind":"crossref","label":"Ac 4:36","book":"Act","chapter":4,"verse":36,"letter":"h"},{"kind":"crossref","label":"Ac 9:3–6","book":"Act","chapter":9,"verse":3,"letter":"i"},{"kind":"crossref","label":"Ac 9:20","book":"Act","chapter":9,"verse":20,"letter":"j"},{"kind":"crossref","label":"Ac 9:22","book":"Act","chapter":9,"verse":22,"letter":"k"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 13:46","book":"Act","chapter":13,"verse":46},{"label":"Ac 14:3","book":"Act","chapter":14,"verse":3},{"label":"Ac 18:26","book":"Act","chapter":18,"verse":26},{"label":"Ac 19:8","book":"Act","chapter":19,"verse":8},{"label":"Ac 26:26","book":"Act","chapter":26,"verse":26},{"label":"Eph 6:20","book":"Eph","chapter":6,"verse":20},{"label":"1Th 2:2","book":"1Th","chapter":2,"verse":2},{"label":"Ac 4:36","book":"Act","chapter":4,"verse":36},{"label":"Ac 9:3–6","book":"Act","chapter":9,"verse":3},{"label":"Ac 9:20","book":"Act","chapter":9,"verse":20},{"label":"Ac 9:22","book":"Act","chapter":9,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:28","parts":[{"kind":"text","text":"Saul was coming and going with them in Jerusalem, speaking boldly in the name of the Lord. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:29","parts":[{"kind":"text","text":"He conversed and debated with the Hellenistic Jews, but they tried to kill him. "},{"kind":"crossref","label":"Ac 6:1","book":"Act","chapter":6,"verse":1,"letter":"a"},{"kind":"crossref","label":"2Co 11:26","book":"2Co","chapter":11,"verse":26,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 6:1","book":"Act","chapter":6,"verse":1},{"label":"2Co 11:26","book":"2Co","chapter":11,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:30","parts":[{"kind":"text","text":"When the brothers found out, they took him down to Caesarea and sent him off to Tarsus. "},{"kind":"crossref","label":"Ac 8:40","book":"Act","chapter":8,"verse":40,"letter":"a"},{"kind":"crossref","label":"Gl 1:21","book":"Gal","chapter":1,"verse":21,"letter":"b"}],"crossRefs":[{"label":"Ac 8:40","book":"Act","chapter":8,"verse":40},{"label":"Gl 1:21","book":"Gal","chapter":1,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:31","parts":[{"kind":"text","text":"So the church "},{"kind":"crossref","label":"Mt 16:18","book":"Mat","chapter":16,"verse":18,"letter":"a"},{"kind":"crossref","label":"1Co 14:4","book":"1Co","chapter":14,"verse":4,"letter":"b"},{"kind":"crossref","label":"Rv 1:4","book":"Rev","chapter":1,"verse":4,"letter":"c"},{"kind":"text","text":" throughout all Judea, Galilee, and Samaria had peace and was strengthened. Living in the fear of the Lord and encouraged by the Holy Spirit, it increased in numbers."}],"crossRefs":[{"label":"Mt 16:18","book":"Mat","chapter":16,"verse":18},{"label":"1Co 14:4","book":"1Co","chapter":14,"verse":4},{"label":"Rv 1:4","book":"Rev","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:32","parts":[{"kind":"text","text":"As Peter was traveling from place to place, he also came down to the saints "},{"kind":"crossref","label":"Rm 1:7","book":"Rom","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Eph 5:3","book":"Eph","chapter":5,"verse":3,"letter":"b"},{"kind":"crossref","label":"Eph 6:18","book":"Eph","chapter":6,"verse":18,"letter":"c"},{"kind":"text","text":" who lived in Lydda. "},{"kind":"crossref","label":"1Ch 8:12","book":"1Ch","chapter":8,"verse":12,"letter":"d"},{"kind":"crossref","label":"Ezr 2:23","book":"Ezr","chapter":2,"verse":23,"letter":"e"},{"kind":"crossref","label":"Neh 7:37","book":"Neh","chapter":7,"verse":37,"letter":"f"},{"kind":"crossref","label":"Neh 11:35","book":"Neh","chapter":11,"verse":35,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 1:7","book":"Rom","chapter":1,"verse":7},{"label":"Eph 5:3","book":"Eph","chapter":5,"verse":3},{"label":"Eph 6:18","book":"Eph","chapter":6,"verse":18},{"label":"1Ch 8:12","book":"1Ch","chapter":8,"verse":12},{"label":"Ezr 2:23","book":"Ezr","chapter":2,"verse":23},{"label":"Neh 7:37","book":"Neh","chapter":7,"verse":37},{"label":"Neh 11:35","book":"Neh","chapter":11,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:33","parts":[{"kind":"text","text":"There he found a man named Aeneas, who was paralyzed and had been bedridden for eight years. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:34","parts":[{"kind":"text","text":"Peter said to him, “Aeneas, Jesus Christ heals you. Get up and make your bed,” "},{"kind":"footnote","marker":1,"text":"Or and get ready to eat"},{"kind":"text","text":" and immediately he got up. "},{"kind":"crossref","label":"Ac 3:6","book":"Act","chapter":3,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ac 3:16","book":"Act","chapter":3,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ac 4:10","book":"Act","chapter":4,"verse":10,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 3:6","book":"Act","chapter":3,"verse":6},{"label":"Ac 3:16","book":"Act","chapter":3,"verse":16},{"label":"Ac 4:10","book":"Act","chapter":4,"verse":10}],"footnotes":[{"marker":1,"text":"Or and get ready to eat"}]},{"verseId":"a556c5305ee15c3f-01:Act:9:35","parts":[{"kind":"text","text":"So all who lived in Lydda and Sharon "},{"kind":"crossref","label":"1Ch 5:16","book":"1Ch","chapter":5,"verse":16,"letter":"a"},{"kind":"crossref","label":"1Ch 27:29","book":"1Ch","chapter":27,"verse":29,"letter":"b"},{"kind":"crossref","label":"Sg 2:1","book":"Sng","chapter":2,"verse":1,"letter":"c"},{"kind":"crossref","label":"Is 33:9","book":"Isa","chapter":33,"verse":9,"letter":"d"},{"kind":"crossref","label":"Is 35:2","book":"Isa","chapter":35,"verse":2,"letter":"e"},{"kind":"crossref","label":"Is 65:10","book":"Isa","chapter":65,"verse":10,"letter":"f"},{"kind":"text","text":" saw him and turned to the Lord."}],"crossRefs":[{"label":"1Ch 5:16","book":"1Ch","chapter":5,"verse":16},{"label":"1Ch 27:29","book":"1Ch","chapter":27,"verse":29},{"label":"Sg 2:1","book":"Sng","chapter":2,"verse":1},{"label":"Is 33:9","book":"Isa","chapter":33,"verse":9},{"label":"Is 35:2","book":"Isa","chapter":35,"verse":2},{"label":"Is 65:10","book":"Isa","chapter":65,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:36","parts":[{"kind":"text","text":"In Joppa "},{"kind":"crossref","label":"Jos 19:46","book":"Jos","chapter":19,"verse":46,"letter":"a"},{"kind":"crossref","label":"2Ch 2:16","book":"2Ch","chapter":2,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ezr 3:7","book":"Ezr","chapter":3,"verse":7,"letter":"c"},{"kind":"crossref","label":"Jnh 1:3","book":"Jon","chapter":1,"verse":3,"letter":"d"},{"kind":"crossref","label":"Ac 10:5","book":"Act","chapter":10,"verse":5,"letter":"e"},{"kind":"text","text":" there was a disciple named Tabitha (which is translated Dorcas). She was always doing good works "},{"kind":"crossref","label":"1Tm 2:10","book":"1Ti","chapter":2,"verse":10,"letter":"f"},{"kind":"crossref","label":"Ti 3:8","book":"Tit","chapter":3,"verse":8,"letter":"g"},{"kind":"text","text":" and acts of charity. "}],"crossRefs":[{"label":"Jos 19:46","book":"Jos","chapter":19,"verse":46},{"label":"2Ch 2:16","book":"2Ch","chapter":2,"verse":16},{"label":"Ezr 3:7","book":"Ezr","chapter":3,"verse":7},{"label":"Jnh 1:3","book":"Jon","chapter":1,"verse":3},{"label":"Ac 10:5","book":"Act","chapter":10,"verse":5},{"label":"1Tm 2:10","book":"1Ti","chapter":2,"verse":10},{"label":"Ti 3:8","book":"Tit","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:37","parts":[{"kind":"text","text":"About that time she became sick and died. After washing her, they placed her in a room upstairs. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:38","parts":[{"kind":"text","text":"Since Lydda was near Joppa, the disciples heard that Peter was there and sent two men to him who urged him, “Don’t delay in coming with us.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:9:39","parts":[{"kind":"text","text":"Peter got up and went with them. When he arrived, they led him to the room upstairs. And all the widows 