letter":"c"},{"kind":"crossref","label":"Php 1:19","book":"Php","chapter":1,"verse":19,"letter":"d"},{"kind":"crossref","label":"1Pt 1:11","book":"1Pe","chapter":1,"verse":11,"letter":"e"},{"kind":"text","text":" did not allow them. "}],"crossRefs":[{"label":"Ac 8:29","book":"Act","chapter":8,"verse":29},{"label":"Rm 8:9","book":"Rom","chapter":8,"verse":9},{"label":"Gl 4:6","book":"Gal","chapter":4,"verse":6},{"label":"Php 1:19","book":"Php","chapter":1,"verse":19},{"label":"1Pt 1:11","book":"1Pe","chapter":1,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:8","parts":[{"kind":"text","text":"Passing by Mysia they went down to Troas. "},{"kind":"crossref","label":"Ac 16:11","book":"Act","chapter":16,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ac 20:5–6","book":"Act","chapter":20,"verse":5,"letter":"b"},{"kind":"crossref","label":"2Co 2:12","book":"2Co","chapter":2,"verse":12,"letter":"c"},{"kind":"crossref","label":"2Tm 4:13","book":"2Ti","chapter":4,"verse":13,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 16:11","book":"Act","chapter":16,"verse":11},{"label":"Ac 20:5–6","book":"Act","chapter":20,"verse":5},{"label":"2Co 2:12","book":"2Co","chapter":2,"verse":12},{"label":"2Tm 4:13","book":"2Ti","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:9","parts":[{"kind":"text","text":"During the night Paul had a vision in which a Macedonian man was standing and pleading with him, “Cross over to Macedonia and help us!” "},{"kind":"crossref","label":"Ac 9:10","book":"Act","chapter":9,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ac 20:1","book":"Act","chapter":20,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ac 20:3","book":"Act","chapter":20,"verse":3,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 9:10","book":"Act","chapter":9,"verse":10},{"label":"Ac 20:1","book":"Act","chapter":20,"verse":1},{"label":"Ac 20:3","book":"Act","chapter":20,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:10","parts":[{"kind":"text","text":"After "},{"kind":"crossref","label":"Ac 20:5–15","book":"Act","chapter":20,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ac 21:1–18","book":"Act","chapter":21,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ac 27:1–28:16","book":"Act","chapter":27,"verse":1,"letter":"c"},{"kind":"text","text":" he had seen the vision, we immediately made efforts to set out for Macedonia, concluding that God had called us to preach the gospel to them."}],"crossRefs":[{"label":"Ac 20:5–15","book":"Act","chapter":20,"verse":5},{"label":"Ac 21:1–18","book":"Act","chapter":21,"verse":1},{"label":"Ac 27:1–28:16","book":"Act","chapter":27,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:11","parts":[{"kind":"text","text":"From Troas we put out to sea and sailed straight for Samothrace, the next day to Neapolis, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:12","parts":[{"kind":"text","text":"and from there to Philippi, "},{"kind":"crossref","label":"Ac 20:6","book":"Act","chapter":20,"verse":6,"letter":"a"},{"kind":"crossref","label":"Php 1:1","book":"Php","chapter":1,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Th 2:2","book":"1Th","chapter":2,"verse":2,"letter":"c"},{"kind":"text","text":" a Roman colony and a leading city of the district of Macedonia. We stayed in that city for several days. "}],"crossRefs":[{"label":"Ac 20:6","book":"Act","chapter":20,"verse":6},{"label":"Php 1:1","book":"Php","chapter":1,"verse":1},{"label":"1Th 2:2","book":"1Th","chapter":2,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:13","parts":[{"kind":"text","text":"On the Sabbath day we went outside the city gate by the river, where we expected to find a place of prayer. We sat down and spoke to the women gathered there. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:14","parts":[{"kind":"text","text":"A God-fearing woman named Lydia, a dealer in purple cloth from the city of Thyatira, was listening. The Lord opened her heart to respond to what Paul was saying. "},{"kind":"crossref","label":"Lk 24:45","book":"Luk","chapter":24,"verse":45,"letter":"a"},{"kind":"crossref","label":"Ac 18:7","book":"Act","chapter":18,"verse":7,"letter":"b"},{"kind":"crossref","label":"Rv 1:11","book":"Rev","chapter":1,"verse":11,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 24:45","book":"Luk","chapter":24,"verse":45},{"label":"Ac 18:7","book":"Act","chapter":18,"verse":7},{"label":"Rv 1:11","book":"Rev","chapter":1,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:15","parts":[{"kind":"text","text":"After she and her household were baptized, she urged us, “If you consider me a believer in the Lord, come and stay at my house.” "},{"kind":"crossref","label":"Gn 19:3","book":"Gen","chapter":19,"verse":3,"letter":"a"},{"kind":"crossref","label":"Lk 24:29","book":"Luk","chapter":24,"verse":29,"letter":"b"},{"kind":"crossref","label":"Ac 11:14","book":"Act","chapter":11,"verse":14,"letter":"c"},{"kind":"text","text":" And she persuaded us."}],"crossRefs":[{"label":"Gn 19:3","book":"Gen","chapter":19,"verse":3},{"label":"Lk 24:29","book":"Luk","chapter":24,"verse":29},{"label":"Ac 11:14","book":"Act","chapter":11,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:16","parts":[{"kind":"text","text":"Once, as we were on our way to prayer, a slave girl met us who had a spirit by which she predicted the future. "},{"kind":"crossref","label":"Lv 19:31","book":"Lev","chapter":19,"verse":31,"letter":"a"},{"kind":"crossref","label":"Dt 18:11","book":"Deu","chapter":18,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Sm 28:3","book":"1Sa","chapter":28,"verse":3,"letter":"c"},{"kind":"crossref","label":"1Sm 28:7","book":"1Sa","chapter":28,"verse":7,"letter":"d"},{"kind":"text","text":" She made a large profit for her owners by fortune-telling. "}],"crossRefs":[{"label":"Lv 19:31","book":"Lev","chapter":19,"verse":31},{"label":"Dt 18:11","book":"Deu","chapter":18,"verse":11},{"label":"1Sm 28:3","book":"1Sa","chapter":28,"verse":3},{"label":"1Sm 28:7","book":"1Sa","chapter":28,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:17","parts":[{"kind":"text","text":"As she followed Paul and us she cried out, “These men, who are proclaiming to you "},{"kind":"footnote","marker":1,"text":"Other mss read us"},{"kind":"text","text":" a way of salvation, are the servants of the Most High God.” "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Other mss read us"}]},{"verseId":"a556c5305ee15c3f-01:Act:16:18","parts":[{"kind":"text","text":"She did this for many days."},{"kind":"text","text":" Paul was greatly annoyed. Turning to the spirit, he said, “I command you in the name of Jesus Christ to come out of her!” And it came out right away. "},{"kind":"crossref","label":"Mk 5:7","book":"Mrk","chapter":5,"verse":7,"letter":"a"},{"kind":"crossref","label":"Mk 16:17","book":"Mrk","chapter":16,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Mk 5:7","book":"Mrk","chapter":5,"verse":7},{"label":"Mk 16:17","book":"Mrk","chapter":16,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:19","parts":[{"kind":"text","text":"When her owners realized that their hope of profit was gone, they seized Paul and Silas "},{"kind":"crossref","label":"Mt 10:18","book":"Mat","chapter":10,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ac 8:3","book":"Act","chapter":8,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ac 15:22","book":"Act","chapter":15,"verse":22,"letter":"c"},{"kind":"crossref","label":"Ac 17:6–8","book":"Act","chapter":17,"verse":6,"letter":"d"},{"kind":"crossref","label":"Ac 19:25–26","book":"Act","chapter":19,"verse":25,"letter":"e"},{"kind":"crossref","label":"Ac 21:30","book":"Act","chapter":21,"verse":30,"letter":"f"},{"kind":"crossref","label":"Jms 2:6","book":"Jas","chapter":2,"verse":6,"letter":"g"},{"kind":"text","text":" and dragged them into the marketplace to the authorities. "}],"crossRefs":[{"label":"Mt 10:18","book":"Mat","chapter":10,"verse":18},{"label":"Ac 8:3","book":"Act","chapter":8,"verse":3},{"label":"Ac 15:22","book":"Act","chapter":15,"verse":22},{"label":"Ac 17:6–8","book":"Act","chapter":17,"verse":6},{"label":"Ac 19:25–26","book":"Act","chapter":19,"verse":25},{"label":"Ac 21:30","book":"Act","chapter":21,"verse":30},{"label":"Jms 2:6","book":"Jas","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:20","parts":[{"kind":"text","text":"Bringing them before the chief magistrates, they said, “These men are seriously disturbing our city. They are Jews "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:21","parts":[{"kind":"text","text":"and are promoting customs that are not legal for us as Romans to adopt or practice.” "},{"kind":"crossref","label":"Est 3:8","book":"Est","chapter":3,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ac 16:12","book":"Act","chapter":16,"verse":12,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Est 3:8","book":"Est","chapter":3,"verse":8},{"label":"Ac 16:12","book":"Act","chapter":16,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:22","parts":[{"kind":"text","text":"The crowd joined in the attack against them, and the chief magistrates stripped off their clothes and ordered them to be beaten with rods. "},{"kind":"crossref","label":"2Co 6:5","book":"2Co","chapter":6,"verse":5,"letter":"a"},{"kind":"crossref","label":"2Co 11:25","book":"2Co","chapter":11,"verse":25,"letter":"b"},{"kind":"crossref","label":"1Th 2:2","book":"1Th","chapter":2,"verse":2,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Co 6:5","book":"2Co","chapter":6,"verse":5},{"label":"2Co 11:25","book":"2Co","chapter":11,"verse":25},{"label":"1Th 2:2","book":"1Th","chapter":2,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:23","parts":[{"kind":"text","text":"After they had severely flogged them, they threw them in jail, ordering the jailer to guard them carefully. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:24","parts":[{"kind":"text","text":"Receiving such an order, he put them into the inner prison and secured their feet in the stocks. "},{"kind":"crossref","label":"Jb 13:27","book":"Job","chapter":13,"verse":27,"letter":"a"},{"kind":"crossref","label":"Jb 33:11","book":"Job","chapter":33,"verse":11,"letter":"b"},{"kind":"crossref","label":"Jr 20:2–3","book":"Jer","chapter":20,"verse":2,"letter":"c"},{"kind":"crossref","label":"Jr 29:26","book":"Jer","chapter":29,"verse":26,"letter":"d"}],"crossRefs":[{"label":"Jb 13:27","book":"Job","chapter":13,"verse":27},{"label":"Jb 33:11","book":"Job","chapter":33,"verse":11},{"label":"Jr 20:2–3","book":"Jer","chapter":20,"verse":2},{"label":"Jr 29:26","book":"Jer","chapter":29,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:25","parts":[{"kind":"text","text":"About midnight Paul and Silas were praying and singing hymns to God, and the prisoners were listening to them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:26","parts":[{"kind":"text","text":"Suddenly there was such a violent earthquake that the foundations of the jail were shaken, and immediately all the doors were opened, and everyone’s chains came loose. "},{"kind":"crossref","label":"Ac 4:31","book":"Act","chapter":4,"verse":31,"letter":"a"},{"kind":"crossref","label":"Ac 5:19","book":"Act","chapter":5,"verse":19,"letter":"b"},{"kind":"crossref","label":"Ac 12:7","book":"Act","chapter":12,"verse":7,"letter":"c"},{"kind":"crossref","label":"Ac 12:10","book":"Act","chapter":12,"verse":10,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 4:31","book":"Act","chapter":4,"verse":31},{"label":"Ac 5:19","book":"Act","chapter":5,"verse":19},{"label":"Ac 12:7","book":"Act","chapter":12,"verse":7},{"label":"Ac 12:10","book":"Act","chapter":12,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:27","parts":[{"kind":"text","text":"When the jailer woke up and saw the doors of the prison standing open, he drew his sword and was going to kill himself, since he thought the prisoners had escaped."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:28","parts":[{"kind":"text","text":"But Paul called out in a loud voice, “Don’t harm yourself, because we’re all here!”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:29","parts":[{"kind":"text","text":"The jailer called for lights, rushed in, and fell down trembling before Paul and Silas. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:30","parts":[{"kind":"text","text":"He escorted them out and said, “Sirs, what must I do to be saved?” "},{"kind":"crossref","label":"Ac 2:37","book":"Act","chapter":2,"verse":37,"letter":"a"},{"kind":"crossref","label":"Ac 22:10","book":"Act","chapter":22,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Ac 2:37","book":"Act","chapter":2,"verse":37},{"label":"Ac 22:10","book":"Act","chapter":22,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:31","parts":[{"kind":"text","text":"They said, “Believe in the Lord Jesus, and you will be saved —you and your household.” "},{"kind":"crossref","label":"Mk 16:16","book":"Mrk","chapter":16,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ac 11:14","book":"Act","chapter":11,"verse":14,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 16:16","book":"Mrk","chapter":16,"verse":16},{"label":"Ac 11:14","book":"Act","chapter":11,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:32","parts":[{"kind":"text","text":"And they spoke the word of the Lord to him along with everyone in his house. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:33","parts":[{"kind":"text","text":"He took them the same hour of the night and washed their wounds. Right away he and all his family were baptized. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:34","parts":[{"kind":"text","text":"He brought them into his house, set a meal before them, and rejoiced because he had come to believe in God with his entire household. "},{"kind":"crossref","label":"Ac 11:14","book":"Act","chapter":11,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ac 16:15","book":"Act","chapter":16,"verse":15,"letter":"b"}],"crossRefs":[{"label":"Ac 11:14","book":"Act","chapter":11,"verse":14},{"label":"Ac 16:15","book":"Act","chapter":16,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:35","parts":[{"kind":"text","text":"When daylight came, the chief magistrates sent the police to say, “Release those men.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:36","parts":[{"kind":"text","text":"The jailer reported these words to Paul: “The magistrates have sent orders for you to be released. So come out now and go in peace.” "},{"kind":"crossref","label":"Ac 15:33","book":"Act","chapter":15,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ac 16:27","book":"Act","chapter":16,"verse":27,"letter":"b"}],"crossRefs":[{"label":"Ac 15:33","book":"Act","chapter":15,"verse":33},{"label":"Ac 16:27","book":"Act","chapter":16,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:37","parts":[{"kind":"text","text":"But Paul said to them, “They beat us in public without a trial, although we are Roman citizens, and threw us in jail. And now are they going to send us away secretly? Certainly not! On the contrary, let them come themselves and escort us out.” "},{"kind":"crossref","label":"Ac 22:25–29","book":"Act","chapter":22,"verse":25,"letter":"a"}],"crossRefs":[{"label":"Ac 22:25–29","book":"Act","chapter":22,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:38","parts":[{"kind":"text","text":"The police reported these words to the magistrates. They were afraid when they heard that Paul and Silas were Roman citizens. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:39","parts":[{"kind":"text","text":"So they came to appease them, and escorting them from prison, they urged them to leave town. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:16:40","parts":[{"kind":"text","text":"After leaving the jail, they came to Lydia’s house, where they saw and encouraged the brothers and sisters, and departed. "},{"kind":"crossref","label":"Mt 8:34","book":"Mat","chapter":8,"verse":34,"letter":"a"},{"kind":"crossref","label":"Ac 16:14","book":"Act","chapter":16,"verse":14,"letter":"b"}],"crossRefs":[{"label":"Mt 8:34","book":"Mat","chapter":8,"verse":34},{"label":"Ac 16:14","book":"Act","chapter":16,"verse":14}],"footnotes":[]}]},"cachedAt":1783279647746}