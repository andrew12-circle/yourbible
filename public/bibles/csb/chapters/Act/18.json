hapter":11,"verse":14},{"label":"1Co 1:14","book":"1Co","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:9","parts":[{"kind":"text","text":"The Lord said to Paul in a night vision, “Don’t be afraid, but keep on speaking and don’t be silent. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:10","parts":[{"kind":"text","text":"For I am with you, and no one will lay a hand on you to hurt you, because I have many people in this city.”"},{"kind":"crossref","label":"Mt 28:20","book":"Mat","chapter":28,"verse":20,"letter":"a"},{"kind":"crossref","label":"Ac 23:11","book":"Act","chapter":23,"verse":11,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 28:20","book":"Mat","chapter":28,"verse":20},{"label":"Ac 23:11","book":"Act","chapter":23,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:11","parts":[{"kind":"text","text":"He stayed there a year and a half, teaching the word of God among them."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:12","parts":[{"kind":"text","text":"While Gallio was proconsul of Achaia, the Jews made a united attack against Paul and brought him to the tribunal. "},{"kind":"crossref","label":"Ac 13:7","book":"Act","chapter":13,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ac 18:27","book":"Act","chapter":18,"verse":27,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 13:7","book":"Act","chapter":13,"verse":7},{"label":"Ac 18:27","book":"Act","chapter":18,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:13","parts":[{"kind":"text","text":"“This man,” they said, “is persuading people to worship God in ways contrary to the law.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:14","parts":[{"kind":"text","text":"As Paul was about to open his mouth, Gallio said to the Jews, “If it were a matter of wrongdoing or of a serious crime, it would be reasonable for me to put up with you Jews. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:15","parts":[{"kind":"text","text":"But if these are questions about words, names, and your own law, see to it yourselves. I refuse to be a judge of such things.” "},{"kind":"crossref","label":"Ac 23:29","book":"Act","chapter":23,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ac 25:11","book":"Act","chapter":25,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ac 25:19","book":"Act","chapter":25,"verse":19,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 23:29","book":"Act","chapter":23,"verse":29},{"label":"Ac 25:11","book":"Act","chapter":25,"verse":11},{"label":"Ac 25:19","book":"Act","chapter":25,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:16","parts":[{"kind":"text","text":"So he drove them from the tribunal. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:17","parts":[{"kind":"text","text":"And they all "},{"kind":"footnote","marker":1,"text":"Other mss read Then all the Greeks"},{"kind":"text","text":" seized Sosthenes, "},{"kind":"crossref","label":"1Co 1:1","book":"1Co","chapter":1,"verse":1,"letter":"a"},{"kind":"text","text":" the leader of the synagogue, and beat him in front of the tribunal, but none of these things mattered to Gallio."}],"crossRefs":[{"label":"1Co 1:1","book":"1Co","chapter":1,"verse":1}],"footnotes":[{"marker":1,"text":"Other mss read Then all the Greeks"}]},{"verseId":"a556c5305ee15c3f-01:Act:18:18","parts":[{"kind":"text","text":"After staying for some time, Paul said farewell to the brothers and sisters and sailed away to Syria, accompanied by Priscilla and Aquila. He shaved his head at Cenchreae because of a vow he had taken. "},{"kind":"crossref","label":"Nm 6:2","book":"Num","chapter":6,"verse":2,"letter":"a"},{"kind":"crossref","label":"Nm 6:5","book":"Num","chapter":6,"verse":5,"letter":"b"},{"kind":"crossref","label":"Nm 6:9","book":"Num","chapter":6,"verse":9,"letter":"c"},{"kind":"crossref","label":"Nm 6:18","book":"Num","chapter":6,"verse":18,"letter":"d"},{"kind":"crossref","label":"Ac 21:24","book":"Act","chapter":21,"verse":24,"letter":"e"},{"kind":"crossref","label":"Rm 16:1","book":"Rom","chapter":16,"verse":1,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 6:2","book":"Num","chapter":6,"verse":2},{"label":"Nm 6:5","book":"Num","chapter":6,"verse":5},{"label":"Nm 6:9","book":"Num","chapter":6,"verse":9},{"label":"Nm 6:18","book":"Num","chapter":6,"verse":18},{"label":"Ac 21:24","book":"Act","chapter":21,"verse":24},{"label":"Rm 16:1","book":"Rom","chapter":16,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:19","parts":[{"kind":"text","text":"When they reached Ephesus "},{"kind":"crossref","label":"Ac 19:1","book":"Act","chapter":19,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ac 20:16","book":"Act","chapter":20,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Co 15:32","book":"1Co","chapter":15,"verse":32,"letter":"c"},{"kind":"crossref","label":"1Tm 1:3","book":"1Ti","chapter":1,"verse":3,"letter":"d"},{"kind":"crossref","label":"2Tm 1:18","book":"2Ti","chapter":1,"verse":18,"letter":"e"},{"kind":"text","text":" he left them there, but he himself entered the synagogue and debated with the Jews. "}],"crossRefs":[{"label":"Ac 19:1","book":"Act","chapter":19,"verse":1},{"label":"Ac 20:16","book":"Act","chapter":20,"verse":16},{"label":"1Co 15:32","book":"1Co","chapter":15,"verse":32},{"label":"1Tm 1:3","book":"1Ti","chapter":1,"verse":3},{"label":"2Tm 1:18","book":"2Ti","chapter":1,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:20","parts":[{"kind":"text","text":"When they asked him to stay for a longer time, he declined, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:21","parts":[{"kind":"text","text":"but he said farewell and added, "},{"kind":"footnote","marker":1,"text":"Other mss add “By all means it is necessary to keep the coming festival in Jerusalem. But"},{"kind":"text","text":" “I’ll come back to you again, if God wills.” "},{"kind":"crossref","label":"Rm 1:10","book":"Rom","chapter":1,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Co 4:19","book":"1Co","chapter":4,"verse":19,"letter":"b"},{"kind":"crossref","label":"1Co 16:7","book":"1Co","chapter":16,"verse":7,"letter":"c"},{"kind":"crossref","label":"Heb 6:3","book":"Heb","chapter":6,"verse":3,"letter":"d"},{"kind":"crossref","label":"Jms 4:15","book":"Jas","chapter":4,"verse":15,"letter":"e"},{"kind":"crossref","label":"1Pt 3:17","book":"1Pe","chapter":3,"verse":17,"letter":"f"},{"kind":"text","text":" Then he set sail from Ephesus."}],"crossRefs":[{"label":"Rm 1:10","book":"Rom","chapter":1,"verse":10},{"label":"1Co 4:19","book":"1Co","chapter":4,"verse":19},{"label":"1Co 16:7","book":"1Co","chapter":16,"verse":7},{"label":"Heb 6:3","book":"Heb","chapter":6,"verse":3},{"label":"Jms 4:15","book":"Jas","chapter":4,"verse":15},{"label":"1Pt 3:17","book":"1Pe","chapter":3,"verse":17}],"footnotes":[{"marker":1,"text":"Other mss add “By all means it is necessary to keep the coming festival in Jerusalem. But"}]},{"verseId":"a556c5305ee15c3f-01:Act:18:22","parts":[{"kind":"text","text":"On landing at Caesarea, he went up to Jerusalem and greeted the church, then went down to Antioch. "},{"kind":"crossref","label":"Ac 8:40","book":"Act","chapter":8,"verse":40,"letter":"a"},{"kind":"crossref","label":"Ac 11:19","book":"Act","chapter":11,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Ac 8:40","book":"Act","chapter":8,"verse":40},{"label":"Ac 11:19","book":"Act","chapter":11,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:23","parts":[{"kind":"text","text":"After spending some time there, he set out, traveling through one place after another in the region of Galatia and Phrygia, strengthening all the disciples. "},{"kind":"crossref","label":"Ac 14:22","book":"Act","chapter":14,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ac 16:6","book":"Act","chapter":16,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Ac 14:22","book":"Act","chapter":14,"verse":22},{"label":"Ac 16:6","book":"Act","chapter":16,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:24","parts":[{"kind":"text","text":"Now a Jew named Apollos, "},{"kind":"crossref","label":"Ac 19:1","book":"Act","chapter":19,"verse":1,"letter":"a"},{"kind":"crossref","label":"1Co 1:12","book":"1Co","chapter":1,"verse":12,"letter":"b"},{"kind":"crossref","label":"1Co 3:5","book":"1Co","chapter":3,"verse":5,"letter":"c"},{"kind":"crossref","label":"1Co 4:6","book":"1Co","chapter":4,"verse":6,"letter":"d"},{"kind":"crossref","label":"1Co 16:12","book":"1Co","chapter":16,"verse":12,"letter":"e"},{"kind":"crossref","label":"Ti 3:13","book":"Tit","chapter":3,"verse":13,"letter":"f"},{"kind":"text","text":" a native Alexandrian, an eloquent man who was competent in the use of the Scriptures, arrived in Ephesus. "}],"crossRefs":[{"label":"Ac 19:1","book":"Act","chapter":19,"verse":1},{"label":"1Co 1:12","book":"1Co","chapter":1,"verse":12},{"label":"1Co 3:5","book":"1Co","chapter":3,"verse":5},{"label":"1Co 4:6","book":"1Co","chapter":4,"verse":6},{"label":"1Co 16:12","book":"1Co","chapter":16,"verse":12},{"label":"Ti 3:13","book":"Tit","chapter":3,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:25","parts":[{"kind":"text","text":"He had been instructed in the way of the Lord; and being fervent in spirit, "},{"kind":"footnote","marker":1,"text":"Or in the Spirit"},{"kind":"text","text":" he was speaking and teaching accurately about Jesus, although he knew only John’s baptism. "},{"kind":"crossref","label":"Lk 7:29","book":"Luk","chapter":7,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ac 9:2","book":"Act","chapter":9,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ac 19:3","book":"Act","chapter":19,"verse":3,"letter":"c"},{"kind":"crossref","label":"Rm 12:11","book":"Rom","chapter":12,"verse":11,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 7:29","book":"Luk","chapter":7,"verse":29},{"label":"Ac 9:2","book":"Act","chapter":9,"verse":2},{"label":"Ac 19:3","book":"Act","chapter":19,"verse":3},{"label":"Rm 12:11","book":"Rom","chapter":12,"verse":11}],"footnotes":[{"marker":1,"text":"Or in the Spirit"}]},{"verseId":"a556c5305ee15c3f-01:Act:18:26","parts":[{"kind":"text","text":"He began to speak boldly in the synagogue. After Priscilla and Aquila heard him, they took him aside "},{"kind":"footnote","marker":2,"text":"Lit they received him"},{"kind":"text","text":" and explained the way of God to him more accurately. "},{"kind":"crossref","label":"Mt 2:8","book":"Mat","chapter":2,"verse":8,"letter":"a"},{"kind":"crossref","label":"Lk 1:3","book":"Luk","chapter":1,"verse":3,"letter":"b"},{"kind":"crossref","label":"Ac 18:25","book":"Act","chapter":18,"verse":25,"letter":"c"},{"kind":"crossref","label":"Ac 23:15","book":"Act","chapter":23,"verse":15,"letter":"d"},{"kind":"crossref","label":"Ac 23:20","book":"Act","chapter":23,"verse":20,"letter":"e"},{"kind":"crossref","label":"Ac 24:22","book":"Act","chapter":24,"verse":22,"letter":"f"},{"kind":"crossref","label":"Eph 5:15","book":"Eph","chapter":5,"verse":15,"letter":"g"},{"kind":"crossref","label":"1Th 5:2","book":"1Th","chapter":5,"verse":2,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 2:8","book":"Mat","chapter":2,"verse":8},{"label":"Lk 1:3","book":"Luk","chapter":1,"verse":3},{"label":"Ac 18:25","book":"Act","chapter":18,"verse":25},{"label":"Ac 23:15","book":"Act","chapter":23,"verse":15},{"label":"Ac 23:20","book":"Act","chapter":23,"verse":20},{"label":"Ac 24:22","book":"Act","chapter":24,"verse":22},{"label":"Eph 5:15","book":"Eph","chapter":5,"verse":15},{"label":"1Th 5:2","book":"1Th","chapter":5,"verse":2}],"footnotes":[{"marker":2,"text":"Lit they received him"}]},{"verseId":"a556c5305ee15c3f-01:Act:18:27","parts":[{"kind":"text","text":"When he wanted to cross over to Achaia, the brothers and sisters wrote to the disciples to welcome him. After he arrived, he was a great help to those who by grace had believed. "},{"kind":"crossref","label":"Ac 18:12","book":"Act","chapter":18,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ac 18:18","book":"Act","chapter":18,"verse":18,"letter":"b"},{"kind":"crossref","label":"1Co 3:6","book":"1Co","chapter":3,"verse":6,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ac 18:12","book":"Act","chapter":18,"verse":12},{"label":"Ac 18:18","book":"Act","chapter":18,"verse":18},{"label":"1Co 3:6","book":"1Co","chapter":3,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:18:28","parts":[{"kind":"text","text":"For he vigorously refuted the Jews in public, demonstrating through the Scriptures that Jesus is the Messiah. "},{"kind":"crossref","label":"Ac 9:22","book":"Act","chapter":9,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ac 17:2–3","book":"Act","chapter":17,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ac 18:5","book":"Act","chapter":18,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Ac 9:22","book":"Act","chapter":9,"verse":22},{"label":"Ac 17:2–3","book":"Act","chapter":17,"verse":2},{"label":"Ac 18:5","book":"Act","chapter":18,"verse":5}],"footnotes":[]}]},"cachedAt":1783279648352}