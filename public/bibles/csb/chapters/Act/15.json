1,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ac 2:46","book":"Act","chapter":2,"verse":46,"letter":"b"},{"kind":"crossref","label":"Ac 4:24","book":"Act","chapter":4,"verse":24,"letter":"c"},{"kind":"crossref","label":"Ac 5:12","book":"Act","chapter":5,"verse":12,"letter":"d"},{"kind":"crossref","label":"Ac 7:57","book":"Act","chapter":7,"verse":57,"letter":"e"},{"kind":"crossref","label":"Ac 8:6","book":"Act","chapter":8,"verse":6,"letter":"f"},{"kind":"crossref","label":"Ac 12:20","book":"Act","chapter":12,"verse":20,"letter":"g"},{"kind":"crossref","label":"Ac 18:12","book":"Act","chapter":18,"verse":12,"letter":"h"},{"kind":"crossref","label":"Ac 19:29","book":"Act","chapter":19,"verse":29,"letter":"i"},{"kind":"text","text":" decided to select men and send them to you along with our dearly loved Barnabas and Paul, "}],"crossRefs":[{"label":"Ac 1:14","book":"Act","chapter":1,"verse":14},{"label":"Ac 2:46","book":"Act","chapter":2,"verse":46},{"label":"Ac 4:24","book":"Act","chapter":4,"verse":24},{"label":"Ac 5:12","book":"Act","chapter":5,"verse":12},{"label":"Ac 7:57","book":"Act","chapter":7,"verse":57},{"label":"Ac 8:6","book":"Act","chapter":8,"verse":6},{"label":"Ac 12:20","book":"Act","chapter":12,"verse":20},{"label":"Ac 18:12","book":"Act","chapter":18,"verse":12},{"label":"Ac 19:29","book":"Act","chapter":19,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:15:26","parts":[{"kind":"text","text":"who have risked their lives "},{"kind":"crossref","label":"Ac 9:23–25","book":"Act","chapter":9,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ac 14:19","book":"Act","chapter":14,"verse":19,"letter":"b"},{"kind":"text","text":" for the name of our Lord Jesus Christ. "}],"crossRefs":[{"label":"Ac 9:23–25","book":"Act","chapter":9,"verse":23},{"label":"Ac 14:19","book":"Act","chapter":14,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:15:27","parts":[{"kind":"text","text":"Therefore we have sent Judas and Silas, who