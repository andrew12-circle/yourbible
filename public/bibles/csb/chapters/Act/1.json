":"Other mss read to share"},{"kind":"text","text":" in this apostolic ministry "},{"kind":"crossref","label":"Rm 1:5","book":"Rom","chapter":1,"verse":5,"letter":"a"},{"kind":"crossref","label":"1Co 9:2","book":"1Co","chapter":9,"verse":2,"letter":"b"},{"kind":"crossref","label":"Gl 2:8","book":"Gal","chapter":2,"verse":8,"letter":"c"},{"kind":"text","text":" that Judas left to go where he belongs.” "}],"crossRefs":[{"label":"Rm 1:5","book":"Rom","chapter":1,"verse":5},{"label":"1Co 9:2","book":"1Co","chapter":9,"verse":2},{"label":"Gl 2:8","book":"Gal","chapter":2,"verse":8}],"footnotes":[{"marker":1,"text":"Other mss read to share"}]},{"verseId":"a556c5305ee15c3f-01:Act:1:26","parts":[{"kind":"text","text":"Then they cast lots "},{"kind":"crossref","label":"Mt 27:35","book":"Mat","chapter":27,"verse":35,"letter":"a"},{"kind":"crossref","label":"Mk 15:24","book":"Mrk","chapter":15,"verse":24,"letter":"b"},{"kind":"crossref","label":"Lk 23:34","book":"Luk","chapter":23,"verse":34,"letter":"c"},{"kind":"crossref","label":"Jn 19:24","book":"Jhn","chapter":19,"verse":24,"letter":"d"},{"kind":"crossref","label":"Ac 8:21","book":"Act","chapter":8,"verse":21,"letter":"e"},{"kind":"crossref","label":"Ac 26:18","book":"Act","chapter":26,"verse":18,"letter":"f"},{"kind":"crossref","label":"Col 1:12","book":"Col","chapter":1,"verse":12,"letter":"g"},{"kind":"crossref","label":"1Pt 5:3","book":"1Pe","chapter":5,"verse":3,"letter":"h"},{"kind":"text","text":" for them, and the lot fell to Matthias and he was added to the eleven apostles."}],"crossRefs":[{"label":"Mt 27:35","book":"Mat","chapter":27,"verse":35},{"label":"Mk 15:24","book":"Mrk","chapter":15,"verse":24},{"label":"Lk 23:34","book":"Luk","chapter":23,"verse":34},{"label":"Jn 19:24","book":"Jhn","chapter":19,"verse":24},{"label":"Ac 8:21","book":"Act","chapter":8,"verse":21},{"label":"Ac 26:18","book":"Act","chapter":26,"verse":18},{"label":"Col 1:12","book":"Col","chapter":1,"verse":12},{"label":"1Pt 5:3","book":"1