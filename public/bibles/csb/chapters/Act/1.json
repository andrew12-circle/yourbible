etter":"b"},{"kind":"crossref","label":"Mt 27:7","book":"Mat","chapter":27,"verse":7,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 26:14–15","book":"Mat","chapter":26,"verse":14},{"label":"Mt 27:5","book":"Mat","chapter":27,"verse":5},{"label":"Mt 27:7","book":"Mat","chapter":27,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:1:19","parts":[{"kind":"text","text":"This became known to all the residents of Jerusalem, so that in their own language that field is called Hakeldama (that is, “Field of Blood”). "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:1:20","parts":[{"kind":"text","text":"“For it is written in the Book of Psalms:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:1:21","parts":[{"kind":"text","text":"“Therefore, from among the men who have accompanied us during the whole time the Lord Jesus went in and out among us — "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Act:1:22","parts":[{"kind":"text","text":"beginning from the baptism of John until the day he was taken up from us —from among these, it is necessary that one become a witness with us of his resurrection.” "},{"kind":"crossref","label":"Mk 1:4","book":"Mrk","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ac 2:31","book":"Act","chapter":2,"verse":31,"letter":"b"},{"kind":"crossref","label":"Ac 4:2","book":"Act","chapter":4,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ac 17:18","book":"Act","chapter":17,"verse":18,"letter":"d"},{"kind":"crossref","label":"Ac 23:6","book":"Act","chapter":23,"verse":6,"letter":"e"},{"kind":"crossref","label":"Ac 24:15","book":"Act","chapter":24,"verse":15,"letter":"f"},{"kind":"crossref","label":"Ac 26:23","book":"Act","chapter":26,"verse":23,"letter":"g"}],"crossRefs":[{"label":"Mk 1:4","book":"Mrk","chapter":1,"verse":4},{"label":"Ac 2:31","book":"Act","chapter":2,"verse":31},{"label":"Ac 4:2","book":"Act","chapter":4,"verse":2},{"label":"