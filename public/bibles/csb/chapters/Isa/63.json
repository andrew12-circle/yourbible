":"text","text":"Yet you are our Father,"},{"kind":"text","text":" even though Abraham does not know us"},{"kind":"text","text":" and Israel doesn’t recognize us."},{"kind":"text","text":" You, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", are our Father;"},{"kind":"text","text":" your name is Our Redeemer "},{"kind":"crossref","label":"Is 41:14","book":"Isa","chapter":41,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 43:14","book":"Isa","chapter":43,"verse":14,"letter":"b"},{"kind":"text","text":" from Ancient Times."}],"crossRefs":[{"label":"Is 41:14","book":"Isa","chapter":41,"verse":14},{"label":"Is 43:14","book":"Isa","chapter":43,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:63:17","parts":[{"kind":"text","text":"Why, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", do you make us stray from your ways?"},{"kind":"text","text":" You harden our hearts so we do not fear "},{"kind":"footnote","marker":1,"text":"Lit our heart from fearing"},{"kind":"text","text":" you. "},{"kind":"crossref","label":"Is 6:10","book":"Isa","chapter":6,"verse":10,"letter":"a"},{"kind":"text","text":" Return, because of your servants,"},{"kind":"text","text":" the tribes of your heritage."}],"crossRefs":[{"label":"Is 6:10","book":"Isa","chapter":6,"verse":10}],"footnotes":[{"marker":1,"text":"Lit our heart from fearing"}]},{"verseId":"a556c5305ee15c3f-01:Isa:63:18","parts":[{"kind":"text","text":"Your holy people had a possession "},{"kind":"footnote","marker":1,"text":"Or Your people possessed your holy place"},{"kind":"text","text":" for a little while,"},{"kind":"text","text":" but our enemies have trampled down"},{"kind":"text","text":" your sanctuary. "},{"kind":"crossref","label":"Ps 74:3–7","book":"Psa","chapter":74,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 64:11","book":"Isa","chapter":64,"verse":11,"letter":"b"}],"crossRefs":[{"label":"Ps 74:3–7","book":"Psa","chapter":74,"verse":3},{"label":"Is 64:11","book":"Isa","chapter":64,"verse":11}],"footnotes":[{"marker":1,"text":"Or Your people possessed your holy place"}]},{"verseId":"a556c5305ee15c3f-01:Isa:63:19","parts":[{"kind":"text","text":"We have become like those you never ruled,"},{"kind":"text","text":" like those who did not bear your name. "},{"kind":"crossref","label":"Dt 28:10","book":"Deu","chapter":28,"verse":10,"letter":"a"},{"kind":"crossref","label":"Is 43:7","book":"Isa","chapter":43,"verse":7,"letter":"b"},{"kind":"crossref","label":"Is 65:1","book":"Isa","chapter":65,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Dt 28:10","book":"Deu","chapter":28,"verse":10},{"label":"Is 43:7","book":"Isa","chapter":43,"verse":7},{"label":"Is 65:1","book":"Isa","chapter":65,"verse":1}],"footnotes":[]}]},"cachedAt":1783279556017}