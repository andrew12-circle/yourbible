d":"crossref","label":"Jr 44:29","book":"Jer","chapter":44,"verse":29,"letter":"c"},{"kind":"text","text":" and wicked people for their iniquities."},{"kind":"text","text":" I will put an end to the pride of the arrogant "},{"kind":"crossref","label":"Is 2:11","book":"Isa","chapter":2,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 23:9","book":"Isa","chapter":23,"verse":9,"letter":"b"},{"kind":"crossref","label":"Dn 5:22","book":"Dan","chapter":5,"verse":22,"letter":"c"},{"kind":"text","text":" and humiliate the insolence of tyrants."}],"crossRefs":[{"label":"Jr 23:2","book":"Jer","chapter":23,"verse":2},{"label":"Jr 36:31","book":"Jer","chapter":36,"verse":31},{"label":"Jr 44:29","book":"Jer","chapter":44,"verse":29},{"label":"Is 2:11","book":"Isa","chapter":2,"verse":11},{"label":"Is 23:9","book":"Isa","chapter":23,"verse":9},{"label":"Dn 5:22","book":"Dan","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:13:12","parts":[{"kind":"text","text":"I will make a human more scarce than fine gold,"},{"kind":"text","text":" and mankind more rare than the gold of Ophir. "},{"kind":"crossref","label":"1Kg 9:28","book":"1Ki","chapter":9,"verse":28,"letter":"a"},{"kind":"crossref","label":"Jb 28:16","book":"Job","chapter":28,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ps 45:9","book":"Psa","chapter":45,"verse":9,"letter":"c"}],"crossRefs":[{"label":"1Kg 9:28","book":"1Ki","chapter":9,"verse":28},{"label":"Jb 28:16","book":"Job","chapter":28,"verse":16},{"label":"Ps 45:9","book":"Psa","chapter":45,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:13:13","parts":[{"kind":"text","text":"Therefore I will make the heavens tremble,"},{"kind":"text","text":" and the earth will shake from its foundations "},{"kind":"crossref","label":"Ps 18:7","book":"Psa","chapter":18,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 2:19","book":"Isa","chapter":2,"verse":19,"letter":"b"},{"kind":"crossref","label":"Is 24:1","book":"Isa","chapter":24,"verse":1,"letter":"c"},{"kind":"crossref","label":"Is 24:19","book":"Isa","chapter":24,"verse":19,"letter":"d"},{"kind":"crossref","label":"Hg 2:6","book":"Hag","chapter":2,"verse":6,"letter":"e"},{"kind":"text","text":" at the wrath of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies,"},{"kind":"text","text":" on the day of his burning anger."}],"crossRefs":[{"label":"Ps 18:7","book":"Psa","chapter":18,"verse":7},{"label":"Is 2:19","book":"Isa","chapter":2,"verse":19},{"label":"Is 24:1","book":"Isa","chapter":24,"verse":1},{"label":"Is 24:19","book":"Isa","chapter":24,"verse":19},{"label":"Hg 2:6","book":"Hag","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:13:14","parts":[{"kind":"text","text":"Like wandering gazelles"},{"kind":"text","text":" and like sheep without a shepherd, "},{"kind":"crossref","label":"1Kg 22:17","book":"1Ki","chapter":22,"verse":17,"letter":"a"},{"kind":"crossref","label":"Mt 9:36","book":"Mat","chapter":9,"verse":36,"letter":"b"},{"kind":"crossref","label":"Mk 6:34","book":"Mrk","chapter":6,"verse":34,"letter":"c"},{"kind":"crossref","label":"1Pt 2:25","book":"1Pe","chapter":2,"verse":25,"letter":"d"},{"kind":"text","text":" each one will turn to his own people,"},{"kind":"text","text":" each one will flee to his own land."}],"crossRefs":[{"label":"1Kg 22:17","book":"1Ki","chapter":22,"verse":17},{"label":"Mt 9:36","book":"Mat","chapter":9,"verse":36},{"label":"Mk 6:34","book":"Mrk","chapter":6,"verse":34},{"label":"1Pt 2:25","book":"1Pe","chapter":2,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:13:15","parts":[{"kind":"text","text":"Whoever is found will be stabbed,"},{"kind":"text","text":" and whoever is caught will die by the sword."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:13:16","parts":[{"kind":"text","text":"Their children will be dashed to pieces before their eyes; "},{"kind":"crossref","label":"Ps 137