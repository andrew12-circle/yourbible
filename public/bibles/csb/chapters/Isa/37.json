 and rescue it"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:37:36","parts":[{"kind":"text","text":"Then "},{"kind":"crossref","label":"2Kg 19:35","book":"2Ki","chapter":19,"verse":35,"letter":"a"},{"kind":"crossref","label":"2Ch 32:21","book":"2Ch","chapter":32,"verse":21,"letter":"b"},{"kind":"text","text":" the angel of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"crossref","label":"Gn 16:7–11","book":"Gen","chapter":16,"verse":7,"letter":"c"},{"kind":"crossref","label":"Ex 3:2","book":"Exo","chapter":3,"verse":2,"letter":"d"},{"kind":"crossref","label":"Nm 22:22","book":"Num","chapter":22,"verse":22,"letter":"e"},{"kind":"crossref","label":"Jdg 6:11–12","book":"Jdg","chapter":6,"verse":11,"letter":"f"},{"kind":"crossref","label":"2Sm 24:16","book":"2Sa","chapter":24,"verse":16,"letter":"g"},{"kind":"crossref","label":"Ps 34:7","book":"Psa","chapter":34,"verse":7,"letter":"h"},{"kind":"text","text":" went out and struck down one hundred eighty-five thousand in the camp of the Assyrians. When the people got up the next morning, there were all the dead bodies! "}],"crossRefs":[{"label":"2Kg 19:35","book":"2Ki","chapter":19,"verse":35},{"label":"2Ch 32:21","book":"2Ch","chapter":32,"verse":21},{"label":"Gn 16:7–11","book":"Gen","chapter":16,"verse":7},{"label":"Ex 3:2","book":"Exo","chapter":3,"verse":2},{"label":"Nm 22:22","book":"Num","chapter":22,"verse":22},{"label":"Jdg 6:11–12","book":"Jdg","chapter":6,"verse":11},{"label":"2Sm 24:16","book":"2Sa","chapter":24,"verse":16},{"label":"Ps 34:7","book":"Psa","chapter":34,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:37:37","parts":[{"kind":"text","text":"So King Sennacherib of Assyria broke camp and left. He returned home and lived in Nineveh. "},{"kind":"crossref","label":"Gn 10:11","book":"Gen","chapter":10,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jnh 1:2","book":"Jon","chapter":1,"verse":2,"letter":"b"},{"kind":"crossref","label":"Jnh 3:3","