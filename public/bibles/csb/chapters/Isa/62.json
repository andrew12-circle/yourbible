{"label":"Dt 7:6","book":"Deu","chapter":7,"verse":6},{"label":"Is 4:3","book":"Isa","chapter":4,"verse":3},{"label":"1Pt 2:9","book":"1Pe","chapter":2,"verse":9}],"footnotes":[{"marker":1,"text":"Lit will call them"}]}]},"cachedAt":1783279555680}