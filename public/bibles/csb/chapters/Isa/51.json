l":"Is 14:11","book":"Isa","chapter":14,"verse":11,"letter":"a"},{"kind":"text","text":" But my righteousness will last forever,"},{"kind":"text","text":" and my salvation for all generations."}],"crossRefs":[{"label":"Is 50:9","book":"Isa","chapter":50,"verse":9},{"label":"Is 14:11","book":"Isa","chapter":14,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:9","parts":[{"kind":"text","text":"Wake up, wake up!"},{"kind":"text","text":" Arm of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", clothe yourself with strength."},{"kind":"text","text":" Wake up as in days past,"},{"kind":"text","text":" as in generations long ago."},{"kind":"text","text":" Wasn’t it you who hacked Rahab to pieces, "},{"kind":"crossref","label":"Jb 26:12","book":"Job","chapter":26,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ps 89:10","book":"Psa","chapter":89,"verse":10,"letter":"b"},{"kind":"crossref","label":"Is 30:7","book":"Isa","chapter":30,"verse":7,"letter":"c"},{"kind":"text","text":" who pierced the sea monster? "},{"kind":"crossref","label":"Ps 74:13","book":"Psa","chapter":74,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 27:1","book":"Isa","chapter":27,"verse":1,"letter":"b"}],"crossRefs":[{"label":"Jb 26:12","book":"Job","chapter":26,"verse":12},{"label":"Ps 89:10","book":"Psa","chapter":89,"verse":10},{"label":"Is 30:7","book":"Isa","chapter":30,"verse":7},{"label":"Ps 74:13","book":"Psa","chapter":74,"verse":13},{"label":"Is 27:1","book":"Isa","chapter":27,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:10","parts":[{"kind":"text","text":"Wasn’t it you who dried up the sea, "},{"kind":"crossref","label":"Is 11:15–16","book":"Isa","chapter":11,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 50:2","book":"Isa","chapter":50,"verse":2,"letter":"b"},{"kind":"crossref","label":"Is 63:11–12","book":"Isa","chapter":63,"verse":11,"letter":"c"},{"kind":"text","text":" the waters of the great deep,"},{"kind":"text","text":" who made the sea-bed into a road"},{"kind":"text","text":" for the redeemed to pass over? "},{"kind":"crossref","label":"Ex 15:13","book":"Exo","chapter":15,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Is 11:15–16","book":"Isa","chapter":11,"verse":15},{"label":"Is 50:2","book":"Isa","chapter":50,"verse":2},{"label":"Is 63:11–12","book":"Isa","chapter":63,"verse":11},{"label":"Ex 15:13","book":"Exo","chapter":15,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:11","parts":[{"kind":"text","text":"And the ransomed of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will return "},{"kind":"crossref","label":"Is 35:10","book":"Isa","chapter":35,"verse":10,"letter":"a"},{"kind":"text","text":" and come to Zion with singing,"},{"kind":"text","text":" crowned with unending joy."},{"kind":"text","text":" Joy and gladness will overtake them,"},{"kind":"text","text":" and sorrow and sighing will flee."}],"crossRefs":[{"label":"Is 35:10","book":"Isa","chapter":35,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:12","parts":[{"kind":"text","text":"I —I am the one who comforts you."},{"kind":"text","text":" Who are you that you should fear humans who die, "},{"kind":"crossref","label":"Ps 118:6","book":"Psa","chapter":118,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 2:22","book":"Isa","chapter":2,"verse":22,"letter":"b"},{"kind":"text","text":" or a son of man who is given up like grass? "},{"kind":"crossref","label":"Is 40:6–7","book":"Isa","chapter":40,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jms 1:10","book":"Jas","chapter":1,"verse":10,"letter":"b"},{"kind":"crossref","label":"1Pt 1:24","book":"1Pe","chapter":1,"verse":24,"letter":"c"}],"crossRefs":[{"label":"Ps 118:6","book":"Psa","chapter":118,"verse":6},{"label":"Is 2:22","book":"Isa","chapter":2,"verse":22},{"label":"Is 40:6–7","book":"Isa","chapter":40,"verse":6},{"label":"Jms 1:10","book":"Jas","chapter":1,"verse":10},{"label":"1Pt 1:24","book":"1Pe","chapter":1,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:13","parts":[{"kind":"text","text":"But you have forgotten the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", your Maker,"},{"kind":"text","text":" who stretched out the heavens"},{"kind":"text","text":" and laid the foundations of the earth. "},{"kind":"crossref","label":"Is 44:24","book":"Isa","chapter":44,"verse":24,"letter":"a"},{"kind":"crossref","label":"Is 45:12","book":"Isa","chapter":45,"verse":12,"letter":"b"},{"kind":"crossref","label":"Am 9:6","book":"Amo","chapter":9,"verse":6,"letter":"c"},{"kind":"crossref","label":"Zch 12:1","book":"Zec","chapter":12,"verse":1,"letter":"d"},{"kind":"text","text":" You are in constant dread all day long"},{"kind":"text","text":" because of the fury of the oppressor,"},{"kind":"text","text":" who has set himself to destroy."},{"kind":"text","text":" But where is the fury of the oppressor? "},{"kind":"crossref","label":"Is 49:26","book":"Isa","chapter":49,"verse":26,"letter":"a"}],"crossRefs":[{"label":"Is 44:24","book":"Isa","chapter":44,"verse":24},{"label":"Is 45:12","book":"Isa","chapter":45,"verse":12},{"label":"Am 9:6","book":"Amo","chapter":9,"verse":6},{"label":"Zch 12:1","book":"Zec","chapter":12,"verse":1},{"label":"Is 49:26","book":"Isa","chapter":49,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:14","parts":[{"kind":"text","text":"The prisoner "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"text","text":" is soon to be set free;"},{"kind":"text","text":" he will not die and go to the Pit,"},{"kind":"text","text":" and his food will not be lacking."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Isa:51:15","parts":[{"kind":"text","text":"For I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God"},{"kind":"text","text":" who stirs up the sea so that its waves roar "},{"kind":"crossref","label":"Ps 107:25","book":"Psa","chapter":107,"verse":25,"letter":"a"},{"kind":"crossref","label":"Jr 31:35","book":"Jer","chapter":31,"verse":35,"letter":"b"},{"kind":"text","text":" —"},{"kind":"text","text":" his name is the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies."}],"crossRefs":[{"label":"Ps 107:25","book":"Psa","chapter":107,"verse":25},{"label":"Jr 31:35","book":"Jer","chapter":31,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:16","parts":[{"kind":"text","text":"I have put my words in your mouth, "},{"kind":"crossref","label":"Is 59:21","book":"Isa","chapter":59,"verse":21,"letter":"a"},{"kind":"text","text":" and covered you in the shadow of my hand, "},{"kind":"crossref","label":"Ex 33:22","book":"Exo","chapter":33,"verse":22,"letter":"a"},{"kind":"crossref","label":"Is 49:2","book":"Isa","chapter":49,"verse":2,"letter":"b"},{"kind":"text","text":" in order to plant "},{"kind":"footnote","marker":1,"text":"Syr reads to stretch out"},{"kind":"text","text":" the heavens,"},{"kind":"text","text":" to found the earth,"},{"kind":"text","text":" and to say to Zion, “You are my people.”"}],"crossRefs":[{"label":"Is 59:21","book":"Isa","chapter":59,"verse":21},{"label":"Ex 33:22","book":"Exo","chapter":33,"verse":22},{"label":"Is 49:2","book":"Isa","chapter":49,"verse":2}],"footnotes":[{"marker":1,"text":"Syr reads to stretch out"}]},{"verseId":"a556c5305ee15c3f-01:Isa:51:17","parts":[{"kind":"text","text":"Wake yourself, wake yourself up!"},{"kind":"text","text":" Stand up, Jerusalem,"},{"kind":"text","text":" you who have drunk the cup of his fury "},{"kind":"crossref","label":"Jb 21:20","book":"Job","chapter":21,"verse":20,"letter":"a"},{"kind":"crossref","label":"Is 63:6","book":"Isa","chapter":63,"verse":6,"letter":"b"},{"kind":"crossref","label":"Jr 25:15","book":"Jer","chapter":25,"verse":15,"letter":"c"},{"kind":"crossref","label":"Mt 20:22","book":"Mat","chapter":20,"verse":22,"letter":"d"},{"kind":"crossref","label":"Mt 26:39","book":"Mat","chapter":26,"verse":39,"letter":"e"},{"kind":"crossref","label":"Jn 18:1","book":"Jhn","chapter":18,"verse":1,"letter":"f"},{"kind":"crossref","label":"Rv 14:10","book":"Rev","chapter":14,"verse":10,"letter":"g"},{"kind":"text","text":" from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s hand;"},{"kind":"text","text":" you who have drunk the goblet to the dregs —"},{"kind":"text","text":" the cup that causes people to stagger."}],"crossRefs":[{"label":"Jb 21:20","book":"Job","chapter":21,"verse":20},{"label":"Is 63:6","book":"Isa","chapter":63,"verse":6},{"label":"Jr 25:15","book":"Jer","chapter":25,"verse":15},{"label":"Mt 20:22","book":"Mat","chapter":20,"verse":22},{"label":"Mt 26:39","book":"Mat","chapter":26,"verse":39},{"label":"Jn 18:1","book":"Jhn","chapter":18,"verse":1},{"label":"Rv 14:10","book":"Rev","chapter":14,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:18","parts":[{"kind":"text","text":"There is no one to guide her"},{"kind":"text","text":" among all the children she has raised;"},{"kind":"text","text":" there is no one to take hold of her hand"},{"kind":"text","text":" among all the offspring she has brought up."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:19","parts":[{"kind":"text","text":"These two things have happened to you: "},{"kind":"crossref","label":"Is 47:9","book":"Isa","chapter":47,"verse":9,"letter":"a"},{"kind":"text","text":" devastation and destruction,"},{"kind":"text","text":" famine and sword."},{"kind":"text","text":" Who will grieve for you?"},{"kind":"text","text":" How can I "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Syr, Vg read you? Who can"},{"kind":"text","text":" comfort you?"}],"crossRefs":[{"label":"Is 47:9","book":"Isa","chapter":47,"verse":9}],"footnotes":[{"marker":1,"text":"DSS, LXX, Syr, Vg read you? Who can"}]},{"verseId":"a556c5305ee15c3f-01:Isa:51:20","parts":[{"kind":"text","text":"Your children have fainted;"},{"kind":"text","text":" they lie at the head of every street"},{"kind":"text","text":" like an antelope in a net."},{"kind":"text","text":" They are full of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s fury,"},{"kind":"text","text":" the rebuke of your God."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:21","parts":[{"kind":"text","text":"So listen to this, suffering"},{"kind":"text","text":" and drunken one —but not with wine. "},{"kind":"crossref","label":"Is 29:9","book":"Isa","chapter":29,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Is 29:9","book":"Isa","chapter":29,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:22","parts":[{"kind":"text","text":"This is what your Lord says —"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", even your God,"},{"kind":"text","text":" who defends his people "},{"kind":"crossref","label":"Is 3:12–13","book":"Isa","chapter":3,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 49:25","book":"Isa","chapter":49,"verse":25,"letter":"b"},{"kind":"crossref","label":"Jr 50:34","book":"Jer","chapter":50,"verse":34,"letter":"c"},{"kind":"text","text":" —"},{"kind":"text","text":" “Look, I have removed from your hand"},{"kind":"text","text":" the cup that causes staggering;"},{"kind":"text","text":" that goblet, the cup of my fury."},{"kind":"text","text":" You will never drink it again."}],"crossRefs":[{"label":"Is 3:12–13","book":"Isa","chapter":3,"verse":12},{"label":"Is 49:25","book":"Isa","chapter":49,"verse":25},{"label":"Jr 50:34","book":"Jer","chapter":50,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:51:23","parts":[{"kind":"text","text":"I will put it into the hands of your tormentors,"},{"kind":"text","text":" who said to you, "},{"kind":"crossref","label":"Is 49:26","book":"Isa","chapter":49,"verse":26,"letter":"a"},{"kind":"crossref","label":"Jr 25:15–17","book":"Jer","chapter":25,"verse":15,"letter":"b"},{"kind":"crossref","label":"Jr 25:26","book":"Jer","chapter":25,"verse":26,"letter":"c"},{"kind":"crossref","label":"Jr 25:28","book":"Jer","chapter":25,"verse":28,"letter":"d"},{"kind":"crossref","label":"Zch 12:2","book":"Zec","chapter":12,"verse":2,"letter":"e"},{"kind":"text","text":" ‘Lie down, so we can walk over you.’"},{"kind":"text","text":" You made your back like the ground,"},{"kind":"text","text":" and like a street for those who walk on it."}],"crossRefs":[{"label":"Is 49:26","book":"Isa","chapter":49,"verse":26},{"label":"Jr 25:15–17","book":"Jer","chapter":25,"verse":15},{"label":"Jr 25:26","book":"Jer","chapter":25,"verse":26},{"label":"Jr 25:28","book":"Jer","chapter":25,"verse":28},{"label":"Zch 12:2","book":"Zec","chapter":12,"verse":2}],"footnotes":[]}]},"cachedAt":1783279552343}