int you"},{"kind":"text","text":" to be a covenant for the people, "},{"kind":"crossref","label":"Is 42:6","book":"Isa","chapter":42,"verse":6,"letter":"a"},{"kind":"text","text":" to restore the land,"},{"kind":"text","text":" to make them possess the desolate inheritances,"}],"crossRefs":[{"label":"Ps 69:13","book":"Psa","chapter":69,"verse":13},{"label":"2Co 6:2","book":"2Co","chapter":6,"verse":2},{"label":"Is 42:6","book":"Isa","chapter":42,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:9","parts":[{"kind":"text","text":"saying to the prisoners, “Come out,” "},{"kind":"crossref","label":"Is 42:7","book":"Isa","chapter":42,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 61:1","book":"Isa","chapter":61,"verse":1,"letter":"b"},{"kind":"crossref","label":"Lk 4:18","book":"Luk","chapter":4,"verse":18,"letter":"c"},{"kind":"text","text":" and to those who are in darkness, “Show yourselves.”"},{"kind":"text","text":" They will feed along the pathways,"},{"kind":"text","text":" and their pastures will be on all the barren heights. "},{"kind":"crossref","label":"Is 41:18","book":"Isa","chapter":41,"verse":18,"letter":"a"}],"crossRefs":[{"label":"Is 42:7","book":"Isa","chapter":42,"verse":7},{"label":"Is 61:1","book":"Isa","chapter":61,"verse":1},{"label":"Lk 4:18","book":"Luk","chapter":4,"verse":18},{"label":"Is 41:18","book":"Isa","chapter":41,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:10","parts":[{"kind":"text","text":"They will not hunger or thirst,"},{"kind":"text","text":" the scorching heat or sun will not strike them;"},{"kind":"text","text":" for their compassionate one will guide them,"},{"kind":"text","text":" and lead them to springs. "},{"kind":"crossref","label":"Ps 23:2","book":"Psa","chapter":23,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 40:11","book":"Isa","chapter":40,"verse":11,"letter":"b"},{"kind":"crossref","label":"Jn 4:10","book":"Jhn","chapter":4,"verse":10,"letter":"c"},{"kind":"crossref","label":"Rv 7:16–17","book":"Rev","chapter":7,"verse":16,"letter":"d"}],"crossRefs":[{"label":"Ps 23:2","book":"Psa","chapter":23,"verse":2},{"label":"Is 40:11","book":"Isa","chapter":40,"verse":11},{"label":"Jn 4:10","book":"Jhn","chapter":4,"verse":10},{"label":"Rv 7:16–17","book":"Rev","chapter":7,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:11","parts":[{"kind":"text","text":"I will make all my mountains into a road,"},{"kind":"text","text":" and my highways will be raised up. "},{"kind":"crossref","label":"Is 40:4","book":"Isa","chapter":40,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Is 40:4","book":"Isa","chapter":40,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:12","parts":[{"kind":"text","text":"See, these will come from far away,"},{"kind":"text","text":" from the north and from the west, "},{"kind":"footnote","marker":1,"text":"Lit sea"},{"kind":"crossref","label":"Is 43:5–6","book":"Isa","chapter":43,"verse":5,"letter":"a"},{"kind":"text","text":" and from the land of Sinim. "},{"kind":"footnote","marker":1,"text":"DSS read of the Syenites"},{"kind":"footnote","marker":2,"text":"Perhaps modern Aswan in southern Egypt"}],"crossRefs":[{"label":"Is 43:5–6","book":"Isa","chapter":43,"verse":5}],"footnotes":[{"marker":1,"text":"Lit sea"},{"marker":1,"text":"DSS read of the Syenites"},{"marker":2,"text":"Perhaps modern Aswan in southern Egypt"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:13","parts":[{"kind":"text","text":"Shout for joy, you heavens! "},{"kind":"crossref","label":"Is 44:23","book":"Isa","chapter":44,"verse":23,"letter":"a"},{"kind":"text","text":" Earth, rejoice!"},{"kind":"text","text":" Mountains break into joyful shouts!"},{"kind":"text","text":" For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has comforted his people, "},{"kind":"crossref","label":"Is 40:1","book":"Isa","chapter":40,"verse":1,"letter":"a"},{"kind":"text","text":" and will have compassion on his afflicted ones. "},{"kind":"crossref","label":"Is 54:7–10","book":"Isa","chapter":54,"verse":7,"letter":"a"},{"kind":"crossref","label":"Mt 11:29","book":"Mat","chapter":11,"verse":29,"letter":"b"}],"crossRefs":[{"label":"Is 44:23","book":"Isa","chapter":44,"verse":23},{"label":"Is 40:1","book":"Isa","chapter":40,"verse":1},{"label":"Is 54:7–10","book":"Isa","chapter":54,"verse":7},{"label":"Mt 11:29","book":"Mat","chapter":11,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:14","parts":[{"kind":"text","text":"Zion says, “The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has abandoned me;"},{"kind":"text","text":" the Lord has forgotten me!”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:15","parts":[{"kind":"text","text":"“Can a woman forget her nursing child,"},{"kind":"text","text":" or lack compassion for the child of her womb?"},{"kind":"text","text":" Even if these forget,"},{"kind":"text","text":" yet I will not forget you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:16","parts":[{"kind":"text","text":"Look, I have inscribed you on the palms of my hands; "},{"kind":"crossref","label":"Sg 8:6","book":"Sng","chapter":8,"verse":6,"letter":"a"},{"kind":"crossref","label":"Hg 2:23","book":"Hag","chapter":2,"verse":23,"letter":"b"},{"kind":"text","text":" your walls are continually before me."}],"crossRefs":[{"label":"Sg 8:6","book":"Sng","chapter":8,"verse":6},{"label":"Hg 2:23","book":"Hag","chapter":2,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:17","parts":[{"kind":"text","text":"Your builders "},{"kind":"footnote","marker":1,"text":"DSS, Aq, Theod, Vg; MT, Syr, Sym read sons"},{"kind":"text","text":" hurry;"},{"kind":"text","text":" those who destroy and devastate you will leave you."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"DSS, Aq, Theod, Vg; MT, Syr, Sym read sons"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:18","parts":[{"kind":"text","text":"Look up, and look around."},{"kind":"text","text":" They all gather together; they come to you. "},{"kind":"crossref","label":"Is 60:4","book":"Isa","chapter":60,"verse":4,"letter":"a"},{"kind":"text","text":" As I live” —"},{"kind":"text","text":" “you will wear all your children "},{"kind":"footnote","marker":1,"text":"Lit all of them"},{"kind":"text","text":" as jewelry,"},{"kind":"text","text":" and put them on as a bride does."}],"crossRefs":[{"label":"Is 60:4","book":"Isa","chapter":60,"verse":4}],"footnotes":[{"marker":1,"text":"Lit all of them"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:19","parts":[{"kind":"text","text":"For your waste and desolate places"},{"kind":"text","text":" and your land marked by ruins"},{"kind":"text","text":" will now be indeed too small for the inhabitants, "},{"kind":"crossref","label":"Is 54:1–2","book":"Isa","chapter":54,"verse":1,"letter":"a"},{"kind":"crossref","label":"Zch 10:10","book":"Zec","chapter":10,"verse":10,"letter":"b"},{"kind":"text","text":" and those who swallowed you up will be far away."}],"crossRefs":[{"label":"Is 54:1–2","book":"Isa","chapter":54,"verse":1},{"label":"Zch 10:10","book":"Zec","chapter":10,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:20","parts":[{"kind":"text","text":"Yet as you listen, the children"},{"kind":"text","text":" that you have been deprived of will say,"},{"kind":"text","text":" ‘This place is too small for me;"},{"kind":"text","text":" make room for me so that I may settle.’ "},{"kind":"crossref","label":"Is 54:1–3","book":"Isa","chapter":54,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Is 54:1–3","book":"Isa","chapter":54,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:21","parts":[{"kind":"text","text":"Then you will say within yourself,"},{"kind":"text","text":" ‘Who fathered these for me?"},{"kind":"text","text":" I was deprived of my children and unable to conceive,"},{"kind":"text","text":" exiled and wandering —"},{"kind":"text","text":" but who brought them up?"},{"kind":"text","text":" See, I was left by myself —"},{"kind":"text","text":" but these, where did they come from?’” "},{"kind":"footnote","marker":1,"text":"Lit where are they"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit where are they"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:22","parts":[{"kind":"text","text":"This is what the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" Look, I will lift up my hand to the nations,"},{"kind":"text","text":" and raise my banner to the peoples. "},{"kind":"crossref","label":"Is 11:10–12","book":"Isa","chapter":11,"verse":10,"letter":"a"},{"kind":"crossref","label":"Is 18:3","book":"Isa","chapter":18,"verse":3,"letter":"b"},{"kind":"crossref","label":"Is 62:10","book":"Isa","chapter":62,"verse":10,"letter":"c"},{"kind":"text","text":" They will bring your sons in their arms,"},{"kind":"text","text":" and your daughters will be carried on their shoulders. "},{"kind":"crossref","label":"Is 14:2","book":"Isa","chapter":14,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 43:6","book":"Isa","chapter":43,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 60:4","book":"Isa","chapter":60,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Is 11:10–12","book":"Isa","chapter":11,"verse":10},{"label":"Is 18:3","book":"Isa","chapter":18,"verse":3},{"label":"Is 62:10","book":"Isa","chapter":62,"verse":10},{"label":"Is 14:2","book":"Isa","chapter":14,"verse":2},{"label":"Is 43:6","book":"Isa","chapter":43,"verse":6},{"label":"Is 60:4","book":"Isa","chapter":60,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:23","parts":[{"kind":"text","text":"Kings will be your guardians"},{"kind":"text","text":" and their queens "},{"kind":"footnote","marker":1,"text":"Lit princesses"},{"kind":"text","text":" your nursing mothers. "},{"kind":"crossref","label":"Is 60:3","book":"Isa","chapter":60,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 60:10","book":"Isa","chapter":60,"verse":10,"letter":"b"},{"kind":"text","text":" They will bow down to you"},{"kind":"text","text":" with their faces to the ground"},{"kind":"text","text":" and lick the dust at your feet. "},{"kind":"crossref","label":"Is 14:1–2","book":"Isa","chapter":14,"verse":1,"letter":"a"},{"kind":"text","text":" Then you will know that I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"; "},{"kind":"crossref","label":"Is 41:20","book":"Isa","chapter":41,"verse":20,"letter":"a"},{"kind":"crossref","label":"Is 43:10","book":"Isa","chapter":43,"verse":10,"letter":"b"},{"kind":"crossref","label":"Is 60:16","book":"Isa","chapter":60,"verse":16,"letter":"c"},{"kind":"text","text":" those who put their hope in me"},{"kind":"text","text":" will not be put to shame. "},{"kind":"crossref","label":"Ps 25:3","book":"Psa","chapter":25,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 45:17","book":"Isa","chapter":45,"verse":17,"letter":"b"},{"kind":"crossref","label":"Jl 2:27","book":"Jol","chapter":2,"verse":27,"letter":"c"}],"crossRefs":[{"label":"Is 60:3","book":"Isa","chapter":60,"verse":3},{"label":"Is 60:10","book":"Isa","chapter":60,"verse":10},{"label":"Is 14:1–2","book":"Isa","chapter":14,"verse":1},{"label":"Is 41:20","book":"Isa","chapter":41,"verse":20},{"label":"Is 43:10","book":"Isa","chapter":43,"verse":10},{"label":"Is 60:16","book":"Isa","chapter":60,"verse":16},{"label":"Ps 25:3","book":"Psa","chapter":25,"verse":3},{"label":"Is 45:17","book":"Isa","chapter":45,"verse":17},{"label":"Jl 2:27","book":"Jol","chapter":2,"verse":27}],"footnotes":[{"marker":1,"text":"Lit princesses"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:24","parts":[{"kind":"text","text":"Can the prey be taken from a mighty man,"},{"kind":"text","text":" or the captives of a tyrant "},{"kind":"footnote","marker":1,"text":"DSS, Syr, Vg; MT reads a righteous man"},{"kind":"text","text":" be delivered?"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"DSS, Syr, Vg; MT reads a righteous man"}]},{"verseId":"a556c5305ee15c3f-01:Isa:49:25","parts":[{"kind":"text","text":"For this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" “Even the captives of a mighty man will be taken,"},{"kind":"text","text":" and the prey of a tyrant will be delivered;"},{"kind":"text","text":" I will contend with the one who contends with you,"},{"kind":"text","text":" and I will save your children."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:49:26","parts":[{"kind":"text","text":"I will make your oppressors eat their own flesh, "},{"kind":"crossref","label":"Is 9:20","book":"Isa","chapter":9,"verse":20,"letter":"a"},{"kind":"text","text":" and they will be drunk with their own blood"},{"kind":"text","text":" as with sweet wine."},{"kind":"text","text":" Then all humanity will know"},{"kind":"text","text":" that I, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", am your Savior, "},{"kind":"crossref","label":"Is 43:3","book":"Isa","chapter":43,"verse":3,"letter":"a"},{"kind":"text","text":" and your Redeemer, "},{"kind":"crossref","label":"Is 41:14","book":"Isa","chapter":41,"verse":14,"letter":"a"},{"kind":"text","text":" the Mighty One of Jacob.” "},{"kind":"crossref","label":"Gn 49:24","book":"Gen","chapter":49,"verse":24,"letter":"b"},{"kind":"crossref","label":"Ps 132:2","book":"Psa","chapter":132,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ps 132:5","book":"Psa","chapter":132,"verse":5,"letter":"d"},{"kind":"crossref","label":"Is 60:16","book":"Isa","chapter":60,"verse":16,"letter":"e"}],"crossRefs":[{"label":"Is 9:20","book":"Isa","chapter":9,"verse":20},{"label":"Is 43:3","book":"Isa","chapter":43,"verse":3},{"label":"Is 41:14","book":"Isa","chapter":41,"verse":14},{"label":"Gn 49:24","book":"Gen","chapter":49,"verse":24},{"label":"Ps 132:2","book":"Psa","chapter":132,"verse":2},{"label":"Ps 132:5","book":"Psa","chapter":132,"verse":5},{"label":"Is 60:16","book":"Isa","chapter":60,"verse":16}],"footnotes":[]}]},"cachedAt":1783279551732}