},{"kind":"text","text":" of your "},{"kind":"footnote","marker":1,"text":"LXX, Syr read for their iniquities and the iniquities of their"},{"kind":"text","text":" ancestors together,”"},{"kind":"text","text":" says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."},{"kind":"text","text":" “Because they burned incense on the mountains"},{"kind":"text","text":" and reproached me on the hills, "},{"kind":"crossref","label":"Ezk 20:27–28","book":"Ezk","chapter":20,"verse":27,"letter":"a"},{"kind":"crossref","label":"Hs 9:10","book":"Hos","chapter":9,"verse":10,"letter":"b"},{"kind":"crossref","label":"Zch 8:14","book":"Zec","chapter":8,"verse":14,"letter":"c"},{"kind":"crossref","label":"Mal 3:7","book":"Mal","chapter":3,"verse":7,"letter":"d"},{"kind":"text","text":" I will reward them fully "},{"kind":"footnote","marker":1,"text":"Lit reward into their lap"},{"kind":"text","text":" for their former deeds.”"}],"crossRefs":[{"label":"Is 13:11","book":"Isa","chapter":13,"verse":11},{"label":"Ezk 20:27–28","book":"Ezk","chapter":20,"verse":27},{"label":"Hs 9:10","book":"Hos","chapter":9,"verse":10},{"label":"Zch 8:14","book":"Zec","chapter":8,"verse":14},{"label":"Mal 3:7","book":"Mal","chapter":3,"verse":7}],"footnotes":[{"marker":1,"text":"LXX, Syr read for their iniquities and the iniquities of their"},{"marker":1,"text":"Lit reward into their lap"}]},{"verseId":"a556c5305ee15c3f-01:Isa:65:8","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says this:"},{"kind":"text","text":" “As the new wine is found in a bunch of grapes,"},{"kind":"text","text":" and one says, ‘Don’t destroy it,"},{"kind":"text","text":" for there’s some good "},{"kind":"footnote","marker":1,"text":"Or there’s a blessing"},{"kind":"text","text":" in it,’"},{"kind":"text","text":" so I will act because of my servants"},{"kind":"text","text":" and not destroy them all."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or there’s a blessing"}]},{"verseId":"a556c5305ee15c3f-01:Isa:65:9","parts":[{"kind":"text","text":"I will produce descendants from Jacob, "},{"kind":"crossref","label":"Jr 31:36–37","book":"Jer","chapter":31,"verse":36,"letter":"a"},{"kind":"text","text":" and heirs to my mountains from Judah;"},{"kind":"text","text":" my chosen "},{"kind":"crossref","label":"Is 41:8","book":"Isa","chapter":41,"verse":8,"letter":"a"},{"kind":"text","text":" ones will possess it,"},{"kind":"text","text":" and my servants will dwell there. "},{"kind":"crossref","label":"Is 49:8","book":"Isa","chapter":49,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 60:21","book":"Isa","chapter":60,"verse":21,"letter":"b"},{"kind":"crossref","label":"Am 9:11–15","book":"Amo","chapter":9,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Jr 31:36–37","book":"Jer","chapter":31,"verse":36},{"label":"Is 41:8","book":"Isa","chapter":41,"verse":8},{"label":"Is 49:8","book":"Isa","chapter":49,"verse":8},{"label":"Is 60:21","book":"Isa","chapter":60,"verse":21},{"label":"Am 9:11–15","book":"Amo","chapter":9,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:10","parts":[{"kind":"text","text":"Sharon will be a pasture for flocks, "},{"kind":"crossref","label":"Is 33:9","book":"Isa","chapter":33,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 35:2","book":"Isa","chapter":35,"verse":2,"letter":"b"},{"kind":"text","text":" and the Valley of Achor a place for herds to lie down, "},{"kind":"crossref","label":"Jos 7:26","book":"Jos","chapter":7,"verse":26,"letter":"a"},{"kind":"crossref","label":"Hs 2:15","book":"Hos","chapter":2,"verse":15,"letter":"b"},{"kind":"text","text":" for my people who have sought me. "},{"kind":"crossref","label":"Is 51:1","book":"Isa","chapter":51,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Is 33:9","book":"Isa","chapter":33,"verse":9},{"label":"Is 35:2","book":"Isa","chapter":35,"verse":2},{"label":"Jos 7:26","book":"Jos","chapter":7,"verse":26},{"label":"Hs 2:15","book":"Hos","chapter":2,"verse":15},{"label":"Is 51:1","book":"Isa","chapter":51,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:11","parts":[{"kind":"text","text":"But you who abandon the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" who forget my holy mountain,"},{"kind":"text","text":" who prepare a table for Fortune"},{"kind":"text","text":" and fill bowls of mixed wine for Destiny, "},{"kind":"footnote","marker":1,"text":"Pagan gods"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Pagan gods"}]},{"verseId":"a556c5305ee15c3f-01:Isa:65:12","parts":[{"kind":"text","text":"I will destine you for the sword,"},{"kind":"text","text":" and all of you will kneel down to be slaughtered,"},{"kind":"text","text":" because I called and you did not answer,"},{"kind":"text","text":" I spoke and you did not hear;"},{"kind":"text","text":" you did what was evil in my sight"},{"kind":"text","text":" and chose what I did not delight in.” "},{"kind":"crossref","label":"2Ch 36:15–16","book":"2Ch","chapter":36,"verse":15,"letter":"a"},{"kind":"crossref","label":"Pr 1:24","book":"Pro","chapter":1,"verse":24,"letter":"b"},{"kind":"crossref","label":"Is 41:28","book":"Isa","chapter":41,"verse":28,"letter":"c"},{"kind":"crossref","label":"Is 50:2","book":"Isa","chapter":50,"verse":2,"letter":"d"},{"kind":"crossref","label":"Is 66:4","book":"Isa","chapter":66,"verse":4,"letter":"e"},{"kind":"crossref","label":"Jr 7:13","book":"Jer","chapter":7,"verse":13,"letter":"f"}],"crossRefs":[{"label":"2Ch 36:15–16","book":"2Ch","chapter":36,"verse":15},{"label":"Pr 1:24","book":"Pro","chapter":1,"verse":24},{"label":"Is 41:28","book":"Isa","chapter":41,"verse":28},{"label":"Is 50:2","book":"Isa","chapter":50,"verse":2},{"label":"Is 66:4","book":"Isa","chapter":66,"verse":4},{"label":"Jr 7:13","book":"Jer","chapter":7,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:13","parts":[{"kind":"text","text":"Therefore, this is what the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" “Look! My servants will eat,"},{"kind":"text","text":" but you will be hungry."},{"kind":"text","text":" Look! My servants will drink,"},{"kind":"text","text":" but you will be thirsty."},{"kind":"text","text":" Look! My servants will rejoice,"},{"kind":"text","text":" but you will be put to shame."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:14","parts":[{"kind":"text","text":"Look! My servants will shout for joy from a glad heart,"},{"kind":"text","text":" but you will cry out from an anguished heart,"},{"kind":"text","text":" and you will lament out of a broken spirit."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:15","parts":[{"kind":"text","text":"You will leave your name behind"},{"kind":"text","text":" as a curse for my chosen ones, "},{"kind":"crossref","label":"Jr 24:9","book":"Jer","chapter":24,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jr 25:18","book":"Jer","chapter":25,"verse":18,"letter":"b"},{"kind":"crossref","label":"Zch 8:13","book":"Zec","chapter":8,"verse":13,"letter":"c"},{"kind":"text","text":" and the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" will kill you;"},{"kind":"text","text":" but he will give his servants another name. "},{"kind":"crossref","label":"Is 62:2","book":"Isa","chapter":62,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Jr 24:9","book":"Jer","chapter":24,"verse":9},{"label":"Jr 25:18","book":"Jer","chapter":25,"verse":18},{"label":"Zch 8:13","book":"Zec","chapter":8,"verse":13},{"label":"Is 62:2","book":"Isa","chapter":62,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:16","parts":[{"kind":"text","text":"Whoever asks for a blessing in the land"},{"kind":"text","text":" will ask for a blessing by the God of truth, "},{"kind":"crossref","label":"Ps 31:5","book":"Psa","chapter":31,"verse":5,"letter":"a"},{"kind":"crossref","label":"2Co 1:20","book":"2Co","chapter":1,"verse":20,"letter":"b"},{"kind":"crossref","label":"Rv 3:7","book":"Rev","chapter":3,"verse":7,"letter":"c"},{"kind":"crossref","label":"Rv 3:14","book":"Rev","chapter":3,"verse":14,"letter":"d"},{"kind":"text","text":" and whoever swears in the land"},{"kind":"text","text":" will swear by the God of truth."},{"kind":"text","text":" For the former troubles will be forgotten"},{"kind":"text","text":" and hidden from my sight."}],"crossRefs":[{"label":"Ps 31:5","book":"Psa","chapter":31,"verse":5},{"label":"2Co 1:20","book":"2Co","chapter":1,"verse":20},{"label":"Rv 3:7","book":"Rev","chapter":3,"verse":7},{"label":"Rv 3:14","book":"Rev","chapter":3,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:17","parts":[{"kind":"text","text":"“For I will create new heavens and a new earth; "},{"kind":"crossref","label":"Is 66:22","book":"Isa","chapter":66,"verse":22,"letter":"a"},{"kind":"crossref","label":"2Pt 3:13","book":"2Pe","chapter":3,"verse":13,"letter":"b"},{"kind":"crossref","label":"Rv 21:1","book":"Rev","chapter":21,"verse":1,"letter":"c"},{"kind":"text","text":" the past events will not be remembered or come to mind."}],"crossRefs":[{"label":"Is 66:22","book":"Isa","chapter":66,"verse":22},{"label":"2Pt 3:13","book":"2Pe","chapter":3,"verse":13},{"label":"Rv 21:1","book":"Rev","chapter":21,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:18","parts":[{"kind":"text","text":"Then be glad and rejoice forever"},{"kind":"text","text":" in what I am creating;"},{"kind":"text","text":" for I will create Jerusalem to be a joy"},{"kind":"text","text":" and its people to be a delight."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:19","parts":[{"kind":"text","text":"I will rejoice in Jerusalem"},{"kind":"text","text":" and be glad in my people."},{"kind":"text","text":" The sound of weeping and crying"},{"kind":"text","text":" will no longer be heard in her. "},{"kind":"crossref","label":"Is 25:8","book":"Isa","chapter":25,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 30:19","book":"Isa","chapter":30,"verse":19,"letter":"b"},{"kind":"crossref","label":"Is 35:10","book":"Isa","chapter":35,"verse":10,"letter":"c"},{"kind":"crossref","label":"Is 51:11","book":"Isa","chapter":51,"verse":11,"letter":"d"},{"kind":"crossref","label":"Rv 7:17","book":"Rev","chapter":7,"verse":17,"letter":"e"},{"kind":"crossref","label":"Rv 21:4","book":"Rev","chapter":21,"verse":4,"letter":"f"}],"crossRefs":[{"label":"Is 25:8","book":"Isa","chapter":25,"verse":8},{"label":"Is 30:19","book":"Isa","chapter":30,"verse":19},{"label":"Is 35:10","book":"Isa","chapter":35,"verse":10},{"label":"Is 51:11","book":"Isa","chapter":51,"verse":11},{"label":"Rv 7:17","book":"Rev","chapter":7,"verse":17},{"label":"Rv 21:4","book":"Rev","chapter":21,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:20","parts":[{"kind":"text","text":"In her, a nursing infant will no longer live"},{"kind":"text","text":" only a few days, "},{"kind":"footnote","marker":1,"text":"Lit her, no longer infant of days"},{"kind":"text","text":" or an old man not live out his days."},{"kind":"text","text":" Indeed, the one who dies at a hundred years old"},{"kind":"text","text":" will be mourned as a young man, "},{"kind":"footnote","marker":1,"text":"Lit the youth of a hundred years will die"},{"kind":"text","text":" and the one who misses a hundred years"},{"kind":"text","text":" will be considered cursed. "},{"kind":"crossref","label":"Ec 8:12–13","book":"Ecc","chapter":8,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 3:11","book":"Isa","chapter":3,"verse":11,"letter":"b"},{"kind":"crossref","label":"Is 22:14","book":"Isa","chapter":22,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Ec 8:12–13","book":"Ecc","chapter":8,"verse":12},{"label":"Is 3:11","book":"Isa","chapter":3,"verse":11},{"label":"Is 22:14","book":"Isa","chapter":22,"verse":14}],"footnotes":[{"marker":1,"text":"Lit her, no longer infant of days"},{"marker":1,"text":"Lit the youth of a hundred years will die"}]},{"verseId":"a556c5305ee15c3f-01:Isa:65:21","parts":[{"kind":"text","text":"People will build houses and live in them;"},{"kind":"text","text":" they will plant vineyards and eat their fruit. "},{"kind":"crossref","label":"Jos 24:13","book":"Jos","chapter":24,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 37:30","book":"Isa","chapter":37,"verse":30,"letter":"b"},{"kind":"crossref","label":"Jr 29:5","book":"Jer","chapter":29,"verse":5,"letter":"c"},{"kind":"crossref","label":"Jr 29:28","book":"Jer","chapter":29,"verse":28,"letter":"d"},{"kind":"crossref","label":"Ezk 28:26","book":"Ezk","chapter":28,"verse":26,"letter":"e"},{"kind":"crossref","label":"Zp 1:13","book":"Zep","chapter":1,"verse":13,"letter":"f"}],"crossRefs":[{"label":"Jos 24:13","book":"Jos","chapter":24,"verse":13},{"label":"Is 37:30","book":"Isa","chapter":37,"verse":30},{"label":"Jr 29:5","book":"Jer","chapter":29,"verse":5},{"label":"Jr 29:28","book":"Jer","chapter":29,"verse":28},{"label":"Ezk 28:26","book":"Ezk","chapter":28,"verse":26},{"label":"Zp 1:13","book":"Zep","chapter":1,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:22","parts":[{"kind":"text","text":"They will not build and others live in them;"},{"kind":"text","text":" they will not plant and others eat."},{"kind":"text","text":" For my people’s lives will be"},{"kind":"text","text":" like the lifetime of a tree. "},{"kind":"crossref","label":"Ps 92:12–14","book":"Psa","chapter":92,"verse":12,"letter":"a"},{"kind":"text","text":" My chosen ones will fully enjoy"},{"kind":"text","text":" the work of their hands."}],"crossRefs":[{"label":"Ps 92:12–14","book":"Psa","chapter":92,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:23","parts":[{"kind":"text","text":"They will not labor without success "},{"kind":"crossref","label":"Dt 28:3","book":"Deu","chapter":28,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 55:2","book":"Isa","chapter":55,"verse":2,"letter":"b"},{"kind":"text","text":" or bear children destined for disaster,"},{"kind":"text","text":" for they will be a people blessed by the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" along with their descendants. "},{"kind":"crossref","label":"Is 61:9","book":"Isa","chapter":61,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Dt 28:3","book":"Deu","chapter":28,"verse":3},{"label":"Is 55:2","book":"Isa","chapter":55,"verse":2},{"label":"Is 61:9","book":"Isa","chapter":61,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:24","parts":[{"kind":"text","text":"Even before they call, I will answer; "},{"kind":"crossref","label":"Ps 91:15","book":"Psa","chapter":91,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 55:6","book":"Isa","chapter":55,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 58:9","book":"Isa","chapter":58,"verse":9,"letter":"c"},{"kind":"crossref","label":"Dn 9:20","book":"Dan","chapter":9,"verse":20,"letter":"d"},{"kind":"crossref","label":"Dn 10:12","book":"Dan","chapter":10,"verse":12,"letter":"e"},{"kind":"text","text":" while they are still speaking, I will hear."}],"crossRefs":[{"label":"Ps 91:15","book":"Psa","chapter":91,"verse":15},{"label":"Is 55:6","book":"Isa","chapter":55,"verse":6},{"label":"Is 58:9","book":"Isa","chapter":58,"verse":9},{"label":"Dn 9:20","book":"Dan","chapter":9,"verse":20},{"label":"Dn 10:12","book":"Dan","chapter":10,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:65:25","parts":[{"kind":"text","text":"The wolf and the lamb will feed together, "},{"kind":"footnote","marker":1,"text":"Lit as one"},{"kind":"text","text":" and the lion will eat straw like cattle, "},{"kind":"crossref","label":"Is 11:6–9","book":"Isa","chapter":11,"verse":6,"letter":"a"},{"kind":"text","text":" but the serpent’s food will be dust! "},{"kind":"crossref","label":"Gn 3:14","book":"Gen","chapter":3,"verse":14,"letter":"a"},{"kind":"crossref","label":"Mc 7:17","book":"Mic","chapter":7,"verse":17,"letter":"b"},{"kind":"text","text":" They will not do what is evil or destroy"},{"kind":"text","text":" on my entire holy mountain,” "},{"kind":"crossref","label":"Is 11:9","book":"Isa","chapter":11,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 27:13","book":"Isa","chapter":27,"verse":13,"letter":"b"},{"kind":"crossref","label":"Is 56:7","book":"Isa","chapter":56,"verse":7,"letter":"c"},{"kind":"text","text":" says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Is 11:6–9","book":"Isa","chapter":11,"verse":6},{"label":"Gn 3:14","book":"Gen","chapter":3,"verse":14},{"label":"Mc 7:17","book":"Mic","chapter":7,"verse":17},{"label":"Is 11:9","book":"Isa","chapter":11,"verse":9},{"label":"Is 27:13","book":"Isa","chapter":27,"verse":13},{"label":"Is 56:7","book":"Isa","chapter":56,"verse":7}],"footnotes":[{"marker":1,"text":"Lit as one"}]}]},"cachedAt":1783279556633}