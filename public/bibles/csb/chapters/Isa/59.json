t","text":"Lord","style":"divine"},{"kind":"text","text":": “My Spirit who is on you, and my words that I have put in your mouth, "},{"kind":"crossref","label":"Is 51:16","book":"Isa","chapter":51,"verse":16,"letter":"b"},{"kind":"text","text":" will not depart from your mouth, or from the mouths of your children, or from the mouths of your children’s children, from now on and forever,” says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Jr 31:31–34","book":"Jer","chapter":31,"verse":31},{"label":"Is 51:16","book":"Isa","chapter":51,"verse":16}],"footnotes":[]}]},"cachedAt":1783279554770}