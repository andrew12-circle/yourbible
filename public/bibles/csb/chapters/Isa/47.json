verse":8,"letter":"b"},{"kind":"crossref","label":"Ezk 16:37","book":"Ezk","chapter":16,"verse":37,"letter":"c"},{"kind":"crossref","label":"Nah 3:5","book":"Nam","chapter":3,"verse":5,"letter":"d"},{"kind":"text","text":" I will take vengeance;"},{"kind":"text","text":" I will spare no one.” "},{"kind":"footnote","marker":1,"text":"Hb obscure"}],"crossRefs":[{"label":"Jr 13:26","book":"Jer","chapter":13,"verse":26},{"label":"Lm 1:8","book":"Lam","chapter":1,"verse":8},{"label":"Ezk 16:37","book":"Ezk","chapter":16,"verse":37},{"label":"Nah 3:5","book":"Nam","chapter":3,"verse":5}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Isa:47:4","parts":[{"kind":"text","text":"The Holy One of Israel is our Redeemer; "},{"kind":"crossref","label":"Is 41:14","book":"Isa","chapter":41,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 43:14","book":"Isa","chapter":43,"verse":14,"letter":"b"},{"kind":"text","text":" The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies is his name."}],"crossRefs":[{"label":"Is 41:14","book":"Isa","chapter":41,"verse":14},{"label":"Is 43:14","book":"Isa","chapter":43,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:5","parts":[{"kind":"text","text":"“Daughter Chaldea,"},{"kind":"text","text":" sit in silence "},{"kind":"crossref","label":"Is 23:2","book":"Isa","chapter":23,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 8:14","book":"Jer","chapter":8,"verse":14,"letter":"b"},{"kind":"crossref","label":"Lm 2:10","book":"Lam","chapter":2,"verse":10,"letter":"c"},{"kind":"crossref","label":"Lm 3:2","book":"Lam","chapter":3,"verse":2,"letter":"d"},{"kind":"crossref","label":"Lm 3:28","book":"Lam","chapter":3,"verse":28,"letter":"e"},{"kind":"text","text":" and go into darkness."},{"kind":"text","text":" For you will no longer be called mistress of kingdoms."}],"crossRefs":[{"label":"Is 23:2","book":"Isa","chapter":23,"verse":2},{"label":"Jr 8:14","book"