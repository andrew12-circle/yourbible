el":"Nah 3:4","book":"Nam","chapter":3,"verse":4,"letter":"b"},{"kind":"crossref","label":"Rv 18:23","book":"Rev","chapter":18,"verse":23,"letter":"c"},{"kind":"text","text":" and the potency of your spells."}],"crossRefs":[{"label":"Is 47:13","book":"Isa","chapter":47,"verse":13},{"label":"Nah 3:4","book":"Nam","chapter":3,"verse":4},{"label":"Rv 18:23","book":"Rev","chapter":18,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:10","parts":[{"kind":"text","text":"You were secure in your wickedness;"},{"kind":"text","text":" you said, ‘No one sees me.’ "},{"kind":"crossref","label":"Ps 139:3","book":"Psa","chapter":139,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 139:11","book":"Psa","chapter":139,"verse":11,"letter":"b"},{"kind":"text","text":" Your wisdom and knowledge"},{"kind":"text","text":" led you astray."},{"kind":"text","text":" You said to yourself,"},{"kind":"text","text":" ‘I am, and there is no one else.’"}],"crossRefs":[{"label":"Ps 139:3","book":"Psa","chapter":139,"verse":3},{"label":"Ps 139:11","book":"Psa","chapter":139,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:11","parts":[{"kind":"text","text":"But disaster will happen to you;"},{"kind":"text","text":" you will not know how to avert it."},{"kind":"text","text":" And it will fall on you,"},{"kind":"text","text":" but you will be unable to ward it off. "},{"kind":"footnote","marker":1,"text":"Or to atone for it"},{"kind":"text","text":" Devastation will happen to you suddenly"},{"kind":"text","text":" and unexpectedly. "},{"kind":"crossref","label":"Is 13:6","book":"Isa","chapter":13,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 51:8","book":"Jer","chapter":51,"verse":8,"letter":"b"},{"kind":"crossref","label":"Jr 51:43","book":"Jer","chapter":51,"verse":43,"letter":"c"},{"kind":"crossref","label":"Lk 17:27","book":"Luk","chapter":17,"verse":27,"letter":"d"},{"kind":"crossref","label":"1Th 5:3","book":"1Th","chapter":5,"verse":3,"letter":"e"}],"crossRefs":[{"label":"Is 13:6","book":"Isa","chapter":13,"verse":6},{"label":"Jr 51:8","book":"Jer","chapter":51,"verse":8},{"label":"Jr 51:43","book":"Jer","chapter":51,"verse":43},{"label":"Lk 17:27","book":"Luk","chapter":17,"verse":27},{"label":"1Th 5:3","book":"1Th","chapter":5,"verse":3}],"footnotes":[{"marker":1,"text":"Or to atone for it"}]},{"verseId":"a556c5305ee15c3f-01:Isa:47:12","parts":[{"kind":"text","text":"So take your stand with your spells"},{"kind":"text","text":" and your many sorceries,"},{"kind":"text","text":" which you have wearied yourself with from your youth."},{"kind":"text","text":" Perhaps you will be able to succeed;"},{"kind":"text","text":" perhaps you will inspire terror!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:13","parts":[{"kind":"text","text":"You are worn out with your many consultations."},{"kind":"text","text":" So let the astrologers stand and save you —"},{"kind":"text","text":" those who observe the stars, "},{"kind":"crossref","label":"Is 8:19","book":"Isa","chapter":8,"verse":19,"letter":"a"},{"kind":"crossref","label":"Is 44:25","book":"Isa","chapter":44,"verse":25,"letter":"b"},{"kind":"crossref","label":"Is 47:9","book":"Isa","chapter":47,"verse":9,"letter":"c"},{"kind":"crossref","label":"Dn 2:2","book":"Dan","chapter":2,"verse":2,"letter":"d"},{"kind":"crossref","label":"Dn 2:10","book":"Dan","chapter":2,"verse":10,"letter":"e"},{"kind":"text","text":" those who predict monthly"},{"kind":"text","text":" what will happen to you."}],"crossRefs":[{"label":"Is 8:19","book":"Isa","chapter":8,"verse":19},{"label":"Is 44:25","book":"Isa","chapter":44,"verse":25},{"label":"Is 47:9","book":"Isa","chapter":47,"verse":9},{"label":"Dn 2:2","book":"Dan","chapter":2,"verse":2},{"label":"Dn 2:10","book":"Dan","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:14","parts":[{"kind":"text","text":"Look, they are like stubble; "},{"kind":"crossref","label":"Is 5:24","book":"Isa","chapter":5,"verse":24,"letter":"a"},{"kind":"crossref","label":"Nah 1:10","book":"Nam","chapter":1,"verse":10,"letter":"b"},{"kind":"crossref","label":"Mal 4:1","book":"Mal","chapter":4,"verse":1,"letter":"c"},{"kind":"text","text":" fire burns them. "},{"kind":"crossref","label":"Is 10:17","book":"Isa","chapter":10,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jr 51:30–32","book":"Jer","chapter":51,"verse":30,"letter":"b"},{"kind":"crossref","label":"Jr 51:58","book":"Jer","chapter":51,"verse":58,"letter":"c"},{"kind":"text","text":" They cannot rescue themselves"},{"kind":"text","text":" from the power of the flame."},{"kind":"text","text":" This is not a coal for warming themselves,"},{"kind":"text","text":" or a fire to sit beside!"}],"crossRefs":[{"label":"Is 5:24","book":"Isa","chapter":5,"verse":24},{"label":"Nah 1:10","book":"Nam","chapter":1,"verse":10},{"label":"Mal 4:1","book":"Mal","chapter":4,"verse":1},{"label":"Is 10:17","book":"Isa","chapter":10,"verse":17},{"label":"Jr 51:30–32","book":"Jer","chapter":51,"verse":30},{"label":"Jr 51:58","book":"Jer","chapter":51,"verse":58}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:47:15","parts":[{"kind":"text","text":"This is what they are to you —"},{"kind":"text","text":" those who have wearied you"},{"kind":"text","text":" and have traded with you from your youth —"},{"kind":"text","text":" each wanders on his own way;"},{"kind":"text","text":" no one can save you."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279551092}