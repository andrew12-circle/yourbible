":2,"verse":17,"letter":"e"},{"kind":"text","text":" his name is the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies."}],"crossRefs":[{"label":"Is 10:20","book":"Isa","chapter":10,"verse":20},{"label":"Jr 7:4","book":"Jer","chapter":7,"verse":4},{"label":"Jr 21:2","book":"Jer","chapter":21,"verse":2},{"label":"Mc 3:11","book":"Mic","chapter":3,"verse":11},{"label":"Rm 2:17","book":"Rom","chapter":2,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:48:3","parts":[{"kind":"text","text":"I declared the past events long ago;"},{"kind":"text","text":" they came out of my mouth; I proclaimed them."},{"kind":"text","text":" Suddenly I acted, and they occurred."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:48:4","parts":[{"kind":"text","text":"Because I know that you are stubborn,"},{"kind":"text","text":" and your neck is iron "},{"kind":"footnote","marker":1,"text":"Lit is an iron sinew"},{"kind":"text","text":" and your forehead bronze, "},{"kind":"crossref","label":"Ex 32:9","book":"Exo","chapter":32,"verse":9,"letter":"a"},{"kind":"crossref","label":"Dt 31:27","book":"Deu","chapter":31,"verse":27,"letter":"b"},{"kind":"crossref","label":"Ezk 2:4","book":"Ezk","chapter":2,"verse":4,"letter":"c"},{"kind":"crossref","label":"Ezk 3:7–9","book":"Ezk","chapter":3,"verse":7,"letter":"d"}],"crossRefs":[{"label":"Ex 32:9","book":"Exo","chapter":32,"verse":9},{"label":"Dt 31:27","book":"Deu","chapter":31,"verse":27},{"label":"Ezk 2:4","book":"Ezk","chapter":2,"verse":4},{"label":"Ezk 3:7–9","book":"Ezk","chapter":3,"verse":7}],"footnotes":[{"marker":1,"text":"Lit is an iron sinew"}]},{"verseId":"a556c5305ee15c3f-01:Isa:48:5","parts":[{"kind":"text","text":"therefore I declared to you long ago."},{"kind":"text","text":" I announced it to you before it occurred,"},{"kind":"text","text":" so you could not claim, ‘My idol caused them;"},{"kind":"text","text":" my carved image and cast idol control them.’ "},{