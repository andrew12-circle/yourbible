},{"label":"Is 45:12","book":"Isa","chapter":45,"verse":12},{"label":"Is 45:18","book":"Isa","chapter":45,"verse":18},{"label":"Heb 1:10–12","book":"Heb","chapter":1,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:48:14","parts":[{"kind":"text","text":"All of you, assemble and listen!"},{"kind":"text","text":" Who among the idols "},{"kind":"footnote","marker":1,"text":"Lit among them"},{"kind":"text","text":" has declared these things?"},{"kind":"text","text":" The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" loves him; "},{"kind":"footnote","marker":1,"text":"= Cyrus"},{"kind":"text","text":" he will accomplish his will against Babylon, "},{"kind":"crossref","label":"Is 13:4–5","book":"Isa","chapter":13,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 13:17","book":"Isa","chapter":13,"verse":17,"letter":"b"},{"kind":"crossref","label":"Is 46:10–11","book":"Isa","chapter":46,"verse":10,"letter":"c"},{"kind":"text","text":" and his arm will be against the Chaldeans."}],"crossRefs":[{"label":"Is 13:4–5","book":"Isa","chapter":13,"verse":4},{"label":"Is 13:17","book":"Isa","chapter":13,"verse":17},{"label":"Is 46:10–11","book":"Isa","chapter":46,"verse":10}],"footnotes":[{"marker":1,"text":"Lit among them"},{"marker":1,"text":"= Cyrus"}]},{"verseId":"a556c5305ee15c3f-01:Isa:48:15","parts":[{"kind":"text","text":"I —I have spoken;"},{"kind":"text","text":" yes, I have called him; "},{"kind":"crossref","label":"Is 41:2","book":"Isa","chapter":41,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 45:1–2","book":"Isa","chapter":45,"verse":1,"letter":"b"},{"kind":"text","text":" I have brought him,"},{"kind":"text","text":" and he will succeed in his mission. "},{"kind":"crossref","label":"Is 53:10","book":"Isa","chapter":53,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Is 41:2","book":"Isa","chapter":41,"verse":2},{"label":"Is 45:1–2","book":"Isa","chapter":45,"verse":1},{"label":"Is 53:10","book":"Isa","chapter":