:17","book":"Isa","chapter":54,"verse":17,"letter":"h"},{"kind":"crossref","label":"Lk 1:54","book":"Luk","chapter":1,"verse":54,"letter":"i"},{"kind":"text","text":" Jacob!”"}],"crossRefs":[{"label":"Is 41:8–9","book":"Isa","chapter":41,"verse":8},{"label":"Is 42:19","book":"Isa","chapter":42,"verse":19},{"label":"Is 43:10","book":"Isa","chapter":43,"verse":10},{"label":"Is 44:1–2","book":"Isa","chapter":44,"verse":1},{"label":"Is 44:21","book":"Isa","chapter":44,"verse":21},{"label":"Is 45:4","book":"Isa","chapter":45,"verse":4},{"label":"Is 49:3","book":"Isa","chapter":49,"verse":3},{"label":"Is 54:17","book":"Isa","chapter":54,"verse":17},{"label":"Lk 1:54","book":"Luk","chapter":1,"verse":54}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:48:21","parts":[{"kind":"text","text":"They did not thirst"},{"kind":"text","text":" when he led them through the deserts;"},{"kind":"text","text":" he made water flow from the rock for them; "},{"kind":"crossref","label":"Ex 17:6","book":"Exo","chapter":17,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 78:15–16","book":"Psa","chapter":78,"verse":15,"letter":"b"},{"kind":"text","text":" he split the rock, and water gushed out."}],"crossRefs":[{"label":"Ex 17:6","book":"Exo","chapter":17,"verse":6},{"label":"Ps 78:15–16","book":"Psa","chapter":78,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:48:22","parts":[{"kind":"text","text":"“There is no peace for the wicked,” says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Is 57:21","book":"Isa","chapter":57,"verse":21,"letter":"a"}],"crossRefs":[{"label":"Is 57:21","book":"Isa","chapter":57,"verse":21}],"footnotes":[]}]},"cachedAt":1783279551418}