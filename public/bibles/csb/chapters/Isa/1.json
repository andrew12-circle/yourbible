2","book":"1Ki","chapter":8,"verse":22,"letter":"a"},{"kind":"text","text":" I will refuse to look at you;"},{"kind":"text","text":" even if you offer countless prayers,"},{"kind":"text","text":" I will not listen. "},{"kind":"crossref","label":"Is 59:2","book":"Isa","chapter":59,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 7:16","book":"Jer","chapter":7,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ezk 8:18","book":"Ezk","chapter":8,"verse":18,"letter":"c"},{"kind":"crossref","label":"Am 5:23","book":"Amo","chapter":5,"verse":23,"letter":"d"},{"kind":"crossref","label":"Hab 1:2","book":"Hab","chapter":1,"verse":2,"letter":"e"},{"kind":"crossref","label":"Zch 7:13","book":"Zec","chapter":7,"verse":13,"letter":"f"},{"kind":"text","text":" Your hands are covered with blood. "},{"kind":"crossref","label":"Pr 1:28","book":"Pro","chapter":1,"verse":28,"letter":"a"},{"kind":"crossref","label":"Is 59:1–3","book":"Isa","chapter":59,"verse":1,"letter":"b"},{"kind":"crossref","label":"Mc 3:4","book":"Mic","chapter":3,"verse":4,"letter":"c"}],"crossRefs":[{"label":"1Kg 8:22","book":"1Ki","chapter":8,"verse":22},{"label":"Is 59:2","book":"Isa","chapter":59,"verse":2},{"label":"Jr 7:16","book":"Jer","chapter":7,"verse":16},{"label":"Ezk 8:18","book":"Ezk","chapter":8,"verse":18},{"label":"Am 5:23","book":"Amo","chapter":5,"verse":23},{"label":"Hab 1:2","book":"Hab","chapter":1,"verse":2},{"label":"Zch 7:13","book":"Zec","chapter":7,"verse":13},{"label":"Pr 1:28","book":"Pro","chapter":1,"verse":28},{"label":"Is 59:1–3","book":"Isa","chapter":59,"verse":1},{"label":"Mc 3:4","book":"Mic","chapter":3,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:16","parts":[{"kind":"text","text":"“Wash yourselves. Cleanse yourselves. "},{"kind":"crossref","label":"Ps 26:6","book":"Psa","chapter":26,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 4:4","book":"Isa","chapter":4,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 52:11","book":"Isa","chap