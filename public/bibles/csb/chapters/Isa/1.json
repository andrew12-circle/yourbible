 the Holy One of Israel; "},{"kind":"crossref","label":"Is 5:19","book":"Isa","chapter":5,"verse":19,"letter":"e"},{"kind":"crossref","label":"Is 5:24","book":"Isa","chapter":5,"verse":24,"letter":"f"},{"kind":"crossref","label":"Is 10:20","book":"Isa","chapter":10,"verse":20,"letter":"g"},{"kind":"crossref","label":"Is 12:6","book":"Isa","chapter":12,"verse":6,"letter":"h"},{"kind":"crossref","label":"Is 29:19","book":"Isa","chapter":29,"verse":19,"letter":"i"},{"kind":"crossref","label":"Is 30:11–15","book":"Isa","chapter":30,"verse":11,"letter":"j"},{"kind":"text","text":" they have turned their backs on him."}],"crossRefs":[{"label":"Is 13:11","book":"Isa","chapter":13,"verse":11},{"label":"Is 14:20","book":"Isa","chapter":14,"verse":20},{"label":"Mt 3:7","book":"Mat","chapter":3,"verse":7},{"label":"Dt 4:31","book":"Deu","chapter":4,"verse":31},{"label":"Nm 14:11","book":"Num","chapter":14,"verse":11},{"label":"Dt 31:20","book":"Deu","chapter":31,"verse":20},{"label":"Pr 5:12","book":"Pro","chapter":5,"verse":12},{"label":"Is 5:24","book":"Isa","chapter":5,"verse":24},{"label":"Is 5:19","book":"Isa","chapter":5,"verse":19},{"label":"Is 5:24","book":"Isa","chapter":5,"verse":24},{"label":"Is 10:20","book":"Isa","chapter":10,"verse":20},{"label":"Is 12:6","book":"Isa","chapter":12,"verse":6},{"label":"Is 29:19","book":"Isa","chapter":29,"verse":19},{"label":"Is 30:11–15","book":"Isa","chapter":30,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:5","parts":[{"kind":"text","text":"Why do you want more beatings?"},{"kind":"text","text":" Why do you keep on rebelling?"},{"kind":"text","text":" The whole head is hurt,"},{"kind":"text","text":" and the whole heart is sick."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:6","parts":[{"kind":"text","text":"From the sole of the foot even to the head, "},{"kind":"crossref","label":"Jb 2:7","book":"Job","chapter":2,"verse":7,"letter":"a"},{"kind":"text","text":" no spot is uninjured "},{"kind":"crossref","label":"Ps 38:3","book":"Psa","chapter":38,"verse":3,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" wounds, welts, and festering sores"},{"kind":"text","text":" not cleansed, bandaged,"},{"kind":"text","text":" or soothed with oil."}],"crossRefs":[{"label":"Jb 2:7","book":"Job","chapter":2,"verse":7},{"label":"Ps 38:3","book":"Psa","chapter":38,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:7","parts":[{"kind":"text","text":"Your land is desolate,"},{"kind":"text","text":" your cities burned down; "},{"kind":"crossref","label":"Lv 26:33","book":"Lev","chapter":26,"verse":33,"letter":"a"},{"kind":"crossref","label":"Dt 28:51","book":"Deu","chapter":28,"verse":51,"letter":"b"},{"kind":"crossref","label":"Is 6:11–12","book":"Isa","chapter":6,"verse":11,"letter":"c"},{"kind":"crossref","label":"Jr 44:6","book":"Jer","chapter":44,"verse":6,"letter":"d"},{"kind":"text","text":" foreigners devour your fields"},{"kind":"text","text":" right in front of you —"},{"kind":"text","text":" a desolation, like a place demolished by foreigners."}],"crossRefs":[{"label":"Lv 26:33","book":"Lev","chapter":26,"verse":33},{"label":"Dt 28:51","book":"Deu","chapter":28,"verse":51},{"label":"Is 6:11–12","book":"Isa","chapter":6,"verse":11},{"label":"Jr 44:6","book":"Jer","chapter":44,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:8","parts":[{"kind":"text","text":"Daughter Zion "},{"kind":"crossref","label":"Is 10:32","book":"Isa","chapter":10,"verse":32,"letter":"a"},{"kind":"crossref","label":"Is 37:22","book":"Isa","chapter":37,"verse":22,"letter":"b"},{"kind":"crossref","label":"Zch 2:10","book":"Zec","chapter":2,"verse":10,"letter":"c"},{"kind":"crossref","label":"Zch 9:9","book":"Zec","chapter":9,"verse":9,"letter":"d"},{"kind":"text","text":" is abandoned"},{"kind":"text","text":" like a shelter in a vineyard,"},{"kind":"text","text":" like a shack in a cucumber field,"},{"kind":"text","text":" like a besieged city."}],"crossRefs":[{"label":"Is 10:32","book":"Isa","chapter":10,"verse":32},{"label":"Is 37:22","book":"Isa","chapter":37,"verse":22},{"label":"Zch 2:10","book":"Zec","chapter":2,"verse":10},{"label":"Zch 9:9","book":"Zec","chapter":9,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:9","parts":[{"kind":"text","text":"If the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies "},{"kind":"crossref","label":"1Sm 17:45","book":"1Sa","chapter":17,"verse":45,"letter":"a"},{"kind":"text","text":" had not left us a few survivors, "},{"kind":"crossref","label":"Is 10:21–22","book":"Isa","chapter":10,"verse":21,"letter":"a"},{"kind":"text","text":" we would be like Sodom,"},{"kind":"text","text":" we would resemble Gomorrah. "},{"kind":"crossref","label":"Gn 19:24–25","book":"Gen","chapter":19,"verse":24,"letter":"a"},{"kind":"crossref","label":"Is 3:9","book":"Isa","chapter":3,"verse":9,"letter":"b"},{"kind":"crossref","label":"Is 13:19","book":"Isa","chapter":13,"verse":19,"letter":"c"},{"kind":"crossref","label":"Rm 9:29","book":"Rom","chapter":9,"verse":29,"letter":"d"}],"crossRefs":[{"label":"1Sm 17:45","book":"1Sa","chapter":17,"verse":45},{"label":"Is 10:21–22","book":"Isa","chapter":10,"verse":21},{"label":"Gn 19:24–25","book":"Gen","chapter":19,"verse":24},{"label":"Is 3:9","book":"Isa","chapter":3,"verse":9},{"label":"Is 13:19","book":"Isa","chapter":13,"verse":19},{"label":"Rm 9:29","book":"Rom","chapter":9,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:10","parts":[{"kind":"text","text":"Hear the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"crossref","label":"Is 28:14","book":"Isa","chapter":28,"verse":14,"letter":"a"},{"kind":"text","text":" you rulers of Sodom!"},{"kind":"text","text":" Listen to the instruction of our God,"},{"kind":"text","text":" you people of Gomorrah! "},{"kind":"crossref","label":"Is 3:9","book":"Isa","chapter":3,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ezk 16:46–49","book":"Ezk","chapter":16,"verse":46,"letter":"b"},{"kind":"crossref","label":"Ezk 16:55","book":"Ezk","chapter":16,"verse":55,"letter":"c"},{"kind":"crossref","label":"Rv 11:8","book":"Rev","chapter":11,"verse":8,"letter":"d"}],"crossRefs":[{"label":"Is 28:14","book":"Isa","chapter":28,"verse":14},{"label":"Is 3:9","book":"Isa","chapter":3,"verse":9},{"label":"Ezk 16:46–49","book":"Ezk","chapter":16,"verse":46},{"label":"Ezk 16:55","book":"Ezk","chapter":16,"verse":55},{"label":"Rv 11:8","book":"Rev","chapter":11,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:11","parts":[{"kind":"text","text":"“What are all your sacrifices to me?”"},{"kind":"text","text":" asks the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."},{"kind":"text","text":" “I have had enough of burnt offerings and rams"},{"kind":"text","text":" and the fat of well-fed cattle;"},{"kind":"text","text":" I have no desire for the blood of bulls,"},{"kind":"text","text":" lambs, or male goats. "},{"kind":"crossref","label":"1Sm 15:22","book":"1Sa","chapter":15,"verse":22,"letter":"a"},{"kind":"crossref","label":"Jr 6:20","book":"Jer","chapter":6,"verse":20,"letter":"b"},{"kind":"crossref","label":"Hs 6:6","book":"Hos","chapter":6,"verse":6,"letter":"c"},{"kind":"crossref","label":"Am 5:21–24","book":"Amo","chapter":5,"verse":21,"letter":"d"},{"kind":"crossref","label":"Mt 23:23","book":"Mat","chapter":23,"verse":23,"letter":"e"},{"kind":"crossref","label":"Mk 12:33","book":"Mrk","chapter":12,"verse":33,"letter":"f"}],"crossRefs":[{"label":"1Sm 15:22","book":"1Sa","chapter":15,"verse":22},{"label":"Jr 6:20","book":"Jer","chapter":6,"verse":20},{"label":"Hs 6:6","book":"Hos","chapter":6,"verse":6},{"label":"Am 5:21–24","book":"Amo","chapter":5,"verse":21},{"label":"Mt 23:23","book":"Mat","chapter":23,"verse":23},{"label":"Mk 12:33","book":"Mrk","chapter":12,"verse":33}],"footnotes":[]},{"ve