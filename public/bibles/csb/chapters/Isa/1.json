use and rebel,"},{"kind":"text","text":" you will be devoured by the sword.” "},{"kind":"crossref","label":"Jr 12:12","book":"Jer","chapter":12,"verse":12,"letter":"a"},{"kind":"text","text":" For the mouth of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has spoken. "},{"kind":"crossref","label":"Is 24:3","book":"Isa","chapter":24,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 40:5","book":"Isa","chapter":40,"verse":5,"letter":"b"},{"kind":"crossref","label":"Is 58:14","book":"Isa","chapter":58,"verse":14,"letter":"c"},{"kind":"crossref","label":"Mc 4:4","book":"Mic","chapter":4,"verse":4,"letter":"d"}],"crossRefs":[{"label":"Jr 12:12","book":"Jer","chapter":12,"verse":12},{"label":"Is 24:3","book":"Isa","chapter":24,"verse":3},{"label":"Is 40:5","book":"Isa","chapter":40,"verse":5},{"label":"Is 58:14","book":"Isa","chapter":58,"verse":14},{"label":"Mc 4:4","book":"Mic","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:1:21","parts":[{"kind":"text","text":"The faithful town —"},{"kind":"text","text":" what an adulteress "},{"kind":"footnote","marker":1,"text":"Or prostitute"},{"kind":"text","text":" she has become!"},{"kind":"text","text":" She was once full of justice."},{"kind":"text","text":" Righteousness once dwelt in her,"},{"kind":"text","text":" but now, murderers!"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or prostitute"}]},{"verseId":"a556c5305ee15c3f-01:Isa:1:22","parts":[{"kind":"text","text":"Your silver has become dross to be discarded,"},{"kind":"text","text":" your beer "},{"kind":"footnote","marker":1,"text":"Or wine"},{"kind":"text","text":" is diluted with water."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or wine"}]},{"verseId":"a556c5305ee15c3f-01:Isa:1:23","parts":[{"kind":"text","text":"Your rulers are rebels,"},{"kind":"text","text":" friends of thieves. "},{"kind":"crossref","label":"Hs 5:10","book":"Hos","chapter":5,"verse":10,"letter":"a"},{"kind":"text","tex