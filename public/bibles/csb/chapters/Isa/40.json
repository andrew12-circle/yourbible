ar, "},{"kind":"crossref","label":"Is 35:2","book":"Isa","chapter":35,"verse":2,"letter":"a"},{"kind":"text","text":" and all humanity "},{"kind":"footnote","marker":1,"text":"Lit flesh"},{"kind":"text","text":" together will see it, "},{"kind":"crossref","label":"Is 52:10","book":"Isa","chapter":52,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jl 2:28","book":"Jol","chapter":2,"verse":28,"letter":"b"},{"kind":"text","text":" for the mouth of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has spoken. "},{"kind":"crossref","label":"Is 1:20","book":"Isa","chapter":1,"verse":20,"letter":"a"},{"kind":"crossref","label":"Is 34:16","book":"Isa","chapter":34,"verse":16,"letter":"b"},{"kind":"crossref","label":"Is 58:14","book":"Isa","chapter":58,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Is 35:2","book":"Isa","chapter":35,"verse":2},{"label":"Is 52:10","book":"Isa","chapter":52,"verse":10},{"label":"Jl 2:28","book":"Jol","chapter":2,"verse":28},{"label":"Is 1:20","book":"Isa","chapter":1,"verse":20},{"label":"Is 34:16","book":"Isa","chapter":34,"verse":16},{"label":"Is 58:14","book":"Isa","chapter":58,"verse":14}],"footnotes":[{"marker":1,"text":"Lit flesh"}]},{"verseId":"a556c5305ee15c3f-01:Isa:40:6","parts":[{"kind":"text","text":"A voice was saying, “Cry out!”"},{"kind":"text","text":" Another said, "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Vg read I said"},{"kind":"text","text":" “What should I cry out?”"},{"kind":"text","text":" “All humanity is grass, "},{"kind":"crossref","label":"1Pt 1:24","book":"1Pe","chapter":1,"verse":24,"letter":"a"},{"kind":"text","text":" and all its goodness is like the flower of the field. "},{"kind":"crossref","label":"Jb 14:2","book":"Job","chapter":14,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 102:11","book":"Psa","chapter":102,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ps 103:15","book":"Psa","chapter":103,"verse":15,"letter":"c"}],"crossRefs":[{"label":"1Pt 1:24","book":"1Pe","chapter":1,"verse":24},{"label":"Jb 14:2","book":"Job","chapter":14,"verse":2},{"label":"Ps 102:11","book":"Psa","chapter":102,"verse":11},{"label":"Ps 103:15","book":"Psa","chapter":103,"verse":15}],"footnotes":[{"marker":1,"text":"DSS, LXX, Vg read I said"}]},{"verseId":"a556c5305ee15c3f-01:Isa:40:7","parts":[{"kind":"text","text":"The grass withers, the flowers fade"},{"kind":"text","text":" when the breath "},{"kind":"footnote","marker":1,"text":"Or wind, or Spirit"},{"kind":"text","text":" of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" blows on them; "},{"kind":"footnote","marker":2,"text":"Lit it"},{"kind":"text","text":" indeed, the people are grass."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or wind, or Spirit"},{"marker":2,"text":"Lit it"}]},{"verseId":"a556c5305ee15c3f-01:Isa:40:8","parts":[{"kind":"text","text":"The grass withers, the flowers fade, "},{"kind":"crossref","label":"Jms 1:11","book":"Jas","chapter":1,"verse":11,"letter":"a"},{"kind":"text","text":" but the word of our God remains forever.” "},{"kind":"crossref","label":"Is 55:11","book":"Isa","chapter":55,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 59:21","book":"Isa","chapter":59,"verse":21,"letter":"b"},{"kind":"crossref","label":"Mk 13:31","book":"Mrk","chapter":13,"verse":31,"letter":"c"},{"kind":"crossref","label":"Lk 21:33","book":"Luk","chapter":21,"verse":33,"letter":"d"}],"crossRefs":[{"label":"Jms 1:11","book":"Jas","chapter":1,"verse":11},{"label":"Is 55:11","book":"Isa","chapter":55,"verse":11},{"label":"Is 59:21","book":"Isa","chapter":59,"verse":21},{"label":"Mk 13:31","book":"Mrk","chapter":13,"verse":31},{"label":"Lk 21:33","book":"Luk","chapter":21,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:40:9","parts":[{"kind":"text","text":"Zion, herald of good news,"},{"kind":"text","text":" go up on a high mountain. "},{"kind":"crossref","label":"Is 52:7","book":"Isa","chapter":52,"verse":7,"letter":"a"},{"kind":"text","text":" Jerusalem, herald of good news, "},{"kind":"crossref","label":"Is 61:1","book":"Isa","chapter":61,"verse":1,"letter":"a"},{"kind":"text","text":" raise your voice loudly."},{"kind":"text","text":" Raise it, do not be afraid!"},{"kind":"text","text":" Say to the cities of Judah,"},{"kind":"text","text":" “Here is your God!” "},{"kind":"crossref","label":"Is 25:9","book":"Isa","chapter":25,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 35:2","book":"Isa","chapter":35,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Is 52:7","book":"Isa","chapter":52,"verse":7},{"label":"Is 61:1","book":"Isa","chapter":61,"verse":1},{"label":"Is 25:9","book":"Isa","chapter":25,"verse":9},{"label":"Is 35:2","book":"Isa","chapter":35,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:40:10","parts":[{"kind":"text","text":"See, the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" comes with strength,"},{"kind":"text","text":" and his power establishes his rule. "},{"kind":"crossref","label":"Is 59:16–18","book":"Isa","chapter":59,"verse":16,"letter":"a"},{"kind":"text","text":" His wages are with him, "},{"kind":"crossref","label":"Is 62:11","book":"Isa","chapter":62,"verse":11,"letter":"a"},{"kind":"crossref","label":"Rv 22:12","book":"Rev","chapter":22,"verse":12,"letter":"b"},{"kind":"text","text":" and his reward accompanies him."}],"crossRefs":[{"label":"Is 59:16–18","book":"Isa","chapter":59,"verse":16},{"label":"Is 62:11","book":"Isa","chapter":62,"verse":11},{"label":"Rv 22:12","book":"Rev","chapter":22,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:40:11","parts":[{"kind":"text","text":"He protects his flock like a shepherd; "},{"kind":"crossref","label":"Jr 31:10","book":"Jer","chapter":31,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ezk 34:12–14","book":"Ezk","chapter":34,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ezk 34:23","book":"Ezk","chapter":34,"verse":23