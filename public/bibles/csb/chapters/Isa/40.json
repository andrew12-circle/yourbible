":"Is 42:5","book":"Isa","chapter":42,"verse":5},{"label":"Is 48:12–13","book":"Isa","chapter":48,"verse":12},{"label":"Ps 147:4–5","book":"Psa","chapter":147,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:40:27","parts":[{"kind":"text","text":"Jacob, why do you say,"},{"kind":"text","text":" and Israel, why do you assert,"},{"kind":"text","text":" “My way is hidden from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" and my claim is ignored by my God”? "},{"kind":"crossref","label":"Is 7:13","book":"Isa","chapter":7,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 49:4","book":"Isa","chapter":49,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 49:14","book":"Isa","chapter":49,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Is 7:13","book":"Isa","chapter":7,"verse":13},{"label":"Is 49:4","book":"Isa","chapter":49,"verse":4},{"label":"Is 49:14","book":"Isa","chapter":49,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:40:28","parts":[{"kind":"text","text":"Do you not know?"},{"kind":"text","text":" Have you not heard?"},{"kind":"text","text":" The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is the everlasting God, "},{"kind":"crossref","label":"Gn 21:33","book":"Gen","chapter":21,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ps 90:2","book":"Psa","chapter":90,"verse":2,"letter":"b"},{"kind":"text","text":" the Creator of the whole earth."},{"kind":"text","text":" He never becomes faint or weary;"},{"kind":"text","text":" there is no limit to his understanding. "},{"kind":"crossref","label":"Ps 147:5","book":"Psa","chapter":147,"verse":5,"letter":"a"},{"kind":"crossref","label":"Rm 11:33","book":"Rom","chapter":11,"verse":33,"letter":"b"}],"crossRefs":[{"label":"Gn 21:33","book":"Gen","chapter":21,"verse":33},{"label":"Ps 90:2","book":"Psa","chapter":90,"verse":2},{"label":"Ps 147:5","book":"Psa","chapter":147,"verse":5},{"label"