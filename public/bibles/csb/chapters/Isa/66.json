hapter":7,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:5","parts":[{"kind":"text","text":"You who tremble at his word, "},{"kind":"crossref","label":"Ezr 9:4","book":"Ezr","chapter":9,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ezr 10:3","book":"Ezr","chapter":10,"verse":3,"letter":"b"},{"kind":"text","text":" hear the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":": "},{"kind":"crossref","label":"Is 28:14","book":"Isa","chapter":28,"verse":14,"letter":"a"},{"kind":"text","text":" “Your brothers who hate and exclude you"},{"kind":"text","text":" for my name’s sake have said, "},{"kind":"crossref","label":"Mt 5:10–12","book":"Mat","chapter":5,"verse":10,"letter":"a"},{"kind":"crossref","label":"Mt 10:22","book":"Mat","chapter":10,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jn 9:34","book":"Jhn","chapter":9,"verse":34,"letter":"c"},{"kind":"crossref","label":"Jn 15:18–20","book":"Jhn","chapter":15,"verse":18,"letter":"d"},{"kind":"text","text":" ‘Let the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" be glorified"},{"kind":"text","text":" so that we can see your joy!’"},{"kind":"text","text":" But they will be put to shame.” "},{"kind":"crossref","label":"Is 26:11","book":"Isa","chapter":26,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 44:9","book":"Isa","chapter":44,"verse":9,"letter":"b"},{"kind":"crossref","label":"Is 65:13","book":"Isa","chapter":65,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Ezr 9:4","book":"Ezr","chapter":9,"verse":4},{"label":"Ezr 10:3","book":"Ezr","chapter":10,"verse":3},{"label":"Is 28:14","book":"Isa","chapter":28,"verse":14},{"label":"Mt 5:10–12","book":"Mat","chapter":5,"verse":10},{"label":"Mt 10:22","book":"Mat","chapter":10,"verse":22},{"label":"Jn 9:34","book":"Jhn","chapter":9,"verse":34},{"label":"Jn 15:18–20","book":"Jhn","chapter":15,"verse":18},{"label":"Is 26:11","book":"Isa","chapter":26,"verse":11},{"label":"Is 44:9","book":"Isa","chapter":44,"verse":9},{"label":"Is 65:13","book":"Isa","chapter":65,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:6","parts":[{"kind":"text","text":"A sound of uproar from the city!"},{"kind":"text","text":" A voice from the temple —"},{"kind":"text","text":" the voice of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" paying back his enemies what they deserve! "},{"kind":"crossref","label":"Is 59:18","book":"Isa","chapter":59,"verse":18,"letter":"a"},{"kind":"crossref","label":"Is 65:6","book":"Isa","chapter":65,"verse":6,"letter":"b"},{"kind":"crossref","label":"Jl 3:7","book":"Jol","chapter":3,"verse":7,"letter":"c"}],"crossRefs":[{"label":"Is 59:18","book":"Isa","chapter":59,"verse":18},{"label":"Is 65:6","book":"Isa","chapter":65,"verse":6},{"label":"Jl 3:7","book":"Jol","chapter":3,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:7","parts":[{"kind":"text","text":"Before Zion was in labor, she gave birth;"},{"kind":"text","text":" before she was in pain, she delivered a boy."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:8","parts":[{"kind":"text","text":"Who has heard of such a thing?"},{"kind":"text","text":" Who has seen such things?"},{"kind":"text","text":" Can a land be born in one day"},{"kind":"text","text":" or a nation be delivered in an instant?"},{"kind":"text","text":" Yet as soon as Zion was in labor,"},{"kind":"text","text":" she gave birth to her sons."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:9","parts":[{"kind":"text","text":"“Will I bring a baby to the point of birth"},{"kind":"text","text":" and not deliver it?”"},{"kind":"text","text":" says the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"},{"kind":"text","text":" “or will I who deliver, close the womb?”"},{"kind":"text","text":" says your God."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:10","parts":[{"kind":"text","text":"Be glad for Jerusalem and rejoice over her,"},{"kind":"text","text":" all who love her. "},{"kind":"crossref","label":"Ps 122:6","book":"Psa","chapter":122,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 137:6","book":"Psa","chapter":137,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 65:18","book":"Isa","chapter":65,"verse":18,"letter":"c"},{"kind":"text","text":" Rejoice greatly with her,"},{"kind":"text","text":" all who mourn over her —"}],"crossRefs":[{"label":"Ps 122:6","book":"Psa","chapter":122,"verse":6},{"label":"Ps 137:6","book":"Psa","chapter":137,"verse":6},{"label":"Is 65:18","book":"Isa","chapter":65,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:11","parts":[{"kind":"text","text":"so that you may nurse and be satisfied"},{"kind":"text","text":" from her comforting breast"},{"kind":"text","text":" and drink deeply and delight yourselves"},{"kind":"text","text":" from her glorious breasts."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:12","parts":[{"kind":"text","text":"For this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" I will make peace flow to her like a river, "},{"kind":"crossref","label":"Ps 72:3","book":"Psa","chapter":72,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 72:7","book":"Psa","chapter":72,"verse":7,"letter":"b"},{"kind":"crossref","label":"Is 48:18","book":"Isa","chapter":48,"verse":18,"letter":"c"},{"kind":"text","text":" and the wealth "},{"kind":"footnote","marker":1,"text":"Or glory"},{"kind":"text","text":" of nations like a flood; "},{"kind":"crossref","label":"Is 61:6","book":"Isa","chapter":61,"verse":6,"letter":"a"},{"kind":"text","text":" you will nurse and be carried on her hip "},{"kind":"crossref","label":"Is 60:4–5","book":"Isa","chapter":60,"verse":4,"letter":"a"},{"kind":"text","text":" and bounced on her lap."}],"crossRefs":[{"label":"Ps 72:3","book":"Psa","chapter":72,"verse":3},{"label":"Ps 72:7","book":"Psa","chapter":72,"verse":7},{"label":"Is 48:18","book":"Isa","chapter":48,"verse":18},{"label":"Is 61:6","book":"Isa","chapter":61,"verse":6},{"label":"Is 60:4–5","book":"Isa","chapter":60,"verse":4}],"footnotes":[{"marker":1,"text":"Or glory"}]},{"verseId":"a556c5305ee15c3f-01:Isa:66:13","parts":[{"kind":"text","text":"As a mother comforts her son,"},{"kind":"text","text":" so I will comfort you, "},{"kind":"crossref","label":"Ps 86:17","book":"Psa","chapter":86,"verse":17,"letter":"a"},{"kind":"crossref","label":"Is 40:1","book":"Isa","chapter":40,"verse":1,"letter":"b"},{"kind":"crossref","label":"Is 49:13","book":"Isa","chapter":49,"verse":13,"letter":"c"},{"kind":"crossref","label":"Is 51:13","book":"Isa","chapter":51,"verse":13,"letter":"d"},{"kind":"crossref","label":"Is 52:9","book":"Isa","chapter":52,"verse":9,"letter":"e"},{"kind":"crossref","label":"2Co 1:3–4","book":"2Co","chapter":1,"verse":3,"letter":"f"},{"kind":"text","text":" and you will be comforted in Jerusalem."}],"crossRefs":[{"label":"Ps 86:17","book":"Psa","chapter":86,"verse":17},{"label":"Is 40:1","book":"Isa","chapter":40,"verse":1},{"label":"Is 49:13","book":"Isa","chapter":49,"verse":13},{"label":"Is 51:13","book":"Isa","chapter":51,"verse":13},{"label":"Is 52:9","book":"Isa","chapter":52,"verse":9},{"label":"2Co 1:3–4","book":"2Co","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:14","parts":[{"kind":"text","text":"You will see, you will rejoice,"},{"kind":"text","text":" and you "},{"kind":"footnote","marker":1,"text":"Lit your bones"},{"kind":"text","text":" will flourish like grass; "},{"kind":"crossref","label":"Ps 72:16","book":"Psa","chapter":72,"verse":16,"letter":"a"},{"kind":"crossref","label":"Pr 11:28","book":"Pro","chapter":11,"verse":28,"letter":"b"},{"kind":"crossref","label":"Is 58:11","book":"Isa","chapter":58,"verse":11,"letter":"c"},{"kind":"text","text":" then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s power will be revealed to his servants,"},{"kind":"text","text":" but he will show his wrath against his enemies."}],"crossRefs":[{"label":"Ps 72:16","book":"Psa","chapter":72,"verse":16},{"label":"Pr 11:28","book":"Pro","chapter":11,"verse":28},{"label":"Is 58:11","book":"Isa","chapter":58,"verse":11}],"footnotes":[{"marker":1,"text":"Lit your bones"}]},{"verseId":"a556c5305ee15c3f-01:Isa:66:15","parts":[{"kind":"text","text":"Look, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will come with fire "},{"kind":"crossref","label":"Is 33:14","book":"Isa","chapter":33,"verse":14,"letter":"a"},{"kind":"crossref","label":"Mal 3:1–2","book":"Mal","chapter":3,"verse":1,"letter":"b"},{"kind":"crossref","label":"2Th 1:7–8","book":"2Th","chapter":1,"verse":7,"letter":"c"},{"kind":"crossref","label":"2Pt 3:7","book":"2Pe","chapter":3,"verse":7,"letter":"d"},{"kind":"text","text":" —"},{"kind":"text","text":" his chariots are like the whirlwind "},{"kind":"crossref","label":"Ps 68:17","book":"Psa","chapter":68,"verse":17,"letter":"a"},{"kind":"crossref","label":"Is 5:28","book":"Isa","chapter":5,"verse":28,"letter":"b"},{"kind":"crossref","label":"Hab 3:8","book":"Hab","chapter":3,"verse":8,"letter":"c"},{"kind":"text","text":" —"},{"kind":"text","text":" to execute his anger with fury"},{"kind":"text","text":" and his rebuke with flames of fire."}],"crossRefs":[{"label":"Is 33:14","book":"Isa","chapter":33,"verse":14},{"label":"Mal 3:1–2","book":"Mal","chapter":3,"verse":1},{"label":"2Th 1:7–8","book":"2Th","chapter":1,"verse":7},{"label":"2Pt 3:7","book":"2Pe","chapter":3,"verse":7},{"label":"Ps 68:17","book":"Psa","chapter":68,"verse":17},{"label":"Is 5:28","book":"Isa","chapter":5,"verse":28},{"label":"Hab 3:8","book":"Hab","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:66:16","parts":[{"kind":"text","text":"For t