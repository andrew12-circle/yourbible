d of men"}]},{"verseId":"a556c5305ee15c3f-01:Isa:29:14","parts":[{"kind":"text","text":"Therefore, I will again confound these people"},{"kind":"text","text":" with wonder after wonder. "},{"kind":"crossref","label":"Is 6:9–10","book":"Isa","chapter":6,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 28:21","book":"Isa","chapter":28,"verse":21,"letter":"b"},{"kind":"crossref","label":"Is 65:7","book":"Isa","chapter":65,"verse":7,"letter":"c"},{"kind":"crossref","label":"Hab 1:5","book":"Hab","chapter":1,"verse":5,"letter":"d"},{"kind":"text","text":" The wisdom of their wise will vanish, "},{"kind":"crossref","label":"Is 44:25","book":"Isa","chapter":44,"verse":25,"letter":"a"},{"kind":"crossref","label":"Jr 8:9","book":"Jer","chapter":8,"verse":9,"letter":"b"},{"kind":"crossref","label":"Jr 49:7","book":"Jer","chapter":49,"verse":7,"letter":"c"},{"kind":"crossref","label":"1Co 1:19","book":"1Co","chapter":1,"verse":19,"letter":"d"},{"kind":"text","text":" and the perception of their perceptive will be hidden."}],"crossRefs":[{"label":"Is 6:9–10","book":"Isa","chapter":6,"verse":9},{"label":"Is 28:21","book":"Isa","chapter":28,"verse":21},{"label":"Is 65:7","book":"Isa","chapter":65,"verse":7},{"label":"Hab 1:5","book":"Hab","chapter":1,"verse":5},{"label":"Is 44:25","book":"Isa","chapter":44,"verse":25},{"label":"Jr 8:9","book":"Jer","chapter":8,"verse":9},{"label":"Jr 49:7","book":"Jer","chapter":49,"verse":7},{"label":"1Co 1:19","book":"1Co","chapter":1,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:29:15","parts":[{"kind":"text","text":"Woe to those who go to great lengths"},{"kind":"text","text":" to hide their plans from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Ps 10:11","book":"Psa","chapter":10,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 10:13","book":"Psa","chapter":10,"verse":13,"letter":"b"},{"kind":"crossref","label":"Is 28:15","book":"Isa","chapter":