"},{"kind":"text","text":" storm, tempest, and a flame of consuming fire. "},{"kind":"crossref","label":"Ex 9:23","book":"Exo","chapter":9,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ex 19:16","book":"Exo","chapter":19,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ex 19:19","book":"Exo","chapter":19,"verse":19,"letter":"c"},{"kind":"crossref","label":"Ex 20:18","book":"Exo","chapter":20,"verse":18,"letter":"d"},{"kind":"crossref","label":"1Sm 2:10","book":"1Sa","chapter":2,"verse":10,"letter":"e"},{"kind":"crossref","label":"1Sm 12:18","book":"1Sa","chapter":12,"verse":18,"letter":"f"},{"kind":"crossref","label":"Jb 40:9","book":"Job","chapter":40,"verse":9,"letter":"g"},{"kind":"crossref","label":"Ps 77:18","book":"Psa","chapter":77,"verse":18,"letter":"h"},{"kind":"crossref","label":"Zch 14:5","book":"Zec","chapter":14,"verse":5,"letter":"i"},{"kind":"crossref","label":"Rv 4:5","book":"Rev","chapter":4,"verse":5,"letter":"j"},{"kind":"crossref","label":"Rv 11:13","book":"Rev","chapter":11,"verse":13,"letter":"k"}],"crossRefs":[{"label":"Ex 9:23","book":"Exo","chapter":9,"verse":23},{"label":"Ex 19:16","book":"Exo","chapter":19,"verse":16},{"label":"Ex 19:19","book":"Exo","chapter":19,"verse":19},{"label":"Ex 20:18","book":"Exo","chapter":20,"verse":18},{"label":"1Sm 2:10","book":"1Sa","chapter":2,"verse":10},{"label":"1Sm 12:18","book":"1Sa","chapter":12,"verse":18},{"label":"Jb 40:9","book":"Job","chapter":40,"verse":9},{"label":"Ps 77:18","book":"Psa","chapter":77,"verse":18},{"label":"Zch 14:5","book":"Zec","chapter":14,"verse":5},{"label":"Rv 4:5","book":"Rev","chapter":4,"verse":5},{"label":"Rv 11:13","book":"Rev","chapter":11,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:29:7","parts":[{"kind":"text","text":"All the many nations "},{"kind":"crossref","label":"Mc 4:11","book":"Mic","chapter":4,"verse":11,"letter":"a"},{"kind":"crossref","label":"Zch 12:9","book":"Zec","chapter":12,"verse":9,"letter":"b"},{"kind":"text","text":" going out to battle against Ariel —"},{"kind":"text","text":" all the attackers, the siege works against her,"},{"kind":"text","text":" and those who oppress her —"},{"kind":"text","text":" will then be like a dream, a vision in the night. "},{"kind":"crossref","label":"Jb 20:8","book":"Job","chapter":20,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 73:20","book":"Psa","chapter":73,"verse":20,"letter":"b"},{"kind":"crossref","label":"Is 17:14","book":"Isa","chapter":17,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Mc 4:11","book":"Mic","chapter":4,"verse":11},{"label":"Zch 12:9","book":"Zec","chapter":12,"verse":9},{"label":"Jb 20:8","book":"Job","chapter":20,"verse":8},{"label":"Ps 73:20","book":"Psa","chapter":73,"verse":20},{"label":"Is 17:14","book":"Isa","chapter":17,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:29:8","parts":[{"kind":"text","text":"It will be like a hungry one who dreams he is eating,"},{"kind":"text","text":" then wakes and is still hungry;"},{"kind":"text","text":" and like a thirsty one who dreams he is drinking,"},{"kind":"text","text":" then wakes and is still thirsty, longing for water."},{"kind":"text","text":" So it will be for all the many nations"},{"kind":"text","text":" who go to battle against Mount Zion."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:29:9","parts":[{"kind":"text","text":"Stop and be astonished;"},{"kind":"text","text":" blind yourselves and be blind!"},{"kind":"text","text":" They are drunk, "},{"kind":"footnote","marker":1,"text":"LXX, Tg, Vg read Be drunk"},{"kind":"text","text":" but not with wine;"},{"kind":"text","text":" they stagger, "},{"kind":"footnote","marker":1,"text":"Tg, Vg read wine; stagger"},{"kind":"text","text":" but not with beer. "},{"kind":"crossref","label":"Lk 1:15","book":"Luk","chapter":1,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Lk 1:15","book":"Luk","chapter":1,"verse":15}],"footnotes":[{"marker":1,"text":"LXX, Tg, Vg rea