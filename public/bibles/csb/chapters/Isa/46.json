ll not delay."},{"kind":"text","text":" I will put salvation in Zion,"},{"kind":"text","text":" my splendor in Israel."}],"crossRefs":[{"label":"Is 51:5","book":"Isa","chapter":51,"verse":5},{"label":"Is 61:11","book":"Isa","chapter":61,"verse":11},{"label":"Rm 3:21","book":"Rom","chapter":3,"verse":21}],"footnotes":[]}]},"cachedAt":1783279550792}