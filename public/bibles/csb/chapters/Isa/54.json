bel":"Is 41:8–9","book":"Isa","chapter":41,"verse":8,"letter":"a"},{"kind":"crossref","label":"Lk 1:54","book":"Luk","chapter":1,"verse":54,"letter":"b"},{"kind":"text","text":" and their vindication is from me.” "},{"kind":"crossref","label":"Is 45:24","book":"Isa","chapter":45,"verse":24,"letter":"a"},{"kind":"crossref","label":"Is 46:13","book":"Isa","chapter":46,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Is 41:8–9","book":"Isa","chapter":41,"verse":8},{"label":"Lk 1:54","book":"Luk","chapter":1,"verse":54},{"label":"Is 45:24","book":"Isa","chapter":45,"verse":24},{"label":"Is 46:13","book":"Isa","chapter":46,"verse":13}],"footnotes":[{"marker":1,"text":"Lit refute every tongue"}]}]},"cachedAt":1783279553236}