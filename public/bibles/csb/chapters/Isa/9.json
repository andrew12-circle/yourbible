":"Isa","chapter":31,"verse":2,"letter":"d"},{"kind":"crossref","label":"Is 32:6","book":"Isa","chapter":32,"verse":6,"letter":"e"},{"kind":"text","text":" and every mouth speaks folly."},{"kind":"text","text":" In all this, his anger has not turned away,"},{"kind":"text","text":" and his hand is still raised to strike."}],"crossRefs":[{"label":"Is 1:4","book":"Isa","chapter":1,"verse":4},{"label":"Is 10:6","book":"Isa","chapter":10,"verse":6},{"label":"Is 14:20","book":"Isa","chapter":14,"verse":20},{"label":"Is 31:2","book":"Isa","chapter":31,"verse":2},{"label":"Is 32:6","book":"Isa","chapter":32,"verse":6}],"footnotes":[{"marker":1,"text":"DSS read not spare"}]},{"verseId":"a556c5305ee15c3f-01:Isa:9:18","parts":[{"kind":"text","text":"For wickedness burns like a fire "},{"kind":"crossref","label":"Ps 83:14","book":"Psa","chapter":83,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 1:7","book":"Isa","chapter":1,"verse":7,"letter":"b"},{"kind":"crossref","label":"Nah 1:10","book":"Nam","chapter":1,"verse":10,"letter":"c"},{"kind":"crossref","label":"Mal 4:1","book":"Mal","chapter":4,"verse":1,"letter":"d"},{"kind":"text","text":" that consumes thorns and briers"},{"kind":"text","text":" and kindles the forest thickets"},{"kind":"text","text":" so that they go up in a column of smoke."}],"crossRefs":[{"label":"Ps 83:14","book":"Psa","chapter":83,"verse":14},{"label":"Is 1:7","book":"Isa","chapter":1,"verse":7},{"label":"Nah 1:10","book":"Nam","chapter":1,"verse":10},{"label":"Mal 4:1","book":"Mal","chapter":4,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:9:19","parts":[{"kind":"text","text":"The land is scorched"},{"kind":"text","text":" by the wrath of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies,"},{"kind":"text","text":" and the people are like fuel for the fire. "},{"kind":"crossref","label":"Is 1:31","book":"Isa","chapter":1,"verse":31,"letter":"a"},{"kind":"crossref","label":"Is 24:6","book":