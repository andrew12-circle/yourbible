":"Is 29:20","book":"Isa","chapter":29,"verse":20,"letter":"e"},{"kind":"text","text":" who rule this people in Jerusalem."}],"crossRefs":[{"label":"Is 1:10","book":"Isa","chapter":1,"verse":10},{"label":"Is 39:5","book":"Isa","chapter":39,"verse":5},{"label":"Is 39:8","book":"Isa","chapter":39,"verse":8},{"label":"Is 66:5","book":"Isa","chapter":66,"verse":5},{"label":"Is 29:20","book":"Isa","chapter":29,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:15","parts":[{"kind":"text","text":"For you said, “We have made a covenant with Death,"},{"kind":"text","text":" and we have an agreement with Sheol;"},{"kind":"text","text":" when the overwhelming catastrophe "},{"kind":"footnote","marker":1,"text":"Or whip; Hb obscure, also in v. 18"},{"kind":"text","text":" passes through, "},{"kind":"crossref","label":"Is 8:7–8","book":"Isa","chapter":8,"verse":7,"letter":"a"},{"kind":"text","text":" it will not touch us,"},{"kind":"text","text":" because we have made falsehood our refuge"},{"kind":"text","text":" and have hidden behind treachery.”"}],"crossRefs":[{"label":"Is 8:7–8","book":"Isa","chapter":8,"verse":7}],"footnotes":[{"marker":1,"text":"Or whip; Hb obscure, also in v. 18"}]},{"verseId":"a556c5305ee15c3f-01:Isa:28:16","parts":[{"kind":"text","text":"Therefore the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" said:"},{"kind":"text","text":" “Look, I have laid a stone "},{"kind":"crossref","label":"Is 8:14","book":"Isa","chapter":8,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 26:4","book":"Isa","chapter":26,"verse":4,"letter":"b"},{"kind":"text","text":" in Zion,"},{"kind":"text","text":" a tested stone,"},{"kind":"text","text":" a precious cornerstone, a sure foundation; "},{"kind":"crossref","label":"Mt 21:42","book":"Mat","chapter":21,"verse":42,"letter":"a"},{"kind":"crossref","label":"Mk 12:10","book":"Mrk","chapter":12,"verse":10,"letter":"b"},{"kind":"crossref","label":"Lk 20:17","book":"Luk","chapter":20,"verse":17,"letter":"c"},{"kind":"crossref","label":"Ac 4:11","book":"Act","chapter":4,"verse":11,"letter":"d"},{"kind":"crossref","label":"1Co 3:11","book":"1Co","chapter":3,"verse":11,"letter":"e"},{"kind":"crossref","label":"Eph 2:20","book":"Eph","chapter":2,"verse":20,"letter":"f"},{"kind":"text","text":" the one who believes will be unshakable. "},{"kind":"footnote","marker":1,"text":"Lit will not hurry"},{"kind":"crossref","label":"Rm 9:33","book":"Rom","chapter":9,"verse":33,"letter":"a"},{"kind":"crossref","label":"1Pt 2:6","book":"1Pe","chapter":2,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Is 8:14","book":"Isa","chapter":8,"verse":14},{"label":"Is 26:4","book":"Isa","chapter":26,"verse":4},{"label":"Mt 21:42","book":"Mat","chapter":21,"verse":42},{"label":"Mk 12:10","book":"Mrk","chapter":12,"verse":10},{"label":"Lk 20:17","book":"Luk","chapter":20,"verse":17},{"label":"Ac 4:11","book":"Act","chapter":4,"verse":11},{"label":"1Co 3:11","book":"1Co","chapter":3,"verse":11},{"label":"Eph 2:20","book":"Eph","chapter":2,"verse":20},{"label":"Rm 9:33","book":"Rom","chapter":9,"verse":33},{"label":"1Pt 2:6","book":"1Pe","chapter":2,"verse":6}],"footnotes":[{"marker":1,"text":"Lit will not hurry"}]},{"verseId":"a556c5305ee15c3f-01:Isa:28:17","parts":[{"kind":"text","text":"And I will make justice the measuring line"},{"kind":"text","text":" and righteousness the mason’s level.” "},{"kind":"crossref","label":"2Kg 21:13","book":"2Ki","chapter":21,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 5:16","book":"Isa","chapter":5,"verse":16,"letter":"b"},{"kind":"crossref","label":"Is 30:18","book":"Isa","chapter":30,"verse":18,"letter":"c"},{"kind":"crossref","label":"Is 61:8","book":"Isa","chapter":61,"verse":8,"letter":"d"},{"kind":"crossref","label":"Am 7:7–9","book":"Amo","chapter":7,"verse":7,"letter":"e"},{"kind":"text","text":" Hail will sweep away the false refuge,"},{"kind":"text","text":" and water will flood your hiding place."}],"crossRefs":[{"label":"2Kg 21:13","book":"2Ki","chapter":21,"verse":13},{"label":"Is 5:16","book":"Isa","chapter":5,"verse":16},{"label":"Is 30:18","book":"Isa","chapter":30,"verse":18},{"label":"Is 61:8","book":"Isa","chapter":61,"verse":8},{"label":"Am 7:7–9","book":"Amo","chapter":7,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:18","parts":[{"kind":"text","text":"Your covenant with Death will be dissolved,"},{"kind":"text","text":" and your agreement with Sheol will not last."},{"kind":"text","text":" When the overwhelming catastrophe passes through,"},{"kind":"text","text":" you will be trampled."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:19","parts":[{"kind":"text","text":"Every time it passes through,"},{"kind":"text","text":" it will carry you away;"},{"kind":"text","text":" it will pass through every morning —"},{"kind":"text","text":" every day and every night."},{"kind":"text","text":" Only terror "},{"kind":"crossref","label":"2Ch 29:8","book":"2Ch","chapter":29,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jr 15:4","book":"Jer","chapter":15,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jr 24:9","book":"Jer","chapter":24,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jr 29:18","book":"Jer","chapter":29,"verse":18,"letter":"d"},{"kind":"text","text":" will cause you"},{"kind":"text","text":" to understand the message. "},{"kind":"footnote","marker":1,"text":"Or The understanding of the message will cause sheer terror"}],"crossRefs":[{"label":"2Ch 29:8","book":"2Ch","chapter":29,"verse":8},{"label":"Jr 15:4","book":"Jer","chapter":15,"verse":4},{"label":"Jr 24:9","book":"Jer","chapter":24,"verse":9},{"label":"Jr 29:18","book":"Jer","chapter":29,"verse":18}],"footnotes":[{"marker":1,"text":"Or The understanding of the message will cause sheer terror"}]},{"verseId":"a556c5305ee15c3f-01:Isa:28:20","parts":[{"kind":"text","text":"Indeed, the bed is too short to stretch out on,"},{"kind":"text","text":" and its cover too small to wrap up in."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:21","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will rise up as he did at Mount Perazim. "},{"kind":"crossref","label":"2Sm 5:20","book":"2Sa","chapter":5,"verse":20,"letter":"a"},{"kind":"crossref","label":"1Ch 14:11","book":"1Ch","chapter":14,"verse":11,"letter":"b"},{"kind":"text","text":" He will rise in wrath, as at the Valley of Gibeon, "},{"kind":"crossref","label":"Jos 10:10","book":"Jos","chapter":10,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jos 10:12","book":"Jos","chapter":10,"verse":12,"letter":"b"},{"kind":"crossref","label":"2Sm 5:25","book":"2Sa","chapter":5,"verse":25,"letter":"c"},{"kind":"crossref","label":"1Ch 14:16","book":"1Ch","chapter":14,"verse":16,"letter":"d"},{"kind":"text","text":" to do his work, his unexpected work,"},{"kind":"text","text":" and to perform his task, his unfamiliar task."}],"crossRefs":[{"label":"2Sm 5:20","book":"2Sa","chapter":5,"verse":20},{"label":"1Ch 14:11","book":"1Ch","chapter":14,"verse":11},{"label":"Jos 10:10","book":"Jos","chapter":10,"verse":10},{"label":"Jos 10:12","book":"Jos","chapter":10,"verse":12},{"label":"2Sm 5:25","book":"2Sa","chapter":5,"verse":25},{"label":"1Ch 14:16","book":"1Ch","chapter":14,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:22","parts":[{"kind":"text","text":"So now, do not scoff,"},{"kind":"text","text":" or your shackles will become stronger."},{"kind":"text","text":" Indeed, I have heard from the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" of Armies"},{"kind":"text","text":" a decree of destruction for the whole land. "},{"kind":"crossref","label":"Is 10:22–23","book":"Isa","chapter":10,"verse":22,"letter":"a"},{"kind":"crossref","label":"Rm 9:27–28","book":"Rom","chapter":9,"verse":27,"letter":"b"}],"crossRefs":[{"label":"Is 10:22–23","book":"Isa","chapter":10,"verse":22},{"label":"Rm 9:27–28","book":"Rom","chapter":9,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:23","parts":[{"kind":"text","text":"Listen and hear my voice."},{"kind":"text","text":" Pay attention and hear what I say."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:24","parts":[{"kind":"text","text":"Does the plowman plow every day to plant seed?"},{"kind":"text","text":" Does he continuously break up and cultivate the soil?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:25","parts":[{"kind":"text","text":"When he has leveled its surface,"},{"kind":"text","text":" does he not then scatter black cumin and sow cumin?"},{"kind":"text","text":" He plants wheat in rows and barley in plots,"},{"kind":"text","text":" with spelt as their border."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:26","parts":[{"kind":"text","text":"His God teaches him order;"},{"kind":"text","text":" he instructs him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:27","parts":[{"kind":"text","text":"Certainly black cumin is not threshed"},{"kind":"text","text":" with a threshing board,"},{"kind":"text","text":" and a cart wheel is not rolled over the cumin."},{"kind":"text","text":" But black cumin is beaten out with a stick,"},{"kind":"text","text":" and cumin with a rod."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:28","parts":[{"kind":"text","text":"Bread grain is crushed,"},{"kind":"text","text":" but is not threshed endlessly."},{"kind":"text","text":" Though the wheel of the farmer’s cart rumbles,"},{"kind":"text","text":" his horses do not crush it."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:28:29","parts":[{"kind":"text","text":"This also comes from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies."},{"kind":"text","text":" He gives wondrous advice;"},{"kind":"text","text":" he gives great wisdom. "},{"kind":"crossref","label":"Is 9:6","book":"Isa","chapter":9,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 32:19","book":"Jer","chapter":32,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Is 9:6","book":"Isa","chapter":9,"verse":6},{"label":"Jr 32:19","book":"Jer","chapter":32,"verse":19}],"footnotes":[]}]},"cachedAt":1783279545347}