"style":"divine"},{"kind":"text","text":", am your Savior "},{"kind":"crossref","label":"Is 43:3","book":"Isa","chapter":43,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 49:26","book":"Isa","chapter":49,"verse":26,"letter":"b"},{"kind":"text","text":" and Redeemer, "},{"kind":"crossref","label":"Is 41:14","book":"Isa","chapter":41,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 43:14","book":"Isa","chapter":43,"verse":14,"letter":"b"},{"kind":"text","text":" the Mighty One of Jacob. "},{"kind":"crossref","label":"Gn 49:24","book":"Gen","chapter":49,"verse":24,"letter":"c"},{"kind":"crossref","label":"Ps 132:2","book":"Psa","chapter":132,"verse":2,"letter":"d"},{"kind":"crossref","label":"Ps 132:5","book":"Psa","chapter":132,"verse":5,"letter":"e"},{"kind":"crossref","label":"Is 49:26","book":"Isa","chapter":49,"verse":26,"letter":"f"}],"crossRefs":[{"label":"Is 49:23","book":"Isa","chapter":49,"verse":23},{"label":"Is 66:11–12","book":"Isa","chapter":66,"verse":11},{"label":"Is 43:3","book":"Isa","chapter":43,"verse":3},{"label":"Is 49:26","book":"Isa","chapter":49,"verse":26},{"label":"Is 41:14","book":"Isa","chapter":41,"verse":14},{"label":"Is 43:14","book":"Isa","chapter":43,"verse":14},{"label":"Gn 49:24","book":"Gen","chapter":49,"verse":24},{"label":"Ps 132:2","book":"Psa","chapter":132,"verse":2},{"label":"Ps 132:5","book":"Psa","chapter":132,"verse":5},{"label":"Is 49:26","book":"Isa","chapter":49,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:60:17","parts":[{"kind":"text","text":"I will bring gold instead of bronze;"},{"kind":"text","text":" I will bring silver instead of iron,"},{"kind":"text","text":" bronze instead of wood,"},{"kind":"text","text":" and iron instead of stones."},{"kind":"text","text":" I will appoint peace as your government"},{"kind":"text","text":" and righteousness as your overseers."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:60:18","parts":[{"kind":"text","text":"Violence will never again be heard of in your land; "},{"kind":"crossref","label":"Is 11:9","book":"Isa","chapter":11,"verse":9,"letter":"a"},{"kind":"text","text":" devastation and destruction"},{"kind":"text","text":" will be gone from your borders."},{"kind":"text","text":" You will call your walls Salvation "},{"kind":"crossref","label":"Is 26:1","book":"Isa","chapter":26,"verse":1,"letter":"a"},{"kind":"text","text":" and your city gates Praise."}],"crossRefs":[{"label":"Is 11:9","book":"Isa","chapter":11,"verse":9},{"label":"Is 26:1","book":"Isa","chapter":26,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:60:19","parts":[{"kind":"text","text":"The sun will no longer be your light by day,"},{"kind":"text","text":" and the brightness of the moon will not shine on you."},{"kind":"text","text":" The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will be your everlasting light, "},{"kind":"crossref","label":"Zch 14:6","book":"Zec","chapter":14,"verse":6,"letter":"a"},{"kind":"crossref","label":"Rv 21:23","book":"Rev","chapter":21,"verse":23,"letter":"b"},{"kind":"crossref","label":"Rv 22:5","book":"Rev","chapter":22,"verse":5,"letter":"c"},{"kind":"text","text":" and your God will be your splendor."}],"crossRefs":[{"label":"Zch 14:6","book":"Zec","chapter":14,"verse":6},{"label":"Rv 21:23","book":"Rev","chapter":21,"verse":23},{"label":"Rv 22:5","book":"Rev","chapter":22,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:60:20","parts":[{"kind":"text","text":"Your sun will no longer set,"},{"kind":"text","text":" and your moon will not fade;"},{"kind":"text","text":" for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will be your everlasting light,"},{"kind":"text","text":" and the days of your sorrow will be over. "},{"kind":"crossref","label":"Is 35:10","book":"Isa","chapter":35,"verse":10,"letter":"a"},{"kind":"crossref","label":"Is 65:19","book":"Isa","chapter":65,"verse":19,"letter":"b"},{"kind":"crossref","label":"Rv 21:4","book":"Rev","chapter":21,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Is 35:10","book":"Isa","chapter":35,"verse":10},{"label":"Is 65:19","book":"Isa","chapter":65,"verse":19},{"label":"Rv 21:4","book":"Rev","chapter":21,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:60:21","parts":[{"kind":"text","text":"All your people will be righteous; "},{"kind":"crossref","label":"Is 52:1","book":"Isa","chapter":52,"verse":1,"letter":"a"},{"kind":"text","text":" they will possess the land forever; "},{"kind":"crossref","label":"Ps 37:9","book":"Psa","chapter":37,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25,"letter":"b"},{"kind":"text","text":" they are the branch I planted,"},{"kind":"text","text":" the work of my "},{"kind":"footnote","marker":1,"text":"LXX, DSS read his"},{"kind":"text","text":" hands,"},{"kind":"text","text":" so that I may be glorified. "},{"kind":"crossref","label":"Is 61:3","book":"Isa","chapter":61,"verse":3,"letter":"a"}],"crossRefs":[{"label":"Is 52:1","book":"Isa","chapter":52,"verse":1},{"label":"Ps 37:9","book":"Psa","chapter":37,"verse":9},{"label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25},{"label":"Is 61:3","book":"Isa","chapter":61,"verse":3}],"footnotes":[{"marker":1,"text":"LXX, DSS read his"}]},{"verseId":"a556c5305ee15c3f-01:Isa:60:22","parts":[{"kind":"text","text":"The least will become a thousand,"},{"kind":"text","text":" the smallest a mighty nation."},{"kind":"text","text":" I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"},{"kind":"text","text":" I will accomplish it quickly in its time."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279555122}