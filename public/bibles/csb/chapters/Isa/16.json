nd weak.”"}],"crossRefs":[{"label":"Jb 7:1","book":"Job","chapter":7,"verse":1},{"label":"Jb 14:6","book":"Job","chapter":14,"verse":6},{"label":"Is 21:16","book":"Isa","chapter":21,"verse":16}],"footnotes":[]}]},"cachedAt":1783279541913}