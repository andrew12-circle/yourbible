ext":"The one who lives righteously"},{"kind":"text","text":" and speaks rightly, "},{"kind":"crossref","label":"Ps 15:2","book":"Psa","chapter":15,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 24:4","book":"Psa","chapter":24,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 58:6–11","book":"Isa","chapter":58,"verse":6,"letter":"c"},{"kind":"text","text":" who refuses profit from extortion,"},{"kind":"text","text":" whose hand never takes a bribe,"},{"kind":"text","text":" who stops his ears from listening to murderous plots"},{"kind":"text","text":" and shuts his eyes against evil schemes "},{"kind":"crossref","label":"Ps 119:37","book":"Psa","chapter":119,"verse":37,"letter":"a"},{"kind":"text","text":" —"}],"crossRefs":[{"label":"Ps 15:2","book":"Psa","chapter":15,"verse":2},{"label":"Ps 24:4","book":"Psa","chapter":24,"verse":4},{"label":"Is 58:6–11","book":"Isa","chapter":58,"verse":6},{"label":"Ps 119:37","book":"Psa","chapter":119,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:16","parts":[{"kind":"text","text":"he will dwell on the heights;"},{"kind":"text","text":" his refuge will be the rocky fortresses,"},{"kind":"text","text":" his food provided, his water assured."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:17","parts":[{"kind":"text","text":"Your eyes will see the King in his beauty; "},{"kind":"crossref","label":"Is 6:5","book":"Isa","chapter":6,"verse":5,"letter":"a"},{"kind":"crossref","label":"Is 24:23","book":"Isa","chapter":24,"verse":23,"letter":"b"},{"kind":"crossref","label":"Is 33:21–22","book":"Isa","chapter":33,"verse":21,"letter":"c"},{"kind":"crossref","label":"Zch 9:9","book":"Zec","chapter":9,"verse":9,"letter":"d"},{"kind":"text","text":" you will see a vast land. "},{"kind":"crossref","label":"Is 54:2–3","book":"Isa","chapter":54,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Is 6:5","book":"Isa","chapter":6,"verse":5},{"label":"Is 24:23","book":"Isa","chapter":24,"verse":23},{"label":"Is 33:21–22","book":"Isa","chapter":33,"verse":21},{"label":"Zch 9:9","book":"Zec","chapter":9,"verse":9},{"label":"Is 54:2–3","book":"Isa","chapter":54,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:18","parts":[{"kind":"text","text":"Your mind will meditate on the past terror:"},{"kind":"text","text":" “Where is the accountant? "},{"kind":"footnote","marker":1,"text":"Lit counter"},{"kind":"text","text":" Where is the tribute collector? "},{"kind":"footnote","marker":1,"text":"Lit weigher"},{"kind":"text","text":" Where is the one who spied out our defenses?” "},{"kind":"footnote","marker":1,"text":"Lit who counts towers"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit counter"},{"marker":1,"text":"Lit weigher"},{"marker":1,"text":"Lit who counts towers"}]},{"verseId":"a556c5305ee15c3f-01:Isa:33:19","parts":[{"kind":"text","text":"You will no longer see the barbarians,"},{"kind":"text","text":" a people whose speech is difficult to comprehend —"},{"kind":"text","text":" who stammer in a language that is not understood. "},{"kind":"crossref","label":"Dt 28:49","book":"Deu","chapter":28,"verse":49,"letter":"a"},{"kind":"crossref","label":"Is 28:11","book":"Isa","chapter":28,"verse":11,"letter":"b"},{"kind":"crossref","label":"Jr 5:15","book":"Jer","chapter":5,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Dt 28:49","book":"Deu","chapter":28,"verse":49},{"label":"Is 28:11","book":"Isa","chapter":28,"verse":11},{"label":"Jr 5:15","book":"Jer","chapter":5,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:20","parts":[{"kind":"text","text":"Look at Zion, the city of our festival times."},{"kind":"text","text":" Your eyes will see Jerusalem,"},{"kind":"text","text":" a peaceful pasture, "},{"kind":"crossref","label":"Ps 46:5","book":"Psa","chapter":46,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 125:1–2","book":"Psa","chapter":125,"verse":1,"letter":"b"},{"kind":"crossref","label":"Is 32:18","book":"Isa","chapter":32,"verse":18,"letter":"c"},{"kind":"text","text":" a tent that does not wander;"},{"kind":"text","text":" its tent pegs will not be pulled up"},{"kind":"text","text":" nor will any of its cords be loosened. "},{"kind":"crossref","label":"Is 54:2","book":"Isa","chapter":54,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Ps 46:5","book":"Psa","chapter":46,"verse":5},{"label":"Ps 125:1–2","book":"Psa","chapter":125,"verse":1},{"label":"Is 32:18","book":"Isa","chapter":32,"verse":18},{"label":"Is 54:2","book":"Isa","chapter":54,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:21","parts":[{"kind":"text","text":"For the majestic one, our "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", will be there, "},{"kind":"crossref","label":"Rm 8:31","book":"Rom","chapter":8,"verse":31,"letter":"a"},{"kind":"text","text":" a place of rivers and broad streams"},{"kind":"text","text":" where ships that are rowed will not go,"},{"kind":"text","text":" and majestic vessels will not pass. "},{"kind":"crossref","label":"Is 41:18","book":"Isa","chapter":41,"verse":18,"letter":"a"},{"kind":"crossref","label":"Is 43:19–20","book":"Isa","chapter":43,"verse":19,"letter":"b"},{"kind":"crossref","label":"Is 48:18","book":"Isa","chapter":48,"verse":18,"letter":"c"},{"kind":"crossref","label":"Is 66:12","book":"Isa","chapter":66,"verse":12,"letter":"d"}],"crossRefs":[{"label":"Rm 8:31","book":"Rom","chapter":8,"verse":31},{"label":"Is 41:18","book":"Isa","chapter":41,"verse":18},{"label":"Is 43:19–20","book":"Isa","chapter":43,"verse":19},{"label":"Is 48:18","book":"Isa","chapter":48,"verse":18},{"label":"Is 66:12","book":"Isa","chapter":66,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:22","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is our Judge,"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is our Lawgiver, "},{"kind":"crossref","label":"Is 1:10","book":"Isa","chapter":1,"verse":10,"letter":"a"},{"kind":"crossref","label":"Is 51:4","book":"Isa","chapter":51,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 51:7","book":"Isa","chapter":51,"verse":7,"letter":"c"},{"kind":"crossref","label":"Jms 4:12","book":"Jas","chapter":4,"verse":12,"letter":"d"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is our King."},{"kind":"text","text":" He will save us. "},{"kind":"crossref","label":"2Sm 22:3","book":"2Sa","chapter":22,"verse":3,"letter":"a"},{"kind":"crossref","label":"2Sm 23:5","book":"2Sa","chapter":23,"verse":5,"letter":"b"},{"kind":"crossref","label":"2Kg 19:19","book":"2Ki","chapter":19,"verse":19,"letter":"c"},{"kind":"crossref","label":"2Kg 19:34","book":"2Ki","chapter":19,"verse":34,"letter":"d"},{"kind":"crossref","label":"Is 25:9","book":"Isa","chapter":25,"verse":9,"letter":"e"},{"kind":"crossref","label":"Is 35:4","book":"Isa","chapter":35,"verse":4,"letter":"f"},{"kind":"crossref","label":"Is 38:20","book":"Isa","chapter":38,"verse":20,"letter":"g"}],"crossRefs":[{"label":"Is 1:10","book":"Isa","chapter":1,"verse":10},{"label":"Is 51:4","book":"Isa","chapter":51,"verse":4},{"label":"Is 51:7","book":"Isa","chapter":51,"verse":7},{"label":"Jms 4:12","book":"Jas","chapter":4,"verse":12},{"label":"2Sm 22:3","book":"2Sa","chapter":22,"verse":3},{"label":"2Sm 23:5","book":"2Sa","chapter":23,"verse":5},{"label":"2Kg 19:19","book":"2Ki","chapter":19,"verse":19},{"label":"2Kg 19:34","book":"2Ki","chapter":19,"verse":34},{"label":"Is 25:9","book":"Isa","chapter":25,"verse":9},{"label":"Is 35:4","book":"Isa","chapter":35,"verse":4},{"label":"Is 38:20","book":"Isa","chapter":38,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:23","parts":[{"kind":"text","text":"Your ropes are slack;"},{"kind":"text","text":" they cannot hold the base of the mast"},{"kind":"text","text":" or spread out the flag."},{"kind":"text","text":" Then abundant spoil will be divided,"},{"kind":"text","text":" the lame will plunder it,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:33:24","parts":[{"kind":"text","text":"and none there will say, “I am sick.”"},{"kind":"text","text":" The people who dwell there"},{"kind":"text","text":" will be forgiven "},{"kind":"crossref","label":"Is 40:2","book":"Isa","chapter":40,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 44:22","book":"Isa","chapter":44,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jr 50:20","book":"Jer","chapter":50,"verse":20,"letter":"c"},{"kind":"crossref","label":"Mc 7:18","book":"Mic","chapter":7,"verse":18,"letter":"d"},{"kind":"crossref","label":"1Jn 1:7–9","book":"1Jn","chapter":1,"verse":7,"letter":"e"},{"kind":"text","text":" their iniquity. "},{"kind":"crossref","label":"Is 13:11","book":"Isa","chapter":13,"verse":11,"letter":"f"}],"crossRefs":[{"label":"Is 40:2","book":"Isa","chapter":40,"verse":2},{"label":"Is 44:22","book":"Isa","chapter":44,"verse":22},{"label":"Jr 50:20","book":"Jer","chapter":50,"verse":20},{"label":"Mc 7:18","book":"Mic","chapter":7,"verse":18},{"label":"1Jn 1:7–9","book":"1Jn","chapter":1,"verse":7},{"label":"Is 13:11","book":"Isa","chapter":13,"verse":11}],"footnotes":[]}]},"cachedAt":1783279546839}