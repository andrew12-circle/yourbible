":"crossref","label":"Is 46:7","book":"Isa","chapter":46,"verse":7,"letter":"c"},{"kind":"crossref","label":"Jr 10:5","book":"Jer","chapter":10,"verse":5,"letter":"d"},{"kind":"text","text":" have no knowledge. "},{"kind":"crossref","label":"Is 44:18–19","book":"Isa","chapter":44,"verse":18,"letter":"a"},{"kind":"crossref","label":"Is 48:5–7","book":"Isa","chapter":48,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Is 44:17","book":"Isa","chapter":44,"verse":17},{"label":"Is 46:1","book":"Isa","chapter":46,"verse":1},{"label":"Is 46:7","book":"Isa","chapter":46,"verse":7},{"label":"Jr 10:5","book":"Jer","chapter":10,"verse":5},{"label":"Is 44:18–19","book":"Isa","chapter":44,"verse":18},{"label":"Is 48:5–7","book":"Isa","chapter":48,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:45:21","parts":[{"kind":"text","text":"Speak up and present your case "},{"kind":"footnote","marker":1,"text":"Lit and approach"},{"kind":"crossref","label":"Is 41:21–23","book":"Isa","chapter":41,"verse":21,"letter":"a"},{"kind":"crossref","label":"Is 43:9","book":"Isa","chapter":43,"verse":9,"letter":"b"},{"kind":"text","text":" —"},{"kind":"text","text":" yes, let them consult each other."},{"kind":"text","text":" Who predicted this long ago?"},{"kind":"text","text":" Who announced it from ancient times?"},{"kind":"text","text":" Was it not I, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"},{"kind":"text","text":" There is no other God but me,"},{"kind":"text","text":" a righteous God and Savior; "},{"kind":"crossref","label":"Is 43:3","book":"Isa","chapter":43,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 43:11","book":"Isa","chapter":43,"verse":11,"letter":"b"},{"kind":"text","text":" there is no one except me. "},{"kind":"crossref","label":"Dt 4:35","book":"Deu","chapter":4,"verse":35,"letter":"a"},{"kind":"crossref","label":"Dt 6:4","book":"Deu","chapter":6,"verse":4,"letter":"b"},{"kind":"crossref","label":"Mk 12:32","book":"