{"key":"a556c5305ee15c3f-01|Isa|15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","chapter":15,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Isa:15:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":1,"text":"A pronouncement concerning Moab: Ar in Moab is devastated, destroyed in a night. Kir in Moab is devastated, destroyed in a night.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":2,"text":"Dibon went up to its temple to weep at its high places. Moab wails on Nebo and at Medeba. Every head is shaved; every beard is chopped short.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":3,"text":"In its streets they wear sackcloth; on its rooftops and in its public squares everyone wails, falling down and weeping.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":4,"text":"Heshbon and Elealeh cry out; their voices are heard as far away as Jahaz. Therefore the soldiers of Moab cry out, and they tremble.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":5,"text":"My heart cries out over Moab, whose fugitives flee as far as Zoar, to Eglath-shelishiyah; they go up the Ascent of Luhith weeping; they raise a cry of destruction on the road to Horonaim.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":6,"text":"The Waters of Nimrim are desolate; the grass is withered, the foliage is gone, and the vegetation has vanished.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":7,"text":"So they carry their wealth and belongings over the Wadi of the Willows.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":8,"text":"For their cry echoes throughout the territory of Moab. Their wailing reaches Eglaim; their wailing reaches Beer-elim.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Isa:15:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","bookOrder":22,"chapter":15,"verse":9,"text":"The Waters of Dibon are full of blood, but I will bring on Dibon even more than this — a lion for those who escape from Moab, and for the survivors in the land.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Isa","chapter":15,"paragraphStarts":[1,2,3,4,5,6,7,8,9],"headings":[{"beforeVerse":1,"text":"A Pronouncement against Moab"}],"poetryBlocks":[{"beforeVerse":2,"level":1},{"beforeVerse":3,"level":1},{"beforeVerse":4,"level":1},{"beforeVerse":5,"level":1},{"beforeVerse":6,"level":1},{"beforeVerse":7,"level":1},{"beforeVerse":8,"level":1},{"beforeVerse":9,"level":1}],"studyByVerse":[{"verseId":"a556c5305ee15c3f-01:Isa:15:1","parts":[{"kind":"text","text":"A pronouncement concerning Moab: "},{"kind":"crossref","label":"Gn 19:31–37","book":"Gen","chapter":19,"verse":31,"letter":"a"},{"kind":"crossref","label":"Is 11:14","book":"Isa","chapter":11,"verse":14,"letter":"b"},{"kind":"crossref","label":"Is 25:10","book":"Isa","chapter":25,"verse":10,"letter":"c"},{"kind":"crossref","label":"Jr 48:1–38","book":"Jer","chapter":48,"verse":1,"letter":"d"},{"kind":"crossref","label":"Ezk 25:8–11","book":"Ezk","chapter":25,"verse":8,"letter":"e"},{"kind":"crossref","label":"Am 2:1–3","book":"Amo","chapter":2,"verse":1,"letter":"f"},{"kind":"crossref","label":"Zp 2:8","book":"Zep","chapter":2,"verse":8,"letter":"g"},{"kind":"text","text":" Ar in Moab is devastated, "},{"kind":"crossref","label":"Nm 21:28","book":"Num","chapter":21,"verse":28,"letter":"a"},{"kind":"text","text":" destroyed in a night."},{"kind":"text","text":" Kir in Moab is devastated,"},{"kind":"text","text":" destroyed in a night."}],"crossRefs":[{"label":"Gn 19:31–37","book":"Gen","chapter":19,"verse":31},{"label":"Is 11:14","book":"Isa","chapter":11,"verse":14},{"label":"Is 25:10","book":"Isa","chapter":25,"verse":10},{"label":"Jr 48:1–38","book":"Jer","chapter":48,"verse":1},{"label":"Ezk 25:8–11","book":"Ezk","chapter":25,"verse":8},{"label":"Am 2:1–3","book":"Amo","chapter":2,"verse":1},{"label":"Zp 2:8","book":"Zep","chapter":2,"verse":8},{"label":"Nm 21:28","book":"Num","chapter":21,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:15:2","parts":[{"kind":"text","text":"Dibon went up to its temple"},{"kind":"text","text":" to weep at its high places."},{"kind":"text","text":" Moab wails on Nebo and at "},{"kind":"footnote","marker":1,"text":"Or wails over Nebo and over"},{"kind":"text","text":" Medeba."},{"kind":"text","text":" Every head is shaved;"},{"kind":"text","text":" every beard is chopped short."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or wails over Nebo and over"}]},{"verseId":"a556c5305ee15c3f-01:Isa:15:3","parts":[{"kind":"text","text":"In its streets they wear sackcloth;"},{"kind":"text","text":" on its rooftops and in its public squares everyone wails,"},{"kind":"text","text":" falling down and weeping."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:15:4","parts":[{"kind":"text","text":"Heshbon and Elealeh cry out;"},{"kind":"text","text":" their voices are heard as far away as Jahaz. "},{"kind":"crossref","label":"Nm 21:28","book":"Num","chapter":21,"verse":28,"letter":"a"},{"kind":"crossref","label":"Nm 32:3","book":"Num","chapter":32,"verse":3,"letter":"