[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:10","parts":[{"kind":"text","text":"Who makes a god or casts a metal image"},{"kind":"text","text":" that benefits no one? "},{"kind":"crossref","label":"Is 41:29","book":"Isa","chapter":41,"verse":29,"letter":"a"},{"kind":"crossref","label":"Jr 10:5","book":"Jer","chapter":10,"verse":5,"letter":"b"},{"kind":"crossref","label":"Hab 2:18","book":"Hab","chapter":2,"verse":18,"letter":"c"},{"kind":"crossref","label":"Ac 19:26","book":"Act","chapter":19,"verse":26,"letter":"d"}],"crossRefs":[{"label":"Is 41:29","book":"Isa","chapter":41,"verse":29},{"label":"Jr 10:5","book":"Jer","chapter":10,"verse":5},{"label":"Hab 2:18","book":"Hab","chapter":2,"verse":18},{"label":"Ac 19:26","book":"Act","chapter":19,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:11","parts":[{"kind":"text","text":"Look, all its worshipers will be put to shame,"},{"kind":"text","text":" and the craftsmen are humans."},{"kind":"text","text":" They all will assemble and stand;"},{"kind":"text","text":" they all will be startled and put to shame."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:12","parts":[{"kind":"text","text":"The ironworker labors over the coals,"},{"kind":"text","text":" shapes the idol with hammers,"},{"kind":"text","text":" and works it with his strong arm."},{"kind":"text","text":" Also he grows hungry and his strength fails;"},{"kind":"text","text":" he doesn’t drink water and is faint."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:13","parts":[{"kind":"text","text":"The woodworker stretches out a measuring line,"},{"kind":"text","text":" he outlines it with a stylus;"},{"kind":"text","text":" he shapes it with chisels"},{"kind":"text","text":" and outlines it with a compass."},{"kind":"text","text":" He makes it according to a human form, "},{"kind":"crossref","label":"Ps 115:5–7","book":"Psa","chapter":115,"verse":5,"letter":"a"},{"kind":"text","text":" like a beautiful person,"},{"kind":"text","text":" to dwell in a temple."}],"crossRefs":[{"label":"Ps 115:5–7","book":"Psa","chapter":115,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:14","parts":[{"kind":"text","text":"He cuts down "},{"kind":"footnote","marker":1,"text":"Lit To cut down for himself"},{"kind":"text","text":" cedars for his use,"},{"kind":"text","text":" or he takes a cypress or an oak."},{"kind":"text","text":" He lets it grow strong among the trees of the forest."},{"kind":"text","text":" He plants a laurel, and the rain makes it grow."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit To cut down for himself"}]},{"verseId":"a556c5305ee15c3f-01:Isa:44:15","parts":[{"kind":"text","text":"A person can use it for fuel."},{"kind":"text","text":" He takes some of it and warms himself;"},{"kind":"text","text":" also he kindles a fire and bakes bread;"},{"kind":"text","text":" he even makes it into a god and worships it;"},{"kind":"text","text":" he makes an idol from it and bows down to it."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:16","parts":[{"kind":"text","text":"He burns half of it in a fire,"},{"kind":"text","text":" and he roasts meat on that half."},{"kind":"text","text":" He eats the roast and is satisfied."},{"kind":"text","text":" He warms himself and says, “Ah!"},{"kind":"text","text":" I am warm, I see the blaze.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:17","parts":[{"kind":"text","text":"He makes a god or his idol with the rest of it."},{"kind":"text","text":" He bows down to it and worships;"},{"kind":"text","text":" he prays to it, "},{"kind":"crossref","label":"1Kg 18:26","book":"1Ki","chapter":18,"verse":26,"letter":"a"},{"kind":"crossref","label":"1Kg 18:28","book":"1Ki","chapter":18,"verse":28,"letter":"b"},{"kind":"crossref","label":"Is 45:20","book":"Isa","chapter":45,"verse":20,"letter":"c"},{"kind":"text","text":" “Save me, for you are my god.”"}],"crossRefs":[{"label":"1Kg 18:26","book":"1Ki","chapter":18,"verse":26},{"label":"1Kg 18:28","book":"1Ki","chapter":18,"verse":28},{"label":"Is 45:20","book":"Isa","chapter":45,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:18","parts":[{"kind":"text","text":"Such people "},{"kind":"footnote","marker":1,"text":"Lit They"},{"kind":"text","text":" do not comprehend"},{"kind":"text","text":" and cannot understand,"},{"kind":"text","text":" for he has shut their eyes "},{"kind":"footnote","marker":1,"text":"Or for their eyes are shut"},{"kind":"text","text":" so they cannot see,"},{"kind":"text","text":" and their minds so they cannot understand."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit They"},{"marker":1,"text":"Or for their eyes are shut"}]},{"verseId":"a556c5305ee15c3f-01:Isa:44:19","parts":[{"kind":"text","text":"No one comes to his senses; "},{"kind":"footnote","marker":1,"text":"Lit No one returns to his heart"},{"kind":"text","text":" no one has the perception or insight to say,"},{"kind":"text","text":" “I burned half of it in the fire,"},{"kind":"text","text":" I also baked bread on its coals,"},{"kind":"text","text":" I roasted meat and ate."},{"kind":"text","text":" Should I make something detestable "},{"kind":"crossref","label":"Dt 27:15","book":"Deu","chapter":27,"verse":15,"letter":"a"},{"kind":"crossref","label":"1Kg 11:5","book":"1Ki","chapter":11,"verse":5,"letter":"b"},{"kind":"crossref","label":"1Kg 11:7","book":"1Ki","chapter":11,"verse":7,"letter":"c"},{"kind":"crossref","label":"2Kg 23:13","book":"2Ki","chapter":23,"verse":13,"letter":"d"},{"kind":"text","text":" with the rest of it?"},{"kind":"text","text":" Should I bow down to a block of wood?”"}],"crossRefs":[{"label":"Dt 27:15","book":"Deu","chapter":27,"verse":15},{"label":"1Kg 11:5","book":"1Ki","chapter":11,"verse":5},{"label":"1Kg 11:7","book":"1Ki","chapter":11,"verse":7},{"label":"2Kg 23:13","book":"2Ki","chapter":23,"verse":13}],"footnotes":[{"marker":1,"text":"Lit No one returns to his heart"}]},{"verseId":"a556c5305ee15c3f-01:Isa:44:20","parts":[{"kind":"text","text":"He feeds on "},{"kind":"footnote","marker":1,"text":"Or He shepherds"},{"kind":"text","text":" ashes."},{"kind":"text","text":" His deceived mind has led him astray,"},{"kind":"text","text":" and he cannot rescue himself,"},{"kind":"text","text":" or say, “Isn’t there a lie in my right hand?” "},{"kind":"crossref","label":"Is 57:11","book":"Isa","chapter":57,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 59:3–4","book":"Isa","chapter":59,"verse":3,"letter":"b"},{"kind":"crossref","label":"Is 59:13","book":"Isa","chapter":59,"verse":13,"letter":"c"},{"kind":"crossref","label":"Rm 1:25","book":"Rom","chapter":1,"verse":25,"letter":"d"}],"crossRefs":[{"label":"Is 57:11","book":"Isa","chapter":57,"verse":11},{"label":"Is 59:3–4","book":"Isa","chapter":59,"verse":3},{"label":"Is 59:13","book":"Isa","chapter":59,"verse":13},{"label":"Rm 1:25","book":"Rom","chapter":1,"verse":25}],"footnotes":[{"marker":1,"text":"Or He shepherds"}]},{"verseId":"a556c5305ee15c3f-01:Isa:44:21","parts":[{"kind":"text","text":"Remember these things, Jacob,"},{"kind":"text","text":" and Israel, for you are my servant;"},{"kind":"text","text":" I formed you, you are my servant;"},{"kind":"text","text":" Israel, you will never be forgotten by me. "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Tg read Israel, do not forget me"},{"kind":"crossref","label":"Is 49:15","book":"Isa","chapter":49,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Is 49:15","book":"Isa","chapter":49,"verse":15}],"footnotes":[{"marker":1,"text":"DSS, LXX, Tg read Israel, do not forget me"}]},{"verseId":"a556c5305ee15c3f-01:Isa:44:22","parts":[{"kind":"text","text":"I have swept away your transgressions like a cloud, "},{"kind":"crossref","label":"Ps 51:1","book":"Psa","chapter":51,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 51:9","book":"Psa","chapter":51,"verse":9,"letter":"b"},{"kind":"crossref","label":"Is 43:25","book":"Isa","chapter":43,"verse":25,"letter":"c"},{"kind":"crossref","label":"Ac 3:19","book":"Act","chapter":3,"verse":19,"letter":"d"},{"kind":"text","text":" and your sins like a mist."},{"kind":"text","text":" Return to me, "},{"kind":"crossref","label":"Is 31:6","book":"Isa","chapter":31,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 55:7","book":"Isa","chapter":55,"verse":7,"letter":"b"},{"kind":"text","text":" for I have redeemed you. "},{"kind":"crossref","label":"Is 43:1","book":"Isa","chapter":43,"verse":1,"letter":"a"},{"kind":"crossref","label":"Is 48:20","book":"Isa","chapter":48,"verse":20,"letter":"b"},{"kind":"crossref","label":"1Co 6:20","book":"1Co","chapter":6,"verse":20,"letter":"c"},{"kind":"crossref","label":"1Pt 1:18","book":"1Pe","chapter":1,"verse":18,"letter":"d"}],"crossRefs":[{"label":"Ps 51:1","book":"Psa","chapter":51,"verse":1},{"label":"Ps 51:9","book":"Psa","chapter":51,"verse":9},{"label":"Is 43:25","book":"Isa","chapter":43,"verse":25},{"label":"Ac 3:19","book":"Act","chapter":3,"verse":19},{"label":"Is 31:6","book":"Isa","chapter":31,"verse":6},{"label":"Is 55:7","book":"Isa","chapter":55,"verse":7},{"label":"Is 43:1","book":"Isa","chapter":43,"verse":1},{"label":"Is 48:20","book":"Isa","chapter":48,"verse":20},{"label":"1Co 6:20","book":"1Co","chapter":6,"verse":20},{"label":"1Pt 1:18","book":"1Pe","chapter":1,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:23","parts":[{"kind":"text","text":"Rejoice, heavens, "},{"kind":"crossref","label":"Ps 69:34","book":"Psa","chapter":69,"verse":34,"letter":"a"},{"kind":"crossref","label":"Ps 96:11–12","book":"Psa","chapter":96,"verse":11,"letter":"b"},{"kind":"crossref","label":"Is 42:10","book":"Isa","chapter":42,"verse":10,"letter":"c"},{"kind":"crossref","label":"Is 49:13","book":"Isa","chapter":49,"verse":13,"letter":"d"},{"kind":"text","text":" for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has acted;"},{"kind":"text","text":" shout, depths of the earth."},{"kind":"text","text":" Break out into singing, mountains,"},{"kind":"text","text":" forest, and every tree in it."},{"kind":"text","text":" For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has redeemed Jacob,"},{"kind":"text","text":" and glorifies himself through Israel. "},{"kind":"crossref","label":"Is 49:3","book":"Isa","chapter":49,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 61:3","book":"Isa","chapter":61,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Ps 69:34","book":"Psa","chapter":69,"verse":34},{"label":"Ps 96:11–12","book":"Psa","chapter":96,"verse":11},{"label":"Is 42:10","book":"Isa","chapter":42,"verse":10},{"label":"Is 49:13","book":"Isa","chapter":49,"verse":13},{"label":"Is 49:3","book":"Isa","chapter":49,"verse":3},{"label":"Is 61:3","book":"Isa","chapter":61,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:24","parts":[{"kind":"text","text":"This is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", your Redeemer "},{"kind":"crossref","label":"Is 41:14","book":"Isa","chapter":41,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 43:14","book":"Isa","chapter":43,"verse":14,"letter":"b"},{"kind":"text","text":" who formed you from the womb, "},{"kind":"crossref","label":"Is 44:2","book":"Isa","chapter":44,"verse":2,"letter":"c"},{"kind":"text","text":" says:"},{"kind":"text","text":" I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", who made everything;"},{"kind":"text","text":" who stretched out the heavens by myself; "},{"kind":"crossref","label":"Is 40:22","book":"Isa","chapter":40,"verse":22,"letter":"a"},{"kind":"crossref","label":"Is 42:5","book":"Isa","chapter":42,"verse":5,"letter":"b"},{"kind":"crossref","label":"Is 45:12","book":"Isa","chapter":45,"verse":12,"letter":"c"},{"kind":"crossref","label":"Is 45:18","book":"Isa","chapter":45,"verse":18,"letter":"d"},{"kind":"crossref","label":"Is 51:13","book":"Isa","chapter":51,"verse":13,"letter":"e"},{"kind":"text","text":" who alone spread out the earth;"}],"crossRefs":[{"label":"Is 41:14","book":"Isa","chapter":41,"verse":14},{"label":"Is 43:14","book":"Isa","chapter":43,"verse":14},{"label":"Is 44:2","book":"Isa","chapter":44,"verse":2},{"label":"Is 40:22","book":"Isa","chapter":40,"verse":22},{"label":"Is 42:5","book":"Isa","chapter":42,"verse":5},{"label":"Is 45:12","book":"Isa","chapter":45,"verse":12},{"label":"Is 45:18","book":"Isa","chapter":45,"verse":18},{"label":"Is 51:13","book":"Isa","chapter":51,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:25","parts":[{"kind":"text","text":"who destroys the omens of the false prophets"},{"kind":"text","text":" and makes fools of diviners;"},{"kind":"text","text":" who confounds the wise"},{"kind":"text","text":" and makes their knowledge foolishness; "},{"kind":"crossref","label":"2Sm 15:31","book":"2Sa","chapter":15,"verse":31,"letter":"a"},{"kind":"crossref","label":"Jb 5:12","book":"Job","chapter":5,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ps 33:10","book":"Psa","chapter":33,"verse":10,"letter":"c"},{"kind":"crossref","label":"Is 29:14","book":"Isa","chapter":29,"verse":14,"letter":"d"},{"kind":"crossref","label":"Jr 51:57","book":"Jer","chapter":51,"verse":57,"letter":"e"},{"kind":"crossref","label":"1Co 1:20","book":"1Co","chapter":1,"verse":20,"letter":"f"},{"kind":"crossref","label":"1Co 1:27","book":"1Co","chapter":1,"verse":27,"letter":"g"}],"crossRefs":[{"label":"2Sm 15:31","book":"2Sa","chapter":15,"verse":31},{"label":"Jb 5:12","book":"Job","chapter":5,"verse":12},{"label":"Ps 33:10","book":"Psa","chapter":33,"verse":10},{"label":"Is 29:14","book":"Isa","chapter":29,"verse":14},{"label":"Jr 51:57","book":"Jer","chapter":51,"verse":57},{"label":"1Co 1:20","book":"1Co","chapter":1,"verse":20},{"label":"1Co 1:27","book":"1Co","chapter":1,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:26","parts":[{"kind":"text","text":"who confirms the message of his servant"},{"kind":"text","text":" and fulfills the counsel of his messengers;"},{"kind":"text","text":" who says to Jerusalem, “She will be inhabited,”"},{"kind":"text","text":" and to the cities of Judah, “They will be rebuilt,”"},{"kind":"text","text":" and I will restore her ruins;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:27","parts":[{"kind":"text","text":"who says to the depths of the sea, “Be dry,”"},{"kind":"text","text":" and I will dry up your rivers;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:44:28","parts":[{"kind":"text","text":"who says to Cyrus, "},{"kind":"crossref","label":"Is 45:1","book":"Isa","chapter":45,"verse":1,"letter":"a"},{"kind":"text","text":" “My shepherd,"},{"kind":"text","text":" he will fulfill all my pleasure” "},{"kind":"crossref","label":"Eph 1:9","book":"Eph","chapter":1,"verse":9,"letter":"a"},{"kind":"text","text":" and says to Jerusalem, “She will be rebuilt,” "},{"kind":"crossref","label":"2Ch 36:22–23","book":"2Ch","chapter":36,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ezr 1:1","book":"Ezr","chapter":1,"verse":1,"letter":"b"},{"kind":"crossref","label":"Is 14:32","book":"Isa","chapter":14,"verse":32,"letter":"c"},{"kind":"crossref","label":"Is 45:13","book":"Isa","chapter":45,"verse":13,"letter":"d"},{"kind":"crossref","label":"Is 54:11","book":"Isa","chapter":54,"verse":11,"letter":"e"},{"kind":"text","text":" and of the temple, “Its foundation will be laid.”"}],"crossRefs":[{"label":"Is 45:1","book":"Isa","chapter":45,"verse":1},{"label":"Eph 1:9","book":"Eph","chapter":1,"verse":9},{"label":"2Ch 36:22–23","book":"2Ch","chapter":36,"verse":22},{"label":"Ezr 1:1","book":"Ezr","chapter":1,"verse":1},{"label":"Is 14:32","book":"Isa","chapter":14,"verse":32},{"label":"Is 45:13","book":"Isa","chapter":45,"verse":13},{"label":"Is 54:11","book":"Isa","chapter":54,"verse":11}],"footnotes":[]}]},"cachedAt":1783279550159}