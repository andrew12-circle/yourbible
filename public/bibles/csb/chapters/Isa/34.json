ng,"},{"kind":"text","text":" and all her princes will come to nothing."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:34:13","parts":[{"kind":"text","text":"Her palaces will be overgrown with thorns;"},{"kind":"text","text":" her fortified cities, with thistles and briers. "},{"kind":"crossref","label":"Is 32:13","book":"Isa","chapter":32,"verse":13,"letter":"a"},{"kind":"text","text":" She will become a dwelling for jackals,"},{"kind":"text","text":" an abode "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Syr, Tg; MT reads jackals, grass"},{"kind":"text","text":" for ostriches. "},{"kind":"crossref","label":"Ps 44:19","book":"Psa","chapter":44,"verse":19,"letter":"a"},{"kind":"crossref","label":"Is 13:22","book":"Isa","chapter":13,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jr 9:11","book":"Jer","chapter":9,"verse":11,"letter":"c"},{"kind":"crossref","label":"Jr 10:22","book":"Jer","chapter":10,"verse":22,"letter":"d"},{"kind":"crossref","label":"Mal 1:3","book":"Mal","chapter":1,"verse":3,"letter":"e"}],"crossRefs":[{"label":"Is 32:13","book":"Isa","chapter":32,"verse":13},{"label":"Ps 44:19","book":"Psa","chapter":44,"verse":19},{"label":"Is 13:22","book":"Isa","chapter":13,"verse":22},{"label":"Jr 9:11","book":"Jer","chapter":9,"verse":11},{"label":"Jr 10:22","book":"Jer","chapter":10,"verse":22},{"label":"Mal 1:3","book":"Mal","chapter":1,"verse":3}],"footnotes":[{"marker":1,"text":"DSS, LXX, Syr, Tg; MT reads jackals, grass"}]},{"verseId":"a556c5305ee15c3f-01:Isa:34:14","parts":[{"kind":"text","text":"The desert creatures will meet hyenas,"},{"kind":"text","text":" and one wild goat will call to another."},{"kind":"text","text":" Indeed, the night birds will stay there"},{"kind":"text","text":" and will find a resting place."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:34:15","parts":[{"kind":"text","text":"Sand partridges "},{"kind":"footnote","marker":1,"text":"Or Arrow snakes, or Owls"},{"kind":"text","text":" will make their nests there;"},{"kind":"text","text":" they will lay and hatch their eggs"},{"kind":"text","text":" and will gather their broods under their shadows."},{"kind":"text","text":" Indeed, the birds of prey will gather there,"},{"kind":"text","text":" each with its mate. "},{"kind":"crossref","label":"Dt 14:13","book":"Deu","chapter":14,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Dt 14:13","book":"Deu","chapter":14,"verse":13}],"footnotes":[{"marker":1,"text":"Or Arrow snakes, or Owls"}]},{"verseId":"a556c5305ee15c3f-01:Isa:34:16","parts":[{"kind":"text","text":"Search and read the scroll of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":": "},{"kind":"crossref","label":"Ps 40:7","book":"Psa","chapter":40,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ps 139:16","book":"Psa","chapter":139,"verse":16,"letter":"b"},{"kind":"crossref","label":"Is 8:16","book":"Isa","chapter":8,"verse":16,"letter":"c"},{"kind":"crossref","label":"Is 30:8","book":"Isa","chapter":30,"verse":8,"letter":"d"},{"kind":"crossref","label":"Dn 7:10","book":"Dan","chapter":7,"verse":10,"letter":"e"},{"kind":"crossref","label":"Mal 3:16","book":"Mal","chapter":3,"verse":16,"letter":"f"},{"kind":"crossref","label":"Rv 20:12","book":"Rev","chapter":20,"verse":12,"letter":"g"},{"kind":"text","text":" Not one of them will be missing,"},{"kind":"text","text":" none will be lacking its mate,"},{"kind":"text","text":" because he has ordered it by my "},{"kind":"footnote","marker":1,"text":"Some Hb mss; other Hb mss, DSS, Syr, Tg read his"},{"kind":"text","text":" mouth,"},{"kind":"text","text":" and he will gather them by his Spirit."}],"crossRefs":[{"label":"Ps 40:7","book":"Psa","chapter":40,"verse":7},{"label":"Ps 139:16","book":"Psa","chapter":139,"verse":16},{"label":"Is 8:16","book":"Isa","chapter":8,"verse":16},{"label":"Is 30:8","book":"Isa","chapter":30,"verse":8},{"label":"Dn 7:10","book":"Dan","chapter":7,"verse":10},{"label":"Mal 3:16","book":"Mal","chapter":3,"verse":16},{"label":"Rv 20:12","book":"Rev","chapter":20,"verse":12}],"footnotes":[{"marker":1,"text":"Some Hb mss; other Hb mss, DSS, Syr, Tg read his"}]},{"verseId":"a556c5305ee15c3f-01:Isa:34:17","parts":[{"kind":"text","text":"He has cast the lot for them;"},{"kind":"text","text":" his hand allotted their portion with a measuring line."},{"kind":"text","text":" They will possess it forever; "},{"kind":"crossref","label":"Nm 24:18","book":"Num","chapter":24,"verse":18,"letter":"a"},{"kind":"text","text":" they will dwell in it from generation to generation."}],"crossRefs":[{"label":"Nm 24:18","book":"Num","chapter":24,"verse":18}],"footnotes":[]}]},"cachedAt":1783279547137}