":"Jr 49:13","book":"Jer","chapter":49,"verse":13},{"label":"Jr 49:22","book":"Jer","chapter":49,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:34:7","parts":[{"kind":"text","text":"The wild oxen will be struck "},{"kind":"footnote","marker":1,"text":"Or will go"},{"kind":"text","text":" down with them,"},{"kind":"text","text":" and young bulls with the mighty bulls."},{"kind":"text","text":" Their land will be soaked with "},{"kind":"footnote","marker":1,"text":"Or will drink its fill of"},{"kind":"text","text":" blood,"},{"kind":"text","text":" and their soil will be saturated with fat."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or will go"},{"marker":1,"text":"Or will drink its fill of"}]},{"verseId":"a556c5305ee15c3f-01:Isa:34:8","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has a day of vengeance, "},{"kind":"crossref","label":"Is 13:6","book":"Isa","chapter":13,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 35:4","book":"Isa","chapter":35,"verse":4,"letter":"b"},{"kind":"crossref","label":"Is 47:3","book":"Isa","chapter":47,"verse":3,"letter":"c"},{"kind":"crossref","label":"Is 61:2","book":"Isa","chapter":61,"verse":2,"letter":"d"},{"kind":"crossref","label":"Is 63:4","book":"Isa","chapter":63,"verse":4,"letter":"e"},{"kind":"text","text":" a time of paying back Edom"},{"kind":"text","text":" for its hostility against Zion."}],"crossRefs":[{"label":"Is 13:6","book":"Isa","chapter":13,"verse":6},{"label":"Is 35:4","book":"Isa","chapter":35,"verse":4},{"label":"Is 47:3","book":"Isa","chapter":47,"verse":3},{"label":"Is 61:2","book":"Isa","chapter":61,"verse":2},{"label":"Is 63:4","book":"Isa","chapter":63,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:34:9","parts":[{"kind":"text","text":"Edom’s streams will be turned into pitch,"},{"kind":"text","text":" her soil into sulfur; "},{"kind":"crossref","label":"Gn 19:24","book":"Gen","chapter":19,"