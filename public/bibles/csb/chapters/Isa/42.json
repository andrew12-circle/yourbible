":"crossref","label":"Lk 1:78–79","book":"Luk","chapter":1,"verse":78,"letter":"e"},{"kind":"text","text":" I will guide them on paths they have not known."},{"kind":"text","text":" I will turn darkness to light in front of them "},{"kind":"crossref","label":"Eph 5:8","book":"Eph","chapter":5,"verse":8,"letter":"a"},{"kind":"text","text":" and rough places into level ground. "},{"kind":"crossref","label":"Is 40:4","book":"Isa","chapter":40,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lk 3:5","book":"Luk","chapter":3,"verse":5,"letter":"b"},{"kind":"text","text":" This is what I will do for them,"},{"kind":"text","text":" and I will not abandon them. "},{"kind":"crossref","label":"Jos 1:5","book":"Jos","chapter":1,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 94:14","book":"Psa","chapter":94,"verse":14,"letter":"b"},{"kind":"crossref","label":"Is 41:17","book":"Isa","chapter":41,"verse":17,"letter":"c"},{"kind":"crossref","label":"Heb 13:5","book":"Heb","chapter":13,"verse":5,"letter":"d"}],"crossRefs":[{"label":"Is 29:18","book":"Isa","chapter":29,"verse":18},{"label":"Is 30:21","book":"Isa","chapter":30,"verse":21},{"label":"Is 32:3","book":"Isa","chapter":32,"verse":3},{"label":"Jr 31:8–9","book":"Jer","chapter":31,"verse":8},{"label":"Lk 1:78–79","book":"Luk","chapter":1,"verse":78},{"label":"Eph 5:8","book":"Eph","chapter":5,"verse":8},{"label":"Is 40:4","book":"Isa","chapter":40,"verse":4},{"label":"Lk 3:5","book":"Luk","chapter":3,"verse":5},{"label":"Jos 1:5","book":"Jos","chapter":1,"verse":5},{"label":"Ps 94:14","book":"Psa","chapter":94,"verse":14},{"label":"Is 41:17","book":"Isa","chapter":41,"verse":17},{"label":"Heb 13:5","book":"Heb","chapter":13,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:17","parts":[{"kind":"text","text":"They will be turned back and utterly ashamed —"},{"kind":"text","text":" those who trust in an idol"},{"kind":"text","text":" and say to a cast image,"},{"kind":"text","text":" ‘You are our gods!’ "},{"kind":"crossref","label":"Ps 97:7","book":"Psa","chapter":97,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 1:29","book":"Isa","chapter":1,"verse":29,"letter":"b"},{"kind":"crossref","label":"Is 44:9","book":"Isa","chapter":44,"verse":9,"letter":"c"},{"kind":"crossref","label":"Is 44:11","book":"Isa","chapter":44,"verse":11,"letter":"d"},{"kind":"crossref","label":"Is 45:16","book":"Isa","chapter":45,"verse":16,"letter":"e"}],"crossRefs":[{"label":"Ps 97:7","book":"Psa","chapter":97,"verse":7},{"label":"Is 1:29","book":"Isa","chapter":1,"verse":29},{"label":"Is 44:9","book":"Isa","chapter":44,"verse":9},{"label":"Is 44:11","book":"Isa","chapter":44,"verse":11},{"label":"Is 45:16","book":"Isa","chapter":45,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:18","parts":[{"kind":"text","text":"“Listen, you deaf!"},{"kind":"text","text":" Look, you blind, so that you may see. "},{"kind":"crossref","label":"Is 35:5","book":"Isa","chapter":35,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Is 35:5","book":"Isa","chapter":35,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:19","parts":[{"kind":"text","text":"Who is blind but my servant, "},{"kind":"crossref","label":"Is 41:8–9","book":"Isa","chapter":41,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 43:10","book":"Isa","chapter":43,"verse":10,"letter":"b"},{"kind":"crossref","label":"Is 44:1–2","book":"Isa","chapter":44,"verse":1,"letter":"c"},{"kind":"crossref","label":"Is 44:21","book":"Isa","chapter":44,"verse":21,"letter":"d"},{"kind":"crossref","label":"Is 45:4","book":"Isa","chapter":45,"verse":4,"letter":"e"},{"kind":"crossref","label":"Is 48:20","book":"Isa","chapter":48,"verse":20,"letter":"f"},{"kind":"crossref","label":"Is 49:3","book":"Isa","chapter":49,"verse":3,"letter":"g"},{"kind":"crossref","label":"Is 54:17","book":"Isa","chapter":54,"verse":17,"letter":"h"},{"kind":"crossref","label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25,"letter":"i"},{"kind":"crossref","label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25,"letter":"j"},{"kind":"crossref","label":"Lk 1:54","book":"Luk","chapter":1,"verse":54,"letter":"k"},{"kind":"text","text":" or deaf like my messenger I am sending?"},{"kind":"text","text":" Who is blind like my dedicated one, "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"text","text":" or blind like the servant of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"}],"crossRefs":[{"label":"Is 41:8–9","book":"Isa","chapter":41,"verse":8},{"label":"Is 43:10","book":"Isa","chapter":43,"verse":10},{"label":"Is 44:1–2","book":"Isa","chapter":44,"verse":1},{"label":"Is 44:21","book":"Isa","chapter":44,"verse":21},{"label":"Is 45:4","book":"Isa","chapter":45,"verse":4},{"label":"Is 48:20","book":"Isa","chapter":48,"verse":20},{"label":"Is 49:3","book":"Isa","chapter":49,"verse":3},{"label":"Is 54:17","book":"Isa","chapter":54,"verse":17},{"label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25},{"label":"Ezk 37:25","book":"Ezk","chapter":37,"verse":25},{"label":"Lk 1:54","book":"Luk","chapter":1,"verse":54}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Isa:42:20","parts":[{"kind":"text","text":"Though seeing many things, "},{"kind":"footnote","marker":1,"text":"Alt Hb tradition reads You see many things;"},{"kind":"text","text":" you pay no attention."},{"kind":"text","text":" Though his ears are open, he does not listen.” "},{"kind":"crossref","label":"Rm 2:21–23","book":"Rom","chapter":2,"verse":21,"letter":"a"}],"crossRefs":[{"label":"Rm 2:21–23","book":"Rom","chapter":2,"verse":21}],"footnotes":[{"marker":1,"text":"Alt Hb tradition reads You see many things;"}]},{"verseId":"a556c5305ee15c3f-01:Isa:42:21","parts":[{"kind":"text","text":"Because of his righteousness, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" was pleased"},{"kind":"text","text":" to magnify his instruction and make it glorious."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:22","parts":[{"kind":"text","text":"But this is a people plundered and looted,"},{"kind":"text","text":" all of them trapped in holes"},{"kind":"text","text":" or imprisoned in dungeons."},{"kind":"text","text":" They have become plunder "},{"kind":"crossref","label":"Dt 1:39","book":"Deu","chapter":1,"verse":39,"letter":"a"},{"kind":"crossref","label":"Jr 2:14","book":"Jer","chapter":2,"verse":14,"letter":"b"},{"kind":"crossref","label":"Ezk 34:8","book":"Ezk","chapter":34,"verse":8,"letter":"c"},{"kind":"crossref","label":"Ezk 36:4","book":"Ezk","chapter":36,"verse":4,"letter":"d"},{"kind":"text","text":" with no one to rescue them"},{"kind":"text","text":" and loot, with no one saying, “Give it back!”"}],"crossRefs":[{"label":"Dt 1:39","book":"Deu","chapter":1,"verse":39},{"label":"Jr 2:14","book":"Jer","chapter":2,"verse":14},{"label":"Ezk 34:8","book":"Ezk","chapter":34,"verse":8},{"label":"Ezk 36:4","book":"Ezk","chapter":36,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:23","parts":[{"kind":"text","text":"Who among you will hear this?"},{"kind":"text","text":" Let him listen and obey in the future."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:42:24","parts":[{"kind":"text","text":"Who gave Jacob to the robber, "},{"kind":"footnote","marker":1,"text":"Lit to loot"},{"kind":"text","text":" and Israel to the plunderers?"},{"kind":"text","text":" Was it not the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"},{"kind":"text","text":" Have we not sinned against him?"},{"kind":"text","text":" They were not willing to walk in his ways,"},{"kind":"text","text":" and they would not listen to his instruction."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit to loot"}]},{"verseId":"a556c5305ee15c3f-01:Isa:42:25","parts":[{"kind":"text","text":"So he poured out his furious anger"},{"kind":"text","text":" and the power of war on Jacob."},{"kind":"text","text":" It surrounded him with fire, but he did not know it;"},{"kind":"text","text":" it burned him, but he didn’t take it to heart. "},{"kind":"crossref","label":"Is 29:13","book":"Isa","chapter":29,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 47:7","book":"Isa","chapter":47,"verse":7,"letter":"b"},{"kind":"crossref","label":"Is 57:1","book":"Isa","chapter":57,"verse":1,"letter":"c"},{"kind":"crossref","label":"Jr 12:11","book":"Jer","chapter":12,"verse":11,"letter":"d"},{"kind":"crossref","label":"Hs 7:9","book":"Hos","chapter":7,"verse":9,"letter":"e"}],"crossRefs":[{"label":"Is 29:13","book":"Isa","chapter":29,"verse":13},{"label":"Is 47:7","book":"Isa","chapter":47,"verse":7},{"label":"Is 57:1","book":"Isa","chapter":57,"verse":1},{"label":"Jr 12:11","book":"Jer","chapter":12,"verse":11},{"label":"Hs 7:9","book":"Hos","chapter":7,"verse":9}],"footnotes":[]}]},"cachedAt":1783279549524}