xt":" and will no longer conceal her slain."}],"crossRefs":[{"label":"Mc 1:3","book":"Mic","chapter":1,"verse":3},{"label":"Is 13:11","book":"Isa","chapter":13,"verse":11}],"footnotes":[]}]},"cachedAt":1783279544763}