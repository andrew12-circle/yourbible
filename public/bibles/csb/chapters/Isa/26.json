"},{"kind":"text","text":" departed spirits do not rise up."},{"kind":"text","text":" Indeed, you have punished and destroyed them;"},{"kind":"text","text":" you have wiped out all memory of them. "},{"kind":"crossref","label":"Jb 18:17","book":"Job","chapter":18,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ps 9:6","book":"Psa","chapter":9,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Jb 18:17","book":"Job","chapter":18,"verse":17},{"label":"Ps 9:6","book":"Psa","chapter":9,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:26:15","parts":[{"kind":"text","text":"You have added to the nation, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Is 9:3","book":"Isa","chapter":9,"verse":3,"letter":"a"},{"kind":"text","text":" You have added to the nation; you are honored."},{"kind":"text","text":" You have expanded all the borders of the land. "},{"kind":"crossref","label":"Is 33:17","book":"Isa","chapter":33,"verse":17,"letter":"a"},{"kind":"crossref","label":"Is 54:2–3","book":"Isa","chapter":54,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Is 9:3","book":"Isa","chapter":9,"verse":3},{"label":"Is 33:17","book":"Isa","chapter":33,"verse":17},{"label":"Is 54:2–3","book":"Isa","chapter":54,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:26:16","parts":[{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", they went to you in their distress; "},{"kind":"crossref","label":"Is 37:3","book":"Isa","chapter":37,"verse":3,"letter":"a"},{"kind":"crossref","label":"Hs 5:15","book":"Hos","chapter":5,"verse":15,"letter":"b"},{"kind":"text","text":" they poured out whispered prayers"},{"kind":"text","text":" because your discipline fell on them. "},{"kind":"footnote","marker":1,"text":"Hb obscure"}],"crossRefs":[{"label":"Is 37:3","book":"Isa","chapter":37,"verse":3},{"label":"Hs 5:15","book":"Hos","chapter":5,"verse":15}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{