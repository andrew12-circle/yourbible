n "},{"kind":"crossref","label":"2Kg 19:29","book":"2Ki","chapter":19,"verse":29,"letter":"a"},{"kind":"crossref","label":"Is 37:30","book":"Isa","chapter":37,"verse":30,"letter":"b"},{"kind":"crossref","label":"Is 38:7–8","book":"Isa","chapter":38,"verse":7,"letter":"c"},{"kind":"crossref","label":"Is 55:13","book":"Isa","chapter":55,"verse":13,"letter":"d"},{"kind":"text","text":" from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God —it can be as deep as Sheol or as high as heaven.”"}],"crossRefs":[{"label":"2Kg 19:29","book":"2Ki","chapter":19,"verse":29},{"label":"Is 37:30","book":"Isa","chapter":37,"verse":30},{"label":"Is 38:7–8","book":"Isa","chapter":38,"verse":7},{"label":"Is 55:13","book":"Isa","chapter":55,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:12","parts":[{"kind":"text","text":"But Ahaz replied, “I will not ask. I will not test the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":".”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:13","parts":[{"kind":"text","text":"Isaiah "},{"kind":"crossref","label":"Mt 3:3","book":"Mat","chapter":3,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mt 12:17","book":"Mat","chapter":12,"verse":17,"letter":"b"},{"kind":"text","text":" said, “Listen, house of David! Is it not enough for you to try the patience of men? Will you also try the patience of my God? "},{"kind":"crossref","label":"Is 1:14","book":"Isa","chapter":1,"verse":14,"letter":"c"},{"kind":"crossref","label":"Is 43:24","book":"Isa","chapter":43,"verse":24,"letter":"d"},{"kind":"crossref","label":"Jr 15:6","book":"Jer","chapter":15,"verse":6,"letter":"e"},{"kind":"crossref","label":"Jr 20:9","book":"Jer","chapter":20,"verse":9,"letter":"f"},{"kind":"crossref","label":"Mal 2:17","book":"Mal","chapter":2,"verse":17,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 3:3","book":"Mat","chapter":3,"verse":3},{"label":"Mt 12:17","book":"Mat","chapter":12,"verse":17},{"label":"Is 1:14","book":"Isa","chapter":1,"verse":14},{"label":"Is 43:24","book":"Isa","chapter":43,"verse":24},{"label":"Jr 15:6","book":"Jer","chapter":15,"verse":6},{"label":"Jr 20:9","book":"Jer","chapter":20,"verse":9},{"label":"Mal 2:17","book":"Mal","chapter":2,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:14","parts":[{"kind":"text","text":"Therefore, the Lord himself will give you "},{"kind":"footnote","marker":1,"text":"In Hb, the word you is pl"},{"kind":"text","text":" a sign: See, the virgin will conceive, "},{"kind":"footnote","marker":2,"text":"Or virgin is pregnant, will"},{"kind":"text","text":" have a son, and name him Immanuel. "},{"kind":"footnote","marker":3,"text":"= God With Us"},{"kind":"crossref","label":"Is 8:8","book":"Isa","chapter":8,"verse":8,"letter":"a"},{"kind":"crossref","label":"Is 8:10","book":"Isa","chapter":8,"verse":10,"letter":"b"},{"kind":"crossref","label":"Mt 1:23","book":"Mat","chapter":1,"verse":23,"letter":"c"},{"kind":"crossref","label":"Lk 1:31","book":"Luk","chapter":1,"verse":31,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 8:8","book":"Isa","chapter":8,"verse":8},{"label":"Is 8:10","book":"Isa","chapter":8,"verse":10},{"label":"Mt 1:23","book":"Mat","chapter":1,"verse":23},{"label":"Lk 1:31","book":"Luk","chapter":1,"verse":31}],"footnotes":[{"marker":1,"text":"In Hb, the word you is pl"},{"marker":2,"text":"Or virgin is pregnant, will"},{"marker":3,"text":"= God With Us"}]},{"verseId":"a556c5305ee15c3f-01:Isa:7:15","parts":[{"kind":"text","text":"By the time he learns to reject what is bad and choose what is good, "},{"kind":"crossref","label":"Dt 1:39","book":"Deu","chapter":1,"verse":39,"letter":"a"},{"kind":"text","text":" he will be eating curds "},{"kind":"footnote","marker":4,"text":"Or sour milk"},{"kind":"text","text":" and honey. "},{"kind":"crossref","label":"Ex 3:8","book":"Exo","chapter":3,"verse":8,"letter":"b"},{"kind":"crossref","label":"2Sm 17:29","book":"2Sa","chapter":17,"verse":29,"letter":"c"},{"kind":"crossref","label":"Is 7:22","book":"Isa","chapter":7,"verse":22,"letter":"d"},{"kind":"crossref","label":"Is 8:15","book":"Isa","chapter":8,"verse":15,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 1:39","book":"Deu","chapter":1,"verse":39},{"label":"Ex 3:8","book":"Exo","chapter":3,"verse":8},{"label":"2Sm 17:29","book":"2Sa","chapter":17,"verse":29},{"label":"Is 7:22","book":"Isa","chapter":7,"verse":22},{"label":"Is 8:15","book":"Isa","chapter":8,"verse":15}],"footnotes":[{"marker":4,"text":"Or sour milk"}]},{"verseId":"a556c5305ee15c3f-01:Isa:7:16","parts":[{"kind":"text","text":"For before the boy knows to reject what is bad and choose what is good, the land of the two kings you dread will be abandoned. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:17","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will bring on you, your people, and your father’s house such a time as has never been since Ephraim separated from Judah: "},{"kind":"crossref","label":"1Kg 12:16","book":"1Ki","chapter":12,"verse":16,"letter":"a"},{"kind":"text","text":" He will bring the king of Assyria.” "},{"kind":"crossref","label":"2Ch 28:20","book":"2Ch","chapter":28,"verse":20,"letter":"b"},{"kind":"crossref","label":"Is 8:7–8","book":"Isa","chapter":8,"verse":7,"letter":"c"},{"kind":"crossref","label":"Is 10:5–6","book":"Isa","chapter":10,"verse":5,"letter":"d"}],"crossRefs":[{"label":"1Kg 12:16","book":"1Ki","chapter":12,"verse":16},{"label":"2Ch 28:20","book":"2Ch","chapter":28,"verse":20},{"label":"Is 8:7–8","book":"Isa","chapter":8,"verse":7},{"label":"Is 10:5–6","book":"Isa","chapter":10,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:18","parts":[{"kind":"text","text":"On that day "},{"kind":"crossref","label":"Is 27:12","book":"Isa","chapter":27,"verse":12,"letter":"a"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will whistle "},{"kind":"crossref","label":"Is 5:25","book":"Isa","chapter":5,"verse":25,"letter":"a"},{"kind":"text","text":" to flies"},{"kind":"text","text":" at the farthest streams of the Nile"},{"kind":"text","text":" and to bees in the land of Assyria."}],"crossRefs":[{"label":"Is 27:12","book":"Isa","chapter":27,"verse":12},{"label":"Is 5:25","book":"Isa","chapter":5,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:19","parts":[{"kind":"text","text":"All of them will come and settle"},{"kind":"text","text":" in the steep ravines, in the clefts of the rocks, "},{"kind":"crossref","label":"Is 2:19","book":"Isa","chapter":2,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 16:16","book":"Jer","chapter":16,"verse":16,"letter":"b"},{"kind":"text","text":" in all the thornbushes, and in all the water holes."}],"crossRefs":[{"label":"Is 2:19","book":"Isa","chapter":2,"verse":19},{"label":"Jr 16:16","book":"Jer","chapter":16,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:20","parts":[{"kind":"text","text":"On that day the Lord will use a razor "},{"kind":"crossref","label":"2Kg 18:13","book":"2Ki","chapter":18,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 24:1","book":"Isa","chapter":24,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ezk 5:1–4","book":"Ezk","chapter":5,"verse":1,"letter":"c"},{"kind":"text","text":" hired from beyond the Euphrates River —the king of Assyria "},{"kind":"crossref","label":"Is 8:7","book":"Isa","chapter":8,"verse":7,"letter":"d"},{"kind":"crossref","label":"Is 11:15","book":"Isa","chapter":11,"verse":15,"letter":"e"},{"kind":"crossref","label":"Jr 2:18","book":"Jer","chapter":2,"verse":18,"letter":"f"},{"kind":"text","text":" —to shave the hair on your heads, the hair on your legs, and even your beards."}],"crossRefs":[{"label":"2Kg 18:13","book":"2Ki","chapter":18,"verse":13},{"label":"Is 24:1","book":"Isa","chapter":24,"verse":1},{"label":"Ezk 5:1–4","book":"Ezk","chapter":5,"verse":1},{"label":"Is 8:7","book":"Isa","chapter":8,"verse":7},{"label":"Is 11:15","book":"Isa","chapter":11,"verse":15},{"label":"Jr 2:18","book":"Jer","chapter":2,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:21","parts":[{"kind":"text","text":"On that day"},{"kind":"text","text":" a man will raise a young cow and two sheep,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:22","parts":[{"kind":"text","text":"and from the abundant milk they give"},{"kind":"text","text":" he will eat curds,"},{"kind":"text","text":" for every survivor in the land will eat curds and honey. "},{"kind":"crossref","label":"Is 8:15","book":"Isa","chapter":8,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Is 8:15","book":"Isa","chapter":8,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:23","parts":[{"kind":"text","text":"And on that day"},{"kind":"text","text":" every place where there were a thousand vines,"},{"kind":"text","text":" worth a thousand pieces of silver,"},{"kind":"text","text":" will become thorns and briers. "},{"kind":"crossref","label":"Is 5:6","book":"Isa","chapter":5,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Is 5:6","book":"Isa","chapter":5,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:24","parts":[{"kind":"text","text":"A man will go there with bow and arrows"},{"kind":"text","text":" because the whole land will be thorns and briers."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Isa:7:25","parts":[{"kind":"text","text":"You will not go to all the hills"},{"kind":"text","text":" that were once tilled with a hoe,"},{"kind":"text","text":" for fear of the thorns and briers."},{"kind":"text","text":" Those hills will be places for oxen to graze"},{"kind":"text","text":" and for sheep to trample."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279539266}