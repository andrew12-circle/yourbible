":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:13","parts":[{"kind":"text","text":"bearing with one another and forgiving one another if anyone has a grievance against another. Just as the Lord has forgiven you, so you are also to forgive. "},{"kind":"crossref","label":"2Co 2:7","book":"2Co","chapter":2,"verse":7,"letter":"a"},{"kind":"crossref","label":"2Co 2:10","book":"2Co","chapter":2,"verse":10,"letter":"b"},{"kind":"crossref","label":"2Co 12:13","book":"2Co","chapter":12,"verse":13,"letter":"c"},{"kind":"crossref","label":"Eph 4:32","book":"Eph","chapter":4,"verse":32,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Co 2:7","book":"2Co","chapter":2,"verse":7},{"label":"2Co 2:10","book":"2Co","chapter":2,"verse":10},{"label":"2Co 12:13","book":"2Co","chapter":12,"verse":13},{"label":"Eph 4:32","book":"Eph","chapter":4,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:14","parts":[{"kind":"text","text":"Above all, put on love, which is the perfect bond of unity. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:15","parts":[{"kind":"text","text":"And let the peace of Christ, to which you were also called "},{"kind":"crossref","label":"Jn 14:27","book":"Jhn","chapter":14,"verse":27,"letter":"a"},{"kind":"crossref","label":"1Co 7:15","book":"1Co","chapter":7,"verse":15,"letter":"b"},{"kind":"crossref","label":"Php 4:7","book":"Php","chapter":4,"verse":7,"letter":"c"},{"kind":"text","text":" in one body, rule your hearts. And be thankful. "}],"crossRefs":[{"label":"Jn 14:27","book":"Jhn","chapter":14,"verse":27},{"label":"1Co 7:15","book":"1Co","chapter":7,"verse":15},{"label":"Php 4:7","book":"Php","chapter":4,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:16","parts":[{"kind":"text","text":"Let the word of Christ dwell richly among you, in all wisdom teaching and admonishing one another through psalms, hymns, and spiritual songs, "},{"kind":"footnote","marker":1,"text":"Or and songs prompted by the Spirit"},{"kind":"text","text":" singing to God with gratitude in your hearts. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or and songs prompted by the Spirit"}]},{"verseId":"a556c5305ee15c3f-01:Col:3:17","parts":[{"kind":"text","text":"And whatever you do, in word or in deed, do everything in the name "},{"kind":"crossref","label":"Jn 14:13","book":"Jhn","chapter":14,"verse":13,"letter":"a"},{"kind":"crossref","label":"Php 2:10","book":"Php","chapter":2,"verse":10,"letter":"b"},{"kind":"text","text":" of the Lord Jesus, giving thanks to God the Father through him."}],"crossRefs":[{"label":"Jn 14:13","book":"Jhn","chapter":14,"verse":13},{"label":"Php 2:10","book":"Php","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:18","parts":[{"kind":"text","text":"Wives, submit yourselves to your husbands, as is fitting in the Lord. "},{"kind":"crossref","label":"Eph 5:22","book":"Eph","chapter":5,"verse":22,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Eph 5:22","book":"Eph","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:3:19","parts":[{"kind":"text","text":"Husbands, "},{"kind":"crossref","label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1,"letter":"a"},{"kind":"text","text":" love your wives "},{"kind":"crossref","label":"Eph 5:25","book":"Eph","chapter":5,"verse":25,"letter":"b"},{"kind":"crossref","label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1,"letter":"c"},{"kind":"text","text":" and don’t be bitter "},{"kind":"crossref","label":"Rv 8:11","book":"Rev","chapter":8,"verse":11,"letter":"d"},{"kind":"crossref","label":"Rv 10:9–10","book":"Rev","chapter":10,"verse":9,"letter":"e"},{"kind":"text","text":" toward them. "}],"crossRefs":[{"label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1},{"label":"Eph 5:25","book":"Eph","chapter":5,"verse":25},{"label":"1Pt 3:1","book":"1Pe","chapter":3,"verse":1},{"label":"Rv 8:11","book":"Rev","chapter":8,"verse":11},{"labe