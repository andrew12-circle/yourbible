erse":19,"letter":"b"}],"crossRefs":[{"label":"Gn 1:1","book":"Gen","chapter":1,"verse":1},{"label":"Mk 13:19","book":"Mrk","chapter":13,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:17","parts":[{"kind":"text","text":"He is before all things, "},{"kind":"crossref","label":"Jn 1:1–2","book":"Jhn","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jn 8:58","book":"Jhn","chapter":8,"verse":58,"letter":"b"},{"kind":"crossref","label":"Heb 1:2–3","book":"Heb","chapter":1,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Jn 1:1–2","book":"Jhn","chapter":1,"verse":1},{"label":"Jn 8:58","book":"Jhn","chapter":8,"verse":58},{"label":"Heb 1:2–3","book":"Heb","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:18","parts":[{"kind":"text","text":"He is also the head of the body, the church;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:19","parts":[{"kind":"text","text":"For God was pleased to have"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:20","parts":[{"kind":"text","text":"and through him to reconcile"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:21","parts":[{"kind":"text","text":"Once you were alienated and hostile in your minds as expressed in your evil actions. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:22","parts":[{"kind":"text","text":"But now he has reconciled you by his physical body through his death, "},{"kind":"crossref","label":"Php 2:8","book":"Php","chapter":2,"verse":8,"letter":"a"},{"kind":"text","text":" to present you holy, faultless, "},{"kind":"crossref","label":"Jd 1:24","book":"Jud","chapter":1,"verse":24,"letter":"b"},{"kind":"text","text":" and blameless before him "},{"kind":"crossref","label":"2Co 4:14","book":"2Co","chapter":4,"verse":14,"letter":"c"},{"kind":"text","text":" — "}],"crossRefs":[{"label":"Php 2:8","book":"Php","chapter":2,"verse":8},{"label":"Jd 1:24","book":"Jud","chapter":1,"verse":24},{"label":"2Co 4:14","book":"2Co","chapter":4,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:23","parts":[{"kind":"text","text":"if indeed you remain grounded and steadfast in the faith "},{"kind":"crossref","label":"Gl 2:16","book":"Gal","chapter":2,"verse":16,"letter":"a"},{"kind":"crossref","label":"Jd 1:3","book":"Jud","chapter":1,"verse":3,"letter":"b"},{"kind":"text","text":" and are not shifted away from the hope "},{"kind":"crossref","label":"1Th 1:3","book":"1Th","chapter":1,"verse":3,"letter":"c"},{"kind":"text","text":" of the gospel that you heard. This gospel has been proclaimed in all creation "},{"kind":"crossref","label":"Rv 3:14","book":"Rev","chapter":3,"verse":14,"letter":"d"},{"kind":"text","text":" under heaven, "},{"kind":"crossref","label":"Rm 10:18","book":"Rom","chapter":10,"verse":18,"letter":"e"},{"kind":"crossref","label":"Eph 6:9","book":"Eph","chapter":6,"verse":9,"letter":"f"},{"kind":"text","text":" and I, Paul, "},{"kind":"crossref","label":"Ac 13:9","book":"Act","chapter":13,"verse":9,"letter":"g"},{"kind":"text","text":" have become a servant of it."}],"crossRefs":[{"label":"Gl 2:16","book":"Gal","chapter":2,"verse":16},{"label":"Jd 1:3","book":"Jud","chapter":1,"verse":3},{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3},{"label":"Rv 3:14","book":"Rev","chapter":3,"verse":14},{"label":"Rm 10:18","book":"Rom","chapter":10,"verse":18},{"label":"Eph 6:9","book":"Eph","chapter":6,"verse":9},{"label":"Ac 13:9","book":"Act","chapter":13,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:24","parts":[{"kind":"text","text":"Now I rejoice in my sufferings "},{"kind":"crossref","label":"2Co 1:4","book":"2Co","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Php 1:29","book":"Php","chapter":1,"verse":29,"letter":"b"},{"kind":"crossref","label":"Php 3:10","book":"Php","chapter":3,"verse":10,"letter":"c"},{"kind":"text","text":" for you, and I am completing in my flesh what is lacking in Christ’s afflictions for his body, "},{"kind":"crossref","label":"Eph 4:4","book":"Eph","chapter":4,"verse":4,"letter":"d"},{"kind":"text","text":" that is, the church. "}],"crossRefs":[{"label":"2Co 1:4","book":"2Co","chapter":1,"verse":4},{"label":"Php 1:29","book":"Php","chapter":1,"verse":29},{"label":"Php 3:10","book":"Php","chapter":3,"verse":10},{"label":"Eph 4:4","book":"Eph","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:25","parts":[{"kind":"text","text":"I have become its servant, according to God’s commission that was given to me for you, to make the word of God fully known, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:26","parts":[{"kind":"text","text":"the mystery hidden for ages and generations but now revealed to his saints. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:27","parts":[{"kind":"text","text":"God wanted to make known among the Gentiles the glorious wealth of this mystery, which is Christ "},{"kind":"crossref","label":"Col 2:2","book":"Col","chapter":2,"verse":2,"letter":"a"},{"kind":"text","text":" in you, the hope "},{"kind":"crossref","label":"1Th 1:3","book":"1Th","chapter":1,"verse":3,"letter":"b"},{"kind":"text","text":" of glory. "}],"crossRefs":[{"label":"Col 2:2","book":"Col","chapter":2,"verse":2},{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:28","parts":[{"kind":"text","text":"We proclaim him, warning and teaching everyone with all wisdom, so that we may present everyone mature in Christ. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Col:1:29","parts":[{"kind":"text","text":"I labor for this, striving "},{"kind":"crossref","label":"Jd 1:3","book":"Jud","chapter":1,"verse":3,"letter":"a"},{"kind":"text","text":" with his strength that works powerfully in me. "},{"kind":"crossref","label":"1Co 15:10","book":"1Co","chapter":15,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Jd 1:3","book":"Jud","chapter":1,"verse":3},{"label":"1Co 15:10","book":"1Co","chapter":15,"verse":10}],"footnotes":[]}]},"cachedAt":1783099549366}