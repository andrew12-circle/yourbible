nd":"crossref","label":"Php 1:7","book":"Php","chapter":1,"verse":7,"letter":"a"},{"kind":"text","text":" Grace be with you. "},{"kind":"footnote","marker":1,"text":"Other mss add Amen."},{"kind":"crossref","label":"1Tm 6:21","book":"1Ti","chapter":6,"verse":21,"letter":"b"},{"kind":"crossref","label":"2Tm 4:22","book":"2Ti","chapter":4,"verse":22,"letter":"c"},{"kind":"crossref","label":"Ti 3:15","book":"Tit","chapter":3,"verse":15,"letter":"d"}],"crossRefs":[{"label":"Php 1:7","book":"Php","chapter":1,"verse":7},{"label":"1Tm 6:21","book":"1Ti","chapter":6,"verse":21},{"label":"2Tm 4:22","book":"2Ti","chapter":4,"verse":22},{"label":"Ti 3:15","book":"Tit","chapter":3,"verse":15}],"footnotes":[{"marker":1,"text":"Other mss add Amen."}]}]},"cachedAt":1783099550245}