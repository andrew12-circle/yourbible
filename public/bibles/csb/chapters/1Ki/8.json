,"book":"Jos","chapter":23,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:57","parts":[{"kind":"text","text":"May the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God be with us as he was with our ancestors. May he not abandon us or leave us "},{"kind":"crossref","label":"Dt 31:6","book":"Deu","chapter":31,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jos 1:5","book":"Jos","chapter":1,"verse":5,"letter":"b"},{"kind":"crossref","label":"Heb 13:5","book":"Heb","chapter":13,"verse":5,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 31:6","book":"Deu","chapter":31,"verse":6},{"label":"Jos 1:5","book":"Jos","chapter":1,"verse":5},{"label":"Heb 13:5","book":"Heb","chapter":13,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:58","parts":[{"kind":"text","text":"so that he causes us to be devoted "},{"kind":"footnote","marker":1,"text":"Lit causes our hearts to be inclined"},{"kind":"text","text":" to him, "},{"kind":"crossref","label":"Jos 24:23","book":"Jos","chapter":24,"verse":23,"letter":"a"},{"kind":"crossref","label":"Jr 31:33","book":"Jer","chapter":31,"verse":33,"letter":"b"},{"kind":"crossref","label":"Php 2:13","book":"Php","chapter":2,"verse":13,"letter":"c"},{"kind":"text","text":" to walk in all his ways, and to keep his commands, statutes, and ordinances, which he commanded our ancestors. "}],"crossRefs":[{"label":"Jos 24:23","book":"Jos","chapter":24,"verse":23},{"label":"Jr 31:33","book":"Jer","chapter":31,"verse":33},{"label":"Php 2:13","book":"Php","chapter":2,"verse":13}],"footnotes":[{"marker":1,"text":"Lit causes our hearts to be inclined"}]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:59","parts":[{"kind":"text","text":"May my words with which I have made my petition before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" be near the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God day and night. May he uphold his servant’s cause and the cause of his people Israel, as each day requires. "},{"kind":"crossref","label":"Pr 30:8","book":"Pro","chapter":30,"verse":8,"letter":"a"},{"kind":"crossref","label":"Mt 6:11","book":"Mat","chapter":6,"verse":11,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Pr 30:8","book":"Pro","chapter":30,"verse":8},{"label":"Mt 6:11","book":"Mat","chapter":6,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:60","parts":[{"kind":"text","text":"May all the peoples of the earth know that the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is God. There is no other! "},{"kind":"crossref","label":"Dt 6:4","book":"Deu","chapter":6,"verse":4,"letter":"a"},{"kind":"crossref","label":"Jos 4:24","book":"Jos","chapter":4,"verse":24,"letter":"b"},{"kind":"crossref","label":"Mk 12:32","book":"Mrk","chapter":12,"verse":32,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 6:4","book":"Deu","chapter":6,"verse":4},{"label":"Jos 4:24","book":"Jos","chapter":4,"verse":24},{"label":"Mk 12:32","book":"Mrk","chapter":12,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:61","parts":[{"kind":"text","text":"Be wholeheartedly devoted to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God "},{"kind":"crossref","label":"Dt 6:5","book":"Deu","chapter":6,"verse":5,"letter":"a"},{"kind":"crossref","label":"1Kg 9:4","book":"1Ki","chapter":9,"verse":4,"letter":"b"},{"kind":"crossref","label":"1Kg 11:4","book":"1Ki","chapter":11,"verse":4,"letter":"c"},{"kind":"text","text":" to walk in his statutes and to keep his commands, as it is today.”"}],"crossRefs":[{"label":"Dt 6:5","book":"Deu","chapter":6,"verse":5},{"label":"1Kg 9:4","book":"1Ki","chapter":9,"verse":4},{"label":"1Kg 11:4","book":"1Ki","chapter":11,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:62","parts":[{"kind":"text","text":"The king and all Israel with him were offering sacrifices in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s presence. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:63","parts":[{"kind":"text","text":"Solomon offered a sacrifice of fellowship offerings to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":": twenty-two thousand cattle and one hundred twenty thousand sheep and goats. "},{"kind":"crossref","label":"1Ch 29:21","book":"1Ch","chapter":29,"verse":21,"letter":"a"},{"kind":"crossref","label":"2Ch 7:4–5","book":"2Ch","chapter":7,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ezr 6:16–17","book":"Ezr","chapter":6,"verse":16,"letter":"c"},{"kind":"text","text":" In this manner the king and all the Israelites dedicated "},{"kind":"crossref","label":"Dt 20:5","book":"Deu","chapter":20,"verse":5,"letter":"d"},{"kind":"crossref","label":"Ezr 6:16","book":"Ezr","chapter":6,"verse":16,"letter":"e"},{"kind":"crossref","label":"Neh 12:27","book":"Neh","chapter":12,"verse":27,"letter":"f"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s temple. "},{"kind":"crossref","label":"2Ch 7:5","book":"2Ch","chapter":7,"verse":5,"letter":"g"}],"crossRefs":[{"label":"1Ch 29:21","book":"1Ch","chapter":29,"verse":21},{"label":"2Ch 7:4–5","book":"2Ch","chapter":7,"verse":4},{"label":"Ezr 6:16–17","book":"Ezr","chapter":6,"verse":16},{"label":"Dt 20:5","book":"Deu","chapter":20,"verse":5},{"label":"Ezr 6:16","book":"Ezr","chapter":6,"verse":16},{"label":"Neh 12:27","book":"Neh","chapter":12,"verse":27},{"label":"2Ch 7:5","book":"2Ch","chapter":7,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:64","parts":[{"kind":"text","text":"On the same day, the king consecrated the middle of the courtyard that was in front of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s temple because that was where he offered the burnt offering, the grain offering, and the fat of the fellowship offerings, Lv 6–7 since the bronze altar before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" was too small to accommodate the burnt offerings, the grain offerings, and the fat of the fellowship offerings. "},{"kind":"crossref","label":"2Ch 7:7","book":"2Ch","chapter":7,"verse":7,"letter":"a"}],"crossRefs":[{"label":"2Ch 7:7","book":"2Ch","chapter":7,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:65","parts":[{"kind":"text","text":"Solomon and all Israel with him —a great assembly, from the entrance of Hamath "},{"kind":"footnote","marker":1,"text":"Or from Lebo-hamath"},{"kind":"crossref","label":"Nm 13:21","book":"Num","chapter":13,"verse":21,"letter":"a"},{"kind":"crossref","label":"Nm 34:8","book":"Num","chapter":34,"verse":8,"letter":"b"},{"kind":"text","text":" to the Brook of Egypt "},{"kind":"crossref","label":"Gn 15:18","book":"Gen","chapter":15,"verse":18,"letter":"c"},{"kind":"text","text":" —observed the festival at that time "},{"kind":"crossref","label":"Lv 23:36","book":"Lev","chapter":23,"verse":36,"letter":"d"},{"kind":"crossref","label":"1Kg 8:2","book":"1Ki","chapter":8,"verse":2,"letter":"e"},{"kind":"text","text":" in the presence of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God, seven days, and seven more days —fourteen days. "},{"kind":"footnote","marker":2,"text":"Temple dedication lasted seven days, and the Festival of Shelters lasted seven days."},{"kind":"crossref","label":"2Ch 7:9","book":"2Ch","chapter":7,"verse":9,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 13:21","book":"Num","chapter":13,"verse":21},{"label":"Nm 34:8","book":"Num","chapter":34,"verse":8},{"label":"Gn 15:18","book":"Gen","chapter":15,"verse":18},{"label":"Lv 23:36","book":"Lev","chapter":23,"verse":36},{"label":"1Kg 8:2","book":"1Ki","chapter":8,"verse":2},{"label":"2Ch 7:9","book":"2Ch","chapter":7,"verse":9}],"footnotes":[{"marker":1,"text":"Or from Lebo-hamath"},{"marker":2,"text":"Temple dedication lasted seven days, and the Festival of Shelters lasted seven days."}]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:66","parts":[{"kind":"text","text":"On the fifteenth day "},{"kind":"footnote","marker":3,"text":"Lit the eighth day"},{"kind":"text","text":" he sent the people away. So they blessed the king and went to their homes "},{"kind":"footnote","marker":4,"text":"Lit tents"},{"kind":"text","text":" rejoicing and with happy hearts for all the goodness that the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" had done for his servant David and for his people Israel. "},{"kind":"crossref","label":"2Ch 7:10","book":"2Ch","chapter":7,"verse":10,"letter":"a"}],"crossRefs":[{"label":"2Ch 7:10","book":"2Ch","chapter":7,"verse":10}],"footnotes":[{"marker":3,"text":"Lit the eighth day"},{"marker":4,"text":"Lit tents"}]}]},"cachedAt":1783279409901}