Ki:8:46","parts":[{"kind":"text","text":"When they sin against you —"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:47","parts":[{"kind":"text","text":"and when they come to their senses "},{"kind":"footnote","marker":1,"text":"Lit they return to their heart"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit they return to their heart"}]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:48","parts":[{"kind":"text","text":"and when they return to you with all their heart and all their soul"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:49","parts":[{"kind":"text","text":"may you hear in heaven, your dwelling place,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:50","parts":[{"kind":"text","text":"May you forgive your people"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:51","parts":[{"kind":"text","text":"For they are your people and your inheritance; "},{"kind":"crossref","label":"Ex 32:11","book":"Exo","chapter":32,"verse":11,"letter":"a"},{"kind":"crossref","label":"Dt 9:26","book":"Deu","chapter":9,"verse":26,"letter":"b"},{"kind":"crossref","label":"Dt 9:29","book":"Deu","chapter":9,"verse":29,"letter":"c"}],"crossRefs":[{"label":"Ex 32:11","book":"Exo","chapter":32,"verse":11},{"label":"Dt 9:26","book":"Deu","chapter":9,"verse":26},{"label":"Dt 9:29","book":"Deu","chapter":9,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:52","parts":[{"kind":"text","text":"May your eyes be open to your servant’s petition"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:53","parts":[{"kind":"text","text":"For you, Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":", have set them apart as your inheritance"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:8:54","parts":[{"kind":"text","text":"When Solomon finished praying this entire prayer and petition to the "},{"kind":"text","text":"Lord","style":"