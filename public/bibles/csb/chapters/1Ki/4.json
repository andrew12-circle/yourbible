,"verse":26},{"label":"2Ch 1:14","book":"2Ch","chapter":1,"verse":14}],"footnotes":[{"marker":4,"text":"2Ch 9:25 reads 4,000 stalls"}]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:27","parts":[{"kind":"text","text":"Each of those deputies for a month in turn provided food for King Solomon and for everyone who came to King Solomon’s table. They neglected nothing. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:28","parts":[{"kind":"text","text":"Each man brought the barley and the straw for the chariot teams and the other horses "},{"kind":"crossref","label":"Est 8:10","book":"Est","chapter":8,"verse":10,"letter":"a"},{"kind":"crossref","label":"Est 8:14","book":"Est","chapter":8,"verse":14,"letter":"b"},{"kind":"text","text":" to the required place according to his assignment. "},{"kind":"footnote","marker":5,"text":"Lit judgment"}],"crossRefs":[{"label":"Est 8:10","book":"Est","chapter":8,"verse":10},{"label":"Est 8:14","book":"Est","chapter":8,"verse":14}],"footnotes":[{"marker":5,"text":"Lit judgment"}]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:29","parts":[{"kind":"text","text":"God gave Solomon wisdom, very great insight, and understanding "},{"kind":"crossref","label":"1Kg 3:12","book":"1Ki","chapter":3,"verse":12,"letter":"a"},{"kind":"text","text":" as vast as the sand on the seashore. "}],"crossRefs":[{"label":"1Kg 3:12","book":"1Ki","chapter":3,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:30","parts":[{"kind":"text","text":"Solomon’s wisdom was greater than the wisdom of all the people of the East, "},{"kind":"crossref","label":"Gn 29:1","book":"Gen","chapter":29,"verse":1,"letter":"a"},{"kind":"text","text":" greater than all the wisdom of Egypt. "},{"kind":"crossref","label":"Is 19:11","book":"Isa","chapter":19,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ac 7:22","book":"Act","chapter":7,"verse":22,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 29:1","book":"Gen","chapter":29,"verse":1},{"label":"Is 19:11","book":"Isa","chapter":19,"verse":11},{"label":"Ac 7:22","book":"Act","chapter":7,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:31","parts":[{"kind":"text","text":"He was wiser than anyone "},{"kind":"crossref","label":"1Kg 3:12","book":"1Ki","chapter":3,"verse":12,"letter":"a"},{"kind":"text","text":" —wiser than Ethan the Ezrahite, "},{"kind":"footnote","marker":1,"text":"1Ch 15:19; Pss 88, 89 titles"},{"kind":"text","text":" and Heman, Calcol, and Darda, sons of Mahol. "},{"kind":"crossref","label":"1Ch 2:6","book":"1Ch","chapter":2,"verse":6,"letter":"b"},{"kind":"text","text":" His reputation extended to all the surrounding nations. "},{"kind":"crossref","label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Kg 10:6","book":"1Ki","chapter":10,"verse":6,"letter":"d"}],"crossRefs":[{"label":"1Kg 3:12","book":"1Ki","chapter":3,"verse":12},{"label":"1Ch 2:6","book":"1Ch","chapter":2,"verse":6},{"label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1},{"label":"1Kg 10:6","book":"1Ki","chapter":10,"verse":6}],"footnotes":[{"marker":1,"text":"1Ch 15:19; Pss 88, 89 titles"}]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:32","parts":[{"kind":"text","text":"Solomon spoke 3,000 proverbs, "},{"kind":"crossref","label":"Pr 1:1","book":"Pro","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ec 9:12","book":"Ecc","chapter":9,"verse":12,"letter":"b"},{"kind":"text","text":" and his songs numbered 1,005. "},{"kind":"crossref","label":"Sg 1:1","book":"Sng","chapter":1,"verse":1,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Pr 1:1","book":"Pro","chapter":1,"verse":1},{"label":"Ec 9:12","book":"Ecc","chapter":9,"verse":12},{"label":"Sg 1:1","book":"Sng","chapter":1,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:33","parts":[{"kind":"text","text":"He spoke about trees, from the cedar in Lebanon to the hyssop growing out of the wall. He also spoke about animals, birds, reptiles, and fish. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ki:4:34","parts":[{"kind":"text","text":"Emissaries of all peoples, sent by every king on earth who had heard of his wisdom, came to listen to Solomon’s wisdom. "},{"kind":"crossref","label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1,"letter":"a"},{"kind":"crossref","label":"1Kg 10:6","book":"1Ki","chapter":10,"verse":6,"letter":"b"}],"crossRefs":[{"label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1},{"label":"1Kg 10:6","book":"1Ki","chapter":10,"verse":6}],"footnotes":[]}]},"cachedAt":1783099303527}