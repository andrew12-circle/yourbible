":[{"kind":"text","text":"Consider what I say, for the Lord will give you understanding in everything."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ti:2:8","parts":[{"kind":"text","text":"Remember Jesus Christ, risen from the dead "},{"kind":"crossref","label":"Mt 17:9","book":"Mat","chapter":17,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jn 21:14","book":"Jhn","chapter":21,"verse":14,"letter":"b"},{"kind":"text","text":" and descended from David, according to my gospel, "}],"crossRefs":[{"label":"Mt 17:9","book":"Mat","chapter":17,"verse":9},{"label":"Jn 21:14","book":"Jhn","chapter":21,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ti:2:9","parts":[{"kind":"text","text":"for which I suffer to the point of being bound like a criminal. But the word of God is not bound. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ti:2:10","parts":[{"kind":"text","text":"This is why I endure "},{"kind":"crossref","label":"Jms 1:12","book":"Jas","chapter":1,"verse":12,"letter":"a"},{"kind":"text","text":" all things for the elect: "},{"kind":"crossref","label":"Mt 24:22","book":"Mat","chapter":24,"verse":22,"letter":"b"},{"kind":"text","text":" so that they also may obtain salvation, which is in Christ Jesus, with eternal glory. "},{"kind":"crossref","label":"Lk 9:32","book":"Luk","chapter":9,"verse":32,"letter":"c"},{"kind":"crossref","label":"Lk 24:26","book":"Luk","chapter":24,"verse":26,"letter":"d"},{"kind":"crossref","label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24,"letter":"e"},{"kind":"crossref","label":"2Co 3:18","book":"2Co","chapter":3,"verse":18,"letter":"f"},{"kind":"crossref","label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1,"letter":"g"},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"h"},{"kind":"crossref","label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18,"letter":"i"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jms 1:12","book":"Jas","chapter":1,