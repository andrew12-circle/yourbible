"verseId":"a556c5305ee15c3f-01:Neh:9:8","parts":[{"kind":"text","text":"You found his heart faithful in your sight, "},{"kind":"crossref","label":"Gn 15:6","book":"Gen","chapter":15,"verse":6,"letter":"a"},{"kind":"crossref","label":"Gn 22:15–18","book":"Gen","chapter":22,"verse":15,"letter":"b"}],"crossRefs":[{"label":"Gn 15:6","book":"Gen","chapter":15,"verse":6},{"label":"Gn 22:15–18","book":"Gen","chapter":22,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:9","parts":[{"kind":"text","text":"You saw the oppression of our ancestors in Egypt "},{"kind":"crossref","label":"Ex 3:7","book":"Exo","chapter":3,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ex 14:10–14","book":"Exo","chapter":14,"verse":10,"letter":"b"},{"kind":"crossref","label":"Ex 14:31","book":"Exo","chapter":14,"verse":31,"letter":"c"}],"crossRefs":[{"label":"Ex 3:7","book":"Exo","chapter":3,"verse":7},{"label":"Ex 14:10–14","book":"Exo","chapter":14,"verse":10},{"label":"Ex 14:31","book":"Exo","chapter":14,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:10","parts":[{"kind":"text","text":"You performed signs and wonders against Pharaoh,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:11","parts":[{"kind":"text","text":"You divided the sea before them,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:12","parts":[{"kind":"text","text":"You led them with a pillar of cloud by day,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:13","parts":[{"kind":"text","text":"You came down on Mount Sinai, "},{"kind":"crossref","label":"Ex 19:20","book":"Exo","chapter":19,"verse":20,"letter":"a"}],"crossRefs":[{"label":"Ex 19:20","book":"Exo","chapter":19,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:14","parts":[{"kind":"text","text":"You revealed your holy Sabbath to them,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:15","parts":[{"kind":"text","text":"You provided bread from heaven "},{"kind":"crossref","label":"Ex 16:4","book":"Exo","chapter":16,"verse":4,"letter":"a"},{"kind":"text","text":" for their hunger;"}],"crossRefs":[{"label":"Ex 16:4","book":"Exo","chapter":16,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:16","parts":[{"kind":"text","text":"But our ancestors acted arrogantly;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:17","parts":[{"kind":"text","text":"They refused to listen"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:18","parts":[{"kind":"text","text":"Even after they had cast an image of a calf"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:19","parts":[{"kind":"text","text":"you did not abandon them in the wilderness"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:20","parts":[{"kind":"text","text":"You sent your good Spirit "},{"kind":"crossref","label":"Nm 11:17","book":"Num","chapter":11,"verse":17,"letter":"a"},{"kind":"crossref","label":"Neh 9:30","book":"Neh","chapter":9,"verse":30,"letter":"b"},{"kind":"text","text":" to instruct them."}],"crossRefs":[{"label":"Nm 11:17","book":"Num","chapter":11,"verse":17},{"label":"Neh 9:30","book":"Neh","chapter":9,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:21","parts":[{"kind":"text","text":"You provided for them in the wilderness forty years, "},{"kind":"crossref","label":"Dt 2:7","book":"Deu","chapter":2,"verse":7,"letter":"a"},{"kind":"crossref","label":"Dt 29:5","book":"Deu","chapter":29,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Dt 2:7","book":"Deu","chapter":2,"verse":7},{"label":"Dt 29:5","book":"Deu","chapter":29,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:22","parts":[{"kind":"text","text":"You gave them kingdoms and peoples"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:23","parts":[{"kind":"text","text":"You multiplied their descendants"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:24","parts":[{"kind":"text","text":"So their descendants went in and possessed the land:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:25","parts":[{"kind":"text","text":"They captured fortified cities and fertile land"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:26","parts":[{"kind":"text","text":"But they were disobedient and rebelled against you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:27","parts":[{"kind":"text","text":"So you handed them over to their enemies,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:28","parts":[{"kind":"text","text":"But as soon as they had relief,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:29","parts":[{"kind":"text","text":"You warned them to turn back to your law,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:30","parts":[{"kind":"text","text":"You were patient with them for many years,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:31","parts":[{"kind":"text","text":"However, in your abundant compassion,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:32","parts":[{"kind":"text","text":"So now, our God —the great, mighty,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:33","parts":[{"kind":"text","text":"You are righteous concerning all that has happened to us,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:34","parts":[{"kind":"text","text":"Our kings, leaders, priests, and ancestors"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:35","parts":[{"kind":"text","text":"When they were in their kingdom,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:36","parts":[{"kind":"text","text":"Here we are today,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:37","parts":[{"kind":"text","text":"Its abundant harvest goes to the kings"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:9:38","parts":[{"kind":"text","text":"In view of all this, we are making a binding agreement "},{"kind":"crossref","label":"2Ch 23:16","book":"2Ch","chapter":23,"verse":16,"letter":"a"},{"kind":"text","text":" in writing on a sealed document containing the names of our leaders, Levites, and priests. "},{"kind":"crossref","label":"Neh 10:1–39","book":"Neh","chapter":10,"verse":1,"letter":"b"}],"crossRefs":[{"label":"2Ch 23:16","book":"2Ch","chapter":23,"verse":16},{"label":"Neh 10:1–39","book":"Neh","chapter":10,"verse":1}],"footnotes":[]}]},"cachedAt":1783099342992}