,"book":"Ezr","chapter":7,"verse":1},{"label":"Nm 29:1","book":"Num","chapter":29,"verse":1},{"label":"Ezr 3:12–13","book":"Ezr","chapter":3,"verse":12},{"label":"Ezr 10:1","book":"Ezr","chapter":10,"verse":1},{"label":"Ezr 10:6","book":"Ezr","chapter":10,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:10","parts":[{"kind":"text","text":"Then he said to them, “Go and eat what is rich, drink what is sweet, and send portions to those who have nothing prepared, "},{"kind":"crossref","label":"2Sm 6:19","book":"2Sa","chapter":6,"verse":19,"letter":"a"},{"kind":"crossref","label":"Est 9:22","book":"Est","chapter":9,"verse":22,"letter":"b"},{"kind":"text","text":" since today "},{"kind":"crossref","label":"Nm 29:1","book":"Num","chapter":29,"verse":1,"letter":"c"},{"kind":"text","text":" is holy to our Lord. Do not grieve, because the joy of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is your strength.” "},{"kind":"footnote","marker":2,"text":"Or stronghold"},{"kind":"crossref","label":"Dt 16:11","book":"Deu","chapter":16,"verse":11,"letter":"d"},{"kind":"crossref","label":"Dt 16:14","book":"Deu","chapter":16,"verse":14,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Sm 6:19","book":"2Sa","chapter":6,"verse":19},{"label":"Est 9:22","book":"Est","chapter":9,"verse":22},{"label":"Nm 29:1","book":"Num","chapter":29,"verse":1},{"label":"Dt 16:11","book":"Deu","chapter":16,"verse":11},{"label":"Dt 16:14","book":"Deu","chapter":16,"verse":14}],"footnotes":[{"marker":2,"text":"Or stronghold"}]},{"verseId":"a556c5305ee15c3f-01:Neh:8:11","parts":[{"kind":"text","text":"And the Levites quieted all the people, saying, “Be still, "},{"kind":"crossref","label":"Ps 46:10","book":"Psa","chapter":46,"verse":10,"letter":"a"},{"kind":"text","text":" since today "},{"kind":"crossref","label":"Nm 29:1","book":"Num","chapter":29,"verse":1,"letter":"b"},{"kind":"text","text":" is holy. Don’t grieve.” "}],"crossRefs":[{"label":"Ps 46:10","book":"Psa","chapter":46,"verse":10},{"label":"Nm 29:1","book":"Num","chapter":29,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:12","parts":[{"kind":"text","text":"Then all the people began to eat and drink, send portions, and have a great celebration, "},{"kind":"crossref","label":"Est 9:22","book":"Est","chapter":9,"verse":22,"letter":"a"},{"kind":"text","text":" because they had understood the words that were explained to them."}],"crossRefs":[{"label":"Est 9:22","book":"Est","chapter":9,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:13","parts":[{"kind":"text","text":"On the second day, the family heads of all the people, along with the priests and Levites, "},{"kind":"crossref","label":"Neh 10:28–29","book":"Neh","chapter":10,"verse":28,"letter":"a"},{"kind":"text","text":" assembled before the scribe Ezra "},{"kind":"crossref","label":"Ezr 7:6","book":"Ezr","chapter":7,"verse":6,"letter":"b"},{"kind":"crossref","label":"Neh 8:1","book":"Neh","chapter":8,"verse":1,"letter":"c"},{"kind":"crossref","label":"Neh 8:9","book":"Neh","chapter":8,"verse":9,"letter":"d"},{"kind":"text","text":" to study the words of the law. "}],"crossRefs":[{"label":"Neh 10:28–29","book":"Neh","chapter":10,"verse":28},{"label":"Ezr 7:6","book":"Ezr","chapter":7,"verse":6},{"label":"Neh 8:1","book":"Neh","chapter":8,"verse":1},{"label":"Neh 8:9","book":"Neh","chapter":8,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:14","parts":[{"kind":"text","text":"They found written in the law how the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" had commanded through Moses that the Israelites should dwell in shelters during the festival of the seventh month. "},{"kind":"crossref","label":"Jn 7:2","book":"Jhn","chapter":7,"verse":2,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 7:2","book":"Jhn","chapter":7,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:15","parts":[{"kind":"text","text":"So they proclaimed and spread this news throughout their towns and in Jerusalem, saying, “Go out to the hill country and bring back branches of olive, wild olive, myrtle, palm, and other leafy trees to make shelters, just as it is written.” "},{"kind":"crossref","label":"Lv 23:4","book":"Lev","chapter":23,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lv 23:34","book":"Lev","chapter":23,"verse":34,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 23:4","book":"Lev","chapter":23,"verse":4},{"label":"Lv 23:34","book":"Lev","chapter":23,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:16","parts":[{"kind":"text","text":"The people went out, brought back branches, and made shelters for themselves on each of their rooftops "},{"kind":"crossref","label":"Dt 22:8","book":"Deu","chapter":22,"verse":8,"letter":"a"},{"kind":"text","text":" and courtyards, the court of the house of God, the square by the Water Gate, "},{"kind":"crossref","label":"Neh 3:26","book":"Neh","chapter":3,"verse":26,"letter":"b"},{"kind":"crossref","label":"Neh 8:1","book":"Neh","chapter":8,"verse":1,"letter":"c"},{"kind":"crossref","label":"Neh 12:37","book":"Neh","chapter":12,"verse":37,"letter":"d"},{"kind":"text","text":" and the square by the Ephraim Gate. "},{"kind":"crossref","label":"2Ch 25:23","book":"2Ch","chapter":25,"verse":23,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 22:8","book":"Deu","chapter":22,"verse":8},{"label":"Neh 3:26","book":"Neh","chapter":3,"verse":26},{"label":"Neh 8:1","book":"Neh","chapter":8,"verse":1},{"label":"Neh 12:37","book":"Neh","chapter":12,"verse":37},{"label":"2Ch 25:23","book":"2Ch","chapter":25,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:17","parts":[{"kind":"text","text":"The whole community that had returned from exile "},{"kind":"crossref","label":"Ezr 1:11","book":"Ezr","chapter":1,"verse":11,"letter":"a"},{"kind":"crossref","label":"Neh 7:6","book":"Neh","chapter":7,"verse":6,"letter":"b"},{"kind":"text","text":" made shelters and lived in them. The Israelites had not celebrated like this from the days of Joshua son of Nun until that day. "},{"kind":"crossref","label":"2Ch 7:9","book":"2Ch","chapter":7,"verse":9,"letter":"c"},{"kind":"crossref","label":"Ezr 3:4","book":"Ezr","chapter":3,"verse":4,"letter":"d"},{"kind":"text","text":" And there was tremendous joy. "},{"kind":"crossref","label":"2Ch 30:21","book":"2Ch","chapter":30,"verse":21,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezr 1:11","book":"Ezr","chapter":1,"verse":11},{"label":"Neh 7:6","book":"Neh","chapter":7,"verse":6},{"label":"2Ch 7:9","book":"2Ch","chapter":7,"verse":9},{"label":"Ezr 3:4","book":"Ezr","chapter":3,"verse":4},{"label":"2Ch 30:21","book":"2Ch","chapter":30,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:8:18","parts":[{"kind":"text","text":"Ezra "},{"kind":"footnote","marker":1,"text":"Some Hb mss, Syr read They"},{"kind":"text","text":" read out of the book of the law of God "},{"kind":"crossref","label":"Neh 8:1","book":"Neh","chapter":8,"verse":1,"letter":"a"},{"kind":"crossref","label":"Neh 8:3","book":"Neh","chapter":8,"verse":3,"letter":"b"},{"kind":"text","text":" every day, from the first day to the last. The Israelites celebrated the festival for seven days, and on the eighth day there was a solemn assembly, according to the ordinance. "},{"kind":"crossref","label":"Lv 23:34","book":"Lev","chapter":23,"verse":34,"letter":"c"}],"crossRefs":[{"label":"Neh 8:1","book":"Neh","chapter":8,"verse":1},{"label":"Neh 8:3","book":"Neh","chapter":8,"verse":3},{"label":"Lv 23:34","book":"Lev","chapter":23,"verse":34}],"footnotes":[{"marker":1,"text":"Some Hb mss, Syr read They"}]}]},"cachedAt":1783099342643}