apter":9,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:1:8","parts":[{"kind":"text","text":"Please remember what you commanded your servant Moses: “If you are unfaithful, I will scatter you among the peoples. "},{"kind":"crossref","label":"Dt 4:25","book":"Deu","chapter":4,"verse":25,"letter":"a"},{"kind":"crossref","label":"Dt 28:64","book":"Deu","chapter":28,"verse":64,"letter":"b"},{"kind":"crossref","label":"Dn 9:7","book":"Dan","chapter":9,"verse":7,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 4:25","book":"Deu","chapter":4,"verse":25},{"label":"Dt 28:64","book":"Deu","chapter":28,"verse":64},{"label":"Dn 9:7","book":"Dan","chapter":9,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:1:9","parts":[{"kind":"text","text":"But if you return to me and carefully observe my commands, even though your exiles were banished to the farthest horizon, "},{"kind":"footnote","marker":2,"text":"Lit skies"},{"kind":"text","text":" I will gather them from there and bring them to the place where I chose to have my name dwell.” "},{"kind":"crossref","label":"Dt 30:1","book":"Deu","chapter":30,"verse":1,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 30:1","book":"Deu","chapter":30,"verse":1}],"footnotes":[{"marker":2,"text":"Lit skies"}]},{"verseId":"a556c5305ee15c3f-01:Neh:1:10","parts":[{"kind":"text","text":"They are your servants and your people. You redeemed them by your great power and strong hand. "},{"kind":"crossref","label":"Dt 9:29","book":"Deu","chapter":9,"verse":29,"letter":"a"},{"kind":"crossref","label":"Dn 9:15","book":"Dan","chapter":9,"verse":15,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 9:29","book":"Deu","chapter":9,"verse":29},{"label":"Dn 9:15","book":"Dan","chapter":9,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:1:11","parts":[{"kind":"text","text":"Please, Lord, let your ear be attentive "},{"kind":"crossref","label":"2Ch 6:40","book":"