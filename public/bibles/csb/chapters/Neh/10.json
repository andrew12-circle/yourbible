t":"Pelatiah, Hanan, Anaiah,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:23","parts":[{"kind":"text","text":"Hoshea, Hananiah, "},{"kind":"crossref","label":"Neh 7:2","book":"Neh","chapter":7,"verse":2,"letter":"a"},{"kind":"text","text":" Hasshub,"}],"crossRefs":[{"label":"Neh 7:2","book":"Neh","chapter":7,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:24","parts":[{"kind":"text","text":"Hallohesh, Pilha, Shobek,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:25","parts":[{"kind":"text","text":"Rehum, Hashabnah, Maaseiah,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:26","parts":[{"kind":"text","text":"Ahijah, Hanan, Anan,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:27","parts":[{"kind":"text","text":"Malluch, Harim, Baanah."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:28","parts":[{"kind":"text","text":"The rest of the people —the priests, Levites, gatekeepers, singers, and temple servants, along with their wives, sons, and daughters, everyone who is able to understand "},{"kind":"crossref","label":"Neh 8:2–3","book":"Neh","chapter":8,"verse":2,"letter":"a"},{"kind":"text","text":" and who has separated themselves from the surrounding peoples "},{"kind":"crossref","label":"Neh 9:2","book":"Neh","chapter":9,"verse":2,"letter":"b"},{"kind":"crossref","label":"Neh 13:3","book":"Neh","chapter":13,"verse":3,"letter":"c"},{"kind":"text","text":" to obey the law of God — "}],"crossRefs":[{"label":"Neh 8:2–3","book":"Neh","chapter":8,"verse":2},{"label":"Neh 9:2","book":"Neh","chapter":9,"verse":2},{"label":"Neh 13:3","book":"Neh","chapter":13,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:29","parts":[{"kind":"text","text":"join with their noble brothers and commit themselves with a sworn oath "},{"kind":"footnote","marker":1,"text":"Lit and enter in a curse and in an oath"},{"kind":"crossref","label":"Ezr 10:5","book":"Ezr","chapter":10,"verse":5,"letter":"a"},{"kind":"crossref","label":"Neh 5:12","book":"Neh","chapter":5,"verse":12,"letter":"b"},{"kind":"text","text":" to follow the law of God given through God’s servant Moses "},{"kind":"crossref","label":"Neh 8:1","book":"Neh","chapter":8,"verse":1,"letter":"c"},{"kind":"text","text":" and to obey carefully all the commands, ordinances, and statutes of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our Lord."}],"crossRefs":[{"label":"Ezr 10:5","book":"Ezr","chapter":10,"verse":5},{"label":"Neh 5:12","book":"Neh","chapter":5,"verse":12},{"label":"Neh 8:1","book":"Neh","chapter":8,"verse":1}],"footnotes":[{"marker":1,"text":"Lit and enter in a curse and in an oath"}]},{"verseId":"a556c5305ee15c3f-01:Neh:10:30","parts":[{"kind":"text","text":"We will not give our daughters in marriage to the surrounding peoples and will not take their daughters as wives for our sons. "},{"kind":"crossref","label":"Ex 34:16","book":"Exo","chapter":34,"verse":16,"letter":"a"},{"kind":"crossref","label":"Neh 13:23","book":"Neh","chapter":13,"verse":23,"letter":"b"}],"crossRefs":[{"label":"Ex 34:16","book":"Exo","chapter":34,"verse":16},{"label":"Neh 13:23","book":"Neh","chapter":13,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:31","parts":[{"kind":"text","text":"When the surrounding peoples bring merchandise or any kind of grain to sell on the Sabbath day, we will not buy from them on the Sabbath or a holy day. "},{"kind":"crossref","label":"Neh 13:16","book":"Neh","chapter":13,"verse":16,"letter":"a"},{"kind":"text","text":" We will also leave the land uncultivated in the seventh year "},{"kind":"crossref","label":"Ex 23:10–11","book":"Exo","chapter":23,"verse":10,"letter":"b"},{"kind":"crossref","label":"Lv 25:1","book":"Lev","chapter":25,"verse":1,"letter":"c"},{"kind":"text","text":" and will cancel every debt. "},{"kind":"crossref","label":"Dt 15:1","book":"Deu","chapter":15,"verse":1,"letter":"d"}],"crossRefs":[{"label":"Neh 13:16","book":"Neh","chapter":13,"verse":16},{"label":"Ex 23:10–11","book":"Exo","chapter":23,"verse":10},{"label":"Lv 25:1","book":"Lev","chapter":25,"verse":1},{"label":"Dt 15:1","book":"Deu","chapter":15,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:32","parts":[{"kind":"text","text":"We will impose the following commands on ourselves:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:33","parts":[{"kind":"text","text":"the bread displayed before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "},{"kind":"footnote","marker":1,"text":"Lit rows of bread"},{"kind":"crossref","label":"Lv 24:5","book":"Lev","chapter":24,"verse":5,"letter":"a"},{"kind":"text","text":" the daily grain offering, the regular burnt offering, the Sabbath and New Moon offerings, "},{"kind":"crossref","label":"Nm 10:10","book":"Num","chapter":10,"verse":10,"letter":"b"},{"kind":"text","text":" the appointed festivals, the holy things, the sin offerings to atone for Israel, "},{"kind":"crossref","label":"Nm 28:2","book":"Num","chapter":28,"verse":2,"letter":"c"},{"kind":"text","text":" and for all the work of the house of our God."}],"crossRefs":[{"label":"Lv 24:5","book":"Lev","chapter":24,"verse":5},{"label":"Nm 10:10","book":"Num","chapter":10,"verse":10},{"label":"Nm 28:2","book":"Num","chapter":28,"verse":2}],"footnotes":[{"marker":1,"text":"Lit rows of bread"}]},{"verseId":"a556c5305ee15c3f-01:Neh:10:34","parts":[{"kind":"text","text":"We have cast lots "},{"kind":"crossref","label":"Lv 16:8","book":"Lev","chapter":16,"verse":8,"letter":"a"},{"kind":"crossref","label":"Neh 11:1","book":"Neh","chapter":11,"verse":1,"letter":"b"},{"kind":"text","text":" among the priests, Levites, and people for the donation of wood by our ancestral families "},{"kind":"footnote","marker":1,"text":"Lit the house of our fathers"},{"kind":"text","text":" at the appointed times each year. They are to bring the wood to our God’s house to burn on the altar of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" our God, "},{"kind":"crossref","label":"Lv 6:12","book":"Lev","chapter":6,"verse":12,"letter":"c"},{"kind":"crossref","label":"Neh 13:31","book":"Neh","chapter":13,"verse":31,"letter":"d"},{"kind":"text","text":" as it is written in the law."}],"crossRefs":[{"label":"Lv 16:8","book":"Lev","chapter":16,"verse":8},{"label":"Neh 11:1","book":"Neh","chapter":11,"verse":1},{"label":"Lv 6:12","book":"Lev","chapter":6,"verse":12},{"label":"Neh 13:31","book":"Neh","chapter":13,"verse":31}],"footnotes":[{"marker":1,"text":"Lit the house of our fathers"}]},{"verseId":"a556c5305ee15c3f-01:Neh:10:35","parts":[{"kind":"text","text":"We will bring the firstfruits of our land and of every fruit tree to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s house year by year. "},{"kind":"crossref","label":"Lv 26:1","book":"Lev","chapter":26,"verse":1,"letter":"a"},{"kind":"crossref","label":"Nm 18:12","book":"Num","chapter":18,"verse":12,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 26:1","book":"Lev","chapter":26,"verse":1},{"label":"Nm 18:12","book":"Num","chapter":18,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:36","parts":[{"kind":"text","text":"We will also bring the firstborn of our sons and our livestock, as prescribed by the law, and will bring the firstborn of our herds and flocks to the house of our God, "},{"kind":"crossref","label":"Ex 13:2","book":"Exo","chapter":13,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ex 13:12","book":"Exo","chapter":13,"verse":12,"letter":"b"},{"kind":"text","text":" to the priests who serve in our God’s house. "}],"crossRefs":[{"label":"Ex 13:2","book":"Exo","chapter":13,"verse":2},{"label":"Ex 13:12","book":"Exo","chapter":13,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:37","parts":[{"kind":"text","text":"We will bring a loaf from our first batch of dough "},{"kind":"crossref","label":"Lv 23:17","book":"Lev","chapter":23,"verse":17,"letter":"a"},{"kind":"crossref","label":"Nm 15:20","book":"Num","chapter":15,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ezk 44:30","book":"Ezk","chapter":44,"verse":30,"letter":"c"},{"kind":"text","text":" to the priests at the storerooms of the house of our God. We will also bring the firstfruits of our grain offerings, of every fruit tree, and of the new wine and fresh oil. "},{"kind":"crossref","label":"Nm 18:12","book":"Num","chapter":18,"verse":12,"letter":"d"},{"kind":"text","text":" A tenth of our land’s produce belongs to the Levites, for the Levites are to collect the one-tenth offering in all our agricultural towns. "},{"kind":"crossref","label":"Lv 27:30","book":"Lev","chapter":27,"verse":30,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 23:17","book":"Lev","chapter":23,"verse":17},{"label":"Nm 15:20","book":"Num","chapter":15,"verse":20},{"label":"Ezk 44:30","book":"Ezk","chapter":44,"verse":30},{"label":"Nm 18:12","book":"Num","chapter":18,"verse":12},{"label":"Lv 27:30","book":"Lev","chapter":27,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:38","parts":[{"kind":"text","text":"A priest from Aaron’s descendants is to accompany the Levites when they collect the tenth, "},{"kind":"crossref","label":"Nm 18:26","book":"Num","chapter":18,"verse":26,"letter":"a"},{"kind":"text","text":" and the Levites are to take a tenth of this offering to the storerooms of the treasury in the house of our God. "},{"kind":"crossref","label":"Neh 13:12–13","book":"Neh","chapter":13,"verse":12,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 18:26","book":"Num","chapter":18,"verse":26},{"label":"Neh 13:12–13","book":"Neh","chapter":13,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Neh:10:39","parts":[{"kind":"text","text":"For the Israelites and the Levites are to bring the contributions of grain, new wine, and fresh oil to the storerooms where the articles of the sanctuary are kept "},{"kind":"crossref","label":"Dt 12:6","book":"Deu","chapter":12,"verse":6,"letter":"a"},{"kind":"crossref","label":"Dt 12:11","book":"Deu","chapter":12,"verse":11,"letter":"b"},{"kind":"text","text":" and where the priests who minister are, along with the gatekeepers and singers. We will not neglect the house of our God. "},{"kind":"crossref","label":"Neh 13:10–11","book":"Neh","chapter":13,"verse":10,"letter":"c"}],"crossRefs":[{"label":"Dt 12:6","book":"Deu","chapter":12,"verse":6},{"label":"Dt 12:11","book":"Deu","chapter":12,"verse":11},{"label":"Neh 13:10–11","book":"Neh","chapter":13,"verse":10}],"footnotes":[]}]},"cachedAt":1783279457631}