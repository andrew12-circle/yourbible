chapter":1,"verse":23,"letter":"c"},{"kind":"crossref","label":"Heb 4:14","book":"Heb","chapter":4,"verse":14,"letter":"d"},{"kind":"crossref","label":"Heb 7:26","book":"Heb","chapter":7,"verse":26,"letter":"e"},{"kind":"crossref","label":"Heb 9:24","book":"Heb","chapter":9,"verse":24,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 3:13","book":"Jhn","chapter":3,"verse":13},{"label":"Jn 6:38","book":"Jhn","chapter":6,"verse":38},{"label":"Eph 1:23","book":"Eph","chapter":1,"verse":23},{"label":"Heb 4:14","book":"Heb","chapter":4,"verse":14},{"label":"Heb 7:26","book":"Heb","chapter":7,"verse":26},{"label":"Heb 9:24","book":"Heb","chapter":9,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:11","parts":[{"kind":"text","text":"And he himself gave some to be apostles, some prophets, some evangelists, some pastors and teachers, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:12","parts":[{"kind":"text","text":"to equip the saints for the work of ministry, to build up the body of Christ, "},{"kind":"crossref","label":"Rm 7:4","book":"Rom","chapter":7,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Co 10:16","book":"1Co","chapter":10,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Co 12:27","book":"1Co","chapter":12,"verse":27,"letter":"c"},{"kind":"crossref","label":"Col 2:17","book":"Col","chapter":2,"verse":17,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 7:4","book":"Rom","chapter":7,"verse":4},{"label":"1Co 10:16","book":"1Co","chapter":10,"verse":16},{"label":"1Co 12:27","book":"1Co","chapter":12,"verse":27},{"label":"Col 2:17","book":"Col","chapter":2,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:13","parts":[{"kind":"text","text":"until we all reach unity in the faith and in the knowledge of God’s Son, "},{"kind":"crossref","label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19,"letter":"a"},{"kind":"crossref","label":"Heb 1:2","book":"Heb","chapter":1,"verse":2,"letter":"b"},{"kind":"text","text":" growing into maturity with a stature "},{"kind":"crossref","label":"Lk 2:52","book":"Luk","chapter":2,"verse":52,"letter":"c"},{"kind":"text","text":" measured by Christ’s fullness. "}],"crossRefs":[{"label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19},{"label":"Heb 1:2","book":"Heb","chapter":1,"verse":2},{"label":"Lk 2:52","book":"Luk","chapter":2,"verse":52}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:14","parts":[{"kind":"text","text":"Then we will no longer be little children, tossed by the waves and blown around by every wind of teaching, "},{"kind":"crossref","label":"Rm 15:4","book":"Rom","chapter":15,"verse":4,"letter":"a"},{"kind":"crossref","label":"Heb 13:9","book":"Heb","chapter":13,"verse":9,"letter":"b"},{"kind":"text","text":" by human cunning with cleverness in the techniques of deceit. "}],"crossRefs":[{"label":"Rm 15:4","book":"Rom","chapter":15,"verse":4},{"label":"Heb 13:9","book":"Heb","chapter":13,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:15","parts":[{"kind":"text","text":"But speaking the truth in love, let us grow in every way into him who is the head "},{"kind":"crossref","label":"Col 2:10","book":"Col","chapter":2,"verse":10,"letter":"a"},{"kind":"text","text":" —Christ. "}],"crossRefs":[{"label":"Col 2:10","book":"Col","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:16","parts":[{"kind":"text","text":"From him the whole body, fitted and knit together "},{"kind":"crossref","label":"Col 2:2","book":"Col","chapter":2,"verse":2,"letter":"a"},{"kind":"text","text":" by every supporting ligament, promotes the growth "},{"kind":"crossref","label":"Col 2:19","book":"Col","chapter":2,"verse":19,"letter":"b"},{"kind":"text","text":" of the body for building itself up in love by the proper working of each individual part."}],"crossRefs":[{"label":"Col 2:2","book":"Col","chapter":2,"verse":2},{"label":"Col 2:19","book":"Col","chapter":2,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:17","parts":[{"kind":"text","text":"Therefore, I say this and testify in the Lord: You should no longer walk as the Gentiles do, in the futility of their thoughts. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:18","parts":[{"kind":"text","text":"They are darkened in their understanding, excluded from the life of God, because of the ignorance that is in them and because "},{"kind":"footnote","marker":1,"text":"Or in them because"},{"kind":"text","text":" of the hardness of their hearts. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or in them because"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:19","parts":[{"kind":"text","text":"They became callous and gave themselves over to promiscuity for the practice of every kind of impurity "},{"kind":"crossref","label":"1Th 4:7","book":"1Th","chapter":4,"verse":7,"letter":"a"},{"kind":"text","text":" with a desire for more and more. "},{"kind":"footnote","marker":2,"text":"Lit with greediness"}],"crossRefs":[{"label":"1Th 4:7","book":"1Th","chapter":4,"verse":7}],"footnotes":[{"marker":2,"text":"Lit with greediness"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:20","parts":[{"kind":"text","text":"But that is not how you came to know Christ, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:21","parts":[{"kind":"text","text":"assuming you heard about him and were taught by him, as the truth "},{"kind":"crossref","label":"2Th 2:10","book":"2Th","chapter":2,"verse":10,"letter":"a"},{"kind":"text","text":" is in Jesus, "}],"crossRefs":[{"label":"2Th 2:10","book":"2Th","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:22","parts":[{"kind":"text","text":"to take off "},{"kind":"footnote","marker":1,"text":"Or Jesus. This means: take off (as a command)"},{"kind":"crossref","label":"Rm 13:12","book":"Rom","chapter":13,"verse":12,"letter":"a"},{"kind":"text","text":" your former way of life, "},{"kind":"crossref","label":"2Pt 3:11","book":"2Pe","chapter":3,"verse":11,"letter":"b"},{"kind":"text","text":" the old self "},{"kind":"crossref","label":"Rm 6:6","book":"Rom","chapter":6,"verse":6,"letter":"c"},{"kind":"crossref","label":"Rm 7:6","book":"Rom","chapter":7,"verse":6,"letter":"d"},{"kind":"crossref","label":"1Co 5:7–8","book":"1Co","chapter":5,"verse":7,"letter":"e"},{"kind":"crossref","label":"2Co 3:14","book":"2Co","chapter":3,"verse":14,"letter":"f"},{"kind":"crossref","label":"Col 3:9","book":"Col","chapter":3,"verse":9,"letter":"g"},{"kind":"text","text":" that is corrupted by deceitful desires, "}],"crossRefs":[{"label":"Rm 13:12","book":"Rom","chapter":13,"verse":12},{"label":"2Pt 3:11","book":"2Pe","chapter":3,"verse":11},{"label":"Rm 6:6","book":"Rom","chapter":6,"verse":6},{"label":"Rm 7:6","book":"Rom","chapter":7,"verse":6},{"label":"1Co 5:7–8","book":"1Co","chapter":5,"verse":7},{"label":"2Co 3:14","book":"2Co","chapter":3,"verse":14},{"label":"Col 3:9","book":"Col","chapter":3,"verse":9}],"footnotes":[{"marker":1,"text":"Or Jesus. This means: take off (as a command)"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:23","parts":[{"kind":"text","text":"to be renewed "},{"kind":"footnote","marker":2,"text":"Or desires; renew (as a command)"},{"kind":"text","text":" in the spirit "},{"kind":"crossref","label":"Ps 51:12","book":"Psa","chapter":51,"verse":12,"letter":"a"},{"kind":"text","text":" of your minds, "}],"crossRefs":[{"label":"Ps 51:12","book":"Psa","chapter":51,"verse":12}],"footnotes":[{"marker":2,"text":"Or desires; renew (as a command)"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:24","parts":[{"kind":"text","text":"and to put on "},{"kind":"footnote","marker":3,"text":"Or minds; and put on (as a command)"},{"kind":"crossref","label":"Rm 13:12","book":"Rom","chapter":13,"verse":12,"letter":"a"},{"kind":"text","text":" the new self, the one created "},{"kind":"crossref","label":"Mk 13:19","book":"Mrk","chapter":13,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jn 1:3","book":"Jhn","chapter":1,"verse":3,"letter":"c"},{"kind":"crossref","label":"Rv 3:14","book":"Rev","chapter":3,"verse":14,"letter":"d"},{"kind":"text","text":" according to God’s likeness "},{"kind":"crossref","label":"Col 3:10","book":"Col","chapter":3,"verse":10,"letter":"e"},{"kind":"crossref","label":"2Pt 1:4","book":"2Pe","chapter":1,"verse":4,"letter":"f"},{"kind":"text","text":" in righteousness and purity of the truth."}],"crossRefs":[{"label":"Rm 13:12","book":"Rom","chapter":13,"verse":12},{"label":"Mk 13:19","book":"Mrk","chapter":13,"verse":19},{"label":"Jn 1:3","book":"Jhn","chapter":1,"verse":3},{"label":"Rv 3:14","book":"Rev","chapter":3,"verse":14},{"label":"Col 3:10","book":"Col","chapter":3,"verse":10},{"label":"2Pt 1:4","book":"2Pe","chapter":1,"verse":4}],"footnotes":[{"marker":3,"text":"Or minds; and put on (as a command)"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:25","parts":[{"kind":"text","text":"Therefore, putting away "},{"kind":"crossref","label":"Pr 31:25","book":"Pro","chapter":31,"verse":25,"letter":"a"},{"kind":"text","text":" lying, speak the truth, each one to his neighbor,"},{"kind":"crossref","label":"Zch 8:16","book":"Zec","chapter":8,"verse":16,"letter":"b"},{"kind":"crossref","label":"Zch 8:16","book":"Zec","chapter":8,"verse":16,"letter":"c"},{"kind":"text","text":" because we are members of one another. "}],"crossRefs":[{"label":"Pr 31:25","book":"Pro","chapter":31,"verse":25},{"label":"Zch 8:16","book":"Zec","chapter":8,"verse":16},{"label":"Zch 8:16","book":"Zec","chapter":8,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:26","parts":[{"kind":"text","text":"Be angry and do not sin."},{"kind":"crossref","label":"Ps 4:4","book":"Psa","chapter":4,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 4:4","book":"Psa","chapter":4,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ps 37:8","book":"Psa","chapter":37,"verse":8,"letter":"c"},{"kind":"crossref","label":"Mt 18:21","book":"Mat","chapter":18,"verse":21,"letter":"d"},{"kind":"crossref","label":"Jms 1:19","book":"Jas","chapter":1,"verse":19,"letter":"e"},{"kind":"text","text":" Don’t let the sun go down on your anger, "}],"crossRefs":[{"label":"Ps 4:4","book":"Psa","chapter":4,"verse":4},{"label":"Ps 4:4","book":"Psa","chapter":4,"verse":4},{"label":"Ps 37:8","book":"Psa","chapter":37,"verse":8},{"label":"Mt 18:21","book":"Mat","chapter":18,"verse":21},{"label":"Jms 1:19","book":"Jas","chapter":1,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:27","parts":[{"kind":"text","text":"and don’t give the devil an opportunity. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:28","parts":[{"kind":"text","text":"Let the thief no longer steal. Instead, he is to do honest work with his own hands, so that he has something to share "},{"kind":"crossref","label":"1Th 2:8","book":"1Th","chapter":2,"verse":8,"letter":"a"},{"kind":"crossref","label":"1Tm 6:18","book":"1Ti","chapter":6,"verse":18,"letter":"b"},{"kind":"text","text":" with anyone in need. "}],"crossRefs":[{"label":"1Th 2:8","book":"1Th","chapter":2,"verse":8},{"label":"1Tm 6:18","book":"1Ti","chapter":6,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:29","parts":[{"kind":"text","text":"No foul language should come from your mouth, but only what is good for building up someone in need, "},{"kind":"footnote","marker":1,"text":"Lit for the building up of the need"},{"kind":"text","text":" so that it gives grace to those who hear. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit for the building up of the need"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:30","parts":[{"kind":"text","text":"And don’t grieve God’s Holy Spirit. "},{"kind":"crossref","label":"Ps 51:11","book":"Psa","chapter":51,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 1:33","book":"Jhn","chapter":1,"verse":33,"letter":"b"},{"kind":"crossref","label":"Ac 2:4","book":"Act","chapter":2,"verse":4,"letter":"c"},{"kind":"crossref","label":"Rm 8:9","book":"Rom","chapter":8,"verse":9,"letter":"d"},{"kind":"crossref","label":"Gl 5:25","book":"Gal","chapter":5,"verse":25,"letter":"e"},{"kind":"crossref","label":"Ti 3:5","book":"Tit","chapter":3,"verse":5,"letter":"f"},{"kind":"crossref","label":"Rv 3:22","book":"Rev","chapter":3,"verse":22,"letter":"g"},{"kind":"text","text":" You were sealed by him "},{"kind":"footnote","marker":2,"text":"Or Spirit, by whom you were sealed"},{"kind":"text","text":" for the day of redemption. "},{"kind":"crossref","label":"Php 1:6","book":"Php","chapter":1,"verse":6,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 51:11","book":"Psa","chapter":51,"verse":11},{"label":"Jn 1:33","book":"Jhn","chapter":1,"verse":33},{"label":"Ac 2:4","book":"Act","chapter":2,"verse":4},{"label":"Rm 8:9","book":"Rom","chapter":8,"verse":9},{"label":"Gl 5:25","book":"Gal","chapter":5,"verse":25},{"label":"Ti 3:5","book":"Tit","chapter":3,"verse":5},{"label":"Rv 3:22","book":"Rev","chapter":3,"verse":22},{"label":"Php 1:6","book":"Php","chapter":1,"verse":6}],"footnotes":[{"marker":2,"text":"Or Spirit, by whom you were sealed"}]},{"verseId":"a556c5305ee15c3f-01:Eph:4:31","parts":[{"kind":"text","text":"Let all bitterness, anger and wrath, shouting and slander be removed from you, along with all malice. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Eph:4:32","parts":[{"kind":"text","text":"And be kind "},{"kind":"crossref","label":"Mt 11:30","book":"Mat","chapter":11,"verse":30,"letter":"a"},{"kind":"crossref","label":"Lk 5:39","book":"Luk","chapter":5,"verse":39,"letter":"b"},{"kind":"crossref","label":"Lk 6:35","book":"Luk","chapter":6,"verse":35,"letter":"c"},{"kind":"crossref","label":"Rm 2:4","book":"Rom","chapter":2,"verse":4,"letter":"d"},{"kind":"crossref","label":"1Co 15:33","book":"1Co","chapter":15,"verse":33,"letter":"e"},{"kind":"crossref","label":"1Pt 2:3","book":"1Pe","chapter":2,"verse":3,"letter":"f"},{"kind":"text","text":" and compassionate "},{"kind":"crossref","label":"1Pt 3:8","book":"1Pe","chapter":3,"verse":8,"letter":"g"},{"kind":"text","text":" to one another, forgiving "},{"kind":"crossref","label":"Ps 25:11","book":"Psa","chapter":25,"verse":11,"letter":"h"},{"kind":"crossref","label":"Mt 9:2","book":"Mat","chapter":9,"verse":2,"letter":"i"},{"kind":"crossref","label":"Mk 2:5","book":"Mrk","chapter":2,"verse":5,"letter":"j"},{"kind":"crossref","label":"Lk 24:47","book":"Luk","chapter":24,"verse":47,"letter":"k"},{"kind":"crossref","label":"Col 3:12–13","book":"Col","chapter":3,"verse":12,"letter":"l"},{"kind":"text","text":" one another, just as God also forgave you "},{"kind":"footnote","marker":3,"text":"Other mss read us"},{"kind":"text","text":" in Christ."}],"crossRefs":[{"label":"Mt 11:30","book":"Mat","chapter":11,"verse":30},{"label":"Lk 5:39","book":"Luk","chapter":5,"verse":39},{"label":"Lk 6:35","book":"Luk","chapter":6,"verse":35},{"label":"Rm 2:4","book":"Rom","chapter":2,"verse":4},{"label":"1Co 15:33","book":"1Co","chapter":15,"verse":33},{"label":"1Pt 2:3","book":"1Pe","chapter":2,"verse":3},{"label":"1Pt 3:8","book":"1Pe","chapter":3,"verse":8},{"label":"Ps 25:11","book":"Psa","chapter":25,"verse":11},{"label":"Mt 9:2","book":"Mat","chapter":9,"verse":2},{"label":"Mk 2:5","book":"Mrk","chapter":2,"verse":5},{"label":"Lk 24:47","book":"Luk","chapter":24,"verse":47},{"label":"Col 3:12–13","book":"Col","chapter":3,"verse":12}],"footnotes":[{"marker":3,"text":"Other mss read us"}]}]},"cachedAt":1783279667726}