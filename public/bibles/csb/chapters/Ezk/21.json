9","book":"Jer","chapter":31,"verse":19,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 31:19","book":"Jer","chapter":31,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:13","parts":[{"kind":"text","text":"Surely it will be a trial! And what if the sword despises even the scepter? The scepter will not continue.” "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"text","text":" This is the declaration of the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:14","parts":[{"kind":"text","text":"“So you, son of man, prophesy and clap your hands together: "},{"kind":"crossref","label":"Nm 24:10","book":"Num","chapter":24,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Nm 24:10","book":"Num","chapter":24,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:15","parts":[{"kind":"text","text":"I have appointed a sword "},{"kind":"crossref","label":"Ezk 32:20","book":"Ezk","chapter":32,"verse":20,"letter":"a"},{"kind":"text","text":" for slaughter "},{"kind":"footnote","marker":1,"text":"Hb obscure"}],"crossRefs":[{"label":"Ezk 32:20","book":"Ezk","chapter":32,"verse":20}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:16","parts":[{"kind":"text","text":"Slash to the right;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:17","parts":[{"kind":"text","text":"I also will clap my hands together, and I will satisfy my wrath. "},{"kind":"crossref","label":"Ezk 5:13","book":"Ezk","chapter":5,"verse":13,"letter":"a"},{"kind":"text","text":" I, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", have spoken.”"}],"crossRefs":[{"label":"Ezk 5:13","book":"Ezk","chapter":5,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:18","parts":[{"kind":"text","text":"The word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" came to me: "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:19","parts":[{"kind":"text","text":"“Now you, son of man, mark out two roads that the sword of Babylon’s king can take. Both of them should originate from the same land. And make a signpost at the fork in the road to each city. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:20","parts":[{"kind":"text","text":"Mark out a road that the sword can take to Rabbah of the Ammonites "},{"kind":"crossref","label":"Jr 49:2","book":"Jer","chapter":49,"verse":2,"letter":"a"},{"kind":"text","text":" and to Judah into fortified Jerusalem. "}],"crossRefs":[{"label":"Jr 49:2","book":"Jer","chapter":49,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:21","parts":[{"kind":"text","text":"For the king of Babylon stands at the split in the road, at the fork of the two roads, to practice divination: he shakes the arrows, consults the idols, and observes the liver. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:21:22","parts":[{"kind":"text","text":"The answer marked "},{"kind":"footnote","marker":1,"text":"Lit The divination for"},{"kind":"text","text":" Jerusalem appears in his right hand, indicating that he should set up battering rams, "},{"kind":"crossref","label":"Ezk 4:2","book":"Ezk","chapter":4,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ezk 26:9","book":"Ezk","chapter":26,"verse":9,"letter":"b"},{"kind":"text","text":" give the order to "},{"kind":"footnote","marker":2,"text":"Lit rams, open the mouth in"},{"kind":"text","text":" slaughter, raise a battle cry, set battering rams against the gates, build a ramp, and construct a siege wall. "}],"crossRefs":[{"label":"Ezk 4:2","book":"Ezk","chapter":4,"verse":2},{"label":"Ezk 26:9","book":"Ezk","chapter":26,"verse":9}],"footnotes":[{"marker":1,"text":"Lit The divination for"},{"marker":2,"text":"Lit rams, op