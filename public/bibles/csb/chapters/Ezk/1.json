3","book":"Nam","chapter":1,"verse":3},{"label":"Ezk 1:27","book":"Ezk","chapter":1,"verse":27},{"label":"Ezk 8:2","book":"Ezk","chapter":8,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:5","parts":[{"kind":"text","text":"The likeness of four living creatures came from it, "},{"kind":"crossref","label":"Ezk 10:14","book":"Ezk","chapter":10,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ezk 10:21","book":"Ezk","chapter":10,"verse":21,"letter":"b"},{"kind":"crossref","label":"Rv 4:6–8","book":"Rev","chapter":4,"verse":6,"letter":"c"},{"kind":"text","text":" and this was their appearance: They looked something like a human, "}],"crossRefs":[{"label":"Ezk 10:14","book":"Ezk","chapter":10,"verse":14},{"label":"Ezk 10:21","book":"Ezk","chapter":10,"verse":21},{"label":"Rv 4:6–8","book":"Rev","chapter":4,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:6","parts":[{"kind":"text","text":"but each of them had four faces and four wings. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:7","parts":[{"kind":"text","text":"Their legs were straight, and the soles of their feet were like the hooves of a calf, sparkling like the gleam of polished bronze. "},{"kind":"crossref","label":"Dn 10:6","book":"Dan","chapter":10,"verse":6,"letter":"a"},{"kind":"crossref","label":"Rv 1:15","book":"Rev","chapter":1,"verse":15,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 10:6","book":"Dan","chapter":10,"verse":6},{"label":"Rv 1:15","book":"Rev","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:8","parts":[{"kind":"text","text":"They had human hands under their wings on their four sides. "},{"kind":"crossref","label":"Ezk 1:17","book":"Ezk","chapter":1,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ezk 10:11","book":"Ezk","chapter":10,"verse":11,"letter":"b"},{"kind":"text","text":" All four of them had faces and wings. "},{"kind":"crossref","label":"Ezk 10:8","book":"Ezk","chapter":10,"verse":8,"letter":"c"},{"kind":"crossref","label":"Ezk 10:21","book":"Ezk","chapter":10,"verse":21,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 1:17","book":"Ezk","chapter":1,"verse":17},{"label":"Ezk 10:11","book":"Ezk","chapter":10,"verse":11},{"label":"Ezk 10:8","book":"Ezk","chapter":10,"verse":8},{"label":"Ezk 10:21","book":"Ezk","chapter":10,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:9","parts":[{"kind":"text","text":"Their wings were touching. The creatures did not turn as they moved; each one went straight ahead. "},{"kind":"crossref","label":"Ezk 10:22","book":"Ezk","chapter":10,"verse":22,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 10:22","book":"Ezk","chapter":10,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:10","parts":[{"kind":"text","text":"Their faces looked something like the face of a human, "},{"kind":"crossref","label":"Rv 4:7","book":"Rev","chapter":4,"verse":7,"letter":"a"},{"kind":"text","text":" and each of the four had the face of a lion on the right, the face of an ox on the left, and the face of an eagle. "},{"kind":"crossref","label":"Ezk 10:14–21","book":"Ezk","chapter":10,"verse":14,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rv 4:7","book":"Rev","chapter":4,"verse":7},{"label":"Ezk 10:14–21","book":"Ezk","chapter":10,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:11","parts":[{"kind":"text","text":"That is what their faces were like. Their wings were spread upward; each had two wings touching that of another and two wings covering its body. "},{"kind":"crossref","label":"Is 6:2","book":"Isa","chapter":6,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ezk 1:23","book":"Ezk","chapter":1,"verse":23,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 6:2","book":"Isa","chapter":6,"verse":2},{"label":"Ezk 1:23","book":"Ezk","chapter":1,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:12","parts":[{"kind":"text","text":"Each creature went straight ahead. "},{"kind":"crossref","label":"Ezk 10:11","book":"Ezk","chapter":10,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ezk 10:22","book":"Ezk","chapter":10,"verse":22,"letter":"b"},{"kind":"text","text":" Wherever the Spirit "},{"kind":"footnote","marker":1,"text":"Or spirit, also in v. 20"},{"kind":"text","text":" wanted to go, they went without turning as they moved. "},{"kind":"crossref","label":"Ezk 1:20","book":"Ezk","chapter":1,"verse":20,"letter":"c"}],"crossRefs":[{"label":"Ezk 10:11","book":"Ezk","chapter":10,"verse":11},{"label":"Ezk 10:22","book":"Ezk","chapter":10,"verse":22},{"label":"Ezk 1:20","book":"Ezk","chapter":1,"verse":20}],"footnotes":[{"marker":1,"text":"Or spirit, also in v. 20"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:13","parts":[{"kind":"text","text":"The likeness of the living creatures was like the appearance of blazing coals of fire or like torches. "},{"kind":"crossref","label":"Ps 104:4","book":"Psa","chapter":104,"verse":4,"letter":"a"},{"kind":"crossref","label":"Rv 4:5","book":"Rev","chapter":4,"verse":5,"letter":"b"},{"kind":"text","text":" Fire was moving back and forth between the living creatures; it was bright, with lightning coming out of it. "}],"crossRefs":[{"label":"Ps 104:4","book":"Psa","chapter":104,"verse":4},{"label":"Rv 4:5","book":"Rev","chapter":4,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:14","parts":[{"kind":"text","text":"The creatures were darting back and forth "},{"kind":"crossref","label":"Zch 4:10","book":"Zec","chapter":4,"verse":10,"letter":"a"},{"kind":"text","text":" like flashes of lightning. "},{"kind":"crossref","label":"Mt 24:27","book":"Mat","chapter":24,"verse":27,"letter":"b"},{"kind":"crossref","label":"Lk 17:24","book":"Luk","chapter":17,"verse":24,"letter":"c"}],"crossRefs":[{"label":"Zch 4:10","book":"Zec","chapter":4,"verse":10},{"label":"Mt 24:27","book":"Mat","chapter":24,"verse":27},{"label":"Lk 17:24","book":"Luk","chapter":17,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:15","parts":[{"kind":"text","text":"When I looked at the living creatures, there was one wheel on the ground beside each of the four-faced creatures. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:16","parts":[{"kind":"text","text":"The appearance of the wheels "},{"kind":"crossref","label":"Ezk 10:9–11","book":"Ezk","chapter":10,"verse":9,"letter":"a"},{"kind":"text","text":" and their craftsmanship was like the gleam of beryl, "},{"kind":"crossref","label":"Dn 10:6","book":"Dan","chapter":10,"verse":6,"letter":"b"},{"kind":"text","text":" and all four had the same likeness. Their appearance and craftsmanship was like a wheel within a wheel. "}],"crossRefs":[{"label":"Ezk 10:9–11","book":"Ezk","chapter":10,"verse":9},{"label":"Dn 10:6","book":"Dan","chapter":10,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:17","parts":[{"kind":"text","text":"When they moved, they went in any of the four directions, without turning as they moved. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:18","parts":[{"kind":"text","text":"Their four rims were tall and awe-inspiring, completely covered with eyes. "},{"kind":"crossref","label":"Ezk 10:12","book":"Ezk","chapter":10,"verse":12,"letter":"a"},{"kind":"crossref","label":"Rv 4:6","book":"Rev","chapter":4,"verse":6,"letter":"b"},{"kind":"crossref","label":"Rv 4:8","book":"Rev","chapter":4,"verse":8,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 10:12","book":"Ezk","chapter":10,"verse":12},{"label":"Rv 4:6","book":"Rev","chapter":4,"verse":6},{"label":"Rv 4:8","book":"Rev","chapter":4,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:19","parts":[{"kind":"text","text":"When the living creatures moved, "},{"kind":"crossref","label":"Ezk 10:16–17","book":"Ezk","chapter":10,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ezk 10:19","book":"Ezk","chapter":10,"verse":19,"letter":"b"},{"kind":"text","text":" the wheels moved beside them, and when the creatures rose from the earth, the wheels also rose. "}],"crossRefs":[{"label":"Ezk 10:16–17","book":"Ezk","chapter":10,"verse":16},{"label":"Ezk 10:19","book":"Ezk","chapter":10,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:20","parts":[{"kind":"text","text":"Wherever the Spirit wanted to go, the creatures went in the direction the Spirit was moving. The wheels rose alongside them, for the spirit of the living creatures was in the wheels. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:21","parts":[{"kind":"text","text":"When the creatures moved, the wheels moved; when the creatures stopped, the wheels stopped; and when the creatures rose from the earth, the wheels rose alongside them, for the spirit of the living creatures was in the wheels."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:22","parts":[{"kind":"text","text":"Over the heads of the living creatures "},{"kind":"crossref","label":"Ezk 10:1","book":"Ezk","chapter":10,"verse":1,"letter":"a"},{"kind":"text","text":" the likeness of an expanse "},{"kind":"crossref","label":"Gn 1:6–8","book":"Gen","chapter":1,"verse":6,"letter":"b"},{"kind":"text","text":" was spread out. It gleamed like awe-inspiring crystal, "},{"kind":"crossref","label":"Rv 4:6","book":"Rev","chapter":4,"verse":6,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 10:1","book":"Ezk","chapter":10,"verse":1},{"label":"Gn 1:6–8","book":"Gen","chapter":1,"verse":6},{"label":"Rv 4:6","book":"Rev","chapter":4,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:23","parts":[{"kind":"text","text":"and under the expanse their wings extended one toward another. They each also had two wings covering their bodies. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:24","parts":[{"kind":"text","text":"When they moved, I heard the sound of their wings like the roar of a huge torrent, "},{"kind":"crossref","label":"Ezk 43:2","book":"Ezk","chapter":43,"verse":2,"letter":"a"},{"kind":"crossref","label":"Rv 1:15","book":"Rev","chapter":1,"verse":15,"letter":"b"},{"kind":"crossref","label":"Rv 19:6","book":"Rev","chapter":19,"verse":6,"letter":"c"},{"kind":"text","text":" like the voice of the Almighty, "},{"kind":"crossref","label":"Ezk 10:5","book":"Ezk","chapter":10,"verse":5,"letter":"d"},{"kind":"text","text":" and a sound of tumult like the noise of an army. "},{"kind":"crossref","label":"Dn 10:6","book":"Dan","chapter":10,"verse":6,"letter":"e"},{"kind":"text","text":" When they stopped, they lowered their wings."}],"crossRefs":[{"label":"Ezk 43:2","book":"Ezk","chapter":43,"verse":2},{"label":"Rv 1:15","book":"Rev","chapter":1,"verse":15},{"label":"Rv 19:6","book":"Rev","chapter":19,"verse":6},{"label":"Ezk 10:5","book":"Ezk","chapter":10,"verse":5},{"label":"Dn 10:6","book":"Dan","chapter":10,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:25","parts":[{"kind":"text","text":"A voice came from above the expanse over their heads; when they stopped, they lowered their wings. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:26","parts":[{"kind":"text","text":"Something like a throne with the appearance of lapis lazuli was above the expanse over their heads. "},{"kind":"crossref","label":"Ezk 10:1","book":"Ezk","chapter":10,"verse":1,"letter":"a"},{"kind":"text","text":" On the throne, high above, was someone who looked like a human. "},{"kind":"crossref","label":"Is 6:1","book":"Isa","chapter":6,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ezk 24:10","book":"Ezk","chapter":24,"verse":10,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 10:1","book":"Ezk","chapter":10,"verse":1},{"label":"Is 6:1","book":"Isa","chapter":6,"verse":1},{"label":"Ezk 24:10","book":"Ezk","chapter":24,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:27","parts":[{"kind":"text","text":"From what seemed to be his waist up, I saw a gleam like amber, with what looked like fire enclosing it all around. "},{"kind":"crossref","label":"Ezk 1:4","book":"Ezk","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ezk 8:2","book":"Ezk","chapter":8,"verse":2,"letter":"b"},{"kind":"text","text":" From what seemed to be his waist down, I also saw what looked like fire. There was a brilliant light all around him. "}],"crossRefs":[{"label":"Ezk 1:4","book":"Ezk","chapter":1,"verse":4},{"label":"Ezk 8:2","book":"Ezk","chapter":8,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:1:28","parts":[{"kind":"text","text":"The appearance of the brilliant light all around was like that of a rainbow in a cloud on a rainy day. "},{"kind":"crossref","label":"Gn 9:13","book":"Gen","chapter":9,"verse":13,"letter":"a"},{"kind":"crossref","label":"Rv 4:3","book":"Rev","chapter":4,"verse":3,"letter":"b"},{"kind":"crossref","label":"Rv 10:1","book":"Rev","chapter":10,"verse":1,"letter":"c"},{"kind":"text","text":" This was the appearance of the likeness of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s glory. "},{"kind":"crossref","label":"Ex 24:16","book":"Exo","chapter":24,"verse":16,"letter":"d"},{"kind":"crossref","label":"Ezk 8:4","book":"Ezk","chapter":8,"verse":4,"letter":"e"},{"kind":"crossref","label":"Ezk 11:22–23","book":"Ezk","chapter":11,"verse":22,"letter":"f"},{"kind":"crossref","label":"Ezk 43:4–5","book":"Ezk","chapter":43,"verse":4,"letter":"g"},{"kind":"text","text":" When I saw it, I fell facedown and heard a voice speaking. "},{"kind":"crossref","label":"Gn 17:3","book":"Gen","chapter":17,"verse":3,"letter":"h"},{"kind":"crossref","label":"Ezk 3:23","book":"Ezk","chapter":3,"verse":23,"letter":"i"},{"kind":"crossref","label":"Dn 8:17","book":"Dan","chapter":8,"verse":17,"letter":"j"},{"kind":"crossref","label":"Rv 1:17","book":"Rev","chapter":1,"verse":17,"letter":"k"}],"crossRefs":[{"label":"Gn 9:13","book":"Gen","chapter":9,"verse":13},{"label":"Rv 4:3","book":"Rev","chapter":4,"verse":3},{"label":"Rv 10:1","book":"Rev","chapter":10,"verse":1},{"label":"Ex 24:16","book":"Exo","chapter":24,"verse":16},{"label":"Ezk 8:4","book":"Ezk","chapter":8,"verse":4},{"label":"Ezk 11:22–23","book":"Ezk","chapter":11,"verse":22},{"label":"Ezk 43:4–5","book":"Ezk","chapter":43,"verse":4},{"label":"Gn 17:3","book":"Gen","chapter":17,"verse":3},{"label":"Ezk 3:23","book":"Ezk","chapter":3,"verse":23},{"label":"Dn 8:17","book":"Dan","chapter":8,"verse":17},{"label":"Rv 1:17","book":"Rev","chapter":1,"verse":17}],"footnotes":[]}]},"cachedAt":1783279575521}