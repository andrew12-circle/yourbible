xt":"Hb obscure"},{"marker":5,"text":"Hb obscure"},{"marker":6,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:17","parts":[{"kind":"text","text":"Judah and the land of Israel were your merchants. They exchanged wheat from Minnith, "},{"kind":"crossref","label":"Jdg 11:33","book":"Jdg","chapter":11,"verse":33,"letter":"a"},{"kind":"text","text":" meal, "},{"kind":"footnote","marker":7,"text":"Or resin; Hb obscure"},{"kind":"text","text":" honey, oil, and balm, for your goods. "}],"crossRefs":[{"label":"Jdg 11:33","book":"Jdg","chapter":11,"verse":33}],"footnotes":[{"marker":7,"text":"Or resin; Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:18","parts":[{"kind":"text","text":"Damascus was also your trading partner because of your numerous products and your abundant wealth of every kind, trading in wine from Helbon and white wool. "},{"kind":"footnote","marker":8,"text":"Or and wool from Zahar"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":8,"text":"Or and wool from Zahar"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:19","parts":[{"kind":"text","text":"Vedan "},{"kind":"footnote","marker":9,"text":"Or Dan"},{"kind":"text","text":" and Javan from Uzal "},{"kind":"footnote","marker":10,"text":"Hb obscure"},{"kind":"crossref","label":"Gn 10:27","book":"Gen","chapter":10,"verse":27,"letter":"a"},{"kind":"text","text":" dealt in your merchandise; wrought iron, cassia, "},{"kind":"crossref","label":"Ex 30:24","book":"Exo","chapter":30,"verse":24,"letter":"b"},{"kind":"text","text":" and aromatic cane were exchanged for your goods. "}],"crossRefs":[{"label":"Gn 10:27","book":"Gen","chapter":10,"verse":27},{"label":"Ex 30:24","book":"Exo","chapter":30,"verse":24}],"footnotes":[{"marker":9,"text":"Or Dan"},{"marker":10,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:20","parts":[{"kind":"text","text":"Dedan "},{"kind":"crossref","label":"Ezk 38:13","book":"Ezk","chapter":38,"verse":13,"letter":"a"},{"kind":"text","text":" was your merchant in saddlecloths for riding. "}],"crossRefs":[{"label":"Ezk 38:13","book":"Ezk","chapter":38,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:21","parts":[{"kind":"text","text":"Arabia and all the princes of Kedar were your business partners, trading with you in lambs, rams, and goats. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:22","parts":[{"kind":"text","text":"The merchants of Sheba "},{"kind":"crossref","label":"Gn 10:7","book":"Gen","chapter":10,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ezk 38:13","book":"Ezk","chapter":38,"verse":13,"letter":"b"},{"kind":"text","text":" and Raamah traded with you. For your merchandise they exchanged the best of all spices and all kinds of precious stones as well as gold. "},{"kind":"crossref","label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1,"letter":"c"},{"kind":"crossref","label":"Rv 18:12","book":"Rev","chapter":18,"verse":12,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 10:7","book":"Gen","chapter":10,"verse":7},{"label":"Ezk 38:13","book":"Ezk","chapter":38,"verse":13},{"label":"1Kg 10:1","book":"1Ki","chapter":10,"verse":1},{"label":"Rv 18:12","book":"Rev","chapter":18,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:23","parts":[{"kind":"text","text":"Haran, Canneh, Eden, "},{"kind":"crossref","label":"2Kg 19:12","book":"2Ki","chapter":19,"verse":12,"letter":"a"},{"kind":"crossref","label":"Is 37:12","book":"Isa","chapter":37,"verse":12,"letter":"b"},{"kind":"text","text":" the merchants of Sheba, Asshur, "},{"kind":"crossref","label":"Gn 25:3","book":"Gen","chapter":25,"verse":3,"letter":"c"},{"kind":"text","text":" and Chilmad traded with you. "}],"crossRefs":[{"label":"2Kg 19:12","book":"2Ki","chapter":19,"verse":12},{"label":"Is 37:12","book":"Isa","chapter":37,"verse":12},{"label":"Gn 25:3","book":"Gen","chapter":25,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:24","parts":[{"kind":"text","text":"They were your merchants in choice garments, cloaks of blue and embroidered materials, and multicolored carpets, "},{"kind":"footnote","marker":11,"text":"Hb obscure"},{"kind":"text","text":" which were bound and secured with cords in your marketplace. "}],"crossRefs":[],"footnotes":[{"marker":11,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:25","parts":[{"kind":"text","text":"Ships of Tarshish "},{"kind":"crossref","label":"1Kg 10:22","book":"1Ki","chapter":10,"verse":22,"letter":"a"},{"kind":"crossref","label":"1Kg 22:48","book":"1Ki","chapter":22,"verse":48,"letter":"b"},{"kind":"crossref","label":"Is 2:16","book":"Isa","chapter":2,"verse":16,"letter":"c"},{"kind":"text","text":" were the carriers for your goods."},{"kind":"text","text":" “ ‘So you became full and heavily loaded "},{"kind":"footnote","marker":1,"text":"Or and very glorious"},{"kind":"text","text":" in the heart of the sea."}],"crossRefs":[{"label":"1Kg 10:22","book":"1Ki","chapter":10,"verse":22},{"label":"1Kg 22:48","book":"1Ki","chapter":22,"verse":48},{"label":"Is 2:16","book":"Isa","chapter":2,"verse":16}],"footnotes":[{"marker":1,"text":"Or and very glorious"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:26","parts":[{"kind":"text","text":"Your rowers have brought you"},{"kind":"text","text":" onto the high seas, "},{"kind":"crossref","label":"Ezk 26:19","book":"Ezk","chapter":26,"verse":19,"letter":"a"},{"kind":"text","text":" but the east wind has wrecked you"},{"kind":"text","text":" in the heart of the sea."}],"crossRefs":[{"label":"Ezk 26:19","book":"Ezk","chapter":26,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:27","parts":[{"kind":"text","text":"Your wealth, merchandise, and goods,"},{"kind":"text","text":" your sailors and captains,"},{"kind":"text","text":" those who repair your leaks,"},{"kind":"text","text":" those who barter for your goods,"},{"kind":"text","text":" and all the warriors on board,"},{"kind":"text","text":" with all the other people within you,"},{"kind":"text","text":" sink into the heart of the sea"},{"kind":"text","text":" on the day of your downfall."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:28","parts":[{"kind":"text","text":"“ ‘The countryside shakes"},{"kind":"text","text":" at the sound of your sailors’ cries. "},{"kind":"crossref","label":"Ezk 26:10","book":"Ezk","chapter":26,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ezk 26:15","book":"Ezk","chapter":26,"verse":15,"letter":"b"}],"crossRefs":[{"label":"Ezk 26:10","book":"Ezk","chapter":26,"verse":10},{"label":"Ezk 26:15","book":"Ezk","chapter":26,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:29","parts":[{"kind":"text","text":"All the oarsmen"},{"kind":"text","text":" disembark from their ships."},{"kind":"text","text":" The sailors and all the captains of the sea"},{"kind":"text","text":" stand on the shore."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:30","parts":[{"kind":"text","text":"Because of you, they raise their voices"},{"kind":"text","text":" and cry out bitterly."},{"kind":"text","text":" They throw dust on their heads; "},{"kind":"crossref","label":"Rv 18:17–19","book":"Rev","chapter":18,"verse":17,"letter":"a"},{"kind":"text","text":" they roll in ashes."}],"crossRefs":[{"label":"Rv 18:17–19","book":"Rev","chapter":18,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:31","parts":[{"kind":"text","text":"They shave their heads because of you"},{"kind":"text","text":" and wrap themselves in sackcloth."},{"kind":"text","text":" They weep over you"},{"kind":"text","text":" with deep anguish and bitter mourning."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:32","parts":[{"kind":"text","text":"“ ‘In their wailing they lament for you, "},{"kind":"crossref","label":"Ezk 26:17","book":"Ezk","chapter":26,"verse":17,"letter":"a"},{"kind":"text","text":" mourning over you:"},{"kind":"text","text":" “Who was like Tyre,"},{"kind":"text","text":" silenced "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"text","text":" in the middle of the sea?"}],"crossRefs":[{"label":"Ezk 26:17","book":"Ezk","chapter":26,"verse":17}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:33","parts":[{"kind":"text","text":"When your merchandise was unloaded from the seas,"},{"kind":"text","text":" you satisfied many peoples."},{"kind":"text","text":" You enriched the kings of the earth"},{"kind":"text","text":" with your abundant wealth and goods."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:34","parts":[{"kind":"text","text":"Now you are wrecked by the sea"},{"kind":"text","text":" in the depths of the waters;"},{"kind":"text","text":" your goods and the people within you"},{"kind":"text","text":" have gone down."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:35","parts":[{"kind":"text","text":"All the inhabitants of the coasts and islands"},{"kind":"text","text":" are appalled "},{"kind":"crossref","label":"Ezk 26:15–16","book":"Ezk","chapter":26,"verse":15,"letter":"a"},{"kind":"text","text":" at you."},{"kind":"text","text":" Their kings shudder with fear;"},{"kind":"text","text":" their faces are contorted."}],"crossRefs":[{"label":"Ezk 26:15–16","book":"Ezk","chapter":26,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:27:36","parts":[{"kind":"text","text":"Those who trade among the peoples"},{"kind":"text","text":" scoff "},{"kind":"footnote","marker":1,"text":"Lit hiss"},{"kind":"crossref","label":"1Kg 9:8","book":"1Ki","chapter":9,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jr 19:8","book":"Jer","chapter":19,"verse":8,"letter":"b"},{"kind":"crossref","label":"Zp 2:15","book":"Zep","chapter":2,"verse":15,"letter":"c"},{"kind":"text","text":" at you;"},{"kind":"text","text":" you have become an object of horror"},{"kind":"text","text":" and will never exist again.”’” "},{"kind":"crossref","label":"Ezk 26:21","book":"Ezk","chapter":26,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ezk 28:19","book":"Ezk","chapter":28,"verse":19,"letter":"b"}],"crossRefs":[{"label":"1Kg 9:8","book":"1Ki","chapter":9,"verse":8},{"label":"Jr 19:8","book":"Jer","chapter":19,"verse":8},{"label":"Zp 2:15","book":"Zep","chapter":2,"verse":15},{"label":"Ezk 26:21","book":"Ezk","chapter":26,"verse":21},{"label":"Ezk 28:19","book":"Ezk","chapter":28,"verse":19}],"footnotes":[{"marker":1,"text":"Lit hiss"}]}]},"cachedAt":1783279583855}