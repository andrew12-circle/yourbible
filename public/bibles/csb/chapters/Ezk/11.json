Ezk","chapter":11,"verse":9,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 24:3–13","book":"Ezk","chapter":24,"verse":3},{"label":"Mc 3:2","book":"Mic","chapter":3,"verse":2},{"label":"Ezk 11:9","book":"Ezk","chapter":11,"verse":9}],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX, Syr, Tg, Vg; other Hb mss read he"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:8","parts":[{"kind":"text","text":"You fear the sword, "},{"kind":"crossref","label":"Pr 10:24","book":"Pro","chapter":10,"verse":24,"letter":"a"},{"kind":"crossref","label":"Is 66:4","book":"Isa","chapter":66,"verse":4,"letter":"b"},{"kind":"text","text":" so I will bring the sword against you. "},{"kind":"crossref","label":"Jb 3:25","book":"Job","chapter":3,"verse":25,"letter":"c"},{"kind":"crossref","label":"Is 24:17–18","book":"Isa","chapter":24,"verse":17,"letter":"d"},{"kind":"text","text":" This is the declaration of the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":". "}],"crossRefs":[{"label":"Pr 10:24","book":"Pro","chapter":10,"verse":24},{"label":"Is 66:4","book":"Isa","chapter":66,"verse":4},{"label":"Jb 3:25","book":"Job","chapter":3,"verse":25},{"label":"Is 24:17–18","book":"Isa","chapter":24,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:9","parts":[{"kind":"text","text":"I will take you out of the city and hand you over to foreigners; I will execute judgments against you. "},{"kind":"crossref","label":"Ezk 5:8","book":"Ezk","chapter":5,"verse":8,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 5:8","book":"Ezk","chapter":5,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:10","parts":[{"kind":"text","text":"You will fall by the sword, "},{"kind":"crossref","label":"Jr 39:6","book":"Jer","chapter":39,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jr 52:9–10","book":"Jer","chapter":52,"verse":9,"letter":"b"},{"kind":"text","text":" and I will judge you at the border of Israel. "},{"kind":"crossref","label":"2Kg 14:25","book":"2Ki","chapter":14,"verse":25,"letter":"c"},{"kind":"text","text":" Then you will know that I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "}],"crossRefs":[{"label":"Jr 39:6","book":"Jer","chapter":39,"verse":6},{"label":"Jr 52:9–10","book":"Jer","chapter":52,"verse":9},{"label":"2Kg 14:25","book":"2Ki","chapter":14,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:11","parts":[{"kind":"text","text":"The city will not be a pot for you, "},{"kind":"crossref","label":"Ezk 11:3","book":"Ezk","chapter":11,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ezk 11:7","book":"Ezk","chapter":11,"verse":7,"letter":"b"},{"kind":"text","text":" and you will not be the meat within it. I will judge you at the border of Israel, "}],"crossRefs":[{"label":"Ezk 11:3","book":"Ezk","chapter":11,"verse":3},{"label":"Ezk 11:7","book":"Ezk","chapter":11,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:12","parts":[{"kind":"text","text":"so you will know that I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", whose statutes you have not followed and whose ordinances you have not practiced. Instead, you have acted according to the ordinances of the nations around you.’” "},{"kind":"crossref","label":"Ezk 8:10","book":"Ezk","chapter":8,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ezk 8:14","book":"Ezk","chapter":8,"verse":14,"letter":"b"},{"kind":"crossref","label":"Ezk 8:16","book":"Ezk","chapter":8,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Ezk 8:10","book":"Ezk","chapter":8,"verse":10},{"label":"Ezk 8:14","book":"Ezk","chapter":8,"verse":14},{"label":"Ezk 8:16","book":"Ezk","chapter":8,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:13","parts":[{"kind":"text","text":"Now while I was prophesying, Pelatiah son of Benaiah died. "},{"kind":"crossref","label":"Ac 5:5","book":"Act","chapter":5,"verse":5,"letter":"a"},{"kind":"text","text":" Then I fell facedown and cried out loudly, “Oh, Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":"! "},{"kind":"crossref","label":"Ezk 9:8","book":"Ezk","chapter":9,"verse":8,"letter":"b"},{"kind":"text","text":" You are bringing the remnant of Israel to an end!”"}],"crossRefs":[{"label":"Ac 5:5","book":"Act","chapter":5,"verse":5},{"label":"Ezk 9:8","book":"Ezk","chapter":9,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:14","parts":[{"kind":"text","text":"The word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" came to me again: "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:15","parts":[{"kind":"text","text":"“Son of man, your own relatives, those who have the right to redeem your property, "},{"kind":"footnote","marker":1,"text":"LXX, Syr read your relatives, your fellow exiles"},{"kind":"footnote","marker":2,"text":"Or own brothers, your relatives"},{"kind":"text","text":" along with the entire house of Israel —all of them —are those to whom the residents of Jerusalem have said, ‘You are far from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"; this land has been given to us as a possession.’"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"LXX, Syr read your relatives, your fellow exiles"},{"marker":2,"text":"Or own brothers, your relatives"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:16","parts":[{"kind":"text","text":"“Therefore say, ‘This is what the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" says: Though I sent them far away among the nations and scattered them among the countries, yet for a little while I have been a sanctuary for them "},{"kind":"crossref","label":"Is 8:14","book":"Isa","chapter":8,"verse":14,"letter":"a"},{"kind":"text","text":" in the countries where they have gone.’"}],"crossRefs":[{"label":"Is 8:14","book":"Isa","chapter":8,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:17","parts":[{"kind":"text","text":"“Therefore say, ‘This is what the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" says: I will gather you from the peoples "},{"kind":"crossref","label":"Ezk 20:34","book":"Ezk","chapter":20,"verse":34,"letter":"a"},{"kind":"crossref","label":"Ezk 20:41","book":"Ezk","chapter":20,"verse":41,"letter":"b"},{"kind":"crossref","label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25,"letter":"c"},{"kind":"text","text":" and assemble you from the countries where you have been scattered, and I will give you the land of Israel.’"}],"crossRefs":[{"label":"Ezk 20:34","book":"Ezk","chapter":20,"verse":34},{"label":"Ezk 20:41","book":"Ezk","chapter":20,"verse":41},{"label":"Ezk 28:25","book":"Ezk","chapter":28,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:18","parts":[{"kind":"text","text":"“When they arrive there, they will remove all its "},{"kind":"crossref","label":"Ezk 37:23","book":"Ezk","chapter":37,"verse":23,"letter":"a"},{"kind":"text","text":" abhorrent acts "},{"kind":"crossref","label":"Ezk 5:11","book":"Ezk","chapter":5,"verse":11,"letter":"b"},{"kind":"text","text":" and detestable practices from it. "}],"crossRefs":[{"label":"Ezk 37:23","book":"Ezk","chapter":37,"verse":23},{"label":"Ezk 5:11","book":"Ezk","chapter":5,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:19","parts":[{"kind":"text","text":"I will give them integrity of "},{"kind":"footnote","marker":1,"text":"Lit give them one"},{"kind":"text","text":" heart "},{"kind":"crossref","label":"Jr 32:39","book":"Jer","chapter":32,"verse":39,"letter":"a"},{"kind":"text","text":" and put a new spirit within them; I will remove their heart of stone "},{"kind":"crossref","label":"Zch 7:12","book":"Zec","chapter":7,"verse":12,"letter":"b"},{"kind":"text","text":" from their bodies "},{"kind":"footnote","marker":2,"text":"Lit flesh"},{"kind":"text","text":" and give them a heart of flesh, "},{"kind":"crossref","label":"Ps 51:10","book":"Psa","chapter":51,"verse":10,"letter":"c"},{"kind":"crossref","label":"Jr 31:33","book":"Jer","chapter":31,"verse":33,"letter":"d"},{"kind":"crossref","label":"Ezk 36:26","book":"Ezk","chapter":36,"verse":26,"letter":"e"},{"kind":"crossref","label":"2Co 3:3","book":"2Co","chapter":3,"verse":3,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 32:39","book":"Jer","chapter":32,"verse":39},{"label":"Zch 7:12","book":"Zec","chapter":7,"verse":12},{"label":"Ps 51:10","book":"Psa","chapter":51,"verse":10},{"label":"Jr 31:33","book":"Jer","chapter":31,"verse":33},{"label":"Ezk 36:26","book":"Ezk","chapter":36,"verse":26},{"label":"2Co 3:3","book":"2Co","chapter":3,"verse":3}],"footnotes":[{"marker":1,"text":"Lit give them one"},{"marker":2,"text":"Lit flesh"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:20","parts":[{"kind":"text","text":"so that they will follow my statutes, "},{"kind":"crossref","label":"Ps 105:45","book":"Psa","chapter":105,"verse":45,"letter":"a"},{"kind":"crossref","label":"Ezk 36:27","book":"Ezk","chapter":36,"verse":27,"letter":"b"},{"kind":"text","text":" keep my ordinances, and practice them. They will be my people, and I will be their God. "},{"kind":"crossref","label":"Ezk 36:28","book":"Ezk","chapter":36,"verse":28,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 105:45","book":"Psa","chapter":105,"verse":45},{"label":"Ezk 36:27","book":"Ezk","chapter":36,"verse":27},{"label":"Ezk 36:28","book":"Ezk","chapter":36,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:21","parts":[{"kind":"text","text":"But as for those whose hearts pursue their desire for abhorrent acts and detestable practices, I will bring their conduct down on their own heads.” "},{"kind":"crossref","label":"Ezk 9:10","book":"Ezk","chapter":9,"verse":10,"letter":"a"},{"kind":"text","text":" This is the declaration of the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Ezk 9:10","book":"Ezk","chapter":9,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:22","parts":[{"kind":"text","text":"Then the cherubim, with the wheels beside them, lifted their wings, "},{"kind":"crossref","label":"Ezk 10:19","book":"Ezk","chapter":10,"verse":19,"letter":"a"},{"kind":"text","text":" and the glory of the God of Israel was above them. "}],"crossRefs":[{"label":"Ezk 10:19","book":"Ezk","chapter":10,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:23","parts":[{"kind":"text","text":"The glory of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"crossref","label":"Ezk 8:4","book":"Ezk","chapter":8,"verse":4,"letter":"a"},{"kind":"text","text":" rose up from within the city and stopped on the mountain "},{"kind":"crossref","label":"Zch 14:4","book":"Zec","chapter":14,"verse":4,"letter":"b"},{"kind":"text","text":" east of the city. "},{"kind":"footnote","marker":1,"text":"= the Mount of Olives"},{"kind":"crossref","label":"Ezk 10:4","book":"Ezk","chapter":10,"verse":4,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 8:4","book":"Ezk","chapter":8,"verse":4},{"label":"Zch 14:4","book":"Zec","chapter":14,"verse":4},{"label":"Ezk 10:4","book":"Ezk","chapter":10,"verse":4}],"footnotes":[{"marker":1,"text":"= the Mount of Olives"}]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:24","parts":[{"kind":"text","text":"The Spirit lifted me up "},{"kind":"crossref","label":"Ezk 8:3","book":"Ezk","chapter":8,"verse":3,"letter":"a"},{"kind":"text","text":" and brought me to Chaldea and to the exiles in a vision from the Spirit of God. After the vision I had seen left me, "}],"crossRefs":[{"label":"Ezk 8:3","book":"Ezk","chapter":8,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Ezk:11:25","parts":[{"kind":"text","text":"I spoke to the exiles about all the things the "},{"kind":"text","text":"Lord","style":"divin