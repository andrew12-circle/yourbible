,"book":"Dan","chapter":7,"verse":17,"letter":"e"},{"kind":"crossref","label":"Dn 8:21","book":"Dan","chapter":8,"verse":21,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 10:21","book":"Dan","chapter":10,"verse":21},{"label":"Dn 12:1","book":"Dan","chapter":12,"verse":1},{"label":"Jd 1:9","book":"Jud","chapter":1,"verse":9},{"label":"Rv 12:7","book":"Rev","chapter":12,"verse":7},{"label":"Dn 7:17","book":"Dan","chapter":7,"verse":17},{"label":"Dn 8:21","book":"Dan","chapter":8,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:10:14","parts":[{"kind":"text","text":"Now I have come to help you understand what will happen to your people in the last days, "},{"kind":"crossref","label":"Dt 31:29","book":"Deu","chapter":31,"verse":29,"letter":"a"},{"kind":"crossref","label":"Dn 2:28","book":"Dan","chapter":2,"verse":28,"letter":"b"},{"kind":"text","text":" for the vision refers to those days.” "},{"kind":"crossref","label":"Dn 8:26","book":"Dan","chapter":8,"verse":26,"letter":"c"},{"kind":"crossref","label":"Dn 12:4","book":"Dan","chapter":12,"verse":4,"letter":"d"},{"kind":"crossref","label":"Dn 12:9","book":"Dan","chapter":12,"verse":9,"letter":"e"}],"crossRefs":[{"label":"Dt 31:29","book":"Deu","chapter":31,"verse":29},{"label":"Dn 2:28","book":"Dan","chapter":2,"verse":28},{"label":"Dn 8:26","book":"Dan","chapter":8,"verse":26},{"label":"Dn 12:4","book":"Dan","chapter":12,"verse":4},{"label":"Dn 12:9","book":"Dan","chapter":12,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:10:15","parts":[{"kind":"text","text":"While he was saying these words to me, I turned my face toward the ground and was speechless. "},{"kind":"crossref","label":"Ezk 3:26","book":"Ezk","chapter":3,"verse":26,"letter":"a"},{"kind":"crossref","label":"Ezk 24:27","book":"Ezk","chapter":24,"verse":27,"letter":"b"},{"kind":"crossref","label":"Lk 1:20","book":"Luk","chapter":1,"verse":20,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label"