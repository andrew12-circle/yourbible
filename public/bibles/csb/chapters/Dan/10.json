t":" your servant, "},{"kind":"footnote","marker":1,"text":"Lit Can I, a servant of my lord"},{"kind":"text","text":" speak with someone like you, my lord? Now I have no strength, and there is no breath in me.”"}],"crossRefs":[{"label":"Ex 24:10–11","book":"Exo","chapter":24,"verse":10},{"label":"Is 6:1–5","book":"Isa","chapter":6,"verse":1}],"footnotes":[{"marker":1,"text":"Lit Can I, a servant of my lord"}]},{"verseId":"a556c5305ee15c3f-01:Dan:10:18","parts":[{"kind":"text","text":"Then the one with a human appearance touched me again and strengthened me. "},{"kind":"crossref","label":"Is 35:3–4","book":"Isa","chapter":35,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 35:3–4","book":"Isa","chapter":35,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:10:19","parts":[{"kind":"text","text":"He said, “Don’t be afraid, "},{"kind":"crossref","label":"Jdg 6:23","book":"Jdg","chapter":6,"verse":23,"letter":"a"},{"kind":"crossref","label":"Is 43:1","book":"Isa","chapter":43,"verse":1,"letter":"b"},{"kind":"crossref","label":"Dn 10:12","book":"Dan","chapter":10,"verse":12,"letter":"c"},{"kind":"text","text":" you who are "},{"kind":"footnote","marker":1,"text":"Lit afraid, man"},{"kind":"text","text":" treasured by God. "},{"kind":"crossref","label":"Dn 9:23","book":"Dan","chapter":9,"verse":23,"letter":"d"},{"kind":"crossref","label":"Dn 10:11","book":"Dan","chapter":10,"verse":11,"letter":"e"},{"kind":"text","text":" Peace to you; be very strong!” "},{"kind":"crossref","label":"Jos 1:6–7","book":"Jos","chapter":1,"verse":6,"letter":"f"},{"kind":"crossref","label":"Jos 1:9","book":"Jos","chapter":1,"verse":9,"letter":"g"},{"kind":"crossref","label":"Is 35:4","book":"Isa","chapter":35,"verse":4,"letter":"h"}],"crossRefs":[{"label":"Jdg 6:23","book":"Jdg","chapter":6,"verse":23},{"label":"Is 43:1","book":"Isa","chapter":43,"verse":1},{"label":"Dn 10:12","book":"Dan","chapter":10,"verse":12},{"label":"Dn 9:23","book":"Dan","chapter":9,"verse":23},{"label":"Dn 10:11","book":"Dan","chapter":10,"verse":11},{"label":"Jos 1:6–7","book":"Jos","chapter":1,"verse":6},{"label":"Jos 1:9","book":"Jos","chapter":1,"verse":9},{"label":"Is 35:4","book":"Isa","chapter":35,"verse":4}],"footnotes":[{"marker":1,"text":"Lit afraid, man"}]},{"verseId":"a556c5305ee15c3f-01:Dan:10:20","parts":[{"kind":"text","text":"He said, “Do you know why I’ve come to you? I must return at once to fight against the prince of Persia, and when I leave, the prince of Greece will come. "},{"kind":"crossref","label":"Dn 8:21","book":"Dan","chapter":8,"verse":21,"letter":"a"},{"kind":"crossref","label":"Dn 11:2","book":"Dan","chapter":11,"verse":2,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dn 8:21","book":"Dan","chapter":8,"verse":21},{"label":"Dn 11:2","book":"Dan","chapter":11,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:10:21","parts":[{"kind":"text","text":"However, I will tell you what is recorded in the book of truth. (No one has the courage to support me against those princes except Michael, "},{"kind":"crossref","label":"Dn 10:13","book":"Dan","chapter":10,"verse":13,"letter":"a"},{"kind":"crossref","label":"Rv 12:7","book":"Rev","chapter":12,"verse":7,"letter":"b"},{"kind":"text","text":" your prince."}],"crossRefs":[{"label":"Dn 10:13","book":"Dan","chapter":10,"verse":13},{"label":"Rv 12:7","book":"Rev","chapter":12,"verse":7}],"footnotes":[]}]},"cachedAt":1783099473508}