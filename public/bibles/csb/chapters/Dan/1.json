ref","label":"Gn 39:21","book":"Gen","chapter":39,"verse":21,"letter":"a"},{"kind":"crossref","label":"1Kg 8:50","book":"1Ki","chapter":8,"verse":50,"letter":"b"},{"kind":"crossref","label":"Jb 5:15","book":"Job","chapter":5,"verse":15,"letter":"c"},{"kind":"crossref","label":"Ps 106:46","book":"Psa","chapter":106,"verse":46,"letter":"d"},{"kind":"crossref","label":"Pr 16:7","book":"Pro","chapter":16,"verse":7,"letter":"e"},{"kind":"crossref","label":"Ac 7:10","book":"Act","chapter":7,"verse":10,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 39:21","book":"Gen","chapter":39,"verse":21},{"label":"1Kg 8:50","book":"1Ki","chapter":8,"verse":50},{"label":"Jb 5:15","book":"Job","chapter":5,"verse":15},{"label":"Ps 106:46","book":"Psa","chapter":106,"verse":46},{"label":"Pr 16:7","book":"Pro","chapter":16,"verse":7},{"label":"Ac 7:10","book":"Act","chapter":7,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:10","parts":[{"kind":"text","text":"yet he said to Daniel, “I fear my lord the king, who assigned your food and drink. What if he sees your faces looking thinner than the other young men your age? You would endanger my life "},{"kind":"footnote","marker":1,"text":"Lit would make my head guilty"},{"kind":"text","text":" with the king.”"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit would make my head guilty"}]},{"verseId":"a556c5305ee15c3f-01:Dan:1:11","parts":[{"kind":"text","text":"So Daniel said to the guard whom the chief eunuch had assigned to Daniel, Hananiah, Mishael, and Azariah, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:12","parts":[{"kind":"text","text":"“Please test your servants for ten days. Let us be given vegetables to eat and water to drink. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:13","parts":[{"kind":"text","text":"Then examine our appearance and the appearance of the young men who are eating the king’s food, and deal with your servants based on what you see.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:14","parts":[{"kind":"text","text":"He agreed with them about this and tested them for ten days. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:15","parts":[{"kind":"text","text":"At the end of ten days they looked better and healthier "},{"kind":"footnote","marker":1,"text":"Lit fatter of flesh"},{"kind":"text","text":" than all the young men who were eating the king’s food. "},{"kind":"crossref","label":"Ex 23:25","book":"Exo","chapter":23,"verse":25,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 23:25","book":"Exo","chapter":23,"verse":25}],"footnotes":[{"marker":1,"text":"Lit fatter of flesh"}]},{"verseId":"a556c5305ee15c3f-01:Dan:1:16","parts":[{"kind":"text","text":"So the guard continued to remove their food and the wine they were to drink and gave them vegetables."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:17","parts":[{"kind":"text","text":"God gave these four young men knowledge and understanding "},{"kind":"crossref","label":"Jb 32:8","book":"Job","chapter":32,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ac 7:22","book":"Act","chapter":7,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jms 1:5","book":"Jas","chapter":1,"verse":5,"letter":"c"},{"kind":"text","text":" in every kind of literature and wisdom. Daniel also understood visions and dreams "},{"kind":"crossref","label":"1Kg 3:10","book":"1Ki","chapter":3,"verse":10,"letter":"d"},{"kind":"crossref","label":"Dn 2:19","book":"Dan","chapter":2,"verse":19,"letter":"e"},{"kind":"crossref","label":"Dn 2:30","book":"Dan","chapter":2,"verse":30,"letter":"f"},{"kind":"crossref","label":"Dn 4:18–19","book":"Dan","chapter":4,"verse":18,"letter":"g"},{"kind":"crossref","label":"Dn 7:1","book":"Dan","chapter":7,"verse":1,"letter":"h"},{"kind":"text","text":" of every kind. "}],"crossRefs":[{"label":"Jb 32:8","book":"Job","chapter":32,"verse":8},{"label":"Ac 7:22","book":"Act","chapter":7,"verse":22},{"label":"Jms 1:5","book":"Jas","chapter":1,"verse":5},{"label":"1Kg 3:10","book":"1Ki","chapter":3,"verse":10},{"label":"Dn 2:19","book":"Dan","chapter":2,"verse":19},{"label":"Dn 2:30","book":"Dan","chapter":2,"verse":30},{"label":"Dn 4:18–19","book":"Dan","chapter":4,"verse":18},{"label":"Dn 7:1","book":"Dan","chapter":7,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:18","parts":[{"kind":"text","text":"At the end of the time that the king had said to present them, the chief eunuch presented them to Nebuchadnezzar. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:19","parts":[{"kind":"text","text":"The king interviewed them, and among all of them, no one was found equal to Daniel, Hananiah, Mishael, and Azariah. "},{"kind":"crossref","label":"Gn 41:37–39","book":"Gen","chapter":41,"verse":37,"letter":"a"},{"kind":"text","text":" So they began to attend the king. "}],"crossRefs":[{"label":"Gn 41:37–39","book":"Gen","chapter":41,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:20","parts":[{"kind":"text","text":"In every matter of wisdom and understanding that the king consulted them about, he found them ten times "},{"kind":"footnote","marker":1,"text":"Lit hands"},{"kind":"crossref","label":"1Sm 1:8","book":"1Sa","chapter":1,"verse":8,"letter":"a"},{"kind":"text","text":" better than all the magicians and mediums "},{"kind":"crossref","label":"Pr 3:13–18","book":"Pro","chapter":3,"verse":13,"letter":"b"},{"kind":"crossref","label":"Dn 5:11","book":"Dan","chapter":5,"verse":11,"letter":"c"},{"kind":"text","text":" in his entire kingdom. "}],"crossRefs":[{"label":"1Sm 1:8","book":"1Sa","chapter":1,"verse":8},{"label":"Pr 3:13–18","book":"Pro","chapter":3,"verse":13},{"label":"Dn 5:11","book":"Dan","chapter":5,"verse":11}],"footnotes":[{"marker":1,"text":"Lit hands"}]},{"verseId":"a556c5305ee15c3f-01:Dan:1:21","parts":[{"kind":"text","text":"Daniel remained there until the first year of King Cyrus. "},{"kind":"crossref","label":"Ezr 1:1–2","book":"Ezr","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"Is 45:1","book":"Isa","chapter":45,"verse":1,"letter":"b"},{"kind":"crossref","label":"Dn 6:28","book":"Dan","chapter":6,"verse":28,"letter":"c"},{"kind":"crossref","label":"Dn 10:1","book":"Dan","chapter":10,"verse":1,"letter":"d"}],"crossRefs":[{"label":"Ezr 1:1–2","book":"Ezr","chapter":1,"verse":1},{"label":"Is 45:1","book":"Isa","chapter":45,"verse":1},{"label":"Dn 6:28","book":"Dan","chapter":6,"verse":28},{"label":"Dn 10:1","book":"Dan","chapter":10,"verse":1}],"footnotes":[]}]},"cachedAt":1783279590883}