:"b"},{"kind":"text","text":" They were to be trained for three years, and at the end of that time they were to attend the king. "},{"kind":"footnote","marker":1,"text":"Lit to stand before the king"},{"kind":"crossref","label":"Gn 41:46","book":"Gen","chapter":41,"verse":46,"letter":"c"},{"kind":"crossref","label":"1Sm 16:22","book":"1Sa","chapter":16,"verse":22,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Kg 25:30","book":"2Ki","chapter":25,"verse":30},{"label":"Dn 11:26","book":"Dan","chapter":11,"verse":26},{"label":"Gn 41:46","book":"Gen","chapter":41,"verse":46},{"label":"1Sm 16:22","book":"1Sa","chapter":16,"verse":22}],"footnotes":[{"marker":1,"text":"Lit to stand before the king"}]},{"verseId":"a556c5305ee15c3f-01:Dan:1:6","parts":[{"kind":"text","text":"Among them, from the Judahites, were Daniel, "},{"kind":"crossref","label":"Ezk 14:14","book":"Ezk","chapter":14,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ezk 14:20","book":"Ezk","chapter":14,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ezk 28:3","book":"Ezk","chapter":28,"verse":3,"letter":"c"},{"kind":"text","text":" Hananiah, Mishael, and Azariah. "}],"crossRefs":[{"label":"Ezk 14:14","book":"Ezk","chapter":14,"verse":14},{"label":"Ezk 14:20","book":"Ezk","chapter":14,"verse":20},{"label":"Ezk 28:3","book":"Ezk","chapter":28,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Dan:1:7","parts":[{"kind":"text","text":"The chief eunuch gave them names; he gave the name Belteshazzar to Daniel, Shadrach to Hananiah, Meshach to Mishael, and Abednego to Azariah. "},{"kind":"crossref","label":"2Kg 23:34","book":"2Ki","chapter":23,"verse":34,"letter":"a"},{"kind":"crossref","label":"2Kg 24:17","book":"2Ki","chapter":24,"verse":17,"letter":"b"},{"kind":"crossref","label":"Dn 4:8","book":"Dan","chapter":4,"verse":8,"letter":"c"},{"kind":"crossref","label":"Dn 4:19","book":"Dan","chapter":4,"verse":19,"letter":"d"},{"kind":"crossref","label":"Dn 5:12","book":"Dan","cha