27,"verse":25},{"label":"1Sm 12:3","book":"1Sa","chapter":12,"verse":3},{"label":"2Ch 19:7","book":"2Ch","chapter":19,"verse":7},{"label":"Ps 15:5","book":"Psa","chapter":15,"verse":5},{"label":"Pr 17:23","book":"Pro","chapter":17,"verse":23},{"label":"Is 33:15","book":"Isa","chapter":33,"verse":15},{"label":"Ezk 22:12","book":"Ezk","chapter":22,"verse":12},{"label":"Am 5:12","book":"Amo","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:16:20","parts":[{"kind":"text","text":"Pursue justice and justice alone, so that you will live and possess the land the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is giving you. "},{"kind":"crossref","label":"Ex 23:2–9","book":"Exo","chapter":23,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Ex 23:2–9","book":"Exo","chapter":23,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:16:21","parts":[{"kind":"text","text":"“Do not set up an Asherah of any kind of wood next to the altar you will build for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:16:22","parts":[{"kind":"text","text":"and do not set up a sacred pillar; the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God hates them. "},{"kind":"crossref","label":"Dt 7:1","book":"Deu","chapter":7,"verse":1,"letter":"a"},{"kind":"crossref","label":"Dt 12:2–3","book":"Deu","chapter":12,"verse":2,"letter":"b"},{"kind":"crossref","label":"2Kg 23:2","book":"2Ki","chapter":23,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Dt 7:1","book":"Deu","chapter":7,"verse":1},{"label":"Dt 12:2–3","book":"Deu","chapter":12,"verse":2},{"label":"2Kg 23:2","book":"2Ki","chapter":23,"verse":2}],"footnotes":[]}]},"cachedAt":1783099263680}