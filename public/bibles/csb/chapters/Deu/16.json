,"chapter":9,"verse":25,"letter":"d"},{"kind":"text","text":" and you will have abundant joy."}],"crossRefs":[{"label":"Ex 23:14","book":"Exo","chapter":23,"verse":14},{"label":"Ex 23:17","book":"Exo","chapter":23,"verse":17},{"label":"Ex 34:23–24","book":"Exo","chapter":34,"verse":23},{"label":"1Kg 9:25","book":"1Ki","chapter":9,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:16:16","parts":[{"kind":"text","text":"“All your males are to appear three times a year "},{"kind":"crossref","label":"Ex 23:14","book":"Exo","chapter":23,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ex 23:17","book":"Exo","chapter":23,"verse":17,"letter":"b"},{"kind":"crossref","label":"Ex 34:23–24","book":"Exo","chapter":34,"verse":23,"letter":"c"},{"kind":"crossref","label":"1Kg 9:25","book":"1Ki","chapter":9,"verse":25,"letter":"d"},{"kind":"crossref","label":"Lk 2:42","book":"Luk","chapter":2,"verse":42,"letter":"e"},{"kind":"text","text":" before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God in the place he chooses: at the Festival of Unleavened Bread, the Festival of Weeks, and the Festival of Shelters. No one is to appear before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" empty-handed. "},{"kind":"crossref","label":"Ex 3:21","book":"Exo","chapter":3,"verse":21,"letter":"f"},{"kind":"crossref","label":"Ex 23:15","book":"Exo","chapter":23,"verse":15,"letter":"g"},{"kind":"crossref","label":"Ex 34:20","book":"Exo","chapter":34,"verse":20,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 23:14","book":"Exo","chapter":23,"verse":14},{"label":"Ex 23:17","book":"Exo","chapter":23,"verse":17},{"label":"Ex 34:23–24","book":"Exo","chapter":34,"verse":23},{"label":"1Kg 9:25","book":"1Ki","chapter":9,"verse":25},{"label":"Lk 2:42","book":"Luk","chapter":2,"verse":42},{"label":"Ex 3:21","book":"Exo","chapter":3,"verse":21},{"label":"Ex 23:15","book":"Exo","chapter":23,"verse":15},{"