:"crossref","label":"Dt 4:23","book":"Deu","chapter":4,"verse":23,"letter":"b"},{"kind":"crossref","label":"Dt 6:12","book":"Deu","chapter":6,"verse":12,"letter":"c"},{"kind":"crossref","label":"Dt 8:11","book":"Deu","chapter":8,"verse":11,"letter":"d"},{"kind":"crossref","label":"Dt 12:13","book":"Deu","chapter":12,"verse":13,"letter":"e"},{"kind":"crossref","label":"Dt 12:19","book":"Deu","chapter":12,"verse":19,"letter":"f"},{"kind":"crossref","label":"Dt 12:30","book":"Deu","chapter":12,"verse":30,"letter":"g"},{"kind":"crossref","label":"Dt 15:9","book":"Deu","chapter":15,"verse":9,"letter":"h"},{"kind":"text","text":" that you are not enticed to turn aside, serve, and bow in worship to other gods. "},{"kind":"crossref","label":"Dt 17:3","book":"Deu","chapter":17,"verse":3,"letter":"i"},{"kind":"crossref","label":"Dt 29:26","book":"Deu","chapter":29,"verse":26,"letter":"j"},{"kind":"crossref","label":"Dt 30:17","book":"Deu","chapter":30,"verse":17,"letter":"k"},{"kind":"crossref","label":"Jos 23:16","book":"Jos","chapter":23,"verse":16,"letter":"l"},{"kind":"crossref","label":"Jdg 2:17","book":"Jdg","chapter":2,"verse":17,"letter":"m"},{"kind":"crossref","label":"2Ch 7:19","book":"2Ch","chapter":7,"verse":19,"letter":"n"},{"kind":"crossref","label":"2Ch 7:22","book":"2Ch","chapter":7,"verse":22,"letter":"o"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 34:12","book":"Exo","chapter":34,"verse":12},{"label":"Dt 4:23","book":"Deu","chapter":4,"verse":23},{"label":"Dt 6:12","book":"Deu","chapter":6,"verse":12},{"label":"Dt 8:11","book":"Deu","chapter":8,"verse":11},{"label":"Dt 12:13","book":"Deu","chapter":12,"verse":13},{"label":"Dt 12:19","book":"Deu","chapter":12,"verse":19},{"label":"Dt 12:30","book":"Deu","chapter":12,"verse":30},{"label":"Dt 15:9","book":"Deu","chapter":15,"verse":9},{"label":"Dt 17:3","book":"Deu","chapter":17,"verse":3},{"label":"Dt 29:26","book":"Deu","chapter":29,"verse":26},{"label":"Dt 30:17","book":"Deu","chapter":30,"verse":17},{"label":"Jos 23:16","book":"Jos","chapter":23,"verse":16},{"label":"Jdg 2:17","book":"Jdg","chapter":2,"verse":17},{"label":"2Ch 7:19","book":"2Ch","chapter":7,"verse":19},{"label":"2Ch 7:22","book":"2Ch","chapter":7,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:17","parts":[{"kind":"text","text":"Then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s anger will burn against you. "},{"kind":"crossref","label":"Ex 22:24","book":"Exo","chapter":22,"verse":24,"letter":"a"},{"kind":"crossref","label":"Dt 7:4","book":"Deu","chapter":7,"verse":4,"letter":"b"},{"kind":"crossref","label":"Dt 31:17","book":"Deu","chapter":31,"verse":17,"letter":"c"},{"kind":"crossref","label":"Jos 23:16","book":"Jos","chapter":23,"verse":16,"letter":"d"},{"kind":"text","text":" He will shut the sky, and there will be no rain; "},{"kind":"crossref","label":"1Kg 8:35","book":"1Ki","chapter":8,"verse":35,"letter":"e"},{"kind":"crossref","label":"2Ch 2:6","book":"2Ch","chapter":2,"verse":6,"letter":"f"},{"kind":"crossref","label":"2Ch 6:26","book":"2Ch","chapter":6,"verse":26,"letter":"g"},{"kind":"crossref","label":"2Ch 7:13","book":"2Ch","chapter":7,"verse":13,"letter":"h"},{"kind":"text","text":" the land will not yield its produce, and you will perish quickly from the good land "},{"kind":"crossref","label":"Dt 8:7","book":"Deu","chapter":8,"verse":7,"letter":"i"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is giving you."}],"crossRefs":[{"label":"Ex 22:24","book":"Exo","chapter":22,"verse":24},{"label":"Dt 7:4","book":"Deu","chapter":7,"verse":4},{"label":"Dt 31:17","book":"Deu","chapter":31,"verse":17},{"label":"Jos 23:16","book":"Jos","chapter":23,"verse":16},{"label":"1Kg 8:35","book":"1Ki","chapter":8,"verse":35},{"label":"2Ch 2:6","book":"2Ch","chapter":2,"verse":6},{"label":"2Ch 6:26","book":"2Ch","chapter":6,"verse":26},{"label":"2Ch 7:13","book":"2Ch","chapter":7,"verse":13},{"label":"Dt 8:7","book":"Deu","chapter":8,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:18","parts":[{"kind":"text","text":"“Imprint these words of mine on your hearts and minds, bind them as a sign on your hands, and let them be a symbol "},{"kind":"footnote","marker":1,"text":"Or phylactery; Mt 23:5"},{"kind":"text","text":" on your foreheads. "},{"kind":"footnote","marker":2,"text":"Lit symbol between your eyes; Ex 13:16; Dt 6:8"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or phylactery; Mt 23:5"},{"marker":2,"text":"Lit symbol between your eyes; Ex 13:16; Dt 6:8"}]},{"verseId":"a556c5305ee15c3f-01:Deu:11:19","parts":[{"kind":"text","text":"Teach them to your children, "},{"kind":"crossref","label":"Dt 4:9","book":"Deu","chapter":4,"verse":9,"letter":"a"},{"kind":"text","text":" talking about them when you sit in your house and when you walk along the road, when you lie down and when you get up. "}],"crossRefs":[{"label":"Dt 4:9","book":"Deu","chapter":4,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:20","parts":[{"kind":"text","text":"Write them on the doorposts of your house and on your city gates, "},{"kind":"crossref","label":"Dt 6:6","book":"Deu","chapter":6,"verse":6,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 6:6","book":"Deu","chapter":6,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:21","parts":[{"kind":"text","text":"so that as long as the heavens are above the earth, your days and those of your children may be many in the land the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" swore to give your ancestors. "},{"kind":"crossref","label":"Dt 1:35","book":"Deu","chapter":1,"verse":35,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 1:35","book":"Deu","chapter":1,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:22","parts":[{"kind":"text","text":"For if you carefully observe every one of these commands I am giving you to follow —to love the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, walk in all his ways, and remain faithful "},{"kind":"footnote","marker":3,"text":"Lit and hold on"},{"kind":"text","text":" to him — "}],"crossRefs":[],"footnotes":[{"marker":3,"text":"Lit and hold on"}]},{"verseId":"a556c5305ee15c3f-01:Deu:11:23","parts":[{"kind":"text","text":"the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will drive out all these nations before you, and you will drive out nations greater and stronger than you are. "},{"kind":"crossref","label":"Dt 4:38","book":"Deu","chapter":4,"verse":38,"letter":"a"},{"kind":"crossref","label":"Dt 9:1","book":"Deu","chapter":9,"verse":1,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 4:38","book":"Deu","chapter":4,"verse":38},{"label":"Dt 9:1","book":"Deu","chapter":9,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:24","parts":[{"kind":"text","text":"Every place the sole of your foot treads will be yours. "},{"kind":"crossref","label":"Jos 1:3–5","book":"Jos","chapter":1,"verse":3,"letter":"a"},{"kind":"text","text":" Your territory will extend from the wilderness to Lebanon and from the Euphrates River "},{"kind":"footnote","marker":4,"text":"Some Hb mss, LXX, Tg, Vg read the great river, the river Euphrates"},{"kind":"text","text":" to the Mediterranean Sea. "},{"kind":"crossref","label":"Gn 15:18–20","book":"Gen","chapter":15,"verse":18,"letter":"b"},{"kind":"crossref","label":"Ex 23:31","book":"Exo","chapter":23,"verse":31,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jos 1:3–5","book":"Jos","chapter":1,"verse":3},{"label":"Gn 15:18–20","book":"Gen","chapter":15,"verse":18},{"label":"Ex 23:31","book":"Exo","chapter":23,"verse":31}],"footnotes":[{"marker":4,"text":"Some Hb mss, LXX, Tg, Vg read the great river, the river Euphrates"}]},{"verseId":"a556c5305ee15c3f-01:Deu:11:25","parts":[{"kind":"text","text":"No one will be able to stand against you; the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God will put fear and dread of you in all the land where you set foot, as he has promised you. "},{"kind":"crossref","label":"Dt 2:25","book":"Deu","chapter":2,"verse":25,"letter":"a"}],"crossRefs":[{"label":"Dt 2:25","book":"Deu","chapter":2,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:26","parts":[{"kind":"text","text":"“Look, today I set before you a blessing and a curse: "},{"kind":"crossref","label":"Dt 30:15","book":"Deu","chapter":30,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jr 21:8","book":"Jer","chapter":21,"verse":8,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 30:15","book":"Deu","chapter":30,"verse":15},{"label":"Jr 21:8","book":"Jer","chapter":21,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:27","parts":[{"kind":"text","text":"there will be a blessing, if you obey the commands of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God I am giving you today, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:28","parts":[{"kind":"text","text":"and a curse, if you do not obey the commands of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God and you turn aside from the path I command you today by following other gods you have not known. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:29","parts":[{"kind":"text","text":"When the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God brings you into the land you are entering to possess, you are to proclaim the blessing at Mount Gerizim and the curse at Mount Ebal. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:30","parts":[{"kind":"text","text":"Aren’t these mountains across the Jordan, beyond the western road in the land of the Canaanites, who live in the Arabah, opposite Gilgal, near the oaks "},{"kind":"footnote","marker":1,"text":"Sam, LXX, Syr, Aq, Sym read oak; Gn 12:6"},{"kind":"text","text":" of Moreh? "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Sam, LXX, Syr, Aq, Sym read oak; Gn 12:6"}]},{"verseId":"a556c5305ee15c3f-01:Deu:11:31","parts":[{"kind":"text","text":"For you are about to cross the Jordan to enter and take possession of the land the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is giving you. When you possess it and settle in it, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:11:32","parts":[{"kind":"text","text":"be careful to follow all the statutes and ordinances I set before you today."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279358103}