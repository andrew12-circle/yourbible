":"text","text":" who brought you out of the land of Egypt, out of the place of slavery. "},{"kind":"crossref","label":"Lv 26:13","book":"Lev","chapter":26,"verse":13,"letter":"a"},{"kind":"crossref","label":"Dt 5:6","book":"Deu","chapter":5,"verse":6,"letter":"b"},{"kind":"crossref","label":"Dt 8:14","book":"Deu","chapter":8,"verse":14,"letter":"c"},{"kind":"crossref","label":"Dt 13:5","book":"Deu","chapter":13,"verse":5,"letter":"d"},{"kind":"crossref","label":"Dt 13:10","book":"Deu","chapter":13,"verse":10,"letter":"e"},{"kind":"crossref","label":"Jos 24:17","book":"Jos","chapter":24,"verse":17,"letter":"f"},{"kind":"crossref","label":"Jr 34:13","book":"Jer","chapter":34,"verse":13,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 26:13","book":"Lev","chapter":26,"verse":13},{"label":"Dt 5:6","book":"Deu","chapter":5,"verse":6},{"label":"Dt 8:14","book":"Deu","chapter":8,"verse":14},{"label":"Dt 13:5","book":"Deu","chapter":13,"verse":5},{"label":"Dt 13:10","book":"Deu","chapter":13,"verse":10},{"label":"Jos 24:17","book":"Jos","chapter":24,"verse":17},{"label":"Jr 34:13","book":"Jer","chapter":34,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:6:13","parts":[{"kind":"text","text":"Fear the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, worship him, and take your oaths in his name. "},{"kind":"crossref","label":"Dt 10:12","book":"Deu","chapter":10,"verse":12,"letter":"a"},{"kind":"crossref","label":"Dt 10:20","book":"Deu","chapter":10,"verse":20,"letter":"b"},{"kind":"crossref","label":"Dt 13:4","book":"Deu","chapter":13,"verse":4,"letter":"c"},{"kind":"crossref","label":"Jos 24:14","book":"Jos","chapter":24,"verse":14,"letter":"d"},{"kind":"crossref","label":"1Sm 12:24","book":"1Sa","chapter":12,"verse":24,"letter":"e"},{"kind":"crossref","label":"Mt 4:10","book":"Mat","chapter":4,"verse":10,"letter":"f"},{"kind":"crossref","label":"Lk 4:8","book":"Luk","chapter":4,"verse":8,"letter":"g"},{"