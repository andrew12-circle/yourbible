"c"},{"kind":"text","text":" and don’t be stiff-necked any longer. "}],"crossRefs":[{"label":"Dt 30:6","book":"Deu","chapter":30,"verse":6},{"label":"Jr 4:4","book":"Jer","chapter":4,"verse":4},{"label":"Rm 2:29","book":"Rom","chapter":2,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:10:17","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is the God of gods "},{"kind":"crossref","label":"Jos 22:22","book":"Jos","chapter":22,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ps 50:1","book":"Psa","chapter":50,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ps 136:2","book":"Psa","chapter":136,"verse":2,"letter":"c"},{"kind":"crossref","label":"Dn 2:47","book":"Dan","chapter":2,"verse":47,"letter":"d"},{"kind":"crossref","label":"Dn 11:36","book":"Dan","chapter":11,"verse":36,"letter":"e"},{"kind":"text","text":" and Lord of lords, "},{"kind":"crossref","label":"Ps 136:3","book":"Psa","chapter":136,"verse":3,"letter":"f"},{"kind":"crossref","label":"1Tm 6:15","book":"1Ti","chapter":6,"verse":15,"letter":"g"},{"kind":"crossref","label":"Rv 17:14","book":"Rev","chapter":17,"verse":14,"letter":"h"},{"kind":"crossref","label":"Rv 19:6","book":"Rev","chapter":19,"verse":6,"letter":"i"},{"kind":"text","text":" the great, mighty, and awe-inspiring God, showing no partiality and taking no bribe. "},{"kind":"crossref","label":"2Ch 19:7","book":"2Ch","chapter":19,"verse":7,"letter":"j"},{"kind":"crossref","label":"Jb 34:19","book":"Job","chapter":34,"verse":19,"letter":"k"},{"kind":"crossref","label":"Mt 22:16","book":"Mat","chapter":22,"verse":16,"letter":"l"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jos 22:22","book":"Jos","chapter":22,"verse":22},{"label":"Ps 50:1","book":"Psa","chapter":50,"verse":1},{"label":"Ps 136:2","book":"Psa","chapter":136,"verse":2},{"label":"Dn 2:47","book":"Dan","chapter":2,"verse":47},{"label":"Dn 11:36","book":"Dan","chapter":11,"verse":36},{"label":"Ps 136:3","book":"Psa","chapter":136,"verse":3},{"label":"1Tm 6:15","book":"1Ti","chapter":6,"verse":15},{"label":"Rv 17:14","book":"Rev","chapter":17,"verse":14},{"label":"Rv 19:6","book":"Rev","chapter":19,"verse":6},{"label":"2Ch 19:7","book":"2Ch","chapter":19,"verse":7},{"label":"Jb 34:19","book":"Job","chapter":34,"verse":19},{"label":"Mt 22:16","book":"Mat","chapter":22,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:10:18","parts":[{"kind":"text","text":"He executes justice for the fatherless and the widow, and loves the resident alien, giving him food and clothing. "},{"kind":"crossref","label":"Dt 27:19","book":"Deu","chapter":27,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 22:3","book":"Jer","chapter":22,"verse":3,"letter":"b"},{"kind":"crossref","label":"Mal 3:5","book":"Mal","chapter":3,"verse":5,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 27:19","book":"Deu","chapter":27,"verse":19},{"label":"Jr 22:3","book":"Jer","chapter":22,"verse":3},{"label":"Mal 3:5","book":"Mal","chapter":3,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:10:19","parts":[{"kind":"text","text":"You are also to love the resident alien, since you were resident aliens in the land of Egypt. "},{"kind":"crossref","label":"Lv 19:34","book":"Lev","chapter":19,"verse":34,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 19:34","book":"Lev","chapter":19,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:10:20","parts":[{"kind":"text","text":"You are to fear the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God and worship him. Remain faithful "},{"kind":"footnote","marker":1,"text":"Lit Hold on"},{"kind":"text","text":" to him and take oaths in his name. "},{"kind":"crossref","label":"Dt 6:13","book":"Deu","chapter":6,"verse":13,"letter":"a"},{"kind":"crossref","label":"Dt 13:4","book":"Deu","chapter":13,"verse":4,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 6:13","book":"Deu","chapter":6,"verse":13},{"label":"Dt 13:4","book":"Deu","chapter":13,"verse":4}],"footnotes":[{"marker":1,"text":"Lit Hold on"}]},{"verseId":"a556c5305ee15c3f-01:Deu:10:21","parts":[{"kind":"text","text":"He is your praise and he is your God, who has done for you these great and awe-inspiring works your eyes have seen. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:10:22","parts":[{"kind":"text","text":"Your ancestors went down to Egypt, seventy people in all, "},{"kind":"crossref","label":"Gn 46:27","book":"Gen","chapter":46,"verse":27,"letter":"a"},{"kind":"crossref","label":"Ex 1:5","book":"Exo","chapter":1,"verse":5,"letter":"b"},{"kind":"text","text":" and now the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has made you numerous, like the stars of the sky. "},{"kind":"crossref","label":"Gn 15:5","book":"Gen","chapter":15,"verse":5,"letter":"c"},{"kind":"crossref","label":"Gn 22:17","book":"Gen","chapter":22,"verse":17,"letter":"d"},{"kind":"crossref","label":"Gn 26:4","book":"Gen","chapter":26,"verse":4,"letter":"e"}],"crossRefs":[{"label":"Gn 46:27","book":"Gen","chapter":46,"verse":27},{"label":"Ex 1:5","book":"Exo","chapter":1,"verse":5},{"label":"Gn 15:5","book":"Gen","chapter":15,"verse":5},{"label":"Gn 22:17","book":"Gen","chapter":22,"verse":17},{"label":"Gn 26:4","book":"Gen","chapter":26,"verse":4}],"footnotes":[]}]},"cachedAt":1783279357670}