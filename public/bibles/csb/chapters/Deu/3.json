chapter":28,"verse":2},{"label":"2Ch 6:41","book":"2Ch","chapter":6,"verse":41},{"label":"Ps 23:2","book":"Psa","chapter":23,"verse":2},{"label":"Ps 95:11","book":"Psa","chapter":95,"verse":11},{"label":"Ps 116:7","book":"Psa","chapter":116,"verse":7},{"label":"Ps 132:8","book":"Psa","chapter":132,"verse":8},{"label":"Ps 132:14","book":"Psa","chapter":132,"verse":14},{"label":"Is 11:10","book":"Isa","chapter":11,"verse":10},{"label":"Is 14:3","book":"Isa","chapter":14,"verse":3},{"label":"Is 14:7","book":"Isa","chapter":14,"verse":7},{"label":"Is 28:12","book":"Isa","chapter":28,"verse":12},{"label":"Is 32:18","book":"Isa","chapter":32,"verse":18},{"label":"Is 63:14","book":"Isa","chapter":63,"verse":14},{"label":"Is 66:1","book":"Isa","chapter":66,"verse":1},{"label":"Heb 3:11","book":"Heb","chapter":3,"verse":11},{"label":"Nm 32:20","book":"Num","chapter":32,"verse":20},{"label":"Jos 1:14–15","book":"Jos","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:21","parts":[{"kind":"text","text":"“I commanded Joshua at that time: Your own eyes have seen everything the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has done to these two kings. The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will do the same to all the kingdoms you are about to enter. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:22","parts":[{"kind":"text","text":"Don’t be afraid of them, for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God fights for you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:23","parts":[{"kind":"text","text":"“At that time I begged the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":": "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:24","parts":[{"kind":"text","text":"Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":", you have begun to show your greatness and your strong hand to your servant, for what god is there in heaven or on earth who can perform deeds and mighty acts like yours? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:25","parts":[{"kind":"text","text":"Please let me cross over and see the beautiful land "},{"kind":"crossref","label":"Dt 8:7","book":"Deu","chapter":8,"verse":7,"letter":"a"},{"kind":"text","text":" on the other side of the Jordan, that good hill country and Lebanon."}],"crossRefs":[{"label":"Dt 8:7","book":"Deu","chapter":8,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:26","parts":[{"kind":"text","text":"“But the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" was angry with me because of you "},{"kind":"footnote","marker":1,"text":"Or me for your sake"},{"kind":"text","text":" and would not listen to me. The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said to me, ‘That’s enough! Do not speak to me again about this matter. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or me for your sake"}]},{"verseId":"a556c5305ee15c3f-01:Deu:3:27","parts":[{"kind":"text","text":"Go to the top of Pisgah and look to the west, north, south, and east, and see it with your own eyes, for you will not cross the Jordan. "},{"kind":"crossref","label":"Nm 20:1","book":"Num","chapter":20,"verse":1,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 20:1","book":"Num","chapter":20,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:28","parts":[{"kind":"text","text":"But commission Joshua and encourage and strengthen him, for he will cross over ahead of the people and enable them to inherit this land that you will see.’ "},{"kind":"crossref","label":"Nm 27:12","book":"Num","chapter":27,"verse":12,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 27:12","book":"Num","chapter":27,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:29","parts":[{"kind":"text","text":"So we stayed in the valley facing Beth-peor."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279355035}