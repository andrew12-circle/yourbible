49:2","book":"Jer","chapter":49,"verse":2},{"label":"1Sm 17:4","book":"1Sa","chapter":17,"verse":4}],"footnotes":[{"marker":1,"text":"Or sarcophagus"},{"marker":2,"text":"Lit nine cubits its length and four cubits its width, by a man’s cubit"}]},{"verseId":"a556c5305ee15c3f-01:Deu:3:12","parts":[{"kind":"text","text":"“At that time we took possession of this land. "},{"kind":"crossref","label":"Gn 28:4","book":"Gen","chapter":28,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lv 20:24","book":"Lev","chapter":20,"verse":24,"letter":"b"},{"kind":"crossref","label":"Dt 4:5","book":"Deu","chapter":4,"verse":5,"letter":"c"},{"kind":"crossref","label":"Dt 6:1","book":"Deu","chapter":6,"verse":1,"letter":"d"},{"kind":"crossref","label":"Dt 7:1","book":"Deu","chapter":7,"verse":1,"letter":"e"},{"kind":"crossref","label":"Dt 8:1","book":"Deu","chapter":8,"verse":1,"letter":"f"},{"kind":"crossref","label":"Dt 12:29","book":"Deu","chapter":12,"verse":29,"letter":"g"},{"kind":"crossref","label":"Dt 30:5","book":"Deu","chapter":30,"verse":5,"letter":"h"},{"kind":"text","text":" I gave to the Reubenites and Gadites the area extending from Aroer by the Arnon Valley, and half the hill country of Gilead along with its cities. "}],"crossRefs":[{"label":"Gn 28:4","book":"Gen","chapter":28,"verse":4},{"label":"Lv 20:24","book":"Lev","chapter":20,"verse":24},{"label":"Dt 4:5","book":"Deu","chapter":4,"verse":5},{"label":"Dt 6:1","book":"Deu","chapter":6,"verse":1},{"label":"Dt 7:1","book":"Deu","chapter":7,"verse":1},{"label":"Dt 8:1","book":"Deu","chapter":8,"verse":1},{"label":"Dt 12:29","book":"Deu","chapter":12,"verse":29},{"label":"Dt 30:5","book":"Deu","chapter":30,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:13","parts":[{"kind":"text","text":"I gave to half the tribe of Manasseh the rest of Gilead and all Bashan, the kingdom of Og. The entire region of Argob, the whole territory of Bashan, used to be called the land of the Rephaim. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:14","parts":[{"kind":"text","text":"Jair, a descendant of Manasseh, took over the entire region of Argob as far as the border of the Geshurites and Maacathites. He called Bashan by his own name, Jair’s Villages, "},{"kind":"footnote","marker":1,"text":"Or Havvoth-jair"},{"kind":"text","text":" as it is today. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or Havvoth-jair"}]},{"verseId":"a556c5305ee15c3f-01:Deu:3:15","parts":[{"kind":"text","text":"I gave Gilead to Machir, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:16","parts":[{"kind":"text","text":"and I gave to the Reubenites and Gadites the area extending from Gilead to the Arnon Valley (the middle of the valley was the border) and up to the Jabbok River, the border of the Ammonites. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:17","parts":[{"kind":"text","text":"The Arabah and Jordan are also borders from Chinnereth "},{"kind":"footnote","marker":2,"text":"= the Sea of Galilee; Jos 12:3; 13:27; Lk 5:1"},{"kind":"text","text":" as far as the Sea of the Arabah, the Dead Sea, under the slopes of Pisgah on the east. "},{"kind":"crossref","label":"Nm 32:1","book":"Num","chapter":32,"verse":1,"letter":"a"},{"kind":"crossref","label":"Nm 32:33","book":"Num","chapter":32,"verse":33,"letter":"b"},{"kind":"crossref","label":"Jos 12:2–3","book":"Jos","chapter":12,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Nm 32:1","book":"Num","chapter":32,"verse":1},{"label":"Nm 32:33","book":"Num","chapter":32,"verse":33},{"label":"Jos 12:2–3","book":"Jos","chapter":12,"verse":2}],"footnotes":[{"marker":2,"text":"= the Sea of Galilee; Jos 12:3; 13:27; Lk 5:1"}]},{"verseId":"a556c5305ee15c3f-01:Deu:3:18","parts":[{"kind":"text","text":"“I commanded you at that time: The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has given you this land to possess. All your valiant men will cross over in battle formation ahead of your brothers the Israelites. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:19","parts":[{"kind":"text","text":"But your wives, dependents, and livestock —I know that you have a lot of livestock —will remain in the cities I have given you "},{"kind":"crossref","label":"Dt 1:39","book":"Deu","chapter":1,"verse":39,"letter":"a"},{"kind":"crossref","label":"Dt 2:35","book":"Deu","chapter":2,"verse":35,"letter":"b"},{"kind":"crossref","label":"Dt 3:7","book":"Deu","chapter":3,"verse":7,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 1:39","book":"Deu","chapter":1,"verse":39},{"label":"Dt 2:35","book":"Deu","chapter":2,"verse":35},{"label":"Dt 3:7","book":"Deu","chapter":3,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:3:20","parts":[{"kind":"text","text":"until the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" gives rest "},{"kind":"crossref","label":"Gn 2:15","book":"Gen","chapter":2,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ex 20:11","book":"Exo","chapter":20,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ex 23:12","book":"Exo","chapter":23,"verse":12,"letter":"c"},{"kind":"crossref","label":"Ex 33:14","book":"Exo","chapter":33,"verse":14,"letter":"d"},{"kind":"crossref","label":"Nm 10:33","book":"Num","chapter":10,"verse":33,"letter":"e"},{"kind":"crossref","label":"Nm 10:36","book":"Num","chapter":10,"verse":36,"letter":"f"},{"kind":"crossref","label":"Dt 12:9","book":"Deu","chapter":12,"verse":9,"letter":"g"},{"kind":"crossref","label":"Dt 25:19","book":"Deu","chapter":25,"verse":19,"letter":"h"},{"kind":"crossref","label":"Dt 28:65","book":"Deu","chapter":28,"verse":65,"letter":"i"},{"kind":"crossref","label":"Jos 1:13","book":"Jos","chapter":1,"verse":13,"letter":"j"},{"kind":"crossref","label":"Jos 1:15","book":"Jos","chapter":1,"verse":15,"letter":"k"},{"kind":"crossref","label":"Jos 21:44","book":"Jos","chapter":21,"verse"