},{"verseId":"a556c5305ee15c3f-01:Deu:32:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":19,"text":"When the Lord saw this, he despised them,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":20,"text":"He said, “I will hide my face from them;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":21,"text":"They have provoked my jealousy","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":22,"text":"For fire has been kindled because of my anger","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":23,"text":"“I will pile disasters on them;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":24,"text":"They will be weak from hunger,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":25,"text":"Outside, the sword will take their children,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":26,"text":"“I would have said: I will cut them to pieces","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":27,"text":"if I had not feared provocation from the enemy,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":28,"text":"Israel is a nation lacking sense","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":29,"text":"If only they were wise, they would comprehend this;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":30,"text":"How could one pursue a thousand,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":31,"text":"But their “rock” is not like our Rock,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":32,"text":"For their vine is from the vine of Sodom","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":33,"text":"Their wine is serpents’ venom,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":34,"text":"“Is it not stored up with me,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":35,"text":"Vengeance and retribution belong to me.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":36,"text":"The Lord will indeed vindicate his people","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:37","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":37,"text":"He will say, “Where are their gods,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:38","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":38,"text":"Who ate the fat of their sacrifices","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:39","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":39,"text":"See now that I alone am he;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:40","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":40,"text":"I raise my hand to heaven and declare:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:41","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":41,"text":"when I sharpen my flashing sword,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:42","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":42,"text":"I will make my arrows drunk with blood","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:43","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":43,"text":"Rejoice, you nations, concerning his people,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:44","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":44,"text":"Moses came with Joshua son of Nun and recited all the words of this song in the presence of the people.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:45","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"verse":45,"text":"After Moses finished reciting all these words to all Israel,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Deu:32:46","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Deu","bookOrder":4,"chapter":32,"v