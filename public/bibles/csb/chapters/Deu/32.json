r":2,"text":"= Upright One, referring to Israel"}]},{"verseId":"a556c5305ee15c3f-01:Deu:32:16","parts":[{"kind":"text","text":"They provoked his jealousy with different gods;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:17","parts":[{"kind":"text","text":"They sacrificed to demons, not God,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:18","parts":[{"kind":"text","text":"You ignored the Rock who gave you birth;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:19","parts":[{"kind":"text","text":"When the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" saw this, he despised them,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:20","parts":[{"kind":"text","text":"He said, “I will hide my face from them; "},{"kind":"crossref","label":"Dt 31:17","book":"Deu","chapter":31,"verse":17,"letter":"a"},{"kind":"crossref","label":"Jb 13:24","book":"Job","chapter":13,"verse":24,"letter":"b"},{"kind":"crossref","label":"Jb 34:29","book":"Job","chapter":34,"verse":29,"letter":"c"},{"kind":"crossref","label":"Ps 10:11","book":"Psa","chapter":10,"verse":11,"letter":"d"},{"kind":"crossref","label":"Ps 13:1","book":"Psa","chapter":13,"verse":1,"letter":"e"},{"kind":"crossref","label":"Ps 22:24","book":"Psa","chapter":22,"verse":24,"letter":"f"},{"kind":"crossref","label":"Ps 27:9","book":"Psa","chapter":27,"verse":9,"letter":"g"},{"kind":"crossref","label":"Ps 30:7","book":"Psa","chapter":30,"verse":7,"letter":"h"},{"kind":"crossref","label":"Ps 69:17","book":"Psa","chapter":69,"verse":17,"letter":"i"},{"kind":"crossref","label":"Ps 88:14","book":"Psa","chapter":88,"verse":14,"letter":"j"},{"kind":"crossref","label":"Ps 102:2","book":"Psa","chapter":102,"verse":2,"letter":"k"},{"kind":"crossref","label":"Ps 104:29","book":"Psa","chapter":104,"verse":29,"letter":"l"},{"kind":"crossref","label":"Ps 143:7","book":"Psa","chapter":143,"verse":7,"letter":"m"},{"ki