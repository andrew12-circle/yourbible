","text":"They have provoked my jealousy"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:22","parts":[{"kind":"text","text":"For fire has been kindled because of my anger"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:23","parts":[{"kind":"text","text":"“I will pile disasters on them;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:24","parts":[{"kind":"text","text":"They will be weak from hunger,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:25","parts":[{"kind":"text","text":"Outside, the sword will take their children,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:26","parts":[{"kind":"text","text":"“I would have said: I will cut them to pieces "},{"kind":"footnote","marker":1,"text":"LXX reads will scatter them"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"LXX reads will scatter them"}]},{"verseId":"a556c5305ee15c3f-01:Deu:32:27","parts":[{"kind":"text","text":"if I had not feared provocation from the enemy,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:28","parts":[{"kind":"text","text":"Israel is a nation lacking sense"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:29","parts":[{"kind":"text","text":"If only they were wise, they would comprehend this;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:30","parts":[{"kind":"text","text":"How could one pursue a thousand,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:31","parts":[{"kind":"text","text":"But their “rock” is not like our Rock,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:32","parts":[{"kind":"text","text":"For their vine is from the vine of Sodom"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:33","parts":[{"kind":"text","text":"Their wine is serpents’ venom,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:34","parts":[{"kind":"text","text":"“Is it not stored up with me,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:35","parts":[{"kind":"text","text":"Vengeance and retribution belong to me. "},{"kind":"footnote","marker":1,"text":"MT; LXX reads On a day of vengeance I will repay."},{"kind":"crossref","label":"1Sm 24:12","book":"1Sa","chapter":24,"verse":12,"letter":"a"},{"kind":"crossref","label":"2Sm 22:48","book":"2Sa","chapter":22,"verse":48,"letter":"b"},{"kind":"crossref","label":"Jr 11:20","book":"Jer","chapter":11,"verse":20,"letter":"c"},{"kind":"crossref","label":"Jr 51:36","book":"Jer","chapter":51,"verse":36,"letter":"d"},{"kind":"crossref","label":"Nah 1:2","book":"Nam","chapter":1,"verse":2,"letter":"e"},{"kind":"crossref","label":"Rm 12:19","book":"Rom","chapter":12,"verse":19,"letter":"f"},{"kind":"crossref","label":"Heb 10:30","book":"Heb","chapter":10,"verse":30,"letter":"g"}],"crossRefs":[{"label":"1Sm 24:12","book":"1Sa","chapter":24,"verse":12},{"label":"2Sm 22:48","book":"2Sa","chapter":22,"verse":48},{"label":"Jr 11:20","book":"Jer","chapter":11,"verse":20},{"label":"Jr 51:36","book":"Jer","chapter":51,"verse":36},{"label":"Nah 1:2","book":"Nam","chapter":1,"verse":2},{"label":"Rm 12:19","book":"Rom","chapter":12,"verse":19},{"label":"Heb 10:30","book":"Heb","chapter":10,"verse":30}],"footnotes":[{"marker":1,"text":"MT; LXX reads On a day of vengeance I will repay."}]},{"verseId":"a556c5305ee15c3f-01:Deu:32:36","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will indeed vindicate his people"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:37","parts":[{"kind":"text","text":"He will say, “Where are their gods,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:38","parts":[{"kind":"text","text":"Who ate the fat of their sacrifices"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:39","parts":[{"kind":"text","text":"See now that I alone am he;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:40","parts":[{"kind":"text","text":"I raise my hand to heaven and declare:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:41","parts":[{"kind":"text","text":"when I sharpen my flashing sword,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:42","parts":[{"kind":"text","text":"I will make my arrows drunk with blood"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:43","parts":[{"kind":"text","text":"Rejoice, you nations, concerning his people, "},{"kind":"footnote","marker":1,"text":"LXX reads Rejoice, you heavens, along with him, and let all the sons of God worship him; rejoice, you nations, with his people, and let all the angels of God strengthen themselves in him; DSS read Rejoice, you heavens, along with him, and let all the angels worship him; Heb 1:6"},{"kind":"crossref","label":"Rm 15:10","book":"Rom","chapter":15,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Rm 15:10","book":"Rom","chapter":15,"verse":10}],"footnotes":[{"marker":1,"text":"LXX reads Rejoice, you heavens, along with him, and let all the sons of God worship him; rejoice, you nations, with his people, and let all the angels of God strengthen themselves in him; DSS read Rejoice, you heavens, along with him, and let all the angels worship him; Heb 1:6"}]},{"verseId":"a556c5305ee15c3f-01:Deu:32:44","parts":[{"kind":"text","text":"Moses came with Joshua "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Vg; MT reads Hoshea; Nm 13:8,16"},{"kind":"text","text":" son of Nun and recited all the words of this song in the presence of the people. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"LXX, Syr, Vg; MT reads Hoshea; Nm 13:8,16"}]},{"verseId":"a556c5305ee15c3f-01:Deu:32:45","parts":[{"kind":"text","text":"After Moses finished reciting all these words to all Israel, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:46","parts":[{"kind":"text","text":"he said to them, “Take to heart all these words I am giving as a warning to you today, "},{"kind":"crossref","label":"Dt 11:18","book":"Deu","chapter":11,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ezk 3:10","book":"Ezk","chapter":3,"verse":10,"letter":"b"},{"kind":"crossref","label":"Mal 2:2","book":"Mal","chapter":2,"verse":2,"letter":"c"},{"kind":"text","text":" so that you may command your children to follow all the words of this law carefully. "},{"kind":"crossref","label":"Dt 29:29","book":"Deu","chapter":29,"verse":29,"letter":"d"},{"kind":"crossref","label":"Dt 31:12","book":"Deu","chapter":31,"verse":12,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 11:18","book":"Deu","chapter":11,"verse":18},{"label":"Ezk 3:10","book":"Ezk","chapter":3,"verse":10},{"label":"Mal 2:2","book":"Mal","chapter":2,"verse":2},{"label":"Dt 29:29","book":"Deu","chapter":29,"verse":29},{"label":"Dt 31:12","book":"Deu","chapter":31,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:47","parts":[{"kind":"text","text":"For they are not meaningless words to you but they are your life, "},{"kind":"crossref","label":"Dt 30:20","book":"Deu","chapter":30,"verse":20,"letter":"a"},{"kind":"crossref","label":"Pr 4:13","book":"Pro","chapter":4,"verse":13,"letter":"b"},{"kind":"text","text":" and by them you will live long in the land you are crossing the Jordan to possess.”"}],"crossRefs":[{"label":"Dt 30:20","book":"Deu","chapter":30,"verse":20},{"label":"Pr 4:13","book":"Pro","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:48","parts":[{"kind":"text","text":"On that same day the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" spoke to Moses, "},{"kind":"crossref","label":"Nm 27:12","book":"Num","chapter":27,"verse":12,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 27:12","book":"Num","chapter":27,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:49","parts":[{"kind":"text","text":"“Go up Mount Nebo "},{"kind":"crossref","label":"Dt 34:1","book":"Deu","chapter":34,"verse":1,"letter":"a"},{"kind":"text","text":" in the Abarim range in the land of Moab, across from Jericho, and view the land of Canaan I am giving the Israelites as a possession. "}],"crossRefs":[{"label":"Dt 34:1","book":"Deu","chapter":34,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:50","parts":[{"kind":"text","text":"Then you will die on the mountain that you go up, and you will be gathered to your people, "},{"kind":"crossref","label":"Gn 25:8","book":"Gen","chapter":25,"verse":8,"letter":"a"},{"kind":"crossref","label":"Gn 25:17","book":"Gen","chapter":25,"verse":17,"letter":"b"},{"kind":"crossref","label":"Gn 35:29","book":"Gen","chapter":35,"verse":29,"letter":"c"},{"kind":"crossref","label":"Gn 49:33","book":"Gen","chapter":49,"verse":33,"letter":"d"},{"kind":"crossref","label":"Nm 27:13","book":"Num","chapter":27,"verse":13,"letter":"e"},{"kind":"crossref","label":"Nm 31:2","book":"Num","chapter":31,"verse":2,"letter":"f"},{"kind":"text","text":" just as your brother Aaron died on Mount Hor and was gathered to his people. "},{"kind":"crossref","label":"Nm 20:22","book":"Num","chapter":20,"verse":22,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 25:8","book":"Gen","chapter":25,"verse":8},{"label":"Gn 25:17","book":"Gen","chapter":25,"verse":17},{"label":"Gn 35:29","book":"Gen","chapter":35,"verse":29},{"label":"Gn 49:33","book":"Gen","chapter":49,"verse":33},{"label":"Nm 27:13","book":"Num","chapter":27,"verse":13},{"label":"Nm 31:2","book":"Num","chapter":31,"verse":2},{"label":"Nm 20:22","book":"Num","chapter":20,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:51","parts":[{"kind":"text","text":"For both of you broke faith with me among the Israelites at the Waters of Meribath-kadesh in the Wilderness of Zin by failing to treat me as holy in their presence. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:32:52","parts":[{"kind":"text","text":"Although from a distance you will view the land that I am giving the Israelites, you will not go there.” "},{"kind":"crossref","label":"Nm 20:2","book":"Num","chapter":20,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Nm 20:2","book":"Num","chapter":20,"verse":2}],"footnotes":[]}]},"cachedAt":1783099268597}