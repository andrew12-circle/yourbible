":"2Ch","chapter":14,"verse":3},{"label":"2Ch 31:1","book":"2Ch","chapter":31,"verse":1},{"label":"2Ch 34:4","book":"2Ch","chapter":34,"verse":4},{"label":"2Ch 34:7","book":"2Ch","chapter":34,"verse":7},{"label":"Is 27:9","book":"Isa","chapter":27,"verse":9}],"footnotes":[{"marker":1,"text":"Lit that"}]},{"verseId":"a556c5305ee15c3f-01:Deu:12:4","parts":[{"kind":"text","text":"Don’t worship the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God this way. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:5","parts":[{"kind":"text","text":"Instead, turn to the place the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God chooses "},{"kind":"crossref","label":"Dt 14:23","book":"Deu","chapter":14,"verse":23,"letter":"a"},{"kind":"crossref","label":"Dt 15:20","book":"Deu","chapter":15,"verse":20,"letter":"b"},{"kind":"crossref","label":"Dt 16:2","book":"Deu","chapter":16,"verse":2,"letter":"c"},{"kind":"crossref","label":"Dt 16:7","book":"Deu","chapter":16,"verse":7,"letter":"d"},{"kind":"crossref","label":"Dt 16:11","book":"Deu","chapter":16,"verse":11,"letter":"e"},{"kind":"crossref","label":"Dt 16:15","book":"Deu","chapter":16,"verse":15,"letter":"f"},{"kind":"crossref","label":"Dt 17:8","book":"Deu","chapter":17,"verse":8,"letter":"g"},{"kind":"crossref","label":"Dt 17:10","book":"Deu","chapter":17,"verse":10,"letter":"h"},{"kind":"crossref","label":"Dt 18:6","book":"Deu","chapter":18,"verse":6,"letter":"i"},{"kind":"crossref","label":"Dt 26:2","book":"Deu","chapter":26,"verse":2,"letter":"j"},{"kind":"crossref","label":"Dt 31:11","book":"Deu","chapter":31,"verse":11,"letter":"k"},{"kind":"crossref","label":"Jos 9:27","book":"Jos","chapter":9,"verse":27,"letter":"l"},{"kind":"text","text":" from all your tribes to put his name for his dwelling and go there. "}],"crossRefs":[{"label":"Dt 14:23","book":"Deu","chapter":14,"verse":23},{"label":"Dt 15:20","book":"Deu","chapter":15,"verse":20},{"label":"Dt 16:2","book":"Deu","chapter":16,"verse":2},{"label":"Dt 16:7","book":"Deu","chapter":16,"verse":7},{"label":"Dt 16:11","book":"Deu","chapter":16,"verse":11},{"label":"Dt 16:15","book":"Deu","chapter":16,"verse":15},{"label":"Dt 17:8","book":"Deu","chapter":17,"verse":8},{"label":"Dt 17:10","book":"Deu","chapter":17,"verse":10},{"label":"Dt 18:6","book":"Deu","chapter":18,"verse":6},{"label":"Dt 26:2","book":"Deu","chapter":26,"verse":2},{"label":"Dt 31:11","book":"Deu","chapter":31,"verse":11},{"label":"Jos 9:27","book":"Jos","chapter":9,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:6","parts":[{"kind":"text","text":"You are to bring there your burnt offerings and sacrifices, your tenths and personal contributions, "},{"kind":"footnote","marker":2,"text":"Lit and the contributions from your hands"},{"kind":"text","text":" your vow offerings and freewill offerings, and the firstborn of your herds and flocks. "}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Lit and the contributions from your hands"}]},{"verseId":"a556c5305ee15c3f-01:Deu:12:7","parts":[{"kind":"text","text":"You will eat there in the presence of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God and rejoice with your household in everything you do, "},{"kind":"footnote","marker":3,"text":"Lit you put your hand to, also in v. 18"},{"kind":"text","text":" because the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has blessed you."}],"crossRefs":[],"footnotes":[{"marker":3,"text":"Lit you put your hand to, also in v. 18"}]},{"verseId":"a556c5305ee15c3f-01:Deu:12:8","parts":[{"kind":"text","text":"“You are not to do as we are doing here today; everyone is doing whatever seems right in his own sight. "},{"kind":"crossref","label":"Ex 15:26","book":"Exo","chapter":15,"verse":26,"letter":"a"},{"kind":"crossref","label":"Jdg 17:6","book":"Jdg","chapter":17,"verse":6,"letter":"b"},{"kind":"crossref","label":"Jdg 21:25","book":"Jdg","chapter":21,"verse":25,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 15:26","book":"Exo","chapter":15,"verse":26},{"label":"Jdg 17:6","book":"Jdg","chapter":17,"verse":6},{"label":"Jdg 21:25","book":"Jdg","chapter":21,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:9","parts":[{"kind":"text","text":"Indeed, you have not yet come into the resting place "},{"kind":"crossref","label":"Dt 3:20","book":"Deu","chapter":3,"verse":20,"letter":"a"},{"kind":"crossref","label":"Dt 5:14","book":"Deu","chapter":5,"verse":14,"letter":"b"},{"kind":"crossref","label":"Dt 25:19","book":"Deu","chapter":25,"verse":19,"letter":"c"},{"kind":"crossref","label":"Dt 28:65","book":"Deu","chapter":28,"verse":65,"letter":"d"},{"kind":"text","text":" and the inheritance "},{"kind":"crossref","label":"Dt 15:4","book":"Deu","chapter":15,"verse":4,"letter":"e"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is giving you. "}],"crossRefs":[{"label":"Dt 3:20","book":"Deu","chapter":3,"verse":20},{"label":"Dt 5:14","book":"Deu","chapter":5,"verse":14},{"label":"Dt 25:19","book":"Deu","chapter":25,"verse":19},{"label":"Dt 28:65","book":"Deu","chapter":28,"verse":65},{"label":"Dt 15:4","book":"Deu","chapter":15,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:10","parts":[{"kind":"text","text":"When you cross the Jordan and live in the land the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is giving you to inherit, "},{"kind":"crossref","label":"Dt 15:4","book":"Deu","chapter":15,"verse":4,"letter":"a"},{"kind":"text","text":" and he gives you rest from all the enemies around you and you live in security, "}],"crossRefs":[{"label":"Dt 15:4","book":"Deu","chapter":15,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:11","parts":[{"kind":"text","text":"then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God will choose the place to have his name dwell. "},{"kind":"crossref","label":"Dt 14:23","book":"Deu","chapter":14,"verse":23,"letter":"a"},{"kind":"crossref","label":"Dt 16:2","book":"Deu","chapter":16,"verse":2,"letter":"b"},{"kind":"crossref","label":"Dt 16:6","book":"Deu","chapter":16,"verse":6,"letter":"c"},{"kind":"crossref","label":"Dt 16:11","book":"Deu","chapter":16,"verse":11,"letter":"d"},{"kind":"crossref","label":"Dt 26:2","book":"Deu","chapter":26,"verse":2,"letter":"e"},{"kind":"text","text":" Bring there everything I command you: your burnt offerings, sacrifices, offerings of the tenth, personal contributions, "},{"kind":"footnote","marker":1,"text":"Lit tenth, the contributions from your hands"},{"kind":"text","text":" and all your choice offerings you vow to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "}],"crossRefs":[{"label":"Dt 14:23","book":"Deu","chapter":14,"verse":23},{"label":"Dt 16:2","book":"Deu","chapter":16,"verse":2},{"label":"Dt 16:6","book":"Deu","chapter":16,"verse":6},{"label":"Dt 16:11","book":"Deu","chapter":16,"verse":11},{"label":"Dt 26:2","book":"Deu","chapter":26,"verse":2}],"footnotes":[{"marker":1,"text":"Lit tenth, the contributions from your hands"}]},{"verseId":"a556c5305ee15c3f-01:Deu:12:12","parts":[{"kind":"text","text":"You will rejoice "},{"kind":"crossref","label":"Lv 23:40","book":"Lev","chapter":23,"verse":40,"letter":"a"},{"kind":"crossref","label":"Dt 14:26","book":"Deu","chapter":14,"verse":26,"letter":"b"},{"kind":"crossref","label":"Dt 16:11–15","book":"Deu","chapter":16,"verse":11,"letter":"c"},{"kind":"crossref","label":"Dt 26:11","book":"Deu","chapter":26,"verse":11,"letter":"d"},{"kind":"crossref","label":"Dt 27:7","book":"Deu","chapter":27,"verse":7,"letter":"e"},{"kind":"text","text":" before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God —you, your sons and daughters, your male and female slaves, and the Levite who is within your city gates, since he has no portion or inheritance among you. "},{"kind":"crossref","label":"Ex 20:10","book":"Exo","chapter":20,"verse":10,"letter":"f"},{"kind":"crossref","label":"Nm 18:20","book":"Num","chapter":18,"verse":20,"letter":"g"},{"kind":"crossref","label":"Dt 5:14","book":"Deu","chapter":5,"verse":14,"letter":"h"},{"kind":"crossref","label":"Dt 12:18","book":"Deu","chapter":12,"verse":18,"letter":"i"},{"kind":"crossref","label":"Dt 14:21","book":"Deu","chapter":14,"verse":21,"letter":"j"},{"kind":"crossref","label":"Dt 14:27","book":"Deu","chapter":14,"verse":27,"letter":"k"},{"kind":"crossref","label":"Dt 14:29","book":"Deu","chapter":14,"verse":29,"letter":"l"},{"kind":"crossref","label":"Dt 16:11","book":"Deu","chapter":16,"verse":11,"letter":"m"},{"kind":"crossref","label":"Dt 16:14","book":"Deu","chapter":16,"verse":14,"letter":"n"},{"kind":"crossref","label":"Dt 23:16","book":"Deu","chapter":23,"verse":16,"letter":"o"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 23:40","book":"Lev","chapter":23,"verse":40},{"label":"Dt 14:26","book":"Deu","chapter":14,"verse":26},{"label":"Dt 16:11–15","book":"Deu","chapter":16,"verse":11},{"label":"Dt 26:11","book":"Deu","chapter":26,"verse":11},{"label":"Dt 27:7","book":"Deu","chapter":27,"verse":7},{"label":"Ex 20:10","book":"Exo","chapter":20,"verse":10},{"label":"Nm 18:20","book":"Num","chapter":18,"verse":20},{"label":"Dt 5:14","book":"Deu","chapter":5,"verse":14},{"label":"Dt 12:18","book":"Deu","chapter":12,"verse":18},{"label":"Dt 14:21","book":"Deu","chapter":14,"verse":21},{"label":"Dt 14:27","book":"Deu","chapter":14,"verse":27},{"label":"Dt 14:29","book":"Deu","chapter":14,"verse":29},{"label":"Dt 16:11","book":"Deu","chapter":16,"verse":11},{"label":"Dt 16:14","book":"Deu","chapter":16,"verse":14},{"label":"Dt 23:16","book":"Deu","chapter":23,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:13","parts":[{"kind":"text","text":"Be careful not to offer your burnt offerings in all the sacred places you see. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:14","parts":[{"kind":"text","text":"You must offer your burnt offerings only in the place the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" chooses in one of your tribes, and there you must do everything I command you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:15","parts":[{"kind":"text","text":"“But whenever you want, you may slaughter and eat meat within any of your city gates, "},{"kind":"crossref","label":"Dt 15:22","book":"Deu","chapter":15,"verse":22,"letter":"a"},{"kind":"text","text":" according to the blessing the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has given you. Those who are clean or unclean may eat it, as they would a gazelle or deer, "}],"crossRefs":[{"label":"Dt 15:22","book":"Deu","chapter":15,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:16","parts":[{"kind":"text","text":"but you must not eat the blood; pour it on the ground like water. "},{"kind":"crossref","label":"Lv 17:10","book":"Lev","chapter":17,"verse":10,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 17:10","book":"Lev","chapter":17,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:17","parts":[{"kind":"text","text":"Within your city gates you may not eat the tenth of your grain, new wine, or fresh oil; the firstborn of your herd or flock; any of your vow offerings that you pledge; your freewill offerings; or your personal contributions. "},{"kind":"footnote","marker":1,"text":"Lit or the contributions from your hands"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit or the contributions from your hands"}]},{"verseId":"a556c5305ee15c3f-01:Deu:12:18","parts":[{"kind":"text","text":"You are to eat them in the presence of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God at the place the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God chooses —you, your son and daughter, your male and female slave, and the Levite who is within your city gates. Rejoice before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God in everything you do, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:19","parts":[{"kind":"text","text":"and be careful not to neglect the Levite, as long as you live in your land."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:20","parts":[{"kind":"text","text":"“When the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God enlarges your territory as he has promised you, "},{"kind":"crossref","label":"Ex 34:24","book":"Exo","chapter":34,"verse":24,"letter":"a"},{"kind":"text","text":" and you say, ‘I want to eat meat’ because you have a strong desire to eat meat, you may eat it whenever you want. "}],"crossRefs":[{"label":"Ex 34:24","book":"Exo","chapter":34,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:21","parts":[{"kind":"text","text":"If the place where the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God chooses to put his name is too far from you, you may slaughter any of your herd or flock he has given you, as I have commanded you, and you may eat it within your city gates whenever you want. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:22","parts":[{"kind":"text","text":"Indeed, you may eat it as the gazelle and deer are eaten; both the clean and the unclean may eat it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:23","parts":[{"kind":"text","text":"But don’t eat the blood, since the blood is the life, and you must not eat the life with the meat. "},{"kind":"crossref","label":"Lv 17:11","book":"Lev","chapter":17,"verse":11,"letter":"a"},{"kind":"crossref","label":"Lv 17:14","book":"Lev","chapter":17,"verse":14,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 17:11","book":"Lev","chapter":17,"verse":11},{"label":"Lv 17:14","book":"Lev","chapter":17,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:24","parts":[{"kind":"text","text":"Do not eat blood; pour it on the ground like water. "},{"kind":"crossref","label":"Lv 3:17","book":"Lev","chapter":3,"verse":17,"letter":"a"},{"kind":"crossref","label":"Lv 7:26","book":"Lev","chapter":7,"verse":26,"letter":"b"},{"kind":"crossref","label":"Lv 17:14","book":"Lev","chapter":17,"verse":14,"letter":"c"},{"kind":"crossref","label":"Lv 19:26","book":"Lev","chapter":19,"verse":26,"letter":"d"},{"kind":"crossref","label":"Dt 15:23","book":"Deu","chapter":15,"verse":23,"letter":"e"},{"kind":"crossref","label":"1Sm 14:34","book":"1Sa","chapter":14,"verse":34,"letter":"f"},{"kind":"crossref","label":"Ezk 33:25","book":"Ezk","chapter":33,"verse":25,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 3:17","book":"Lev","chapter":3,"verse":17},{"label":"Lv 7:26","book":"Lev","chapter":7,"verse":26},{"label":"Lv 17:14","book":"Lev","chapter":17,"verse":14},{"label":"Lv 19:26","book":"Lev","chapter":19,"verse":26},{"label":"Dt 15:23","book":"Deu","chapter":15,"verse":23},{"label":"1Sm 14:34","book":"1Sa","chapter":14,"verse":34},{"label":"Ezk 33:25","book":"Ezk","chapter":33,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:25","parts":[{"kind":"text","text":"Do not eat it, so that you and your children after you will prosper, because you will be doing what is right in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s sight."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:26","parts":[{"kind":"text","text":"“But you are to take the holy offerings you have and your vow offerings and go to the place the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" chooses. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:27","parts":[{"kind":"text","text":"Present the meat and blood of your burnt offerings on the altar of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God. The blood of your other sacrifices is to be poured out beside the altar of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, but you may eat the meat. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:28","parts":[{"kind":"text","text":"Be careful to obey all these things I command you, so that you and your children after you may prosper forever, because you will be doing what is good and right in the sight of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:29","parts":[{"kind":"text","text":"“When the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God annihilates the nations before you, "},{"kind":"crossref","label":"Dt 19:1","book":"Deu","chapter":19,"verse":1,"letter":"a"},{"kind":"text","text":" which you are entering to take possession of, "},{"kind":"crossref","label":"Dt 3:12","book":"Deu","chapter":3,"verse":12,"letter":"b"},{"kind":"text","text":" and you drive them out and live in their land, "}],"crossRefs":[{"label":"Dt 19:1","book":"Deu","chapter":19,"verse":1},{"label":"Dt 3:12","book":"Deu","chapter":3,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:30","parts":[{"kind":"text","text":"be careful not to be ensnared by their ways "},{"kind":"crossref","label":"Ex 23:33","book":"Exo","chapter":23,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ex 34:12","book":"Exo","chapter":34,"verse":12,"letter":"b"},{"kind":"crossref","label":"Dt 7:16","book":"Deu","chapter":7,"verse":16,"letter":"c"},{"kind":"crossref","label":"Dt 7:25","book":"Deu","chapter":7,"verse":25,"letter":"d"},{"kind":"crossref","label":"Jos 23:13","book":"Jos","chapter":23,"verse":13,"letter":"e"},{"kind":"crossref","label":"Jdg 8:27","book":"Jdg","chapter":8,"verse":27,"letter":"f"},{"kind":"crossref","label":"Ps 106:36","book":"Psa","chapter":106,"verse":36,"letter":"g"},{"kind":"crossref","label":"Heb 12:1","book":"Heb","chapter":12,"verse":1,"letter":"h"},{"kind":"text","text":" after they have been destroyed before you. Do not inquire about their gods, asking, ‘How did these nations worship their gods? I’ll also do the same.’ "}],"crossRefs":[{"label":"Ex 23:33","book":"Exo","chapter":23,"verse":33},{"label":"Ex 34:12","book":"Exo","chapter":34,"verse":12},{"label":"Dt 7:16","book":"Deu","chapter":7,"verse":16},{"label":"Dt 7:25","book":"Deu","chapter":7,"verse":25},{"label":"Jos 23:13","book":"Jos","chapter":23,"verse":13},{"label":"Jdg 8:27","book":"Jdg","chapter":8,"verse":27},{"label":"Ps 106:36","book":"Psa","chapter":106,"verse":36},{"label":"Heb 12:1","book":"Heb","chapter":12,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:31","parts":[{"kind":"text","text":"You must not do the same to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, because they practice every detestable act, which the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" hates, for their gods. They even burn their sons and daughters in the fire to their gods. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Deu:12:32","parts":[{"kind":"text","text":"Be careful to do everything I command you; do not add anything to it or take anything away from it. "},{"kind":"crossref","label":"Dt 4:2","book":"Deu","chapter":4,"verse":2,"letter":"a"},{"kind":"crossref","label":"Rv 22:18–19","book":"Rev","chapter":22,"verse":18,"letter":"b"}],"crossRefs":[{"label":"Dt 4:2","book":"Deu","chapter":4,"verse":2},{"label":"Rv 22:18–19","book":"Rev","chapter":22,"verse":18}],"footnotes":[]}]},"cachedAt":1783279358559}