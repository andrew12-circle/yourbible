 "},{"kind":"crossref","label":"1Co 13:1","book":"1Co","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jms 2:18","book":"Jas","chapter":2,"verse":18,"letter":"c"}],"crossRefs":[{"label":"1Th 1:3","book":"1Th","chapter":1,"verse":3},{"label":"1Co 13:1","book":"1Co","chapter":13,"verse":1},{"label":"Jms 2:18","book":"Jas","chapter":2,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gal:5:7","parts":[{"kind":"text","text":"You were running well. Who prevented you from obeying the truth? "},{"kind":"crossref","label":"Jn 8:14","book":"Jhn","chapter":8,"verse":14,"letter":"a"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 8:14","book":"Jhn","chapter":8,"verse":14},{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gal:5:8","parts":[{"kind":"text","text":"This persuasion does not come from the one who calls you. "},{"kind":"crossref","label":"Col 3:15","book":"Col","chapter":3,"verse":15,"letter":"a"},{"kind":"crossref","label":"1Pt 1:15","book":"1Pe","chapter":1,"verse":15,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Col 3:15","book":"Col","chapter":3,"verse":15},{"label":"1Pt 1:15","book":"1Pe","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Gal:5:9","parts":[{"kind":"text","text":"A little leaven "},{"kind":"footnote","marker":1,"text":"Or yeast"},{"kind":"text","text":" leavens the whole batch of dough. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or yeast"}]},{"verseId":"a556c5305ee15c3f-01:Gal:5:10","parts":[{"kind":"text","text":"I myself am persuaded in the Lord you will not accept any other view. But whoever it is that is confusing you will pay the penalty. "},{"kind":"crossref","label":"Mk 12:40","book":"Mrk","chapter":12,"verse":40,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 12:40","book":"Mrk","chapter":12,"v