:22","book":"Exo","chapter":2,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:17:9","parts":[{"kind":"text","text":"but does not bring it to the entrance to the tent of meeting to sacrifice it to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", that person is to be cut off from his people."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:17:10","parts":[{"kind":"text","text":"“Anyone from the house of Israel or from the aliens who reside among them who eats any blood, "},{"kind":"crossref","label":"Gn 9:4","book":"Gen","chapter":9,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lv 3:17","book":"Lev","chapter":3,"verse":17,"letter":"b"},{"kind":"text","text":" I will turn "},{"kind":"footnote","marker":1,"text":"Lit will set my face"},{"kind":"text","text":" against that person who eats blood and cut him off from his people. "}],"crossRefs":[{"label":"Gn 9:4","book":"Gen","chapter":9,"verse":4},{"label":"Lv 3:17","book":"Lev","chapter":3,"verse":17}],"footnotes":[{"marker":1,"text":"Lit will set my face"}]},{"verseId":"a556c5305ee15c3f-01:Lev:17:11","parts":[{"kind":"text","text":"For the life of a creature is in the blood, and I have appointed it to you to make atonement on the altar for "},{"kind":"footnote","marker":2,"text":"Or to ransom"},{"kind":"text","text":" your lives, since it is the lifeblood that makes atonement. "},{"kind":"crossref","label":"Mt 26:28","book":"Mat","chapter":26,"verse":28,"letter":"a"},{"kind":"crossref","label":"Mk 14:24","book":"Mrk","chapter":14,"verse":24,"letter":"b"},{"kind":"crossref","label":"Rm 3:25","book":"Rom","chapter":3,"verse":25,"letter":"c"},{"kind":"crossref","label":"Rm 5:9","book":"Rom","chapter":5,"verse":9,"letter":"d"},{"kind":"crossref","label":"Eph 1:7","book":"Eph","chapter":1,"verse":7,"letter":"e"},{"kind":"crossref","label":"Col 1:14","book":"Col","chapter":1,"verse":14,"letter":"f"},{"kind":"crossref","label":"Col 1:20","book":"Col","ch