abel":"Ps 104:18","book":"Psa","chapter":104,"verse":18},{"label":"Pr 30:26","book":"Pro","chapter":30,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:6","parts":[{"kind":"text","text":"hares, though they chew the cud,"},{"kind":"text","text":" do not have hooves —they are unclean for you;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:7","parts":[{"kind":"text","text":"pigs, though they have divided hooves,"},{"kind":"text","text":" do not chew the cud —they are unclean for you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:8","parts":[{"kind":"text","text":"Do not eat any of their meat or touch their carcasses —they are unclean for you. "},{"kind":"crossref","label":"Lv 7:21","book":"Lev","chapter":7,"verse":21,"letter":"a"},{"kind":"crossref","label":"Lv 11:24–27","book":"Lev","chapter":11,"verse":24,"letter":"b"},{"kind":"crossref","label":"Is 52:11","book":"Isa","chapter":52,"verse":11,"letter":"c"},{"kind":"crossref","label":"2Co 6:17","book":"2Co","chapter":6,"verse":17,"letter":"d"}],"crossRefs":[{"label":"Lv 7:21","book":"Lev","chapter":7,"verse":21},{"label":"Lv 11:24–27","book":"Lev","chapter":11,"verse":24},{"label":"Is 52:11","book":"Isa","chapter":52,"verse":11},{"label":"2Co 6:17","book":"2Co","chapter":6,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:9","parts":[{"kind":"text","text":"“This is what you may eat from all that is in the water: You may eat everything in the water that has fins and scales, whether in the seas or streams. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:10","parts":[{"kind":"text","text":"But these are to be abhorrent to you: everything in the seas or streams that does not have fins and scales among all the swarming things and other living creatures "},{"kind":"crossref","label":"Gn 1:20","book":"Gen","chapter":1,"verse":20,"letter":"a"},{"kind":"crossref","label":"Gn 2:19","book":"Gen","chapter":2,"verse":19,"letter":"b"},{"kind":"crossref","label":"Lv 11:46","book":"Lev","chapter":11,"verse":46,"letter":"c"},{"kind":"text","text":" in the water. "}],"crossRefs":[{"label":"Gn 1:20","book":"Gen","chapter":1,"verse":20},{"label":"Gn 2:19","book":"Gen","chapter":2,"verse":19},{"label":"Lv 11:46","book":"Lev","chapter":11,"verse":46}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:11","parts":[{"kind":"text","text":"They are to remain abhorrent to you; you must not eat any of their meat, and you must abhor their carcasses. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:12","parts":[{"kind":"text","text":"Everything in the water that does not have fins and scales will be abhorrent to you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:13","parts":[{"kind":"text","text":"“You are to abhor these birds. They must not be eaten because they are abhorrent:"},{"kind":"text","text":" eagles, "},{"kind":"footnote","marker":1,"text":"Or griffon-vultures"},{"kind":"crossref","label":"Dt 14:12","book":"Deu","chapter":14,"verse":12,"letter":"a"},{"kind":"crossref","label":"Dt 28:49","book":"Deu","chapter":28,"verse":49,"letter":"b"},{"kind":"crossref","label":"Dt 32:11","book":"Deu","chapter":32,"verse":11,"letter":"c"},{"kind":"crossref","label":"Pr 23:5","book":"Pro","chapter":23,"verse":5,"letter":"d"},{"kind":"crossref","label":"Is 40:31","book":"Isa","chapter":40,"verse":31,"letter":"e"},{"kind":"text","text":" bearded vultures,"}],"crossRefs":[{"label":"Dt 14:12","book":"Deu","chapter":14,"verse":12},{"label":"Dt 28:49","book":"Deu","chapter":28,"verse":49},{"label":"Dt 32:11","book":"Deu","chapter":32,"verse":11},{"label":"Pr 23:5","book":"Pro","chapter":23,"verse":5},{"label":"Is 40:31","book":"Isa","chapter":40,"verse":31}],"footnotes":[{"marker":1,"text":"Or griffon-vultures"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:14","parts":[{"kind":"text","text":"kites, "},{"kind":"footnote","marker":1,"text":"Or hawks"},{"kind":"text","text":" any kind of falcon, "},{"kind":"footnote","marker":1,"text":"Or buzzards, or hawks"},{"kind":"crossref","label":"Dt 14:13","book":"Deu","chapter":14,"verse":13,"letter":"a"},{"kind":"crossref","label":"Jb 28:7","book":"Job","chapter":28,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Dt 14:13","book":"Deu","chapter":14,"verse":13},{"label":"Jb 28:7","book":"Job","chapter":28,"verse":7}],"footnotes":[{"marker":1,"text":"Or hawks"},{"marker":1,"text":"Or buzzards, or hawks"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:15","parts":[{"kind":"text","text":"every kind of raven, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:16","parts":[{"kind":"text","text":"ostriches, "},{"kind":"footnote","marker":1,"text":"Or eagle owls"},{"kind":"text","text":" short-eared owls, gulls, "},{"kind":"footnote","marker":1,"text":"Or long-eared owls"},{"kind":"text","text":" any kind of hawk, "},{"kind":"crossref","label":"Dt 14:15","book":"Deu","chapter":14,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jb 39:26","book":"Job","chapter":39,"verse":26,"letter":"b"}],"crossRefs":[{"label":"Dt 14:15","book":"Deu","chapter":14,"verse":15},{"label":"Jb 39:26","book":"Job","chapter":39,"verse":26}],"footnotes":[{"marker":1,"text":"Or eagle owls"},{"marker":1,"text":"Or long-eared owls"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:17","parts":[{"kind":"text","text":"little "},{"kind":"footnote","marker":1,"text":"Or tawny"},{"kind":"text","text":" owls, cormorants, "},{"kind":"footnote","marker":2,"text":"Or pelicans"},{"kind":"text","text":" long-eared owls, "},{"kind":"footnote","marker":1,"text":"Or ibis"},{"kind":"crossref","label":"Dt 14:16","book":"Deu","chapter":14,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Dt 14:16","book":"Deu","chapter":14,"verse":16}],"footnotes":[{"marker":1,"text":"Or tawny"},{"marker":2,"text":"Or pelicans"},{"marker":1,"text":"Or ibis"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:18","parts":[{"kind":"text","text":"barn "},{"kind":"footnote","marker":1,"text":"Or little"},{"kind":"text","text":" owls, eagle owls, "},{"kind":"footnote","marker":2,"text":"Or pelicans, or horned owls"},{"kind":"crossref","label":"Dt 14:17","book":"Deu","chapter":14,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ps 102:6","book":"Psa","chapter":102,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 34:11","book":"Isa","chapter":34,"verse":11,"letter":"c"},{"kind":"crossref","label":"Zp 2:14","book":"Zep","chapter":2,"verse":14,"letter":"d"}],"crossRefs":[{"label":"Dt 14:17","book":"Deu","chapter":14,"verse":17},{"label":"Ps 102:6","book":"Psa","chapter":102,"verse":6},{"label":"Is 34:11","book":"Isa","chapter":34,"verse":11},{"label":"Zp 2:14","book":"Zep","chapter":2,"verse":14}],"footnotes":[{"marker":1,"text":"Or little"},{"marker":2,"text":"Or pelicans, or horned owls"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:19","parts":[{"kind":"text","text":"storks, "},{"kind":"footnote","marker":1,"text":"Or herons"},{"kind":"text","text":" any kind of heron, "},{"kind":"footnote","marker":1,"text":"Or cormorants, or hawks"},{"kind":"text","text":" hoopoes, and bats."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or herons"},{"marker":1,"text":"Or cormorants, or hawks"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:20","parts":[{"kind":"text","text":"“All winged insects that walk on all fours are to be abhorrent to you. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:21","parts":[{"kind":"text","text":"But you may eat these kinds of all the winged insects that walk on all fours: those that have jointed legs above their feet for hopping on the ground. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:22","parts":[{"kind":"text","text":"You may eat these:"},{"kind":"text","text":" any kind of locust, "},{"kind":"crossref","label":"Dt 28:38","book":"Deu","chapter":28,"verse":38,"letter":"a"},{"kind":"text","text":" katydid, cricket, and grasshopper."}],"crossRefs":[{"label":"Dt 28:38","book":"Deu","chapter":28,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:23","parts":[{"kind":"text","text":"All other winged insects that have four feet are to be abhorrent to you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:24","parts":[{"kind":"text","text":"“These will make you unclean. Whoever touches their carcasses will be unclean "},{"kind":"crossref","label":"Ezk 22:3–4","book":"Ezk","chapter":22,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ezk 23:17","book":"Ezk","chapter":23,"verse":17,"letter":"b"},{"kind":"crossref","label":"Ezk 44:25","book":"Ezk","chapter":44,"verse":25,"letter":"c"},{"kind":"crossref","label":"Mc 2:10","book":"Mic","chapter":2,"verse":10,"letter":"d"},{"kind":"crossref","label":"Hg 2:13","book":"Hag","chapter":2,"verse":13,"letter":"e"},{"kind":"text","text":" until evening, "}],"crossRefs":[{"label":"Ezk 22:3–4","book":"Ezk","chapter":22,"verse":3},{"label":"Ezk 23:17","book":"Ezk","chapter":23,"verse":17},{"label":"Ezk 44:25","book":"Ezk","chapter":44,"verse":25},{"label":"Mc 2:10","book":"Mic","chapter":2,"verse":10},{"label":"Hg 2:13","book":"Hag","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:25","parts":[{"kind":"text","text":"and whoever carries any of their carcasses is to wash his clothes and will be unclean until evening. "},{"kind":"crossref","label":"Lv 16:28","book":"Lev","chapter":16,"verse":28,"letter":"a"},{"kind":"crossref","label":"Lv 17:15–16","book":"Lev","chapter":17,"verse":15,"letter":"b"},{"kind":"crossref","label":"Lv 22:6","book":"Lev","chapter":22,"verse":6,"letter":"c"},{"kind":"crossref","label":"Nm 19:7","book":"Num","chapter":19,"verse":7,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 16:28","book":"Lev","chapter":16,"verse":28},{"label":"Lv 17:15–16","book":"Lev","chapter":17,"verse":15},{"label":"Lv 22:6","book":"Lev","chapter":22,"verse":6},{"label":"Nm 19:7","book":"Num","chapter":19,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:26","parts":[{"kind":"text","text":"All animals that have hooves but do not have a divided hoof and do not chew the cud are unclean for you. Whoever touches them becomes unclean. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:27","parts":[{"kind":"text","text":"All the four-footed animals "},{"kind":"crossref","label":"Rv 18:2","book":"Rev","chapter":18,"verse":2,"letter":"a"},{"kind":"text","text":" that walk on their paws are unclean for you. Whoever touches their carcasses will be unclean until evening, "}],"crossRefs":[{"label":"Rv 18:2","book":"Rev","chapter":18,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:28","parts":[{"kind":"text","text":"and anyone who carries their carcasses is to wash his clothes and will be unclean until evening. They are unclean for you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:29","parts":[{"kind":"text","text":"“These creatures that swarm "},{"kind":"crossref","label":"Ex 8:3","book":"Exo","chapter":8,"verse":3,"letter":"a"},{"kind":"text","text":" on the ground are unclean for you:"},{"kind":"text","text":" weasels, "},{"kind":"footnote","marker":1,"text":"Or mole rats, or rats"},{"kind":"text","text":" mice, "},{"kind":"crossref","label":"1Sm 6:4","book":"1Sa","chapter":6,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Sm 6:11","book":"1Sa","chapter":6,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Sm 6:18","book":"1Sa","chapter":6,"verse":18,"letter":"c"},{"kind":"crossref","label":"Is 66:17","book":"Isa","chapter":66,"verse":17,"letter":"d"},{"kind":"text","text":" any kind of large lizard, "},{"kind":"footnote","marker":1,"text":"Or of thorn-tailed, or dabb lizard, or of crocodile"}],"crossRefs":[{"label":"Ex 8:3","book":"Exo","chapter":8,"verse":3},{"label":"1Sm 6:4","book":"1Sa","chapter":6,"verse":4},{"label":"1Sm 6:11","book":"1Sa","chapter":6,"verse":11},{"label":"1Sm 6:18","book":"1Sa","chapter":6,"verse":18},{"label":"Is 66:17","book":"Isa","chapter":66,"verse":17}],"footnotes":[{"marker":1,"text":"Or mole rats, or rats"},{"marker":1,"text":"Or of thorn-tailed, or dabb lizard, or of crocodile"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:30","parts":[{"kind":"text","text":"geckos, monitor lizards, "},{"kind":"footnote","marker":1,"text":"Or spotted lizards, or chameleons"},{"kind":"text","text":" common lizards, "},{"kind":"footnote","marker":1,"text":"Or geckos, or newts, or salamanders"},{"kind":"text","text":" skinks, "},{"kind":"footnote","marker":2,"text":"Or sand lizards, or newts, or snails"},{"kind":"text","text":" and chameleons. "},{"kind":"footnote","marker":1,"text":"Or salamanders, or moles"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or spotted lizards, or chameleons"},{"marker":1,"text":"Or geckos, or newts, or salamanders"},{"marker":2,"text":"Or sand lizards, or newts, or snails"},{"marker":1,"text":"Or salamanders, or moles"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:31","parts":[{"kind":"text","text":"These are unclean for you among all the swarming creatures. Whoever touches them when they are dead will be unclean until evening. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:32","parts":[{"kind":"text","text":"When any one of them dies and falls on anything it becomes unclean —any item of wood, clothing, leather, sackcloth, "},{"kind":"crossref","label":"Gn 37:34","book":"Gen","chapter":37,"verse":34,"letter":"a"},{"kind":"text","text":" or any implement used for work. It is to be rinsed with water and will remain unclean until evening; then it will be clean. "}],"crossRefs":[{"label":"Gn 37:34","book":"Gen","chapter":37,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:33","parts":[{"kind":"text","text":"If any of them falls into any clay pot, everything in it will become unclean; you are to break it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:34","parts":[{"kind":"text","text":"Any edible food "},{"kind":"crossref","label":"Lv 26:5","book":"Lev","chapter":26,"verse":5,"letter":"a"},{"kind":"text","text":" coming into contact with that unclean water will become unclean, and any drinkable liquid in any container will become unclean. "}],"crossRefs":[{"label":"Lv 26:5","book":"Lev","chapter":26,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:35","parts":[{"kind":"text","text":"Anything one of their carcasses falls on will become unclean. If it is an oven or stove, it is to be smashed; it is unclean and will remain unclean for you. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:36","parts":[{"kind":"text","text":"A spring or cistern containing water will remain clean, but someone who touches a carcass in it will become unclean. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:37","parts":[{"kind":"text","text":"If one of their carcasses falls on any seed that is to be sown, it is clean; "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:38","parts":[{"kind":"text","text":"but if water has been put on the seed and one of their carcasses falls on it, it is unclean for you."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:39","parts":[{"kind":"text","text":"“If one of the animals that you use for food dies, anyone who touches its carcass will be unclean until evening. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:40","parts":[{"kind":"text","text":"Anyone who eats some of its carcass is to wash his clothes and will be unclean until evening. Anyone who carries its carcass must wash his clothes and will be unclean until evening."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:41","parts":[{"kind":"text","text":"“All the creatures that swarm on the earth are abhorrent; they must not be eaten. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:42","parts":[{"kind":"text","text":"Do not eat any of the creatures that swarm on the earth, anything that moves on its belly or walks on all fours or on many feet, "},{"kind":"footnote","marker":1,"text":"Lit fours, to anything multiplying pairs of feet"},{"kind":"text","text":" for they are abhorrent. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit fours, to anything multiplying pairs of feet"}]},{"verseId":"a556c5305ee15c3f-01:Lev:11:43","parts":[{"kind":"text","text":"Do not become contaminated by any creature that swarms; do not become unclean or defiled by them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:44","parts":[{"kind":"text","text":"For I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, "},{"kind":"crossref","label":"Nm 15:41","book":"Num","chapter":15,"verse":41,"letter":"a"},{"kind":"text","text":" so you must consecrate yourselves "},{"kind":"crossref","label":"Ex 19:22","book":"Exo","chapter":19,"verse":22,"letter":"b"},{"kind":"crossref","label":"Lv 20:7","book":"Lev","chapter":20,"verse":7,"letter":"c"},{"kind":"crossref","label":"Nm 11:18","book":"Num","chapter":11,"verse":18,"letter":"d"},{"kind":"crossref","label":"Ezk 38:23","book":"Ezk","chapter":38,"verse":23,"letter":"e"},{"kind":"text","text":" and be holy because I am holy. "},{"kind":"crossref","label":"Lv 19:2","book":"Lev","chapter":19,"verse":2,"letter":"f"},{"kind":"crossref","label":"Lv 20:7","book":"Lev","chapter":20,"verse":7,"letter":"g"},{"kind":"crossref","label":"Lv 20:26","book":"Lev","chapter":20,"verse":26,"letter":"h"},{"kind":"crossref","label":"1Pt 1:16","book":"1Pe","chapter":1,"verse":16,"letter":"i"},{"kind":"text","text":" Do not defile yourselves by any swarming creature that crawls on the ground. "}],"crossRefs":[{"label":"Nm 15:41","book":"Num","chapter":15,"verse":41},{"label":"Ex 19:22","book":"Exo","chapter":19,"verse":22},{"label":"Lv 20:7","book":"Lev","chapter":20,"verse":7},{"label":"Nm 11:18","book":"Num","chapter":11,"verse":18},{"label":"Ezk 38:23","book":"Ezk","chapter":38,"verse":23},{"label":"Lv 19:2","book":"Lev","chapter":19,"verse":2},{"label":"Lv 20:7","book":"Lev","chapter":20,"verse":7},{"label":"Lv 20:26","book":"Lev","chapter":20,"verse":26},{"label":"1Pt 1:16","book":"1Pe","chapter":1,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:45","parts":[{"kind":"text","text":"For I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", who brought you up from the land of Egypt to be your God, "},{"kind":"crossref","label":"Ex 6:7","book":"Exo","chapter":6,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ex 20:2","book":"Exo","chapter":20,"verse":2,"letter":"b"},{"kind":"crossref","label":"Lv 25:38","book":"Lev","chapter":25,"verse":38,"letter":"c"},{"kind":"crossref","label":"Lv 25:42","book":"Lev","chapter":25,"verse":42,"letter":"d"},{"kind":"crossref","label":"Lv 26:13","book":"Lev","chapter":26,"verse":13,"letter":"e"},{"kind":"crossref","label":"Lv 26:45","book":"Lev","chapter":26,"verse":45,"letter":"f"},{"kind":"text","text":" so you must be holy because I am holy. "},{"kind":"crossref","label":"Lv 21:8","book":"Lev","chapter":21,"verse":8,"letter":"g"}],"crossRefs":[{"label":"Ex 6:7","book":"Exo","chapter":6,"verse":7},{"label":"Ex 20:2","book":"Exo","chapter":20,"verse":2},{"label":"Lv 25:38","book":"Lev","chapter":25,"verse":38},{"label":"Lv 25:42","book":"Lev","chapter":25,"verse":42},{"label":"Lv 26:13","book":"Lev","chapter":26,"verse":13},{"label":"Lv 26:45","book":"Lev","chapter":26,"verse":45},{"label":"Lv 21:8","book":"Lev","chapter":21,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:46","parts":[{"kind":"text","text":"“This is the law concerning animals, birds, all living creatures that move in the water, and all creatures that swarm on the ground, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:11:47","parts":[{"kind":"text","text":"in order to distinguish between the unclean and the clean, between the animals "},{"kind":"crossref","label":"Lv 26:6","book":"Lev","chapter":26,"verse":6,"letter":"a"},{"kind":"text","text":" that may be eaten and those that may not be eaten.”"}],"crossRefs":[{"label":"Lv 26:6","book":"Lev","chapter":26,"verse":6}],"footnotes":[]}]},"cachedAt":1783279333438}