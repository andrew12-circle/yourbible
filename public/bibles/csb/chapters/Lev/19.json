":"text","text":", sacrifice it so that you may be accepted. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:6","parts":[{"kind":"text","text":"It is to be eaten on the day you sacrifice it or on the next day, but what remains on the third day must be burned. "},{"kind":"crossref","label":"Lv 7:17","book":"Lev","chapter":7,"verse":17,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 7:17","book":"Lev","chapter":7,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:7","parts":[{"kind":"text","text":"If any is eaten on the third day, it is a repulsive thing; it will not be accepted. "},{"kind":"crossref","label":"Lv 1:4","book":"Lev","chapter":1,"verse":4,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 1:4","book":"Lev","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:8","parts":[{"kind":"text","text":"Anyone who eats it will bear his iniquity, for he has profaned what is holy to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". That person is to be cut off from his people. "},{"kind":"crossref","label":"Lv 7:18","book":"Lev","chapter":7,"verse":18,"letter":"a"},{"kind":"crossref","label":"Lv 7:20","book":"Lev","chapter":7,"verse":20,"letter":"b"}],"crossRefs":[{"label":"Lv 7:18","book":"Lev","chapter":7,"verse":18},{"label":"Lv 7:20","book":"Lev","chapter":7,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:9","parts":[{"kind":"text","text":"“When you reap the harvest of your land, you are not to reap to the very edge of your field or gather the gleanings "},{"kind":"crossref","label":"Lv 23:22","book":"Lev","chapter":23,"verse":22,"letter":"a"},{"kind":"crossref","label":"Dt 24:19","book":"Deu","chapter":24,"verse":19,"letter":"b"},{"kind":"crossref","label":"Ru 2:2–7","book":"Rut","chapter":2,"verse":2,"letter":"c"},{"kind":"crossref","label":"Ru 2:15","book":"Rut","chapter":2,"verse":15,"letter":"d"},{"kind":"