ok":"Lev","chapter":21,"verse":12,"letter":"a"},{"kind":"text","text":" your daughter by making her a prostitute, "},{"kind":"crossref","label":"Ex 34:31","book":"Exo","chapter":34,"verse":31,"letter":"b"},{"kind":"crossref","label":"Lv 21:9","book":"Lev","chapter":21,"verse":9,"letter":"c"},{"kind":"crossref","label":"Dt 23:17","book":"Deu","chapter":23,"verse":17,"letter":"d"},{"kind":"text","text":" or the land will be prostituted and filled with depravity. "}],"crossRefs":[{"label":"Lv 21:12","book":"Lev","chapter":21,"verse":12},{"label":"Ex 34:31","book":"Exo","chapter":34,"verse":31},{"label":"Lv 21:9","book":"Lev","chapter":21,"verse":9},{"label":"Dt 23:17","book":"Deu","chapter":23,"verse":17}],"footnotes":[{"marker":1,"text":"Lit profane"}]},{"verseId":"a556c5305ee15c3f-01:Lev:19:30","parts":[{"kind":"text","text":"Keep my Sabbaths and revere my sanctuary; "},{"kind":"crossref","label":"Ex 15:17","book":"Exo","chapter":15,"verse":17,"letter":"a"},{"kind":"crossref","label":"Lv 20:3","book":"Lev","chapter":20,"verse":3,"letter":"b"},{"kind":"crossref","label":"Lv 26:2","book":"Lev","chapter":26,"verse":2,"letter":"c"},{"kind":"crossref","label":"Nm 19:20","book":"Num","chapter":19,"verse":20,"letter":"d"},{"kind":"text","text":" I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Ex 15:17","book":"Exo","chapter":15,"verse":17},{"label":"Lv 20:3","book":"Lev","chapter":20,"verse":3},{"label":"Lv 26:2","book":"Lev","chapter":26,"verse":2},{"label":"Nm 19:20","book":"Num","chapter":19,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:31","parts":[{"kind":"text","text":"“Do not turn to mediums "},{"kind":"footnote","marker":1,"text":"Or spirits of the dead"},{"kind":"crossref","label":"Lv 20:6","book":"Lev","chapter":20,"verse":6,"letter":"a"},{"kind":"text","text":" or consult spiritists, "},{"kind":"footnote","marker":2,"text":"Or familiar spirits"},{"kind":"crossref","label":"Dt 18:11","book":"Deu","chapter":18,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ac 16:16","book":"Act","chapter":16,"verse":16,"letter":"c"},{"kind":"text","text":" or you will be defiled by them; I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God."}],"crossRefs":[{"label":"Lv 20:6","book":"Lev","chapter":20,"verse":6},{"label":"Dt 18:11","book":"Deu","chapter":18,"verse":11},{"label":"Ac 16:16","book":"Act","chapter":16,"verse":16}],"footnotes":[{"marker":1,"text":"Or spirits of the dead"},{"marker":2,"text":"Or familiar spirits"}]},{"verseId":"a556c5305ee15c3f-01:Lev:19:32","parts":[{"kind":"text","text":"“You are to rise in the presence of the elderly and honor the old. "},{"kind":"crossref","label":"Jb 12:12","book":"Job","chapter":12,"verse":12,"letter":"a"},{"kind":"crossref","label":"Jb 32:4","book":"Job","chapter":32,"verse":4,"letter":"b"},{"kind":"crossref","label":"Pr 23:22","book":"Pro","chapter":23,"verse":22,"letter":"c"},{"kind":"crossref","label":"Lm 5:12","book":"Lam","chapter":5,"verse":12,"letter":"d"},{"kind":"crossref","label":"1Tm 5:1","book":"1Ti","chapter":5,"verse":1,"letter":"e"},{"kind":"text","text":" Fear your God; I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Jb 12:12","book":"Job","chapter":12,"verse":12},{"label":"Jb 32:4","book":"Job","chapter":32,"verse":4},{"label":"Pr 23:22","book":"Pro","chapter":23,"verse":22},{"label":"Lm 5:12","book":"Lam","chapter":5,"verse":12},{"label":"1Tm 5:1","book":"1Ti","chapter":5,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:33","parts":[{"kind":"text","text":"“When an alien resides with you in your land, you must not oppress "},{"kind":"crossref","label":"Dt 23:16","book":"Deu","chapter":23,"verse":16,"letter":"a"},{"kind":"text","text":" him. "}],"crossRefs":[{"label":"Dt 23:16","book":"Deu","chapter":23,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:34","parts":[{"kind":"text","text":"You will regard the alien who resides with you as the native-born among you. You are to love him as yourself, "},{"kind":"crossref","label":"Lv 19:18","book":"Lev","chapter":19,"verse":18,"letter":"a"},{"kind":"text","text":" for you were aliens in the land of Egypt; "},{"kind":"crossref","label":"Ex 23:9","book":"Exo","chapter":23,"verse":9,"letter":"b"},{"kind":"crossref","label":"Lv 18:3","book":"Lev","chapter":18,"verse":3,"letter":"c"},{"kind":"crossref","label":"Dt 10:19","book":"Deu","chapter":10,"verse":19,"letter":"d"},{"kind":"crossref","label":"Dt 23:7","book":"Deu","chapter":23,"verse":7,"letter":"e"},{"kind":"text","text":" I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God."}],"crossRefs":[{"label":"Lv 19:18","book":"Lev","chapter":19,"verse":18},{"label":"Ex 23:9","book":"Exo","chapter":23,"verse":9},{"label":"Lv 18:3","book":"Lev","chapter":18,"verse":3},{"label":"Dt 10:19","book":"Deu","chapter":10,"verse":19},{"label":"Dt 23:7","book":"Deu","chapter":23,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:35","parts":[{"kind":"text","text":"“Do not be unfair "},{"kind":"crossref","label":"Dt 25:16","book":"Deu","chapter":25,"verse":16,"letter":"a"},{"kind":"text","text":" in measurements of length, weight, or volume. "}],"crossRefs":[{"label":"Dt 25:16","book":"Deu","chapter":25,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lev:19:36","parts":[{"kind":"text","text":"You are to have honest balances, "},{"kind":"crossref","label":"Hs 12:8","book":"Hos","chapter":12,"verse":8,"letter":"a"},{"kind":"crossref","label":"Am 8:5","book":"Amo","chapter":8,"verse":5,"letter":"b"},{"kind":"crossref","label":"Mc 6:11","book":"Mic","chapter":6,"verse":11,"letter":"c"},{"kind":"text","text":" honest weights, an honest dry measure, "},{"kind":"footnote","marker":1,"text":"Lit honest ephah"},{"kind":"text","text":" and an honest liquid measure; "},{"kind":"footnote","marker":2,"text":"Lit honest hin"},{"kind":"crossref","label":"Dt 25:13","book":"Deu","chapter":25,"verse":13,"letter":"d"},{"kind":"crossref","label":"Pr 16:11","book":"Pro","chapter":16,"verse":11,"letter":"e"},{"kind":"crossref","label":"Ezk 45:10","book":"Ezk","chapter":45,"verse":10,"letter":"f"},{"kind":"text","text":" I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, who brought you out of the land of Egypt. "}],"crossRefs":[{"label":"Hs 12:8","book":"Hos","chapter":12,"verse":8},{"label":"Am 8:5","book":"Amo","chapter":8,"verse":5},{"label":"Mc 6:11","book":"Mic","chapter":6,"verse":11},{"label":"Dt 25:13","book":"Deu","chapter":25,"verse":13},{"label":"Pr 16:11","book":"Pro","chapter":16,"verse":11},{"label":"Ezk 45:10","book":"Ezk","chapter":45,"verse":10}],"footnotes":[{"marker":1,"text":"Lit honest ephah"},{"marker":2,"text":"Lit honest hin"}]},{"verseId":"a556c5305ee15c3f-01:Lev:19:37","parts":[{"kind":"text","text":"Keep all my statutes and all my ordinances and do them; I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":".”"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099245244}