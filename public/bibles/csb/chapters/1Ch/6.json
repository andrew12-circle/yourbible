{"key":"a556c5305ee15c3f-01|1Ch|6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","chapter":6,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:1Ch:6:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":1,"text":"Levi’s sons: Gershom, Kohath, and Merari.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":2,"text":"Kohath’s sons: Amram, Izhar, Hebron, and Uzziel.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":3,"text":"Amram’s children: Aaron, Moses, and Miriam. Aaron’s sons: Nadab, Abihu, Eleazar, and Ithamar.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":4,"text":"Eleazar fathered Phinehas; Phinehas fathered Abishua;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":5,"text":"Abishua fathered Bukki; Bukki fathered Uzzi;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":6,"text":"Uzzi fathered Zerahiah; Zerahiah fathered Meraioth;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":7,"text":"Meraioth fathered Amariah; Amariah fathered Ahitub;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":8,"text":"Ahitub fathered Zadok; Zadok fathered Ahimaaz;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":9,"text":"Ahimaaz fathered Azariah; Azariah fathered Johanan;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":10,"text":"Johanan fathered Azariah, who served as priest in the temple that Solomon built in Jerusalem;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":11,"text":"Azariah fathered Amariah; Amariah fathered Ahitub;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":12,"text":"Ahitub fathered Zadok; Zadok fathered Shallum;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":13,"text":"Shallum fathered Hilkiah; Hilkiah fathered Azariah;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":14,"text":"Azariah fathered Seraiah; and Seraiah fathered Jehozadak.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":15,"text":"Jehozadak went into exile when the Lord sent Judah and Jerusalem into exile at the hands of Nebuchadnezzar.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:16","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":16,"text":"Levi’s sons: Gershom, Kohath, and Merari.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:17","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":17,"text":"These are the names of Gershom’s sons: Libni and Shimei.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:18","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":18,"text":"Kohath’s sons: Amram, Izhar, Hebron and Uzziel.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":19,"text":"Merari’s sons: Mahli and Mushi. These are the Levites’ families according to their fathers:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":20,"text":"Of Gershom: his son Libni, his son Jahath, his son Zimmah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":21,"text":"his son Joah, his son Iddo, his son Zerah, and his son Jeatherai.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":22,"text":"Kohath’s sons: his son Amminadab, his son Korah, his son Assir,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":23,"text":"his son Elkanah, his son Ebiasaph,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":24,"text":"his son Tahath, his son Uriel, his son Uzziah, and his son Shaul.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":25,"text":"Elkanah’s sons: Amasai and Ahimoth,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":26,"text":"his son Elkanah, his son Zophai,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":27,"text":"his son Eliab, his son Jeroham, and his son Elkanah.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":28,"text":"Samuel’s sons: his firstborn Joel, and his second son Abijah.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":29,"text":"Merari’s sons: Mahli, his son Libni, his son Shimei, his son Uzzah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":30,"text":"his son Shimea, his son Haggiah, and his son Asaiah.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":31,"text":"These are the men David put in charge of the music in the Lord’s temple after the ark came to rest there.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":32,"text":"They ministered with song in front of the tabernacle, the tent of meeting, until Solomon built the Lord’s temple in Jerusalem, and they performed their task according to the regulations given to them.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":33,"text":"These are the men who served with their sons. From the Kohathites: Heman the singer, son of Joel, son of Samuel,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":34,"text":"son of Elkanah, son of Jeroham, son of Eliel, son of Toah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":35,"text":"son of Zuph, son of Elkanah, son of Mahath, son of Amasai,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":36,"text":"son of Elkanah, son of Joel, son of Azariah, son of Zephaniah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:37","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":37,"text":"son of Tahath, son of Assir, son of Ebiasaph, son of Korah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:38","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":38,"text":"son of Izhar, son of Kohath, son of Levi, son of Israel.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:39","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":39,"text":"Heman’s relative was Asaph, who stood at his right hand: Asaph son of Berechiah, son of Shimea,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:40","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":40,"text":"son of Michael, son of Baaseiah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:41","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":41,"text":"son of Ethni, son of Zerah, son of Adaiah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:42","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":42,"text":"son of Ethan, son of Zimmah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:43","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":43,"text":"son of Jahath, son of Gershom, son of Levi.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:44","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":44,"text":"On the left, their relatives were Merari’s sons: Ethan son of Kishi, son of Abdi,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:45","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":45,"text":"son of Hashabiah, son of Amaziah, son of Hilkiah,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:46","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":46,"text":"son of Amzi, son of Bani,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:47","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":47,"text":"son of Mahli, son of Mushi, son of Merari, son of Levi.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:48","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":48,"text":"Their relatives, the Levites, were assigned to all the service of the tabernacle, God’s temple.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:49","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":49,"text":"But Aaron and his sons did all the work of the most holy place. They presented the offerings on the altar of burnt offerings and on the altar of incense to make atonement for Israel according to all that Moses the servant of God had commanded.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:50","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":50,"text":"These are Aaron’s sons: his son Eleazar, his son Phinehas, his son Abishua,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:51","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":51,"text":"his son Bukki, his son Uzzi,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:52","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":52,"text":"his son Meraioth, his son Amariah, his son Ahitub,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:53","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":53,"text":"his son Zadok, and his son Ahimaaz.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:54","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":54,"text":"These were the places assigned to Aaron’s descendants from the Kohathite family for their settlements in their territory, because the first lot was for them.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:55","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":55,"text":"They were given Hebron in the land of Judah and its surrounding pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:56","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":56,"text":"but the fields and settlements around the city were given to Caleb son of Jephunneh.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:57","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":57,"text":"Aaron’s descendants were given:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:58","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":58,"text":"Hilen and its pasturelands, Debir and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:59","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":59,"text":"Ashan and its pasturelands, and Beth-shemesh and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:60","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":60,"text":"From the tribe of Benjamin they were given Geba and its pasturelands, Alemeth and its pasturelands, and Anathoth and its pasturelands. They had thirteen towns in all among their families.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:61","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":61,"text":"To the rest of the Kohathites, ten towns from half the tribe of Manasseh were assigned by lot.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:62","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":62,"text":"The Gershomites were assigned thirteen towns from the tribes of Issachar, Asher, Naphtali, and Manasseh in Bashan according to their families.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:63","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":63,"text":"The Merarites were assigned by lot twelve towns from the tribes of Reuben, Gad, and Zebulun according to their families.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:64","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":64,"text":"So the Israelites gave these towns and their pasturelands to the Levites.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:65","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":65,"text":"They assigned by lot the towns named above from the tribes of the descendants of Judah, Simeon, and Benjamin.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:66","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":66,"text":"Some of the families of the Kohathites were given towns from the tribe of Ephraim for their territory:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:67","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":67,"text":"Shechem (a city of refuge) with its pasturelands in the hill country of Ephraim, Gezer and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:68","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":68,"text":"Jokmeam and its pasturelands, Beth-horon and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:69","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":69,"text":"Aijalon and its pasturelands, and Gath-rimmon and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:70","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":70,"text":"From half the tribe of Manasseh, Aner and its pasturelands, and Bileam and its pasturelands were given to the rest of the families of the Kohathites.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:71","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":71,"text":"The Gershomites received:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:72","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":72,"text":"From the tribe of Issachar they received Kedesh and its pasturelands, Daberath and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:73","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":73,"text":"Ramoth and its pasturelands, and Anem and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:74","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":74,"text":"From the tribe of Asher they received Mashal and its pasturelands, Abdon and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:75","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":75,"text":"Hukok and its pasturelands, and Rehob and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:76","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":76,"text":"From the tribe of Naphtali they received Kedesh in Galilee and its pasturelands, Hammon and its pasturelands, and Kiriathaim and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:77","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":77,"text":"The rest of the Merarites received:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:78","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":78,"text":"From the tribe of Reuben across the Jordan at Jericho, to the east of the Jordan, they received Bezer in the desert and its pasturelands, Jahzah and its pasturelands,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:79","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":79,"text":"Kedemoth and its pasturelands, and Mephaath and its pasturelands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Ch:6:80","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Ch","bookOrder":12,"chapter":6,"verse":80,"