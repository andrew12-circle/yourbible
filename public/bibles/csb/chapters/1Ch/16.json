"verse":18,"letter":"c"},{"kind":"text","text":" from everlasting to everlasting.”"},{"kind":"text","text":" Then all the people said, “Amen” and “Praise the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":".”"}],"crossRefs":[{"label":"1Kg 8:15","book":"1Ki","chapter":8,"verse":15},{"label":"1Kg 8:56","book":"1Ki","chapter":8,"verse":56},{"label":"Ps 72:18","book":"Psa","chapter":72,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:37","parts":[{"kind":"text","text":"So David left Asaph and his relatives there before the ark of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s covenant to minister regularly "},{"kind":"crossref","label":"1Ch 16:4–5","book":"1Ch","chapter":16,"verse":4,"letter":"a"},{"kind":"text","text":" before the ark according to the daily requirements. "},{"kind":"crossref","label":"2Ch 8:14","book":"2Ch","chapter":8,"verse":14,"letter":"b"},{"kind":"crossref","label":"Ezr 3:4","book":"Ezr","chapter":3,"verse":4,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Ch 16:4–5","book":"1Ch","chapter":16,"verse":4},{"label":"2Ch 8:14","book":"2Ch","chapter":8,"verse":14},{"label":"Ezr 3:4","book":"Ezr","chapter":3,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:38","parts":[{"kind":"text","text":"He assigned Obed-edom "},{"kind":"crossref","label":"1Ch 13:13","book":"1Ch","chapter":13,"verse":13,"letter":"a"},{"kind":"text","text":" and his "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Vg; Hb reads their"},{"kind":"text","text":" sixty-eight relatives. Obed-edom son of Jeduthun and Hosah "},{"kind":"crossref","label":"1Ch 26:10","book":"1Ch","chapter":26,"verse":10,"letter":"b"},{"kind":"text","text":" were to be gatekeepers. "}],"crossRefs":[{"label":"1Ch 13:13","book":"1Ch","chapter":13,"verse":13},{"label":"1Ch 26:10","book":"1Ch","chapter":26,"verse":10}],"footnotes":[{"marker":1,"text":"LXX, Syr, Vg; Hb reads their"}]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:39","parts":[{"kind":"text","text":"David left the priest Zadok and his fellow priests before the tabernacle of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" at the high place in Gibeon "},{"kind":"crossref","label":"1Kg 3:4","book":"1Ki","chapter":3,"verse":4,"letter":"a"},{"kind":"crossref","label":"1Ch 21:29","book":"1Ch","chapter":21,"verse":29,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Kg 3:4","book":"1Ki","chapter":3,"verse":4},{"label":"1Ch 21:29","book":"1Ch","chapter":21,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:40","parts":[{"kind":"text","text":"to offer burnt offerings regularly, morning and evening, to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" on the altar of burnt offerings and to do everything that was written in the law of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", which he had commanded Israel to keep. "},{"kind":"crossref","label":"Ex 29:38–42","book":"Exo","chapter":29,"verse":38,"letter":"a"},{"kind":"crossref","label":"Nm 28:3","book":"Num","chapter":28,"verse":3,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 29:38–42","book":"Exo","chapter":29,"verse":38},{"label":"Nm 28:3","book":"Num","chapter":28,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:41","parts":[{"kind":"text","text":"With them were Heman, "},{"kind":"crossref","label":"1Ch 6:33","book":"1Ch","chapter":6,"verse":33,"letter":"a"},{"kind":"text","text":" Jeduthun, and the rest who were chosen and designated by name "},{"kind":"crossref","label":"1Ch 25:1–6","book":"1Ch","chapter":25,"verse":1,"letter":"b"},{"kind":"text","text":" to give thanks to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" —for his faithful love endures forever. "},{"kind":"crossref","label":"2Ch 5:13","book":"2Ch","chapter":5,"verse":13,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Ch 6:33","book":"1Ch","chapter":6,"verse":33},{"label":"1Ch 25:1–6","book":"1Ch","chapter":25,"verse":1},{"label":"2Ch 5:13","book":"2Ch","chapter":5,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:42","parts":[{"kind":"text","text":"Heman and Jeduthun had with them trumpets and cymbals to play and musical instruments of God. "},{"kind":"crossref","label":"1Ch 25:7","book":"1Ch","chapter":25,"verse":7,"letter":"a"},{"kind":"crossref","label":"2Ch 7:6","book":"2Ch","chapter":7,"verse":6,"letter":"b"},{"kind":"crossref","label":"2Ch 29:27","book":"2Ch","chapter":29,"verse":27,"letter":"c"},{"kind":"text","text":" Jeduthun’s sons were at the city gate."}],"crossRefs":[{"label":"1Ch 25:7","book":"1Ch","chapter":25,"verse":7},{"label":"2Ch 7:6","book":"2Ch","chapter":7,"verse":6},{"label":"2Ch 29:27","book":"2Ch","chapter":29,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ch:16:43","parts":[{"kind":"text","text":"Then all the people went home, and David returned home to bless his household. "},{"kind":"crossref","label":"2Sm 6:19","book":"2Sa","chapter":6,"verse":19,"letter":"a"}],"crossRefs":[{"label":"2Sm 6:19","book":"2Sa","chapter":6,"verse":19}],"footnotes":[]}]},"cachedAt":1783279431799}