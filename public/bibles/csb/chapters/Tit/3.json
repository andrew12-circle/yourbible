 3:5","book":"Jhn","chapter":3,"verse":5,"letter":"f"},{"kind":"crossref","label":"Eph 5:26","book":"Eph","chapter":5,"verse":26,"letter":"g"},{"kind":"crossref","label":"1Pt 3:21","book":"1Pe","chapter":3,"verse":21,"letter":"h"},{"kind":"text","text":" and renewal by the Holy Spirit. "},{"kind":"crossref","label":"Rm 12:2","book":"Rom","chapter":12,"verse":2,"letter":"i"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Rm 11:14","book":"Rom","chapter":11,"verse":14},{"label":"2Tm 1:9","book":"2Ti","chapter":1,"verse":9},{"label":"Eph 2:9","book":"Eph","chapter":2,"verse":9},{"label":"Eph 2:4","book":"Eph","chapter":2,"verse":4},{"label":"1Pt 1:3","book":"1Pe","chapter":1,"verse":3},{"label":"Jn 3:5","book":"Jhn","chapter":3,"verse":5},{"label":"Eph 5:26","book":"Eph","chapter":5,"verse":26},{"label":"1Pt 3:21","book":"1Pe","chapter":3,"verse":21},{"label":"Rm 12:2","book":"Rom","chapter":12,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Tit:3:6","parts":[{"kind":"text","text":"He poured out his Spirit on us abundantly "},{"kind":"crossref","label":"Jl 2:28","book":"Jol","chapter":2,"verse":28,"letter":"a"},{"kind":"crossref","label":"Ac 2:33","book":"Act","chapter":2,"verse":33,"letter":"b"},{"kind":"crossref","label":"Ac 10:45","book":"Act","chapter":10,"verse":45,"letter":"c"},{"kind":"crossref","label":"Rm 5:5","book":"Rom","chapter":5,"verse":5,"letter":"d"},{"kind":"text","text":" through Jesus Christ our Savior "}],"crossRefs":[{"label":"Jl 2:28","book":"Jol","chapter":2,"verse":28},{"label":"Ac 2:33","book":"Act","chapter":2,"verse":33},{"label":"Ac 10:45","book":"Act","chapter":10,"verse":45},{"label":"Rm 5:5","book":"Rom","chapter":5,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Tit:3:7","parts":[{"kind":"text","text":"so that, having been justified by his grace, "},{"kind":"crossref","label":"Ac 13:43","book":"Act","chapter":13,"verse":43,"letter":"a"},{"kind":"crossref","label":"Ac 15:11","book":"Act","chapter":15,"verse":1