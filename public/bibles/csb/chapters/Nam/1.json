e":"divine"},{"kind":"text","text":" has issued an order concerning you:"},{"kind":"text","text":" There will be no offspring"},{"kind":"text","text":" to carry on your name. "},{"kind":"footnote","marker":1,"text":"LitIt will not be sown from your name any longer"},{"kind":"crossref","label":"Lv 20:3","book":"Lev","chapter":20,"verse":3,"letter":"a"},{"kind":"crossref","label":"1Sm 24:21","book":"1Sa","chapter":24,"verse":21,"letter":"b"},{"kind":"crossref","label":"Ps 89:4","book":"Psa","chapter":89,"verse":4,"letter":"c"},{"kind":"crossref","label":"Is 48:19","book":"Isa","chapter":48,"verse":19,"letter":"d"},{"kind":"crossref","label":"Is 66:22","book":"Isa","chapter":66,"verse":22,"letter":"e"},{"kind":"text","text":" I will eliminate the carved idol and cast image"},{"kind":"text","text":" from the house of your gods; "},{"kind":"crossref","label":"Dt 27:15","book":"Deu","chapter":27,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jdg 18:14","book":"Jdg","chapter":18,"verse":14,"letter":"b"},{"kind":"text","text":" I will prepare your grave,"},{"kind":"text","text":" for you are contemptible."}],"crossRefs":[{"label":"Lv 20:3","book":"Lev","chapter":20,"verse":3},{"label":"1Sm 24:21","book":"1Sa","chapter":24,"verse":21},{"label":"Ps 89:4","book":"Psa","chapter":89,"verse":4},{"label":"Is 48:19","book":"Isa","chapter":48,"verse":19},{"label":"Is 66:22","book":"Isa","chapter":66,"verse":22},{"label":"Dt 27:15","book":"Deu","chapter":27,"verse":15},{"label":"Jdg 18:14","book":"Jdg","chapter":18,"verse":14}],"footnotes":[{"marker":1,"text":"LitIt will not be sown from your name any longer"}]},{"verseId":"a556c5305ee15c3f-01:Nam:1:15","parts":[{"kind":"text","text":"Look to the mountains —"},{"kind":"text","text":" the feet of the herald, "},{"kind":"crossref","label":"Is 52:7","book":"Isa","chapter":52,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 61:1","book":"Isa","chapter":61,"verse":1,"letter":"b"},{"kind":"crossref","label":"Rm 10:15","book":"R