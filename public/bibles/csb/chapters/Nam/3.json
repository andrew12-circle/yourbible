ossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:13","parts":[{"kind":"text","text":"Look, your troops are like women among you;"},{"kind":"text","text":" your land’s city gates"},{"kind":"text","text":" are wide open to your enemies."},{"kind":"text","text":" Fire will devour the bars of your gates."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:14","parts":[{"kind":"text","text":"Draw water for the siege;"},{"kind":"text","text":" strengthen your fortresses."},{"kind":"text","text":" Step into the clay and tread the mortar;"},{"kind":"text","text":" take hold of the brick-mold!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:15","parts":[{"kind":"text","text":"The fire will devour you there;"},{"kind":"text","text":" the sword will cut you down."},{"kind":"text","text":" It will devour you like the young locust. "},{"kind":"crossref","label":"Jl 1:4","book":"Jol","chapter":1,"verse":4,"letter":"a"},{"kind":"text","text":" Multiply yourselves like the young locust;"},{"kind":"text","text":" multiply like the swarming locust!"}],"crossRefs":[{"label":"Jl 1:4","book":"Jol","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:16","parts":[{"kind":"text","text":"You have made your merchants "},{"kind":"crossref","label":"Ezk 16:29","book":"Ezk","chapter":16,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ezk 17:4","book":"Ezk","chapter":17,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ezk 27:3","book":"Ezk","chapter":27,"verse":3,"letter":"c"},{"kind":"crossref","label":"Ezk 27:13","book":"Ezk","chapter":27,"verse":13,"letter":"d"},{"kind":"crossref","label":"Ezk 27:20","book":"Ezk","chapter":27,"verse":20,"letter":"e"},{"kind":"crossref","label":"Ezk 27:23","book":"Ezk","chapter":27,"verse":23,"letter":"f"},{"kind":"crossref","label":"Zp 1:11","book":"Zep","chapter":1,"verse":11,"letter":"g"},{"kind":"crossref","label":"Rv 18:3","book":"Rev","chapter":18,"verse":3,"letter":"h"},{"kind":"crossref","label":"Rv 18:11","book":"Rev","chapter":18,"verse":11,"letter":"i"},{"kind":"crossref","label":"Rv 18:15","book":"Rev","chapter":18,"verse":15,"letter":"j"},{"kind":"crossref","label":"Rv 18:23","book":"Rev","chapter":18,"verse":23,"letter":"k"},{"kind":"text","text":" more numerous than the stars of the sky."},{"kind":"text","text":" The young locust strips "},{"kind":"footnote","marker":1,"text":"Or sheds its skin"},{"kind":"text","text":" the land"},{"kind":"text","text":" and flies away."}],"crossRefs":[{"label":"Ezk 16:29","book":"Ezk","chapter":16,"verse":29},{"label":"Ezk 17:4","book":"Ezk","chapter":17,"verse":4},{"label":"Ezk 27:3","book":"Ezk","chapter":27,"verse":3},{"label":"Ezk 27:13","book":"Ezk","chapter":27,"verse":13},{"label":"Ezk 27:20","book":"Ezk","chapter":27,"verse":20},{"label":"Ezk 27:23","book":"Ezk","chapter":27,"verse":23},{"label":"Zp 1:11","book":"Zep","chapter":1,"verse":11},{"label":"Rv 18:3","book":"Rev","chapter":18,"verse":3},{"label":"Rv 18:11","book":"Rev","chapter":18,"verse":11},{"label":"Rv 18:15","book":"Rev","chapter":18,"verse":15},{"label":"Rv 18:23","book":"Rev","chapter":18,"verse":23}],"footnotes":[{"marker":1,"text":"Or sheds its skin"}]},{"verseId":"a556c5305ee15c3f-01:Nam:3:17","parts":[{"kind":"text","text":"Your court officials are like the swarming locust,"},{"kind":"text","text":" and your scribes like clouds of locusts,"},{"kind":"text","text":" which settle on the walls on a cold day;"},{"kind":"text","text":" when the sun rises, they take off,"},{"kind":"text","text":" and no one knows where they are."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:18","parts":[{"kind":"text","text":"King of Assyria, your shepherds slumber; "},{"kind":"crossref","label":"Jr 23:1–2","book":"Jer","chapter":23,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jr 50:6","book":"Jer","chapter":50,"verse":6,"letter":"b"},{"kind":"text","text":" your officers sleep."},{"kind":"text","text":" Your people are scattered across the mountains "},{"kind":"crossref","label":"Ezk 34:6","book":"Ezk","chapter":34,"verse":6,"letter":"a"},{"kind":"text","text":" with no one to gather them together. "},{"kind":"crossref","label":"1Kg 22:17","book":"1Ki","chapter":22,"verse":17,"letter":"a"}],"crossRefs":[{"label":"Jr 23:1–2","book":"Jer","chapter":23,"verse":1},{"label":"Jr 50:6","book":"Jer","chapter":50,"verse":6},{"label":"Ezk 34:6","book":"Ezk","chapter":34,"verse":6},{"label":"1Kg 22:17","book":"1Ki","chapter":22,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Nam:3:19","parts":[{"kind":"text","text":"There is no remedy for your injury;"},{"kind":"text","text":" your wound is severe. "},{"kind":"crossref","label":"Jr 10:19","book":"Jer","chapter":10,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 14:17","book":"Jer","chapter":14,"verse":17,"letter":"b"},{"kind":"crossref","label":"Jr 30:12","book":"Jer","chapter":30,"verse":12,"letter":"c"},{"kind":"text","text":" All who hear the news about you"},{"kind":"text","text":" will clap their hands because of you, "},{"kind":"crossref","label":"Ps 47:1","book":"Psa","chapter":47,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 98:8","book":"Psa","chapter":98,"verse":8,"letter":"b"},{"kind":"crossref","label":"Lm 2:15","book":"Lam","chapter":2,"verse":15,"letter":"c"},{"kind":"crossref","label":"Ezk 22:13","book":"Ezk","chapter":22,"verse":13,"letter":"d"},{"kind":"text","text":" for who has not experienced"},{"kind":"text","text":" your constant cruelty?"}],"crossRefs":[{"label":"Jr 10:19","book":"Jer","chapter":10,"verse":19},{"label":"Jr 14:17","book":"Jer","chapter":14,"verse":17},{"label":"Jr 30:12","book":"Jer","chapter":30,"verse":12},{"label":"Ps 47:1","book":"Psa","chapter":47,"verse":1},{"label":"Ps 98:8","book":"Psa","chapter":98,"verse":8},{"label":"Lm 2:15","book":"Lam","chapter":2,"verse":15},{"label":"Ezk 22:13","book":"Ezk","chapter":22,"verse":13}],"footnotes":[]}]},"cachedAt":1783279606706}