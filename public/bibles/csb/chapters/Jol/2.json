ame jealous for his land "},{"kind":"crossref","label":"Ezk 36:5","book":"Ezk","chapter":36,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ezk 36:6","book":"Ezk","chapter":36,"verse":6,"letter":"b"},{"kind":"crossref","label":"Zch 1:14","book":"Zec","chapter":1,"verse":14,"letter":"c"},{"kind":"crossref","label":"Zch 8:2","book":"Zec","chapter":8,"verse":2,"letter":"d"},{"kind":"text","text":" and spared his people. "},{"kind":"crossref","label":"Is 60:10","book":"Isa","chapter":60,"verse":10,"letter":"e"},{"kind":"crossref","label":"Is 63:9","book":"Isa","chapter":63,"verse":9,"letter":"f"},{"kind":"crossref","label":"Is 63:15","book":"Isa","chapter":63,"verse":15,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ezk 36:5","book":"Ezk","chapter":36,"verse":5},{"label":"Ezk 36:6","book":"Ezk","chapter":36,"verse":6},{"label":"Zch 1:14","book":"Zec","chapter":1,"verse":14},{"label":"Zch 8:2","book":"Zec","chapter":8,"verse":2},{"label":"Is 60:10","book":"Isa","chapter":60,"verse":10},{"label":"Is 63:9","book":"Isa","chapter":63,"verse":9},{"label":"Is 63:15","book":"Isa","chapter":63,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jol:2:19","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" answered his people:"},{"kind":"text","text":" Look, I am about to send you"},{"kind":"text","text":" grain, new wine, and fresh oil. "},{"kind":"crossref","label":"Jr 31:12","book":"Jer","chapter":31,"verse":12,"letter":"a"},{"kind":"crossref","label":"Hs 2:21","book":"Hos","chapter":2,"verse":21,"letter":"b"},{"kind":"text","text":" You will be satiated with them,"},{"kind":"text","text":" and I will no longer make you"},{"kind":"text","text":" a disgrace among the nations. "},{"kind":"crossref","label":"Ezk 34:29","book":"Ezk","chapter":34,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ezk 36:15","book":"Ezk","chapter":36,"verse":15,"letter":"b"}],"crossRefs":[{"label":"Jr 31:12","