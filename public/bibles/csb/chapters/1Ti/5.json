l":"Ex 29:10","book":"Exo","chapter":29,"verse":10,"letter":"a"},{"kind":"crossref","label":"Lv 4:15","book":"Lev","chapter":4,"verse":15,"letter":"b"},{"kind":"crossref","label":"Lk 4:40","book":"Luk","chapter":4,"verse":40,"letter":"c"},{"kind":"crossref","label":"Ac 6:6","book":"Act","chapter":6,"verse":6,"letter":"d"},{"kind":"crossref","label":"Ac 28:8","book":"Act","chapter":28,"verse":8,"letter":"e"},{"kind":"crossref","label":"1Tm 4:14","book":"1Ti","chapter":4,"verse":14,"letter":"f"},{"kind":"crossref","label":"Heb 6:2","book":"Heb","chapter":6,"verse":2,"letter":"g"},{"kind":"text","text":" anyone as an elder, and don’t share in the sins of others. Keep yourself pure. "},{"kind":"crossref","label":"Php 4:8","book":"Php","chapter":4,"verse":8,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 29:10","book":"Exo","chapter":29,"verse":10},{"label":"Lv 4:15","book":"Lev","chapter":4,"verse":15},{"label":"Lk 4:40","book":"Luk","chapter":4,"verse":40},{"label":"Ac 6:6","book":"Act","chapter":6,"verse":6},{"label":"Ac 28:8","book":"Act","chapter":28,"verse":8},{"label":"1Tm 4:14","book":"1Ti","chapter":4,"verse":14},{"label":"Heb 6:2","book":"Heb","chapter":6,"verse":2},{"label":"Php 4:8","book":"Php","chapter":4,"verse":8}],"footnotes":[{"marker":1,"text":"Lit to lay hands on"}]},{"verseId":"a556c5305ee15c3f-01:1Ti:5:23","parts":[{"kind":"text","text":"Don’t continue drinking only water, but use a little wine because of your stomach and your frequent illnesses. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Ti:5:24","parts":[{"kind":"text","text":"Some people’s sins are obvious, preceding them to judgment, "},{"kind":"crossref","label":"Mt 12:41","book":"Mat","chapter":12,"verse":41,"letter":"a"},{"kind":"crossref","label":"Jn 5:22–30","book":"Jhn","chapter":5,"verse":22,"letter":"b"},{"kind":"crossref","label":"Heb 9:27","book":"Heb","chapter":9,"verse":27,"letter":"c"},{"kind":"text","text":" but the sins of others surface "},{"kind":"footnote","marker":2,"text":"Lit follow"},{"kind":"text","text":" later. "}],"crossRefs":[{"label":"Mt 12:41","book":"Mat","chapter":12,"verse":41},{"label":"Jn 5:22–30","book":"Jhn","chapter":5,"verse":22},{"label":"Heb 9:27","book":"Heb","chapter":9,"verse":27}],"footnotes":[{"marker":2,"text":"Lit follow"}]},{"verseId":"a556c5305ee15c3f-01:1Ti:5:25","parts":[{"kind":"text","text":"Likewise, good works are obvious, and those that are not obvious cannot remain hidden."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099553912}