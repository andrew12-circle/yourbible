1:14","book":"Jos","chapter":1,"verse":14},{"label":"Jos 8:3","book":"Jos","chapter":8,"verse":3},{"label":"2Kg 24:14","book":"2Ki","chapter":24,"verse":14},{"label":"1Ch 12:8","book":"1Ch","chapter":12,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:6:13","parts":[{"kind":"text","text":"Gideon said to him, “Please, my lord, if the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is with us, why has all this happened? And where are all his wonders that our ancestors told us about? They said, ‘Hasn’t the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" brought us out of Egypt?’ But now the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has abandoned us and handed us over to Midian.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:6:14","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" turned to him and said, “Go in the strength you have and deliver Israel from the grasp of Midian. I am sending you!” "},{"kind":"crossref","label":"Ex 3:10","book":"Exo","chapter":3,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Sm 9:16","book":"1Sa","chapter":9,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Sm 16:1","book":"1Sa","chapter":16,"verse":1,"letter":"c"},{"kind":"crossref","label":"Jr 1:7","book":"Jer","chapter":1,"verse":7,"letter":"d"},{"kind":"crossref","label":"Jr 25:15","book":"Jer","chapter":25,"verse":15,"letter":"e"},{"kind":"crossref","label":"Ezk 2:3–4","book":"Ezk","chapter":2,"verse":3,"letter":"f"},{"kind":"crossref","label":"Mal 4:5","book":"Mal","chapter":4,"verse":5,"letter":"g"},{"kind":"crossref","label":"Jn 20:21","book":"Jhn","chapter":20,"verse":21,"letter":"h"}],"crossRefs":[{"label":"Ex 3:10","book":"Exo","chapter":3,"verse":10},{"label":"1Sm 9:16","book":"1Sa","chapter":9,"verse":16},{"label":"1Sm 16:1","book":"1Sa","chapter":16,"verse":1},{"label":"Jr 1:7","book":"