2","book":"1Sa","chapter":14,"verse":22},{"label":"1Ch 6:67","book":"1Ch","chapter":6,"verse":67}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:2:10","parts":[{"kind":"text","text":"That whole generation was also gathered to their ancestors. After them another generation rose up who did not know the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"crossref","label":"Ex 5:2","book":"Exo","chapter":5,"verse":2,"letter":"a"},{"kind":"crossref","label":"1Sm 2:12","book":"1Sa","chapter":2,"verse":12,"letter":"b"},{"kind":"text","text":" or the works he had done for Israel."}],"crossRefs":[{"label":"Ex 5:2","book":"Exo","chapter":5,"verse":2},{"label":"1Sm 2:12","book":"1Sa","chapter":2,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:2:11","parts":[{"kind":"text","text":"The Israelites did what was evil in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s sight. "},{"kind":"crossref","label":"Nm 32:12","book":"Num","chapter":32,"verse":12,"letter":"a"},{"kind":"crossref","label":"Dt 4:25","book":"Deu","chapter":4,"verse":25,"letter":"b"},{"kind":"crossref","label":"Dt 31:29","book":"Deu","chapter":31,"verse":29,"letter":"c"},{"kind":"crossref","label":"1Kg 11:6","book":"1Ki","chapter":11,"verse":6,"letter":"d"},{"kind":"text","text":" They worshiped the Baals "},{"kind":"crossref","label":"Jdg 3:7","book":"Jdg","chapter":3,"verse":7,"letter":"e"},{"kind":"crossref","label":"Jdg 8:33","book":"Jdg","chapter":8,"verse":33,"letter":"f"},{"kind":"crossref","label":"1Sm 12:10","book":"1Sa","chapter":12,"verse":10,"letter":"g"},{"kind":"crossref","label":"2Kg 17:16","book":"2Ki","chapter":17,"verse":16,"letter":"h"},{"kind":"crossref","label":"Jr 2:23","book":"Jer","chapter":2,"verse":23,"letter":"i"},{"kind":"crossref","label":"Jr 9:14","book":"Jer","chapter":9,"verse":14,"letter":"j"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 32:12","book":"Num","chapter":32,"verse":12},{"label":"Dt 4:25","book":"Deu",