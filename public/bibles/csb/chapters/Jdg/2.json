hs. "},{"kind":"crossref","label":"Jdg 10:6","book":"Jdg","chapter":10,"verse":6,"letter":"a"},{"kind":"crossref","label":"1Sm 7:3","book":"1Sa","chapter":7,"verse":3,"letter":"b"},{"kind":"crossref","label":"1Sm 12:10","book":"1Sa","chapter":12,"verse":10,"letter":"c"},{"kind":"crossref","label":"1Kg 11:5","book":"1Ki","chapter":11,"verse":5,"letter":"d"},{"kind":"crossref","label":"1Kg 11:33","book":"1Ki","chapter":11,"verse":33,"letter":"e"},{"kind":"crossref","label":"2Kg 23:13","book":"2Ki","chapter":23,"verse":13,"letter":"f"}],"crossRefs":[{"label":"Jdg 10:6","book":"Jdg","chapter":10,"verse":6},{"label":"1Sm 7:3","book":"1Sa","chapter":7,"verse":3},{"label":"1Sm 12:10","book":"1Sa","chapter":12,"verse":10},{"label":"1Kg 11:5","book":"1Ki","chapter":11,"verse":5},{"label":"1Kg 11:33","book":"1Ki","chapter":11,"verse":33},{"label":"2Kg 23:13","book":"2Ki","chapter":23,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:2:14","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s anger burned against Israel, and he handed them over to marauders who raided them. He sold "},{"kind":"crossref","label":"Jdg 3:8","book":"Jdg","chapter":3,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jdg 4:2","book":"Jdg","chapter":4,"verse":2,"letter":"b"},{"kind":"crossref","label":"Jdg 4:9","book":"Jdg","chapter":4,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jdg 10:7","book":"Jdg","chapter":10,"verse":7,"letter":"d"},{"kind":"crossref","label":"Ps 44:12","book":"Psa","chapter":44,"verse":12,"letter":"e"},{"kind":"crossref","label":"Is 50:1","book":"Isa","chapter":50,"verse":1,"letter":"f"},{"kind":"crossref","label":"Ezk 30:12","book":"Ezk","chapter":30,"verse":12,"letter":"g"},{"kind":"crossref","label":"Jl 3:8","book":"Jol","chapter":3,"verse":8,"letter":"h"},{"kind":"text","text":" them to the enemies around them, and they could no longer resist their enemies. "}],"crossRefs":[{"label":"Jdg 3:8"