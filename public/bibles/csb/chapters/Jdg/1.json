s 6:27","book":"Jos","chapter":6,"verse":27,"letter":"c"},{"kind":"crossref","label":"Jdg 2:18","book":"Jdg","chapter":2,"verse":18,"letter":"d"},{"kind":"crossref","label":"1Sm 18:12","book":"1Sa","chapter":18,"verse":12,"letter":"e"},{"kind":"text","text":" them. "}],"crossRefs":[{"label":"Gn 39:2","book":"Gen","chapter":39,"verse":2},{"label":"Gn 39:21","book":"Gen","chapter":39,"verse":21},{"label":"Jos 6:27","book":"Jos","chapter":6,"verse":27},{"label":"Jdg 2:18","book":"Jdg","chapter":2,"verse":18},{"label":"1Sm 18:12","book":"1Sa","chapter":18,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:23","parts":[{"kind":"text","text":"They sent spies to Bethel (the town was formerly named Luz "},{"kind":"crossref","label":"Gn 28:19","book":"Gen","chapter":28,"verse":19,"letter":"a"},{"kind":"crossref","label":"Gn 35:6","book":"Gen","chapter":35,"verse":6,"letter":"b"},{"kind":"crossref","label":"Gn 48:3","book":"Gen","chapter":48,"verse":3,"letter":"c"},{"kind":"text","text":"). "}],"crossRefs":[{"label":"Gn 28:19","book":"Gen","chapter":28,"verse":19},{"label":"Gn 35:6","book":"Gen","chapter":35,"verse":6},{"label":"Gn 48:3","book":"Gen","chapter":48,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:24","parts":[{"kind":"text","text":"The spies saw a man coming out of the town and said to him, “Please show us how to get into town, and we will show you kindness.” "},{"kind":"crossref","label":"Jos 2:12","book":"Jos","chapter":2,"verse":12,"letter":"a"},{"kind":"crossref","label":"Jos 2:14","book":"Jos","chapter":2,"verse":14,"letter":"b"},{"kind":"crossref","label":"2Sm 9:1","book":"2Sa","chapter":9,"verse":1,"letter":"c"},{"kind":"crossref","label":"2Sm 9:3","book":"2Sa","chapter":9,"verse":3,"letter":"d"},{"kind":"crossref","label":"2Sm 9:7","book":"2Sa","chapter":9,"verse":7,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jos 2:12","book":"Jos","chapter":2,"verse":12},{"label":"Jos 2:14","book":"Jos","chapter":2,"verse":14},{"label":"2Sm 9:1","book":"2Sa","chapter":9,"verse":1},{"label":"2Sm 9:3","book":"2Sa","chapter":9,"verse":3},{"label":"2Sm 9:7","book":"2Sa","chapter":9,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:25","parts":[{"kind":"text","text":"When he showed them the way into the town, they put the town to the sword but released the man and his entire family. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:26","parts":[{"kind":"text","text":"Then the man went to the land of the Hittites, built a town, and named it Luz. That is its name still today."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:27","parts":[{"kind":"text","text":"At that time Manasseh failed to take possession of Beth-shean "},{"kind":"crossref","label":"Jos 17:11","book":"Jos","chapter":17,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jos 17:16","book":"Jos","chapter":17,"verse":16,"letter":"b"},{"kind":"crossref","label":"1Sm 31:10","book":"1Sa","chapter":31,"verse":10,"letter":"c"},{"kind":"crossref","label":"1Sm 31:12","book":"1Sa","chapter":31,"verse":12,"letter":"d"},{"kind":"crossref","label":"2Sm 21:12","book":"2Sa","chapter":21,"verse":12,"letter":"e"},{"kind":"text","text":" and Taanach "},{"kind":"crossref","label":"Jos 21:25","book":"Jos","chapter":21,"verse":25,"letter":"f"},{"kind":"crossref","label":"Jdg 5:19","book":"Jdg","chapter":5,"verse":19,"letter":"g"},{"kind":"text","text":" and their surrounding villages, or the residents of Dor, "},{"kind":"crossref","label":"Jos 11:2","book":"Jos","chapter":11,"verse":2,"letter":"h"},{"kind":"crossref","label":"Jos 12:23","book":"Jos","chapter":12,"verse":23,"letter":"i"},{"kind":"crossref","label":"Jos 17:11","book":"Jos","chapter":17,"verse":11,"letter":"j"},{"kind":"crossref","label":"1Kg 4:11","book":"1Ki","chapter":4,"verse":11,"letter":"k"},{"kind":"text","text":" Ibleam, "},{"kind":"crossref","label":"Jos 17:11","book":"Jos","chapter":17,"verse":11,"lett