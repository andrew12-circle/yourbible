0","book":"Num","chapter":14,"verse":30,"letter":"e"},{"kind":"crossref","label":"Nm 14:38","book":"Num","chapter":14,"verse":38,"letter":"f"},{"kind":"crossref","label":"Nm 26:65","book":"Num","chapter":26,"verse":65,"letter":"g"},{"kind":"crossref","label":"Nm 32:12","book":"Num","chapter":32,"verse":12,"letter":"h"},{"kind":"text","text":" said, “Whoever attacks and captures Kiriath-sepher, I will give my daughter Achsah "},{"kind":"crossref","label":"1Ch 2:49","book":"1Ch","chapter":2,"verse":49,"letter":"i"},{"kind":"text","text":" to him as a wife.” "}],"crossRefs":[{"label":"Nm 13:6","book":"Num","chapter":13,"verse":6},{"label":"Nm 13:13","book":"Num","chapter":13,"verse":13},{"label":"Nm 14:6","book":"Num","chapter":14,"verse":6},{"label":"Nm 14:24","book":"Num","chapter":14,"verse":24},{"label":"Nm 14:30","book":"Num","chapter":14,"verse":30},{"label":"Nm 14:38","book":"Num","chapter":14,"verse":38},{"label":"Nm 26:65","book":"Num","chapter":26,"verse":65},{"label":"Nm 32:12","book":"Num","chapter":32,"verse":12},{"label":"1Ch 2:49","book":"1Ch","chapter":2,"verse":49}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:13","parts":[{"kind":"text","text":"So Othniel "},{"kind":"crossref","label":"Jdg 3:9","book":"Jdg","chapter":3,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jdg 3:11","book":"Jdg","chapter":3,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Ch 4:13","book":"1Ch","chapter":4,"verse":13,"letter":"c"},{"kind":"text","text":" son of Kenaz, Caleb’s youngest brother, captured it, and Caleb gave his daughter Achsah to him as his wife."}],"crossRefs":[{"label":"Jdg 3:9","book":"Jdg","chapter":3,"verse":9},{"label":"Jdg 3:11","book":"Jdg","chapter":3,"verse":11},{"label":"1Ch 4:13","book":"1Ch","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:14","parts":[{"kind":"text","text":"When she arrived, she persuaded Othniel to ask her father for a field. As she got off her donkey, Caleb asked her, “What do you want?” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:15","parts":[{"kind":"text","text":"She answered him, “Give me a blessing. Since you have given me land in the Negev, "},{"kind":"crossref","label":"Gn 12:9","book":"Gen","chapter":12,"verse":9,"letter":"a"},{"kind":"crossref","label":"Gn 13:1","book":"Gen","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"Gn 13:3","book":"Gen","chapter":13,"verse":3,"letter":"c"},{"kind":"crossref","label":"Nm 13:17","book":"Num","chapter":13,"verse":17,"letter":"d"},{"kind":"crossref","label":"Nm 13:22","book":"Num","chapter":13,"verse":22,"letter":"e"},{"kind":"crossref","label":"Nm 13:29","book":"Num","chapter":13,"verse":29,"letter":"f"},{"kind":"crossref","label":"2Sm 24:7","book":"2Sa","chapter":24,"verse":7,"letter":"g"},{"kind":"crossref","label":"Ps 126:4","book":"Psa","chapter":126,"verse":4,"letter":"h"},{"kind":"text","text":" give me springs also.” So Caleb gave her both the upper and lower springs. "},{"kind":"crossref","label":"Jos 15:15–19","book":"Jos","chapter":15,"verse":15,"letter":"i"}],"crossRefs":[{"label":"Gn 12:9","book":"Gen","chapter":12,"verse":9},{"label":"Gn 13:1","book":"Gen","chapter":13,"verse":1},{"label":"Gn 13:3","book":"Gen","chapter":13,"verse":3},{"label":"Nm 13:17","book":"Num","chapter":13,"verse":17},{"label":"Nm 13:22","book":"Num","chapter":13,"verse":22},{"label":"Nm 13:29","book":"Num","chapter":13,"verse":29},{"label":"2Sm 24:7","book":"2Sa","chapter":24,"verse":7},{"label":"Ps 126:4","book":"Psa","chapter":126,"verse":4},{"label":"Jos 15:15–19","book":"Jos","chapter":15,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:16","parts":[{"kind":"text","text":"The descendants of the Kenite, Moses’s father-in-law, "},{"kind":"crossref","label":"Ex 2:18","book":"Exo","chapter":2,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ex 3:1","book":"Exo","chapter":3,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ex 4:18","book":"Exo","chapter":4,"verse":18,"letter":"c"},{"kind":"crossref","label":"Ex 18:1–12","book":"Exo","chapter":18,"verse":1,"letter":"d"},{"kind":"crossref","label":"Nm 10:29","book":"Num","chapter":10,"verse":29,"letter":"e"},{"kind":"text","text":" had gone up with the men of Judah from the City of Palms "},{"kind":"footnote","marker":1,"text":"= Jericho; Dt 34:3; Jdg 3:13; 2Ch 28:15"},{"kind":"crossref","label":"Dt 34:3","book":"Deu","chapter":34,"verse":3,"letter":"f"},{"kind":"crossref","label":"Jdg 3:13","book":"Jdg","chapter":3,"verse":13,"letter":"g"},{"kind":"crossref","label":"2Ch 28:15","book":"2Ch","chapter":28,"verse":15,"letter":"h"},{"kind":"text","text":" to the Wilderness of Judah, which was in the Negev of Arad. "},{"kind":"crossref","label":"Nm 21:1","book":"Num","chapter":21,"verse":1,"letter":"i"},{"kind":"crossref","label":"Nm 33:40","book":"Num","chapter":33,"verse":40,"letter":"j"},{"kind":"crossref","label":"Jos 12:14","book":"Jos","chapter":12,"verse":14,"letter":"k"},{"kind":"text","text":" They went to live among the people."}],"crossRefs":[{"label":"Ex 2:18","book":"Exo","chapter":2,"verse":18},{"label":"Ex 3:1","book":"Exo","chapter":3,"verse":1},{"label":"Ex 4:18","book":"Exo","chapter":4,"verse":18},{"label":"Ex 18:1–12","book":"Exo","chapter":18,"verse":1},{"label":"Nm 10:29","book":"Num","chapter":10,"verse":29},{"label":"Dt 34:3","book":"Deu","chapter":34,"verse":3},{"label":"Jdg 3:13","book":"Jdg","chapter":3,"verse":13},{"label":"2Ch 28:15","book":"2Ch","chapter":28,"verse":15},{"label":"Nm 21:1","book":"Num","chapter":21,"verse":1},{"label":"Nm 33:40","book":"Num","chapter":33,"verse":40},{"label":"Jos 12:14","book":"Jos","chapter":12,"verse":14}],"footnotes":[{"marker":1,"text":"= Jericho; Dt 34:3; Jdg 3:13; 2Ch 28:15"}]},{"verseId":"a556c5305ee15c3f-01:Jdg:1:17","parts":[{"kind":"text","text":"Judah went with his brother Simeon, struck the Canaanites who were living in Zephath, and completely destroyed the town. So they named the town