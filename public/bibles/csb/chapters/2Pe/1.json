,{"kind":"crossref","label":"1Pt 1:5","book":"1Pe","chapter":1,"verse":5,"letter":"a"},{"kind":"text","text":" has given us everything required for life and godliness through the knowledge "},{"kind":"crossref","label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3,"letter":"b"},{"kind":"crossref","label":"Php 3:8","book":"Php","chapter":3,"verse":8,"letter":"c"},{"kind":"crossref","label":"2Pt 1:2","book":"2Pe","chapter":1,"verse":2,"letter":"d"},{"kind":"crossref","label":"2Pt 1:8","book":"2Pe","chapter":1,"verse":8,"letter":"e"},{"kind":"crossref","label":"2Pt 2:20","book":"2Pe","chapter":2,"verse":20,"letter":"f"},{"kind":"crossref","label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18,"letter":"g"},{"kind":"text","text":" of him who called "},{"kind":"crossref","label":"1Th 2:12","book":"1Th","chapter":2,"verse":12,"letter":"h"},{"kind":"crossref","label":"2Th 2:14","book":"2Th","chapter":2,"verse":14,"letter":"i"},{"kind":"crossref","label":"1Pt 5:10","book":"1Pe","chapter":5,"verse":10,"letter":"j"},{"kind":"text","text":" us by "},{"kind":"footnote","marker":2,"text":"Or to"},{"kind":"text","text":" his own glory and goodness. "}],"crossRefs":[{"label":"1Pt 1:5","book":"1Pe","chapter":1,"verse":5},{"label":"Jn 17:3","book":"Jhn","chapter":17,"verse":3},{"label":"Php 3:8","book":"Php","chapter":3,"verse":8},{"label":"2Pt 1:2","book":"2Pe","chapter":1,"verse":2},{"label":"2Pt 1:8","book":"2Pe","chapter":1,"verse":8},{"label":"2Pt 2:20","book":"2Pe","chapter":2,"verse":20},{"label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18},{"label":"1Th 2:12","book":"1Th","chapter":2,"verse":12},{"label":"2Th 2:14","book":"2Th","chapter":2,"verse":14},{"label":"1Pt 5:10","book":"1Pe","chapter":5,"verse":10}],"footnotes":[{"marker":1,"text":"Lit As his"},{"marker":2,"text":"Or to"}]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:4","parts":[{"kind":"text","text":"By these he has given us very great and precious promises, "},{"kind":"crossref","label":"Jos 21:45","book":"Jos","chapter":21,"verse":45,"letter":"a"},{"kind":"crossref","label":"1Kg 8:56","book":"1Ki","chapter":8,"verse":56,"letter":"b"},{"kind":"crossref","label":"Is 38:16","book":"Isa","chapter":38,"verse":16,"letter":"c"},{"kind":"crossref","label":"Jr 33:14","book":"Jer","chapter":33,"verse":14,"letter":"d"},{"kind":"crossref","label":"Rm 9:4","book":"Rom","chapter":9,"verse":4,"letter":"e"},{"kind":"crossref","label":"Rm 15:8","book":"Rom","chapter":15,"verse":8,"letter":"f"},{"kind":"crossref","label":"2Co 7:1","book":"2Co","chapter":7,"verse":1,"letter":"g"},{"kind":"text","text":" so that through them you may share in the divine nature, "},{"kind":"crossref","label":"Eph 4:24","book":"Eph","chapter":4,"verse":24,"letter":"h"},{"kind":"crossref","label":"Heb 12:10","book":"Heb","chapter":12,"verse":10,"letter":"i"},{"kind":"crossref","label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2,"letter":"j"},{"kind":"text","text":" escaping the corruption that is in the world because of evil desire. "}],"crossRefs":[{"label":"Jos 21:45","book":"Jos","chapter":21,"verse":45},{"label":"1Kg 8:56","book":"1Ki","chapter":8,"verse":56},{"label":"Is 38:16","book":"Isa","chapter":38,"verse":16},{"label":"Jr 33:14","book":"Jer","chapter":33,"verse":14},{"label":"Rm 9:4","book":"Rom","chapter":9,"verse":4},{"label":"Rm 15:8","book":"Rom","chapter":15,"verse":8},{"label":"2Co 7:1","book":"2Co","chapter":7,"verse":1},{"label":"Eph 4:24","book":"Eph","chapter":4,"verse":24},{"label":"Heb 12:10","book":"Heb","chapter":12,"verse":10},{"label":"1Jn 3:2","book":"1Jn","chapter":3,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:5","parts":[{"kind":"text","text":"For this very reason, make every effort to supplement your faith with goodness, goodness with knowledge, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:6","parts":[{"kind":"text","text":"knowledge with self-control, "},{"kind":"crossref","label":"Ac 24:25","book":"Act","chapter":24,"verse":25,"letter":"a"},{"kind":"crossref","label":"Gl 5:23","book":"Gal","chapter":5,"verse":23,"letter":"b"},{"kind":"text","text":" self-control with endurance, endurance with godliness, "}],"crossRefs":[{"label":"Ac 24:25","book":"Act","chapter":24,"verse":25},{"label":"Gl 5:23","book":"Gal","chapter":5,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:7","parts":[{"kind":"text","text":"godliness with brotherly affection, "},{"kind":"crossref","label":"Rm 12:10","book":"Rom","chapter":12,"verse":10,"letter":"a"},{"kind":"crossref","label":"Heb 13:1","book":"Heb","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Pt 1:22","book":"1Pe","chapter":1,"verse":22,"letter":"c"},{"kind":"text","text":" and brotherly affection with love. "}],"crossRefs":[{"label":"Rm 12:10","book":"Rom","chapter":12,"verse":10},{"label":"Heb 13:1","book":"Heb","chapter":13,"verse":1},{"label":"1Pt 1:22","book":"1Pe","chapter":1,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:8","parts":[{"kind":"text","text":"For if you possess these qualities in increasing measure, they will keep you from being useless "},{"kind":"crossref","label":"Jms 2:20","book":"Jas","chapter":2,"verse":20,"letter":"a"},{"kind":"text","text":" or unfruitful "},{"kind":"crossref","label":"Mt 7:16–21","book":"Mat","chapter":7,"verse":16,"letter":"b"},{"kind":"crossref","label":"Gl 5:22","book":"Gal","chapter":5,"verse":22,"letter":"c"},{"kind":"crossref","label":"Ti 3:14","book":"Tit","chapter":3,"verse":14,"letter":"d"},{"kind":"text","text":" in the knowledge of our Lord Jesus Christ. "}],"crossRefs":[{"label":"Jms 2:20","book":"Jas","chapter":2,"verse":20},{"label":"Mt 7:16–21","book":"Mat","chapter":7,"verse":16},{"label":"Gl 5:22","book":"Gal","chapter":5,"verse":22},{"label":"Ti 3:14","book":"Tit","chapter":3,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:9","parts":[{"kind":"text","text":"The person who lacks these things is blind and shortsighted and has forgotten the cleansing from his past sins. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:10","parts":[{"kind":"text","text":"Therefore, brothers and sisters, make every effort to confirm your calling and election, "},{"kind":"crossref","label":"Mt 22:14","book":"Mat","chapter":22,"verse":14,"letter":"a"},{"kind":"crossref","label":"Rm 11:29","book":"Rom","chapter":11,"verse":29,"letter":"b"},{"kind":"crossref","label":"2Pt 1:3","book":"2Pe","chapter":1,"verse":3,"letter":"c"},{"kind":"text","text":" because if you do these things you will never stumble. "}],"crossRefs":[{"label":"Mt 22:14","book":"Mat","chapter":22,"verse":14},{"label":"Rm 11:29","book":"Rom","chapter":11,"verse":29},{"label":"2Pt 1:3","book":"2Pe","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:11","parts":[{"kind":"text","text":"For in this way, entry into the eternal kingdom "},{"kind":"crossref","label":"Col 1:13","book":"Col","chapter":1,"verse":13,"letter":"a"},{"kind":"crossref","label":"2Tm 4:18","book":"2Ti","chapter":4,"verse":18,"letter":"b"},{"kind":"text","text":" of our Lord and Savior Jesus Christ will be richly provided for you."}],"crossRefs":[{"label":"Col 1:13","book":"Col","chapter":1,"verse":13},{"label":"2Tm 4:18","book":"2Ti","chapter":4,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:12","parts":[{"kind":"text","text":"Therefore I will always remind you about these things, even though you know them and are established in the truth "},{"kind":"crossref","label":"2Co 11:10","book":"2Co","chapter":11,"verse":10,"letter":"a"},{"kind":"crossref","label":"Col 1:5–6","book":"Col","chapter":1,"verse":5,"letter":"b"},{"kind":"crossref","label":"2Jn 2","book":"2Jn","chapter":1,"verse":2,"letter":"c"},{"kind":"crossref","label":"3Jn 3–4","book":"3Jn","chapter":1,"verse":3,"letter":"d"},{"kind":"text","text":" you now have. "}],"crossRefs":[{"label":"2Co 11:10","book":"2Co","chapter":11,"verse":10},{"label":"Col 1:5–6","book":"Col","chapter":1,"verse":5},{"label":"2Jn 2","book":"2Jn","chapter":1,"verse":2},{"label":"3Jn 3–4","book":"3Jn","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:13","parts":[{"kind":"text","text":"I think it is right, as long as I am in this bodily tent, "},{"kind":"crossref","label":"2Co 5:1–4","book":"2Co","chapter":5,"verse":1,"letter":"a"},{"kind":"text","text":" to wake you up with a reminder, "}],"crossRefs":[{"label":"2Co 5:1–4","book":"2Co","chapter":5,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:14","parts":[{"kind":"text","text":"since I know that I will soon lay aside my tent, as our Lord Jesus Christ has indeed made clear to me. "},{"kind":"crossref","label":"Jn 21:18–23","book":"Jhn","chapter":21,"verse":18,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 21:18–23","book":"Jhn","chapter":21,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:15","parts":[{"kind":"text","text":"And I will also make every effort so that you are able to recall these things at any time after my departure. "},{"kind":"footnote","marker":1,"text":"Or death"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or death"}]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:16","parts":[{"kind":"text","text":"For we did not follow cleverly contrived myths when we made known to you the power and coming of our Lord Jesus Christ; "},{"kind":"crossref","label":"Mk 13:26","book":"Mrk","chapter":13,"verse":26,"letter":"a"},{"kind":"crossref","label":"Mk 14:62","book":"Mrk","chapter":14,"verse":62,"letter":"b"},{"kind":"crossref","label":"1Th 2:19","book":"1Th","chapter":2,"verse":19,"letter":"c"},{"kind":"text","text":" instead, we were eyewitnesses of his majesty. "},{"kind":"crossref","label":"Mt 17:1–6","book":"Mat","chapter":17,"verse":1,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 13:26","book":"Mrk","chapter":13,"verse":26},{"label":"Mk 14:62","book":"Mrk","chapter":14,"verse":62},{"label":"1Th 2:19","book":"1Th","chapter":2,"verse":19},{"label":"Mt 17:1–6","book":"Mat","chapter":17,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:17","parts":[{"kind":"text","text":"For he received honor and glory from God the Father when the voice came to him from the Majestic Glory, saying “This is my beloved Son, "},{"kind":"footnote","marker":1,"text":"Or my Son, my beloved"},{"kind":"text","text":" with whom I am well-pleased!” "},{"kind":"crossref","label":"Is 42:1","book":"Isa","chapter":42,"verse":1,"letter":"a"},{"kind":"crossref","label":"Mt 3:17","book":"Mat","chapter":3,"verse":17,"letter":"b"},{"kind":"crossref","label":"Mt 17:5","book":"Mat","chapter":17,"verse":5,"letter":"c"},{"kind":"crossref","label":"Mk 1:11","book":"Mrk","chapter":1,"verse":11,"letter":"d"},{"kind":"crossref","label":"Mk 9:7","book":"Mrk","chapter":9,"verse":7,"letter":"e"},{"kind":"crossref","label":"Lk 3:22","book":"Luk","chapter":3,"verse":22,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 42:1","book":"Isa","chapter":42,"verse":1},{"label":"Mt 3:17","book":"Mat","chapter":3,"verse":17},{"label":"Mt 17:5","book":"Mat","chapter":17,"verse":5},{"label":"Mk 1:11","book":"Mrk","chapter":1,"verse":11},{"label":"Mk 9:7","book":"Mrk","chapter":9,"verse":7},{"label":"Lk 3:22","book":"Luk","chapter":3,"verse":22}],"footnotes":[{"marker":1,"text":"Or my Son, my beloved"}]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:18","parts":[{"kind":"text","text":"We ourselves heard this voice when it came from heaven while we were with him on the holy mountain. "},{"kind":"crossref","label":"Ps 2:6","book":"Psa","chapter":2,"verse":6,"letter":"a"},{"kind":"crossref","label":"Mt 17:1","book":"Mat","chapter":17,"verse":1,"letter":"b"},{"kind":"crossref","label":"Mk 9:2","book":"Mrk","chapter":9,"verse":2,"letter":"c"},{"kind":"crossref","label":"Lk 9:28","book":"Luk","chapter":9,"verse":28,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 2:6","book":"Psa","chapter":2,"verse":6},{"label":"Mt 17:1","book":"Mat","chapter":17,"verse":1},{"label":"Mk 9:2","book":"Mrk","chapter":9,"verse":2},{"label":"Lk 9:28","book":"Luk","chapter":9,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:19","parts":[{"kind":"text","text":"We also have the prophetic word strongly confirmed, and you will do well to pay attention to it, as to a lamp shining in a dark place, "},{"kind":"crossref","label":"Ps 119:105","book":"Psa","chapter":119,"verse":105,"letter":"a"},{"kind":"text","text":" until the day dawns "},{"kind":"crossref","label":"Mal 4:2","book":"Mal","chapter":4,"verse":2,"letter":"b"},{"kind":"crossref","label":"Rm 13:12","book":"Rom","chapter":13,"verse":12,"letter":"c"},{"kind":"crossref","label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18,"letter":"d"},{"kind":"text","text":" and the morning star "},{"kind":"crossref","label":"Nm 24:17","book":"Num","chapter":24,"verse":17,"letter":"e"},{"kind":"crossref","label":"Rv 22:16","book":"Rev","chapter":22,"verse":16,"letter":"f"},{"kind":"text","text":" rises in your hearts. "}],"crossRefs":[{"label":"Ps 119:105","book":"Psa","chapter":119,"verse":105},{"label":"Mal 4:2","book":"Mal","chapter":4,"verse":2},{"label":"Rm 13:12","book":"Rom","chapter":13,"verse":12},{"label":"2Pt 3:18","book":"2Pe","chapter":3,"verse":18},{"label":"Nm 24:17","book":"Num","chapter":24,"verse":17},{"label":"Rv 22:16","book":"Rev","chapter":22,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:20","parts":[{"kind":"text","text":"Above all, you know this: No prophecy of Scripture comes from the prophet’s own interpretation, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:1:21","parts":[{"kind":"text","text":"because no prophecy ever came by the will of man; "},{"kind":"crossref","label":"Jr 23:26","book":"Jer","chapter":23,"verse":26,"letter":"a"},{"kind":"crossref","label":"2Tm 3:16","book":"2Ti","chapter":3,"verse":16,"letter":"b"},{"kind":"text","text":" instead, men spoke from God as they were carried along by the Holy Spirit. "},{"kind":"crossref","label":"2Sm 23:2","book":"2Sa","chapter":23,"verse":2,"letter":"c"},{"kind":"crossref","label":"Lk 1:70","book":"Luk","chapter":1,"verse":70,"letter":"d"},{"kind":"crossref","label":"Ac 1:16","book":"Act","chapter":1,"verse":16,"letter":"e"},{"kind":"crossref","label":"Ac 3:18","book":"Act","chapter":3,"verse":18,"letter":"f"},{"kind":"crossref","label":"1Pt 1:11","book":"1Pe","chapter":1,"verse":11,"letter":"g"}],"crossRefs":[{"label":"Jr 23:26","book":"Jer","chapter":23,"verse":26},{"label":"2Tm 3:16","book":"2Ti","chapter":3,"verse":16},{"label":"2Sm 23:2","book":"2Sa","chapter":23,"verse":2},{"label":"Lk 1:70","book":"Luk","chapter":1,"verse":70},{"label":"Ac 1:16","book":"Act","chapter":1,"verse":16},{"label":"Ac 3:18","book":"Act","chapter":3,"verse":18},{"label":"1Pt 1:11","book":"1Pe","chapter":1,"verse":11}],"footnotes":[]}]},"cachedAt":1783279684546}