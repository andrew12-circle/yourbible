,"book":"2Pe","chapter":3,"verse":12,"letter":"b"},{"kind":"text","text":" Ever since our ancestors fell asleep, "},{"kind":"crossref","label":"Ac 7:60","book":"Act","chapter":7,"verse":60,"letter":"c"},{"kind":"text","text":" all things continue as they have been since the beginning of creation.” "}],"crossRefs":[{"label":"1Th 2:19","book":"1Th","chapter":2,"verse":19},{"label":"2Pt 3:12","book":"2Pe","chapter":3,"verse":12},{"label":"Ac 7:60","book":"Act","chapter":7,"verse":60}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Pe:3:5","parts":[{"kind":"text","text":"They deliberately overlook this: By the word of God "},{"kind":"crossref","label":"Gn 1:3–30","book":"Gen","chapter":1,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 148:5","book":"Psa","chapter":148,"verse":5,"letter":"b"},{"kind":"crossref","label":"Jn 1:1–3","book":"Jhn","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"Heb 4:12","book":"Heb","chapter":4,"verse":12,"letter":"d"},{"kind":"crossref","label":"Heb 11:3","book":"Heb","chapter":11,"verse":3,"letter":"e"},{"kind":"text","text":" the heavens came into being long ago and the earth was brought about from water and through water. "},{"kind":"crossref","label":"Ps 24:1–2","book":"Psa","chapter":24,"verse":1,"letter":"f"},{"kind":"crossref","label":"Ps 33:6–7","book":"Psa","chapter":33,"verse":6,"letter":"g"},{"kind":"crossref","label":"Ps 136:5–6","book":"Psa","chapter":136,"verse":5,"letter":"h"},{"kind":"crossref","label":"Pr 8:24–29","book":"Pro","chapter":8,"verse":24,"letter":"i"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 1:3–30","book":"Gen","chapter":1,"verse":3},{"label":"Ps 148:5","book":"Psa","chapter":148,"verse":5},{"label":"Jn 1:1–3","book":"Jhn","chapter":1,"verse":1},{"label":"Heb 4:12","book":"Heb","chapter":4,"verse":12},{"label":"Heb 11:3","book":"Heb","chapter":11,"verse":3},{"label":"Ps 24:1–2","book":"Psa","chapter":24,"verse":1},{"label":"Ps 33:6–7","book":"Psa","chapter":33,"verse":6},{"