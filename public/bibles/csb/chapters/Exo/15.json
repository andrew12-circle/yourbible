"kind":"text","text":" with your strength. "},{"kind":"crossref","label":"Ps 77:15","book":"Psa","chapter":77,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ps 77:20","book":"Psa","chapter":77,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ps 78:54","book":"Psa","chapter":78,"verse":54,"letter":"c"}],"crossRefs":[{"label":"Ps 77:15","book":"Psa","chapter":77,"verse":15},{"label":"Ps 77:20","book":"Psa","chapter":77,"verse":20},{"label":"Ps 78:54","book":"Psa","chapter":78,"verse":54}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:14","parts":[{"kind":"text","text":"When the peoples hear, they will shudder;"},{"kind":"text","text":" anguish will seize the inhabitants of Philistia."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:15","parts":[{"kind":"text","text":"Then the chiefs of Edom will be terrified; "},{"kind":"crossref","label":"Gn 36:15","book":"Gen","chapter":36,"verse":15,"letter":"a"},{"kind":"crossref","label":"Gn 36:40","book":"Gen","chapter":36,"verse":40,"letter":"b"},{"kind":"crossref","label":"Nm 22:3","book":"Num","chapter":22,"verse":3,"letter":"c"},{"kind":"crossref","label":"Dt 2:4","book":"Deu","chapter":2,"verse":4,"letter":"d"},{"kind":"crossref","label":"Jos 5:1","book":"Jos","chapter":5,"verse":1,"letter":"e"},{"kind":"text","text":" trembling will seize the leaders of Moab;"},{"kind":"text","text":" all the inhabitants of Canaan will panic;"}],"crossRefs":[{"label":"Gn 36:15","book":"Gen","chapter":36,"verse":15},{"label":"Gn 36:40","book":"Gen","chapter":36,"verse":40},{"label":"Nm 22:3","book":"Num","chapter":22,"verse":3},{"label":"Dt 2:4","book":"Deu","chapter":2,"verse":4},{"label":"Jos 5:1","book":"Jos","chapter":5,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:16","parts":[{"kind":"text","text":"terror "},{"kind":"crossref","label":"Ex 23:27","book":"Exo","chapter":23,"verse":27,"letter":"a"},{"kind":"crossref","label":"Jos 2:9","book":"Jos","chapter":2,"verse":9,"letter":"b"},{"kind":"text","text":" and dread will fall on them."},{"kind":"text","text":" They will be as still "},{"kind":"footnote","marker":1,"text":"Or silent"},{"kind":"text","text":" as a stone"},{"kind":"text","text":" because of your powerful arm"},{"kind":"text","text":" until your people pass by, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" until the people whom you purchased "},{"kind":"footnote","marker":1,"text":"Or created"},{"kind":"text","text":" pass by. "},{"kind":"crossref","label":"1Sm 25:37","book":"1Sa","chapter":25,"verse":37,"letter":"a"},{"kind":"crossref","label":"Ps 74:2","book":"Psa","chapter":74,"verse":2,"letter":"b"},{"kind":"crossref","label":"1Pt 2:9","book":"1Pe","chapter":2,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Ex 23:27","book":"Exo","chapter":23,"verse":27},{"label":"Jos 2:9","book":"Jos","chapter":2,"verse":9},{"label":"1Sm 25:37","book":"1Sa","chapter":25,"verse":37},{"label":"Ps 74:2","book":"Psa","chapter":74,"verse":2},{"label":"1Pt 2:9","book":"1Pe","chapter":2,"verse":9}],"footnotes":[{"marker":1,"text":"Or silent"},{"marker":1,"text":"Or created"}]},{"verseId":"a556c5305ee15c3f-01:Exo:15:17","parts":[{"kind":"text","text":"You will bring them in and plant them"},{"kind":"text","text":" on the mountain of your possession; "},{"kind":"crossref","label":"Ps 44:2","book":"Psa","chapter":44,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 78:54","book":"Psa","chapter":78,"verse":54,"letter":"b"},{"kind":"text","text":" Lord","style":"divine"},{"kind":"text","text":", you have prepared the place"},{"kind":"text","text":" for your dwelling;"},{"kind":"text","text":" Lord, "},{"kind":"footnote","marker":1,"text":"Some Hb mss, DSS, Sam, Tg read Lord"},{"kind":"text","text":" your hands have established the sanctuary."}],"crossRefs":[{"label":"Ps 44:2","book":"Psa","chapter":44,"verse":2},{"label":"Ps 78:54","book":"Psa","chapter":78,"verse":54}],"footnotes":[{"marker":1,"text":"Some Hb mss, DSS, Sam, Tg read Lord"}]},{"verseId":"a556c5305ee15c3f-01:Exo:15:18","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will reign "},{"kind":"crossref","label":"Ps 10:16","book":"Psa","chapter":10,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ps 29:10","book":"Psa","chapter":29,"verse":10,"letter":"b"},{"kind":"crossref","label":"Is 57:15","book":"Isa","chapter":57,"verse":15,"letter":"c"},{"kind":"text","text":" forever and ever!"}],"crossRefs":[{"label":"Ps 10:16","book":"Psa","chapter":10,"verse":16},{"label":"Ps 29:10","book":"Psa","chapter":29,"verse":10},{"label":"Is 57:15","book":"Isa","chapter":57,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:19","parts":[{"kind":"text","text":"When Pharaoh’s horses with his chariots and horsemen went into the sea, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" brought the water of the sea back over them. But the Israelites walked through the sea on dry ground. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:20","parts":[{"kind":"text","text":"Then the prophetess Miriam, "},{"kind":"crossref","label":"Nm 26:59","book":"Num","chapter":26,"verse":59,"letter":"a"},{"kind":"crossref","label":"Jdg 4:4","book":"Jdg","chapter":4,"verse":4,"letter":"b"},{"kind":"text","text":" Aaron’s sister, took a tambourine in her hand, and all the women came out following her with tambourines and dancing. "},{"kind":"crossref","label":"Jdg 11:34","book":"Jdg","chapter":11,"verse":34,"letter":"c"},{"kind":"crossref","label":"1Sm 18:6","book":"1Sa","chapter":18,"verse":6,"letter":"d"},{"kind":"crossref","label":"Ps 150:4","book":"Psa","chapter":150,"verse":4,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 26:59","book":"Num","chapter":26,"verse":59},{"label":"Jdg 4:4","book":"Jdg","chapter":4,"verse":4},{"label":"Jdg 11:34","book":"Jdg","chapter":11,"verse":34},{"label":"1Sm 18:6","book":"1Sa","chapter":18,"verse":6},{"label":"Ps 150:4","book":"Psa","chapter":150,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:21","parts":[{"kind":"text","text":"Miriam sang to them:"},{"kind":"text","text":" Sing to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" for he is highly exalted;"},{"kind":"text","text":" he has thrown the horse"},{"kind":"text","text":" and its rider into the sea."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:22","parts":[{"kind":"text","text":"Then Moses led Israel on from the Red Sea, and they went out to the Wilderness of Shur. They journeyed for three days in the wilderness without finding water. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:23","parts":[{"kind":"text","text":"They came to Marah, but they could not drink the water at Marah because it was bitter —that is why it was named Marah. "},{"kind":"footnote","marker":1,"text":"= Bitter or Bitterness"},{"kind":"text","text":" "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"= Bitter or Bitterness"}]},{"verseId":"a556c5305ee15c3f-01:Exo:15:24","parts":[{"kind":"text","text":"The people grumbled to Moses, “What are we going to drink?” "},{"kind":"crossref","label":"Ex 16:2","book":"Exo","chapter":16,"verse":2,"letter":"a"},{"kind":"crossref","label":"Nm 33:8","book":"Num","chapter":33,"verse":8,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 16:2","book":"Exo","chapter":16,"verse":2},{"label":"Nm 33:8","book":"Num","chapter":33,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:25","parts":[{"kind":"text","text":"So he cried out to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", and the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" showed him a tree. When he threw it into the water, the water became drinkable."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:26","parts":[{"kind":"text","text":"He said, “If you will carefully obey the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God, do what is right in his sight, pay attention to his commands, and keep all his statutes, I will not inflict any illnesses on you that I inflicted on the Egyptians. For I am the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" who heals you.” "},{"kind":"crossref","label":"Ex 23:25","book":"Exo","chapter":23,"verse":25,"letter":"a"},{"kind":"crossref","label":"Dt 7:12","book":"Deu","chapter":7,"verse":12,"letter":"b"},{"kind":"crossref","label":"Dt 7:15","book":"Deu","chapter":7,"verse":15,"letter":"c"},{"kind":"crossref","label":"Dt 28:27","book":"Deu","chapter":28,"verse":27,"letter":"d"},{"kind":"crossref","label":"Dt 28:60","book":"Deu","chapter":28,"verse":60,"letter":"e"},{"kind":"crossref","label":"Ps 103:3","book":"Psa","chapter":103,"verse":3,"letter":"f"}],"crossRefs":[{"label":"Ex 23:25","book":"Exo","chapter":23,"verse":25},{"label":"Dt 7:12","book":"Deu","chapter":7,"verse":12},{"label":"Dt 7:15","book":"Deu","chapter":7,"verse":15},{"label":"Dt 28:27","book":"Deu","chapter":28,"verse":27},{"label":"Dt 28:60","book":"Deu","chapter":28,"verse":60},{"label":"Ps 103:3","book":"Psa","chapter":103,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:15:27","parts":[{"kind":"text","text":"Then they came to Elim, where there were twelve springs and seventy date palms, and they camped there by the water."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279320932}