e Sabbath day and declared it holy."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:12","parts":[{"kind":"text","text":"Honor your father and your mother "},{"kind":"crossref","label":"Lv 19:3","book":"Lev","chapter":19,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mt 15:4","book":"Mat","chapter":15,"verse":4,"letter":"b"},{"kind":"crossref","label":"Mk 7:10","book":"Mrk","chapter":7,"verse":10,"letter":"c"},{"kind":"crossref","label":"Lk 18:20","book":"Luk","chapter":18,"verse":20,"letter":"d"},{"kind":"crossref","label":"Eph 6:2","book":"Eph","chapter":6,"verse":2,"letter":"e"},{"kind":"text","text":" so that you may have a long life in the land that the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is giving you."}],"crossRefs":[{"label":"Lv 19:3","book":"Lev","chapter":19,"verse":3},{"label":"Mt 15:4","book":"Mat","chapter":15,"verse":4},{"label":"Mk 7:10","book":"Mrk","chapter":7,"verse":10},{"label":"Lk 18:20","book":"Luk","chapter":18,"verse":20},{"label":"Eph 6:2","book":"Eph","chapter":6,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:13","parts":[{"kind":"text","text":"Do not murder. "},{"kind":"crossref","label":"Mt 5:21","book":"Mat","chapter":5,"verse":21,"letter":"a"},{"kind":"crossref","label":"Rm 13:9","book":"Rom","chapter":13,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Mt 5:21","book":"Mat","chapter":5,"verse":21},{"label":"Rm 13:9","book":"Rom","chapter":13,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:14","parts":[{"kind":"text","text":"Do not commit adultery. "},{"kind":"crossref","label":"Dt 5:18","book":"Deu","chapter":5,"verse":18,"letter":"a"},{"kind":"crossref","label":"Mt 5:27","book":"Mat","chapter":5,"verse":27,"letter":"b"}],"crossRefs":[{"label":"Dt 5:18","book":"Deu","chapter":5,"verse":18},{"label":"Mt 5:27","book":"Mat","chapter":5,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:15","parts":[{"kind":"te