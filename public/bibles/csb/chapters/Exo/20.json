l":"Heb 13:5","book":"Heb","chapter":13,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:18","parts":[{"kind":"text","text":"All the people witnessed "},{"kind":"footnote","marker":1,"text":"Lit saw"},{"kind":"text","text":" the thunder and lightning, the sound of the ram’s horn, and the mountain surrounded by smoke. When the people saw it "},{"kind":"footnote","marker":2,"text":"Sam, LXX, Syr, Tg, Vg read smoke. The people (or they) were afraid,"},{"kind":"text","text":" they trembled and stood at a distance. "},{"kind":"crossref","label":"Ex 19:18","book":"Exo","chapter":19,"verse":18,"letter":"a"},{"kind":"crossref","label":"Heb 12:18","book":"Heb","chapter":12,"verse":18,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 19:18","book":"Exo","chapter":19,"verse":18},{"label":"Heb 12:18","book":"Heb","chapter":12,"verse":18}],"footnotes":[{"marker":1,"text":"Lit saw"},{"marker":2,"text":"Sam, LXX, Syr, Tg, Vg read smoke. The people (or they) were afraid,"}]},{"verseId":"a556c5305ee15c3f-01:Exo:20:19","parts":[{"kind":"text","text":"“You speak to us, and we will listen,” they said to Moses, “but don’t let God speak to us, or we will die.” "},{"kind":"crossref","label":"Dt 5:25","book":"Deu","chapter":5,"verse":25,"letter":"a"},{"kind":"crossref","label":"Dt 5:27","book":"Deu","chapter":5,"verse":27,"letter":"b"},{"kind":"crossref","label":"Gl 3:19","book":"Gal","chapter":3,"verse":19,"letter":"c"}],"crossRefs":[{"label":"Dt 5:25","book":"Deu","chapter":5,"verse":25},{"label":"Dt 5:27","book":"Deu","chapter":5,"verse":27},{"label":"Gl 3:19","book":"Gal","chapter":3,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:20","parts":[{"kind":"text","text":"Moses responded to the people, “Don’t be afraid, for God has come to test you, so that you will fear him and will not "},{"kind":"footnote","marker":1,"text":"Lit that the fear of him may be in you, and you do not"},{"kind":"text","text":" sin.” "},{"kind":"crossref","label":"Dt 13:3","book":"Deu","chapter":13,"verse":3,"letter":"a"},{"kind":"crossref","label":"Pr 16:6","book":"Pro","chapter":16,"verse":6,"letter":"b"},{"kind":"crossref","label":"Is 8:13","book":"Isa","chapter":8,"verse":13,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 13:3","book":"Deu","chapter":13,"verse":3},{"label":"Pr 16:6","book":"Pro","chapter":16,"verse":6},{"label":"Is 8:13","book":"Isa","chapter":8,"verse":13}],"footnotes":[{"marker":1,"text":"Lit that the fear of him may be in you, and you do not"}]},{"verseId":"a556c5305ee15c3f-01:Exo:20:21","parts":[{"kind":"text","text":"And the people remained standing at a distance as Moses approached the total darkness where God was. "},{"kind":"crossref","label":"Ex 19:16","book":"Exo","chapter":19,"verse":16,"letter":"a"},{"kind":"crossref","label":"Dt 5:22","book":"Deu","chapter":5,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Ex 19:16","book":"Exo","chapter":19,"verse":16},{"label":"Dt 5:22","book":"Deu","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:22","parts":[{"kind":"text","text":"Then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" told Moses, “This is what you are to say to the Israelites: You have seen that I have spoken to you from heaven. "},{"kind":"crossref","label":"Dt 4:36","book":"Deu","chapter":4,"verse":36,"letter":"a"},{"kind":"crossref","label":"Neh 9:13","book":"Neh","chapter":9,"verse":13,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 4:36","book":"Deu","chapter":4,"verse":36},{"label":"Neh 9:13","book":"Neh","chapter":9,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:23","parts":[{"kind":"text","text":"Do not make gods of silver to rival me; do not make gods of gold for yourselves. "},{"kind":"crossref","label":"Ex 20:3","book":"Exo","chapter":20,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ex 32:4","book":"Exo","chapter":32,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Ex 20:3","book":"Exo","chapter":20,"verse":3},{"label":"Ex 32:4","book":"Exo","chapter":32,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:24","parts":[{"kind":"text","text":"“Make an earthen altar for me, and sacrifice on it your burnt offerings and fellowship offerings, your flocks and herds. I will come to you and bless you in every place where I cause my name to be remembered. "},{"kind":"crossref","label":"Gn 12:2","book":"Gen","chapter":12,"verse":2,"letter":"a"},{"kind":"crossref","label":"Dt 12:5","book":"Deu","chapter":12,"verse":5,"letter":"b"},{"kind":"crossref","label":"Dt 16:6","book":"Deu","chapter":16,"verse":6,"letter":"c"},{"kind":"crossref","label":"Dt 16:11","book":"Deu","chapter":16,"verse":11,"letter":"d"},{"kind":"crossref","label":"1Kg 9:3","book":"1Ki","chapter":9,"verse":3,"letter":"e"},{"kind":"crossref","label":"2Ch 6:6","book":"2Ch","chapter":6,"verse":6,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Gn 12:2","book":"Gen","chapter":12,"verse":2},{"label":"Dt 12:5","book":"Deu","chapter":12,"verse":5},{"label":"Dt 16:6","book":"Deu","chapter":16,"verse":6},{"label":"Dt 16:11","book":"Deu","chapter":16,"verse":11},{"label":"1Kg 9:3","book":"1Ki","chapter":9,"verse":3},{"label":"2Ch 6:6","book":"2Ch","chapter":6,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:25","parts":[{"kind":"text","text":"If you make a stone altar for me, do not build it out of cut stones. If you use your chisel on it, you will defile it. "},{"kind":"crossref","label":"Dt 27:5","book":"Deu","chapter":27,"verse":5,"letter":"a"},{"kind":"crossref","label":"Jos 8:31","book":"Jos","chapter":8,"verse":31,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 27:5","book":"Deu","chapter":27,"verse":5},{"label":"Jos 8:31","book":"Jos","chapter":8,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:20:26","parts":[{"kind":"text","text":"Do not go up to my altar on steps, so that your nakedness is not exposed on it."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783280289935}