r":"a"},{"kind":"crossref","label":"Ex 37:3","book":"Exo","chapter":37,"verse":3,"letter":"b"},{"kind":"crossref","label":"Dt 10:3","book":"Deu","chapter":10,"verse":3,"letter":"c"},{"kind":"crossref","label":"Heb 9:4","book":"Heb","chapter":9,"verse":4,"letter":"d"},{"kind":"text","text":" of acacia wood, forty-five inches long, twenty-seven inches wide, and twenty-seven inches high. "},{"kind":"footnote","marker":1,"text":"Lit two and a half cubits its length, one and a half cubits its width, and one and a half cubits its height"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 37:1","book":"Exo","chapter":37,"verse":1},{"label":"Ex 37:3","book":"Exo","chapter":37,"verse":3},{"label":"Dt 10:3","book":"Deu","chapter":10,"verse":3},{"label":"Heb 9:4","book":"Heb","chapter":9,"verse":4}],"footnotes":[{"marker":1,"text":"Lit two and a half cubits its length, one and a half cubits its width, and one and a half cubits its height"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:11","parts":[{"kind":"text","text":"Overlay it with pure gold; overlay it both inside and out. Also make a gold molding all around it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:12","parts":[{"kind":"text","text":"Cast four gold rings for it and place them on its four feet, two rings on one side and two rings on the other side. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:13","parts":[{"kind":"text","text":"Make poles of acacia wood and overlay them with gold. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:14","parts":[{"kind":"text","text":"Insert the poles into the rings on the sides of the ark in order to carry the ark with them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:15","parts":[{"kind":"text","text":"The poles are to remain in the rings of the ark; they must not be removed from it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:16","parts":[{"kind":"text","text":"Put the tablets of "},{"kind":"footnote","marker":2,"text":"the tablets of supplied for clarity, also in v. 21"},{"kind":"text","text":" the testimony that I will give you into the ark. "},{"kind":"crossref","label":"Ex 16:34","book":"Exo","chapter":16,"verse":34,"letter":"a"},{"kind":"crossref","label":"Dt 31:26","book":"Deu","chapter":31,"verse":26,"letter":"b"},{"kind":"crossref","label":"1Kg 8:9","book":"1Ki","chapter":8,"verse":9,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 16:34","book":"Exo","chapter":16,"verse":34},{"label":"Dt 31:26","book":"Deu","chapter":31,"verse":26},{"label":"1Kg 8:9","book":"1Ki","chapter":8,"verse":9}],"footnotes":[{"marker":2,"text":"the tablets of supplied for clarity, also in v. 21"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:17","parts":[{"kind":"text","text":"Make a mercy seat "},{"kind":"crossref","label":"Ex 37:6","book":"Exo","chapter":37,"verse":6,"letter":"a"},{"kind":"crossref","label":"Rm 3:25","book":"Rom","chapter":3,"verse":25,"letter":"b"},{"kind":"crossref","label":"Heb 9:5","book":"Heb","chapter":9,"verse":5,"letter":"c"},{"kind":"text","text":" of pure gold, forty-five inches long and twenty-seven inches wide. "},{"kind":"footnote","marker":3,"text":"Lit two and a half cubits its length, one and a half cubits its width"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 37:6","book":"Exo","chapter":37,"verse":6},{"label":"Rm 3:25","book":"Rom","chapter":3,"verse":25},{"label":"Heb 9:5","book":"Heb","chapter":9,"verse":5}],"footnotes":[{"marker":3,"text":"Lit two and a half cubits its length, one and a half cubits its width"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:18","parts":[{"kind":"text","text":"Make two cherubim of gold; make them of hammered work at the two ends of the mercy seat. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:19","parts":[{"kind":"text","text":"Make one cherub at one end and one cherub at the other end. At its two ends, make the cherubim of one piece with the mercy seat. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:20","parts":[{"kind":"text","text":"The cherubim are to have wings spread out above, covering "},{"kind":"crossref","label":"1Kg 8:7","book":"1Ki","chapter":8,"verse":7,"letter":"a"},{"kind":"crossref","label":"1Ch 28:18","book":"1Ch","chapter":28,"verse":18,"letter":"b"},{"kind":"crossref","label":"Heb 9:5","book":"Heb","chapter":9,"verse":5,"letter":"c"},{"kind":"text","text":" the mercy seat with their wings, and are to face one another. The faces of the cherubim should be toward the mercy seat. "}],"crossRefs":[{"label":"1Kg 8:7","book":"1Ki","chapter":8,"verse":7},{"label":"1Ch 28:18","book":"1Ch","chapter":28,"verse":18},{"label":"Heb 9:5","book":"Heb","chapter":9,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:21","parts":[{"kind":"text","text":"Set the mercy seat on top of the ark and put the tablets of the testimony that I will give you into the ark. "},{"kind":"crossref","label":"Ex 25:16","book":"Exo","chapter":25,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ex 26:34","book":"Exo","chapter":26,"verse":34,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 25:16","book":"Exo","chapter":25,"verse":16},{"label":"Ex 26:34","book":"Exo","chapter":26,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:22","parts":[{"kind":"text","text":"I will meet with you there above the mercy seat, between the two cherubim "},{"kind":"crossref","label":"Nm 7:89","book":"Num","chapter":7,"verse":89,"letter":"a"},{"kind":"crossref","label":"1Sm 4:4","book":"1Sa","chapter":4,"verse":4,"letter":"b"},{"kind":"crossref","label":"2Sm 6:2","book":"2Sa","chapter":6,"verse":2,"letter":"c"},{"kind":"crossref","label":"2Kg 19:15","book":"2Ki","chapter":19,"verse":15,"letter":"d"},{"kind":"crossref","label":"Ps 80:1","book":"Psa","chapter":80,"verse":1,"letter":"e"},{"kind":"crossref","label":"Is 37:16","book":"Isa","chapter":37,"verse":16,"letter":"f"},{"kind":"text","text":" that are over the ark of the testimony; I will speak with you from there about all that I command you regarding the Israelites."}],"crossRefs":[{"label":"Nm 7:89","book":"Num","chapter":7,"verse":89},{"label":"1Sm 4:4","book":"1Sa","chapter":4,"verse":4},{"label":"2Sm 6:2","book":"2Sa","chapter":6,"verse":2},{"label":"2Kg 19:15","book":"2Ki","chapter":19,"verse":15},{"label":"Ps 80:1","book":"Psa","chapter":80,"verse":1},{"label":"Is 37:16","book":"Isa","chapter":37,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:23","parts":[{"kind":"text","text":"“You are to construct a table "},{"kind":"crossref","label":"Ex 37:10","book":"Exo","chapter":37,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Kg 7:48","book":"1Ki","chapter":7,"verse":48,"letter":"b"},{"kind":"crossref","label":"2Ch 4:8","book":"2Ch","chapter":4,"verse":8,"letter":"c"},{"kind":"crossref","label":"Heb 9:2","book":"Heb","chapter":9,"verse":2,"letter":"d"},{"kind":"text","text":" of acacia wood, thirty-six inches long, eighteen inches wide, and twenty-seven inches high. "},{"kind":"footnote","marker":1,"text":"Lit two cubits its length, one cubit its width, and one and a half cubits its height"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 37:10","book":"Exo","chapter":37,"verse":10},{"label":"1Kg 7:48","book":"1Ki","chapter":7,"verse":48},{"label":"2Ch 4:8","book":"2Ch","chapter":4,"verse":8},{"label":"Heb 9:2","book":"Heb","chapter":9,"verse":2}],"footnotes":[{"marker":1,"text":"Lit two cubits its length, one cubit its width, and one and a half cubits its height"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:24","parts":[{"kind":"text","text":"Overlay it with pure gold and make a gold molding all around it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:25","parts":[{"kind":"text","text":"Make a three-inch "},{"kind":"footnote","marker":2,"text":"Lit Make it a handbreadth"},{"kind":"text","text":" frame all around it and make a gold molding for it all around its frame. "}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Lit Make it a handbreadth"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:26","parts":[{"kind":"text","text":"Make four gold rings for it, and attach the rings to the four corners at its four legs. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:27","parts":[{"kind":"text","text":"The rings should be next to the frame as holders for the poles to carry the table. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:28","parts":[{"kind":"text","text":"Make the poles of acacia wood and overlay them with gold, and the table can be carried by them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:29","parts":[{"kind":"text","text":"You are also to make its plates "},{"kind":"crossref","label":"Ex 37:16","book":"Exo","chapter":37,"verse":16,"letter":"a"},{"kind":"crossref","label":"Nm 4:7","book":"Num","chapter":4,"verse":7,"letter":"b"},{"kind":"text","text":" and cups, as well as its pitchers and bowls for pouring drink offerings. Make them out of pure gold. "}],"crossRefs":[{"label":"Ex 37:16","book":"Exo","chapter":37,"verse":16},{"label":"Nm 4:7","book":"Num","chapter":4,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:30","parts":[{"kind":"text","text":"Put the Bread of the Presence "},{"kind":"crossref","label":"Ex 35:13","book":"Exo","chapter":35,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ex 39:36","book":"Exo","chapter":39,"verse":36,"letter":"b"},{"kind":"crossref","label":"Ex 40:23","book":"Exo","chapter":40,"verse":23,"letter":"c"},{"kind":"crossref","label":"Lv 24:5","book":"Lev","chapter":24,"verse":5,"letter":"d"},{"kind":"crossref","label":"Nm 4:7","book":"Num","chapter":4,"verse":7,"letter":"e"},{"kind":"text","text":" on the table before me at all times."}],"crossRefs":[{"label":"Ex 35:13","book":"Exo","chapter":35,"verse":13},{"label":"Ex 39:36","book":"Exo","chapter":39,"verse":36},{"label":"Ex 40:23","book":"Exo","chapter":40,"verse":23},{"label":"Lv 24:5","book":"Lev","chapter":24,"verse":5},{"label":"Nm 4:7","book":"Num","chapter":4,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:31","parts":[{"kind":"text","text":"“You "},{"kind":"crossref","label":"Ex 37:17–24","book":"Exo","chapter":37,"verse":17,"letter":"a"},{"kind":"text","text":" are to make a lampstand "},{"kind":"crossref","label":"1Kg 7:49","book":"1Ki","chapter":7,"verse":49,"letter":"b"},{"kind":"crossref","label":"Zch 4:2","book":"Zec","chapter":4,"verse":2,"letter":"c"},{"kind":"crossref","label":"Heb 9:2","book":"Heb","chapter":9,"verse":2,"letter":"d"},{"kind":"crossref","label":"Rv 1:12","book":"Rev","chapter":1,"verse":12,"letter":"e"},{"kind":"text","text":" out of pure, hammered gold. It is to be made of one piece: its base and shaft, its ornamental cups, and its buds "},{"kind":"footnote","marker":1,"text":"= the outer covering of a flower"},{"kind":"text","text":" and petals. "}],"crossRefs":[{"label":"Ex 37:17–24","book":"Exo","chapter":37,"verse":17},{"label":"1Kg 7:49","book":"1Ki","chapter":7,"verse":49},{"label":"Zch 4:2","book":"Zec","chapter":4,"verse":2},{"label":"Heb 9:2","book":"Heb","chapter":9,"verse":2},{"label":"Rv 1:12","book":"Rev","chapter":1,"verse":12}],"footnotes":[{"marker":1,"text":"= the outer covering of a flower"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:32","parts":[{"kind":"text","text":"Six branches are to extend from its sides, three branches of the lampstand from one side and three branches of the lampstand from the other side. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:33","parts":[{"kind":"text","text":"There are to be three cups shaped like almond blossoms, each with a bud and petals, on one branch, and three cups shaped like almond blossoms, each with a bud and petals, on the next branch. It is to be this way for the six branches that extend from the lampstand. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:34","parts":[{"kind":"text","text":"There are to be four cups shaped like almond blossoms on the lampstand shaft along with its buds and petals. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:35","parts":[{"kind":"text","text":"For the six branches that extend from the lampstand, a bud must be under the first pair of branches from it, a bud under the second pair of branches from it, and a bud under the third pair of branches from it. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:36","parts":[{"kind":"text","text":"Their buds and branches are to be of one piece. "},{"kind":"footnote","marker":2,"text":"Lit piece with it"},{"kind":"text","text":" All of it is to be a single hammered piece of pure gold."}],"crossRefs":[],"footnotes":[{"marker":2,"text":"Lit piece with it"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:37","parts":[{"kind":"text","text":"“Make its seven lamps, "},{"kind":"crossref","label":"Ex 27:21","book":"Exo","chapter":27,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ex 37:23","book":"Exo","chapter":37,"verse":23,"letter":"b"},{"kind":"crossref","label":"Lv 24:3","book":"Lev","chapter":24,"verse":3,"letter":"c"},{"kind":"crossref","label":"Nm 8:2","book":"Num","chapter":8,"verse":2,"letter":"d"},{"kind":"crossref","label":"2Ch 13:11","book":"2Ch","chapter":13,"verse":11,"letter":"e"},{"kind":"text","text":" and set them up so that they illuminate the area in front of it. "}],"crossRefs":[{"label":"Ex 27:21","book":"Exo","chapter":27,"verse":21},{"label":"Ex 37:23","book":"Exo","chapter":37,"verse":23},{"label":"Lv 24:3","book":"Lev","chapter":24,"verse":3},{"label":"Nm 8:2","book":"Num","chapter":8,"verse":2},{"label":"2Ch 13:11","book":"2Ch","chapter":13,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:38","parts":[{"kind":"text","text":"Its snuffers and firepans must be of pure gold. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Exo:25:39","parts":[{"kind":"text","text":"The lampstand "},{"kind":"footnote","marker":1,"text":"Lit It"},{"kind":"text","text":" with all these utensils is to be made from seventy-five pounds "},{"kind":"footnote","marker":2,"text":"Lit a talent"},{"kind":"text","text":" of pure gold. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit It"},{"marker":2,"text":"Lit a talent"}]},{"verseId":"a556c5305ee15c3f-01:Exo:25:40","parts":[{"kind":"text","text":"Be careful to make them according to the pattern "},{"kind":"crossref","label":"Ex 26:30","book":"Exo","chapter":26,"verse":30,"letter":"a"},{"kind":"crossref","label":"Nm 8:4","book":"Num","chapter":8,"verse":4,"letter":"b"},{"kind":"crossref","label":"1Ch 28:11","book":"1Ch","chapter":28,"verse":11,"letter":"c"},{"kind":"crossref","label":"1Ch 28:19","book":"1Ch","chapter":28,"verse":19,"letter":"d"},{"kind":"crossref","label":"Ac 7:44","book":"Act","chapter":7,"verse":44,"letter":"e"},{"kind":"crossref","label":"Heb 8:5","book":"Heb","chapter":8,"verse":5,"letter":"f"},{"kind":"text","text":" you have been shown on the mountain."}],"crossRefs":[{"label":"Ex 26:30","book":"Exo","chapter":26,"verse":30},{"label":"Nm 8:4","book":"Num","chapter":8,"verse":4},{"label":"1Ch 28:11","book":"1Ch","chapter":28,"verse":11},{"label":"1Ch 28:19","book":"1Ch","chapter":28,"verse":19},{"label":"Ac 7:44","book":"Act","chapter":7,"verse":44},{"label":"Heb 8:5","book":"Heb","chapter":8,"verse":5}],"footnotes":[]}]},"cachedAt":1783279324022}