 "},{"kind":"crossref","label":"Sg 6:3","book":"Sng","chapter":6,"verse":3,"letter":"a"},{"kind":"crossref","label":"Sg 7:10","book":"Sng","chapter":7,"verse":10,"letter":"b"},{"kind":"crossref","label":"Sg 8:6","book":"Sng","chapter":8,"verse":6,"letter":"c"},{"kind":"text","text":" he feeds among the lilies."}],"crossRefs":[{"label":"Sg 6:3","book":"Sng","chapter":6,"verse":3},{"label":"Sg 7:10","book":"Sng","chapter":7,"verse":10},{"label":"Sg 8:6","book":"Sng","chapter":8,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Sng:2:17","parts":[{"kind":"text","text":"Until the day breaks "},{"kind":"footnote","marker":1,"text":"Lit breathes"},{"kind":"text","text":" and the shadows flee,"},{"kind":"text","text":" turn around, my love, and be like a gazelle"},{"kind":"text","text":" or a young stag "},{"kind":"crossref","label":"Sg 2:9","book":"Sng","chapter":2,"verse":9,"letter":"a"},{"kind":"text","text":" on the divided mountains. "},{"kind":"footnote","marker":1,"text":"Or the Bether mountains, or the mountains of spices; Hb obscure"},{"kind":"crossref","label":"Sg 4:5","book":"Sng","chapter":4,"verse":5,"letter":"b"},{"kind":"crossref","label":"Sg 8:14","book":"Sng","chapter":8,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Sg 2:9","book":"Sng","chapter":2,"verse":9},{"label":"Sg 4:5","book":"Sng","chapter":4,"verse":5},{"label":"Sg 8:14","book":"Sng","chapter":8,"verse":14}],"footnotes":[{"marker":1,"text":"Lit breathes"},{"marker":1,"text":"Or the Bether mountains, or the mountains of spices; Hb obscure"}]}]},"cachedAt":1783279535452}