 you look at the dance "},{"kind":"crossref","label":"Jdg 21:21","book":"Jdg","chapter":21,"verse":21,"letter":"a"},{"kind":"text","text":" of the two camps! "},{"kind":"footnote","marker":1,"text":"Or dance of Mahanaim"},{"kind":"crossref","label":"Gn 32:2","book":"Gen","chapter":32,"verse":2,"letter":"b"},{"kind":"crossref","label":"2Sm 17:24","book":"2Sa","chapter":17,"verse":24,"letter":"c"}],"crossRefs":[{"label":"Jdg 21:21","book":"Jdg","chapter":21,"verse":21},{"label":"Gn 32:2","book":"Gen","chapter":32,"verse":2},{"label":"2Sm 17:24","book":"2Sa","chapter":17,"verse":24}],"footnotes":[{"marker":1,"text":"Or the perfect one, or the peaceable one"},{"marker":1,"text":"Or dance of Mahanaim"}]}]},"cachedAt":1783279536640}