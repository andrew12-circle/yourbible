},{"kind":"text","text":" as Israel advanced;"},{"kind":"text","text":" his height "},{"kind":"crossref","label":"Nm 13:28","book":"Num","chapter":13,"verse":28,"letter":"a"},{"kind":"text","text":" was like the cedars,"},{"kind":"text","text":" and he was as sturdy as the oaks;"},{"kind":"text","text":" I destroyed his fruit "},{"kind":"crossref","label":"Ezk 17:9","book":"Ezk","chapter":17,"verse":9,"letter":"a"},{"kind":"crossref","label":"Mal 4:1","book":"Mal","chapter":4,"verse":1,"letter":"b"},{"kind":"text","text":" above and his roots beneath."}],"crossRefs":[{"label":"Jos 10:12","book":"Jos","chapter":10,"verse":12},{"label":"Nm 13:28","book":"Num","chapter":13,"verse":28},{"label":"Ezk 17:9","book":"Ezk","chapter":17,"verse":9},{"label":"Mal 4:1","book":"Mal","chapter":4,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Amo:2:10","parts":[{"kind":"text","text":"And I brought you from the land of Egypt "},{"kind":"crossref","label":"Ex 20:2","book":"Exo","chapter":20,"verse":2,"letter":"a"},{"kind":"crossref","label":"Am 3:1","book":"Amo","chapter":3,"verse":1,"letter":"b"},{"kind":"crossref","label":"Am 9:7","book":"Amo","chapter":9,"verse":7,"letter":"c"},{"kind":"text","text":" and led you forty years in the wilderness "},{"kind":"crossref","label":"Dt 2:7","book":"Deu","chapter":2,"verse":7,"letter":"a"},{"kind":"text","text":" in order to possess the land of the Amorite. "},{"kind":"crossref","label":"Nm 21:25","book":"Num","chapter":21,"verse":25,"letter":"a"}],"crossRefs":[{"label":"Ex 20:2","book":"Exo","chapter":20,"verse":2},{"label":"Am 3:1","book":"Amo","chapter":3,"verse":1},{"label":"Am 9:7","book":"Amo","chapter":9,"verse":7},{"label":"Dt 2:7","book":"Deu","chapter":2,"verse":7},{"label":"Nm 21:25","book":"Num","chapter":21,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Amo:2:11","parts":[{"kind":"text","text":"I raised up some of your sons as prophets "},{"kind":"crossref","label":"Dt 18:18","book":"Deu","chapter":18,