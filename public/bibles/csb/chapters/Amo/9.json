w with it. "},{"kind":"crossref","label":"Jl 2:24","book":"Jol","chapter":2,"verse":24,"letter":"a"},{"kind":"crossref","label":"Jl 3:18","book":"Jol","chapter":3,"verse":18,"letter":"b"}],"crossRefs":[{"label":"Lv 26:5","book":"Lev","chapter":26,"verse":5},{"label":"Jl 2:24","book":"Jol","chapter":2,"verse":24},{"label":"Jl 3:18","book":"Jol","chapter":3,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Amo:9:14","parts":[{"kind":"text","text":"I will restore the fortunes of my people Israel. "},{"kind":"footnote","marker":1,"text":"Or restore my people Israel from captivity"},{"kind":"crossref","label":"Dt 30:3","book":"Deu","chapter":30,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 31:23","book":"Jer","chapter":31,"verse":23,"letter":"b"},{"kind":"crossref","label":"Jr 32:42–44","book":"Jer","chapter":32,"verse":42,"letter":"c"},{"kind":"text","text":" They will rebuild and occupy ruined cities, "},{"kind":"crossref","label":"Jr 30:18","book":"Jer","chapter":30,"verse":18,"letter":"a"},{"kind":"crossref","label":"Jr 33:10–11","book":"Jer","chapter":33,"verse":10,"letter":"b"},{"kind":"text","text":" plant vineyards and drink their wine,"},{"kind":"text","text":" make gardens and eat their produce. "},{"kind":"crossref","label":"Is 65:21","book":"Isa","chapter":65,"verse":21,"letter":"a"},{"kind":"crossref","label":"Jr 31:5","book":"Jer","chapter":31,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Dt 30:3","book":"Deu","chapter":30,"verse":3},{"label":"Jr 31:23","book":"Jer","chapter":31,"verse":23},{"label":"Jr 32:42–44","book":"Jer","chapter":32,"verse":42},{"label":"Jr 30:18","book":"Jer","chapter":30,"verse":18},{"label":"Jr 33:10–11","book":"Jer","chapter":33,"verse":10},{"label":"Is 65:21","book":"Isa","chapter":65,"verse":21},{"label":"Jr 31:5","book":"Jer","chapter":31,"verse":5}],"footnotes":[{"marker":1,"text":"Or restore my people Israel from captivity"}]},{"verseId":"a556c5305ee15c3f-01:Amo:9:15","parts":[{"kind":"text","text":"I will plant them on their land,"},{"kind":"text","text":" and they will never again be uprooted"},{"kind":"text","text":" from the land I have given them. "},{"kind":"crossref","label":"2Sm 7:10","book":"2Sa","chapter":7,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jr 24:6","book":"Jer","chapter":24,"verse":6,"letter":"b"},{"kind":"text","text":" The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God has spoken."}],"crossRefs":[{"label":"2Sm 7:10","book":"2Sa","chapter":7,"verse":10},{"label":"Jr 24:6","book":"Jer","chapter":24,"verse":6}],"footnotes":[]}]},"cachedAt":1783279602120}