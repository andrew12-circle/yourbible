":"a"},{"kind":"crossref","label":"Am 6:8","book":"Amo","chapter":6,"verse":8,"letter":"b"},{"kind":"text","text":" by the Pride of Jacob: "},{"kind":"footnote","marker":1,"text":"= the Lord or the promised land"},{"kind":"crossref","label":"Dt 33:26","book":"Deu","chapter":33,"verse":26,"letter":"c"},{"kind":"crossref","label":"Dt 33:29","book":"Deu","chapter":33,"verse":29,"letter":"d"},{"kind":"crossref","label":"Ps 47:4","book":"Psa","chapter":47,"verse":4,"letter":"e"},{"kind":"text","text":" I will never forget all their deeds. "},{"kind":"crossref","label":"Ps 10:11","book":"Psa","chapter":10,"verse":11,"letter":"a"},{"kind":"crossref","label":"Hs 7:2","book":"Hos","chapter":7,"verse":2,"letter":"b"},{"kind":"crossref","label":"Hs 8:13","book":"Hos","chapter":8,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Am 4:2","book":"Amo","chapter":4,"verse":2},{"label":"Am 6:8","book":"Amo","chapter":6,"verse":8},{"label":"Dt 33:26","book":"Deu","chapter":33,"verse":26},{"label":"Dt 33:29","book":"Deu","chapter":33,"verse":29},{"label":"Ps 47:4","book":"Psa","chapter":47,"verse":4},{"label":"Ps 10:11","book":"Psa","chapter":10,"verse":11},{"label":"Hs 7:2","book":"Hos","chapter":7,"verse":2},{"label":"Hs 8:13","book":"Hos","chapter":8,"verse":13}],"footnotes":[{"marker":1,"text":"= the Lord or the promised land"}]},{"verseId":"a556c5305ee15c3f-01:Amo:8:8","parts":[{"kind":"text","text":"Because of this, won’t the land quake "},{"kind":"crossref","label":"Ps 18:7","book":"Psa","chapter":18,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ps 60:2","book":"Psa","chapter":60,"verse":2,"letter":"b"},{"kind":"crossref","label":"Is 5:25","book":"Isa","chapter":5,"verse":25,"letter":"c"},{"kind":"crossref","label":"Am 1:1","book":"Amo","chapter":1,"verse":1,"letter":"d"},{"kind":"text","text":" and all who dwell in it mourn? "},{"kind":"crossref","label":"Hs 4:3","book":"Hos","chapter":4,"verse":3,"letter":"a"},{"kind":"text","text":" All of it will rise like the Nile; "}