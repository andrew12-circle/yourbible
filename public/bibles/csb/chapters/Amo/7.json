","label":"2Kg 4:38","book":"2Ki","chapter":4,"verse":38,"letter":"b"},{"kind":"crossref","label":"2Ch 19:2","book":"2Ch","chapter":19,"verse":2,"letter":"c"},{"kind":"text","text":" rather, I was "},{"kind":"footnote","marker":3,"text":"Or am"},{"kind":"text","text":" a herdsman, "},{"kind":"crossref","label":"Am 1:1","book":"Amo","chapter":1,"verse":1,"letter":"d"},{"kind":"text","text":" and I took care of sycamore figs. "}],"crossRefs":[{"label":"2Kg 2:3","book":"2Ki","chapter":2,"verse":3},{"label":"2Kg 4:38","book":"2Ki","chapter":4,"verse":38},{"label":"2Ch 19:2","book":"2Ch","chapter":19,"verse":2},{"label":"Am 1:1","book":"Amo","chapter":1,"verse":1}],"footnotes":[{"marker":1,"text":"Or am"},{"marker":2,"text":"= a prophet’s disciple or a member of a prophetic guild"},{"marker":3,"text":"Or am"}]},{"verseId":"a556c5305ee15c3f-01:Amo:7:15","parts":[{"kind":"text","text":"But the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" took me from following the flock "},{"kind":"crossref","label":"2Sm 7:8","book":"2Sa","chapter":7,"verse":8,"letter":"a"},{"kind":"text","text":" and said to me, ‘Go, prophesy to my people Israel.’” "},{"kind":"crossref","label":"Jr 1:7","book":"Jer","chapter":1,"verse":7,"letter":"b"},{"kind":"crossref","label":"Ezk 2:3–4","book":"Ezk","chapter":2,"verse":3,"letter":"c"}],"crossRefs":[{"label":"2Sm 7:8","book":"2Sa","chapter":7,"verse":8},{"label":"Jr 1:7","book":"Jer","chapter":1,"verse":7},{"label":"Ezk 2:3–4","book":"Ezk","chapter":2,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Amo:7:16","parts":[{"kind":"text","text":"Now hear the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". You say:"},{"kind":"text","text":" Do not prophesy "},{"kind":"crossref","label":"Am 2:12","book":"Amo","chapter":2,"verse":12,"letter":"a"},{"kind":"text","text":" against Israel;"},{"kind":"text","text":" do not preach "},{"kind":"crossref","label":"Mc 2:6","book":"Mic","chapter":2,"verse":6,"letter":"a"},{"kind":"text","text":" against the house of Isaac."}],"crossRefs":[{"label":"Am 2:12","book":"Amo","chapter":2,"verse":12},{"label":"Mc 2:6","book":"Mic","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Amo:7:17","parts":[{"kind":"text","text":"Therefore, this is what the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" says:"},{"kind":"text","text":" Your wife will be a prostitute in the city, "},{"kind":"crossref","label":"Hs 4:13","book":"Hos","chapter":4,"verse":13,"letter":"a"},{"kind":"text","text":" your sons and daughters will fall by the sword, "},{"kind":"crossref","label":"Jr 14:16","book":"Jer","chapter":14,"verse":16,"letter":"a"},{"kind":"text","text":" and your land will be divided up"},{"kind":"text","text":" with a measuring line."},{"kind":"text","text":" You yourself will die on pagan "},{"kind":"footnote","marker":1,"text":"Lit unclean"},{"kind":"text","text":" soil, "},{"kind":"crossref","label":"2Kg 17:6","book":"2Ki","chapter":17,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ezk 4:13","book":"Ezk","chapter":4,"verse":13,"letter":"b"},{"kind":"crossref","label":"Hs 9:3","book":"Hos","chapter":9,"verse":3,"letter":"c"},{"kind":"text","text":" and Israel will certainly go into exile "},{"kind":"crossref","label":"Jr 36:29–31","book":"Jer","chapter":36,"verse":29,"letter":"a"},{"kind":"text","text":" from its homeland."}],"crossRefs":[{"label":"Hs 4:13","book":"Hos","chapter":4,"verse":13},{"label":"Jr 14:16","book":"Jer","chapter":14,"verse":16},{"label":"2Kg 17:6","book":"2Ki","chapter":17,"verse":6},{"label":"Ezk 4:13","book":"Ezk","chapter":4,"verse":13},{"label":"Hs 9:3","book":"Hos","chapter":9,"verse":3},{"label":"Jr 36:29–31","book":"Jer","chapter":36,"verse":29}],"footnotes":[{"marker":1,"text":"Lit unclean"}]}]},"cachedAt":1783279601336}