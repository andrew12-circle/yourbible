:12","book":"Hos","chapter":10,"verse":12},{"label":"Am 6:12","book":"Amo","chapter":6,"verse":12},{"label":"Gl 6:8","book":"Gal","chapter":6,"verse":8},{"label":"Php 1:11","book":"Php","chapter":1,"verse":11}],"footnotes":[]}]},"cachedAt":1783279682238}