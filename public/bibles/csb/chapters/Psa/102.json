6c5305ee15c3f-01:Psa:102:25","parts":[{"kind":"text","text":"Long ago you established the earth,"},{"kind":"text","text":" and the heavens are the work of your hands. "},{"kind":"crossref","label":"Neh 9:6","book":"Neh","chapter":9,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 96:5","book":"Psa","chapter":96,"verse":5,"letter":"b"},{"kind":"crossref","label":"Heb 1:10–12","book":"Heb","chapter":1,"verse":10,"letter":"c"}],"crossRefs":[{"label":"Neh 9:6","book":"Neh","chapter":9,"verse":6},{"label":"Ps 96:5","book":"Psa","chapter":96,"verse":5},{"label":"Heb 1:10–12","book":"Heb","chapter":1,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:102:26","parts":[{"kind":"text","text":"They will perish, but you will endure;"},{"kind":"text","text":" all of them will wear out like clothing."},{"kind":"text","text":" You will change them like a garment,"},{"kind":"text","text":" and they will pass away. "},{"kind":"crossref","label":"Is 34:4","book":"Isa","chapter":34,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 51:6","book":"Isa","chapter":51,"verse":6,"letter":"b"},{"kind":"crossref","label":"Mt 24:35","book":"Mat","chapter":24,"verse":35,"letter":"c"}],"crossRefs":[{"label":"Is 34:4","book":"Isa","chapter":34,"verse":4},{"label":"Is 51:6","book":"Isa","chapter":51,"verse":6},{"label":"Mt 24:35","book":"Mat","chapter":24,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:102:27","parts":[{"kind":"text","text":"But you are the same,"},{"kind":"text","text":" and your years will never end. "},{"kind":"crossref","label":"Mal 3:6","book":"Mal","chapter":3,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jms 1:17","book":"Jas","chapter":1,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Mal 3:6","book":"Mal","chapter":3,"verse":6},{"label":"Jms 1:17","book":"Jas","chapter":1,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:102:28","parts":[{"kind":"text","text":"Your servants’ children will dwell securely,"},{"k