es of God are"},{"kind":"text","text":" a broken spirit."},{"kind":"text","text":" You will not despise a broken and humbled heart, God. "},{"kind":"crossref","label":"Ps 34:18","book":"Psa","chapter":34,"verse":18,"letter":"a"}],"crossRefs":[{"label":"Ps 34:18","book":"Psa","chapter":34,"verse":18}],"footnotes":[{"marker":1,"text":"Lit The sacrifices of God are"}]},{"verseId":"a556c5305ee15c3f-01:Psa:51:18","parts":[{"kind":"text","text":"In your good pleasure, cause Zion to prosper;"},{"kind":"text","text":" build the walls of Jerusalem. "},{"kind":"crossref","label":"Ps 69:35","book":"Psa","chapter":69,"verse":35,"letter":"a"},{"kind":"crossref","label":"Ps 102:16","book":"Psa","chapter":102,"verse":16,"letter":"b"},{"kind":"crossref","label":"Ps 147:2","book":"Psa","chapter":147,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Ps 69:35","book":"Psa","chapter":69,"verse":35},{"label":"Ps 102:16","book":"Psa","chapter":102,"verse":16},{"label":"Ps 147:2","book":"Psa","chapter":147,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:51:19","parts":[{"kind":"text","text":"Then you will delight in righteous sacrifices,"},{"kind":"text","text":" whole burnt offerings;"},{"kind":"text","text":" then bulls will be offered on your altar. "},{"kind":"crossref","label":"Ps 4:5","book":"Psa","chapter":4,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 66:13","book":"Psa","chapter":66,"verse":13,"letter":"b"},{"kind":"crossref","label":"Ps 66:15","book":"Psa","chapter":66,"verse":15,"letter":"c"},{"kind":"crossref","label":"Mal 3:3","book":"Mal","chapter":3,"verse":3,"letter":"d"}],"crossRefs":[{"label":"Ps 4:5","book":"Psa","chapter":4,"verse":5},{"label":"Ps 66:13","book":"Psa","chapter":66,"verse":13},{"label":"Ps 66:15","book":"Psa","chapter":66,"verse":15},{"label":"Mal 3:3","book":"Mal","chapter":3,"verse":3}],"footnotes":[]}]},"cachedAt":1783279494084}