ef","label":"Ps 19:1","book":"Psa","chapter":19,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 97:6","book":"Psa","chapter":97,"verse":6,"letter":"b"},{"kind":"text","text":" —"},{"kind":"text","text":" your faithfulness also —"},{"kind":"text","text":" in the assembly of the holy ones. "},{"kind":"crossref","label":"Ps 149:1","book":"Psa","chapter":149,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Ps 19:1","book":"Psa","chapter":19,"verse":1},{"label":"Ps 97:6","book":"Psa","chapter":97,"verse":6},{"label":"Ps 149:1","book":"Psa","chapter":149,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:6","parts":[{"kind":"text","text":"For who in the skies can compare with the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"},{"kind":"text","text":" Who among the heavenly beings "},{"kind":"footnote","marker":1,"text":"Or the angels, or the sons of the mighty"},{"kind":"text","text":" is like the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"? "},{"kind":"crossref","label":"Ps 86:8","book":"Psa","chapter":86,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 113:5","book":"Psa","chapter":113,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 86:8","book":"Psa","chapter":86,"verse":8},{"label":"Ps 113:5","book":"Psa","chapter":113,"verse":5}],"footnotes":[{"marker":1,"text":"Or the angels, or the sons of the mighty"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:7","parts":[{"kind":"text","text":"God is greatly feared in the council of the holy ones,"},{"kind":"text","text":" more awe-inspiring than "},{"kind":"footnote","marker":1,"text":"Or ones, revered by"},{"kind":"text","text":" all who surround him. "},{"kind":"crossref","label":"Ps 89:5","book":"Psa","chapter":89,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 96:4","book":"Psa","chapter":96,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Ps 89:5","book":"Psa","chapter":89,"verse":5},{"label":"Ps 96:4","book":"Psa","chapter":96,"verse":4}],"footnotes":[{"marker":1,"text":"Or ones, revered by"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:8","parts":[{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" God of Armies,"},{"kind":"text","text":" who is strong like you, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"? "},{"kind":"crossref","label":"Ex 15:11","book":"Exo","chapter":15,"verse":11,"letter":"a"},{"kind":"crossref","label":"2Sm 7:22","book":"2Sa","chapter":7,"verse":22,"letter":"b"},{"kind":"text","text":" Your faithfulness surrounds you."}],"crossRefs":[{"label":"Ex 15:11","book":"Exo","chapter":15,"verse":11},{"label":"2Sm 7:22","book":"2Sa","chapter":7,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:9","parts":[{"kind":"text","text":"You rule the raging sea;"},{"kind":"text","text":" when its waves surge, you still them. "},{"kind":"crossref","label":"Jb 38:11","book":"Job","chapter":38,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 104:9","book":"Psa","chapter":104,"verse":9,"letter":"b"},{"kind":"crossref","label":"Mt 8:23–27","book":"Mat","chapter":8,"verse":23,"letter":"c"}],"crossRefs":[{"label":"Jb 38:11","book":"Job","chapter":38,"verse":11},{"label":"Ps 104:9","book":"Psa","chapter":104,"verse":9},{"label":"Mt 8:23–27","book":"Mat","chapter":8,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:10","parts":[{"kind":"text","text":"You crushed Rahab like one who is slain; "},{"kind":"crossref","label":"Is 30:7","book":"Isa","chapter":30,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 51:9–10","book":"Isa","chapter":51,"verse":9,"letter":"b"},{"kind":"text","text":" you scattered your enemies with your powerful arm. "},{"kind":"crossref","label":"Ps 68:1","book":"Psa","chapter":68,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 92:9","book":"Psa","chapter":92,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Is 30:7","book":"Isa","chapter":30,"verse":7},{"label":"Is 51:9–10","book":"Isa","chapter":51,"verse":9},{"label":"Ps 68:1","book":"Psa","chapter":68,"verse":1},{"label":"Ps 92:9","book":"Psa","chapter":92,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:11","parts":[{"kind":"text","text":"The heavens are yours; the earth also is yours."},{"kind":"text","text":" The world and everything in it —you founded them. "},{"kind":"crossref","label":"1Ch 29:11","book":"1Ch","chapter":29,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 24:1","book":"Psa","chapter":24,"verse":1,"letter":"b"}],"crossRefs":[{"label":"1Ch 29:11","book":"1Ch","chapter":29,"verse":11},{"label":"Ps 24:1","book":"Psa","chapter":24,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:12","parts":[{"kind":"text","text":"North and south —you created them. "},{"kind":"crossref","label":"Jb 26:7","book":"Job","chapter":26,"verse":7,"letter":"a"},{"kind":"text","text":" Tabor and Hermon shout for joy at your name. "},{"kind":"crossref","label":"Ps 133:3","book":"Psa","chapter":133,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 46:18","book":"Jer","chapter":46,"verse":18,"letter":"b"}],"crossRefs":[{"label":"Jb 26:7","book":"Job","chapter":26,"verse":7},{"label":"Ps 133:3","book":"Psa","chapter":133,"verse":3},{"label":"Jr 46:18","book":"Jer","chapter":46,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:13","parts":[{"kind":"text","text":"You have a mighty arm;"},{"kind":"text","text":" your hand is powerful;"},{"kind":"text","text":" your right hand is lifted high. "},{"kind":"crossref","label":"Ps 98:1","book":"Psa","chapter":98,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 118:16","book":"Psa","chapter":118,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Ps 98:1","book":"Psa","chapter":98,"verse":1},{"label":"Ps 118:16","book":"Psa","chapter":118,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:14","parts":[{"kind":"text","text":"Righteousness and justice are the foundation"},{"kind":"text","text":" of your throne; "},{"kind":"crossref","label":"Ps 97:2","book":"Psa","chapter":97,"verse":2,"letter":"a"},{"kind":"text","text":" faithful love and truth go before you. "},{"kind":"crossref","label":"Ps 85:13","book":"Psa","chapter":85,"verse":13,"letter":"a"}],"crossRefs":[{"label":"Ps 97:2","book":"Psa","chapter":97,"verse":2},{"label":"Ps 85:13","book":"Psa","chapter":85,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:15","parts":[{"kind":"text","text":"Happy are the people who know the joyful shout; "},{"kind":"crossref","label":"Ps 98:6","book":"Psa","chapter":98,"verse":6,"letter":"a"},{"kind":"text","text":" Lord","style":"divine"},{"kind":"text","text":", they walk in the light from your face. "},{"kind":"crossref","label":"Nm 6:25","book":"Num","chapter":6,"verse":25,"letter":"a"},{"kind":"crossref","label":"Ps 56:13","book":"Psa","chapter":56,"verse":13,"letter":"b"},{"kind":"crossref","label":"1Jn 1:7","book":"1Jn","chapter":1,"verse":7,"letter":"c"}],"crossRefs":[{"label":"Ps 98:6","book":"Psa","chapter":98,"verse":6},{"label":"Nm 6:25","book":"Num","chapter":6,"verse":25},{"label":"Ps 56:13","book":"Psa","chapter":56,"verse":13},{"label":"1Jn 1:7","book":"1Jn","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:16","parts":[{"kind":"text","text":"They rejoice in your name all day long,"},{"kind":"text","text":" and they are exalted by your righteousness. "},{"kind":"crossref","label":"Ps 20:5","book":"Psa","chapter":20,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 105:3","book":"Psa","chapter":105,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Ps 20:5","book":"Psa","chapter":20,"verse":5},{"label":"Ps 105:3","book":"Psa","chapter":105,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:17","parts":[{"kind":"text","text":"For you are their magnificent strength; "},{"kind":"crossref","label":"Ps 28:8","book":"Psa","chapter":28,"verse":8,"letter":"a"},{"kind":"text","text":" by your favor our horn is exalted. "},{"kind":"crossref","label":"Ps 148:14","book":"Psa","chapter":148,"verse":14,"letter":"a"}],"crossRefs":[{"label":"Ps 28:8","book":"Psa","chapter":28,"verse":8},{"label":"Ps 148:14","book":"Psa","chapter":148,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:18","parts":[{"kind":"text","text":"Surely our shield "},{"kind":"footnote","marker":1,"text":"= the king"},{"kind":"text","text":" belongs to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" our king to the Holy One of Israel. "},{"kind":"crossref","label":"Ps 84:9","book":"Psa","chapter":84,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Ps 84:9","book":"Psa","chapter":84,"verse":9}],"footnotes":[{"marker":1,"text":"= the king"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:19","parts":[{"kind":"text","text":"You once spoke in a vision to your faithful ones"},{"kind":"text","text":" and said, “I have granted help to a warrior;"},{"kind":"text","text":" I have exalted one chosen "},{"kind":"footnote","marker":1,"text":"Or exalted a young man"},{"kind":"text","text":" from the people. "},{"kind":"crossref","label":"2Sm 17:10","book":"2Sa","chapter":17,"verse":10,"letter":"a"},{"kind":"crossref","label":"1Kg 11:34","book":"1Ki","chapter":11,"verse":34,"letter":"b"},{"kind":"crossref","label":"Ps 78:70","book":"Psa","chapter":78,"verse":70,"letter":"c"}],"crossRefs":[{"label":"2Sm 17:10","book":"2Sa","chapter":17,"verse":10},{"label":"1Kg 11:34","book":"1Ki","chapter":11,"verse":34},{"label":"Ps 78:70","book":"Psa","chapter":78,"verse":70}],"footnotes":[{"marker":1,"text":"Or exalted a young man"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:20","parts":[{"kind":"text","text":"I have found David my servant;"},{"kind":"text","text":" I have anointed him with my sacred oil. "},{"kind":"crossref","label":"1Sm 16:13","book":"1Sa","chapter":16,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 47:9","book":"Psa","chapter":47,"verse":9,"letter":"b"},{"kind":"crossref","label":"Ac 13:22","book":"Act","chapter":13,"verse":22,"letter":"c"}],"crossRefs":[{"label":"1Sm 16:13","book":"1Sa","chapter":16,"verse":13},{"label":"Ps 47:9","book":"Psa","chapter":47,"verse":9},{"label":"Ac 13:22","book":"Act","chapter":13,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:21","parts":[{"kind":"text","text":"My hand will always be with him,"},{"kind":"text","text":" and my arm will strengthen him. "},{"kind":"crossref","label":"Ps 18:35","book":"Psa","chapter":18,"verse":35,"letter":"a"},{"kind":"crossref","label":"Ps 80:17","book":"Psa","chapter":80,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Ps 18:35","book":"Psa","chapter":18,"verse":35},{"label":"Ps 80:17","book":"Psa","chapter":80,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:22","parts":[{"kind":"text","text":"The enemy will not oppress "},{"kind":"footnote","marker":1,"text":"Or not exact tribute from"},{"kind":"text","text":" him;"},{"kind":"text","text":" the wicked will not afflict him. "},{"kind":"crossref","label":"2Sm 7:10","book":"2Sa","chapter":7,"verse":10,"letter":"a"}],"crossRefs":[{"label":"2Sm 7:10","book":"2Sa","chapter":7,"verse":10}],"footnotes":[{"marker":1,"text":"Or not exact tribute from"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:23","parts":[{"kind":"text","text":"I will crush his foes before him"},{"kind":"text","text":" and strike those who hate him. "},{"kind":"crossref","label":"2Sm 7:9","book":"2Sa","chapter":7,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 2:9","book":"Psa","chapter":2,"verse":9,"letter":"b"}],"crossRefs":[{"label":"2Sm 7:9","book":"2Sa","chapter":7,"verse":9},{"label":"Ps 2:9","book":"Psa","chapter":2,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:24","parts":[{"kind":"text","text":"My faithfulness and love will be with him,"},{"kind":"text","text":" and through my name"},{"kind":"text","text":" his horn will be exalted. "},{"kind":"crossref","label":"Ps 21:7","book":"Psa","chapter":21,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ps 132:17","book":"Psa","chapter":132,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Ps 21:7","book":"Psa","chapter":21,"verse":7},{"label":"Ps 132:17","book":"Psa","chapter":132,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:25","parts":[{"kind":"text","text":"I will extend his power to the sea"},{"kind":"text","text":" and his right hand to the rivers. "},{"kind":"crossref","label":"Ps 72:8","book":"Psa","chapter":72,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Ps 72:8","book":"Psa","chapter":72,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:26","parts":[{"kind":"text","text":"He will call to me, ‘You are my Father, "},{"kind":"crossref","label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14,"letter":"a"},{"kind":"crossref","label":"1Ch 22:10","book":"1Ch","chapter":22,"verse":10,"letter":"b"},{"kind":"text","text":" my God, the rock of my salvation.’ "},{"kind":"crossref","label":"2Sm 22:47","book":"2Sa","chapter":22,"verse":47,"letter":"a"},{"kind":"crossref","label":"Ps 18:2","book":"Psa","chapter":18,"verse":2,"letter":"b"}],"crossRefs":[{"label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14},{"label":"1Ch 22:10","book":"1Ch","chapter":22,"verse":10},{"label":"2Sm 22:47","book":"2Sa","chapter":22,"verse":47},{"label":"Ps 18:2","book":"Psa","chapter":18,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:27","parts":[{"kind":"text","text":"I will also make him my firstborn,"},{"kind":"text","text":" greatest of the kings of the earth. "},{"kind":"crossref","label":"Ex 4:22","book":"Exo","chapter":4,"verse":22,"letter":"a"},{"kind":"crossref","label":"Jr 31:9","book":"Jer","chapter":31,"verse":9,"letter":"b"},{"kind":"crossref","label":"Col 1:15","book":"Col","chapter":1,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Ex 4:22","book":"Exo","chapter":4,"verse":22},{"label":"Jr 31:9","book":"Jer","chapter":31,"verse":9},{"label":"Col 1:15","book":"Col","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:28","parts":[{"kind":"text","text":"I will always preserve my faithful love for him,"},{"kind":"text","text":" and my covenant with him will endure. "},{"kind":"crossref","label":"2Ch 13:5","book":"2Ch","chapter":13,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 105:8","book":"Psa","chapter":105,"verse":8,"letter":"b"}],"crossRefs":[{"label":"2Ch 13:5","book":"2Ch","chapter":13,"verse":5},{"label":"Ps 105:8","book":"Psa","chapter":105,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:29","parts":[{"kind":"text","text":"I will establish his line forever,"},{"kind":"text","text":" his throne as long as heaven lasts. "},{"kind":"footnote","marker":1,"text":"Lit as days of heaven"},{"kind":"crossref","label":"Is 9:7","book":"Isa","chapter":9,"verse":7,"letter":"a"},{"kind":"crossref","label":"Jr 33:17","book":"Jer","chapter":33,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Is 9:7","book":"Isa","chapter":9,"verse":7},{"label":"Jr 33:17","book":"Jer","chapter":33,"verse":17}],"footnotes":[{"marker":1,"text":"Lit as days of heaven"}]},{"verseId":"a556c5305ee15c3f-01:Psa:89:30","parts":[{"kind":"text","text":"If his sons abandon my instruction"},{"kind":"text","text":" and do not live by my ordinances, "},{"kind":"crossref","label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14,"letter":"a"},{"kind":"crossref","label":"1Kg 2:4","book":"1Ki","chapter":2,"verse":4,"letter":"b"}],"crossRefs":[{"label":"2Sm 7:14","book":"2Sa","chapter":7,"verse":14},{"label":"1Kg 2:4","book":"1Ki","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:31","parts":[{"kind":"text","text":"if they dishonor my statutes"},{"kind":"text","text":" and do not keep my commands, "},{"kind":"crossref","label":"1Sm 12:15","book":"1Sa","chapter":12,"verse":15,"letter":"a"}],"crossRefs":[{"label":"1Sm 12:15","book":"1Sa","chapter":12,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:32","parts":[{"kind":"text","text":"then I will call their rebellion"},{"kind":"text","text":" to account with the rod,"},{"kind":"text","text":" their iniquity with blows. "},{"kind":"crossref","label":"Jb 9:34","book":"Job","chapter":9,"verse":34,"letter":"a"}],"crossRefs":[{"label":"Jb 9:34","book":"Job","chapter":9,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:33","parts":[{"kind":"text","text":"But I will not withdraw"},{"kind":"text","text":" my faithful love from him"},{"kind":"text","text":" or betray my faithfulness. "},{"kind":"crossref","label":"2Sm 7:15","book":"2Sa","chapter":7,"verse":15,"letter":"a"}],"crossRefs":[{"label":"2Sm 7:15","book":"2Sa","chapter":7,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:34","parts":[{"kind":"text","text":"I will not violate my covenant"},{"kind":"text","text":" or change what my lips have said. "},{"kind":"crossref","label":"Lv 26:44","book":"Lev","chapter":26,"verse":44,"letter":"a"},{"kind":"crossref","label":"Jdg 2:1","book":"Jdg","chapter":2,"verse":1,"letter":"b"}],"crossRefs":[{"label":"Lv 26:44","book":"Lev","chapter":26,"verse":44},{"label":"Jdg 2:1","book":"Jdg","chapter":2,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:35","parts":[{"kind":"text","text":"Once and for all"},{"kind":"text","text":" I have sworn an oath by my holiness;"},{"kind":"text","text":" I will not lie to David. "},{"kind":"crossref","label":"Am 4:2","book":"Amo","chapter":4,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Am 4:2","book":"Amo","chapter":4,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:36","parts":[{"kind":"text","text":"His offspring will continue forever,"},{"kind":"text","text":" his throne like the sun before me, "},{"kind":"crossref","label":"Ps 72:5","book":"Psa","chapter":72,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 72:17","book":"Psa","chapter":72,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Ps 72:5","book":"Psa","chapter":72,"verse":5},{"label":"Ps 72:17","book":"Psa","chapter":72,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:37","parts":[{"kind":"text","text":"like the moon, established forever,"},{"kind":"text","text":" a faithful witness in the sky.” "},{"kind":"crossref","label":"Jb 16:19","book":"Job","chapter":16,"verse":19,"letter":"a"},{"kind":"crossref","label":"Lk 1:33","book":"Luk","chapter":1,"verse":33,"letter":"b"},{"kind":"text","text":" "},{"kind":"text","text":"Selah","style":"selah"}],"crossRefs":[{"label":"Jb 16:19","book":"Job","chapter":16,"verse":19},{"label":"Lk 1:33","book":"Luk","chapter":1,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:38","parts":[{"kind":"text","text":"But you have spurned and rejected him;"},{"kind":"text","text":" you have become enraged with your anointed. "},{"kind":"crossref","label":"1Ch 28:9","book":"1Ch","chapter":28,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 44:9","book":"Psa","chapter":44,"verse":9,"letter":"b"}],"crossRefs":[{"label":"1Ch 28:9","book":"1Ch","chapter":28,"verse":9},{"label":"Ps 44:9","book":"Psa","chapter":44,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:89:39","parts":[{"kind":"text","text":"You have repudiated the covenant with your servant;"},{"kind":"text","text":" you have completely dishonored his crown. "},{"kind":"footnote","marker":1,"text":"Lit have dishonored his crown to the ground"},{"kind":"crossref","label":"Ps 74:7","book":"Psa","chapter":74,"verse":7,"letter":"a"},{"kind":"crossref","label":"Lm 2:7","book":"Lam","chapter":2,"verse":7,"letter":"b"},{"kind":"crossref","label":"Lm 5:16","book":"Lam","chapter":5,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Ps 74:7","book":"Psa","chapter":74,"verse":7},{"label":"Lm 2:7","book":"Lam","chapter":2,"verse":7},{"label":"Lm 5:16","book":"Lam","chapter":5,"verse":16}],"footno