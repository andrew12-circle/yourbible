ervants,"},{"kind":"text","text":" and your splendor by their children. "},{"kind":"crossref","label":"Ps 96:6","book":"Psa","chapter":96,"verse":6,"letter":"a"},{"kind":"crossref","label":"Is 35:2","book":"Isa","chapter":35,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Ps 96:6","book":"Psa","chapter":96,"verse":6},{"label":"Is 35:2","book":"Isa","chapter":35,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:90:17","parts":[{"kind":"text","text":"Let the favor of the Lord our God be on us;"},{"kind":"text","text":" establish for us the work of our hands —"},{"kind":"text","text":" establish the work of our hands! "},{"kind":"crossref","label":"Ps 27:4","book":"Psa","chapter":27,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 26:12","book":"Isa","chapter":26,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Ps 27:4","book":"Psa","chapter":27,"verse":4},{"label":"Is 26:12","book":"Isa","chapter":26,"verse":12}],"footnotes":[]}]},"cachedAt":1783279505497}