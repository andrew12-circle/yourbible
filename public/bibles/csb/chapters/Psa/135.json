{"key":"a556c5305ee15c3f-01|Psa|135","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":135,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:135:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":1,"text":"Hallelujah! Praise the name of the Lord. Give praise, you servants of the Lord","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":2,"text":"who stand in the house of the Lord, in the courts of the house of our God.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":3,"text":"Praise the Lord, for the Lord is good; sing praise to his name, for it is delightful.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":4,"text":"For the Lord has chosen Jacob for himself, Israel as his treasured possession.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":5,"text":"For I know that the Lord is great; our Lord is greater than all gods.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":6,"text":"The Lord does whatever he pleases in heaven and on earth, in the seas and all the depths.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":7,"text":"He causes the clouds to rise from the ends of the earth. He makes lightning for the rain and brings the wind from his storehouses.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":8,"text":"He struck down the firstborn of Egypt, both people and animals.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":9,"text":"He sent signs and wonders against you, Egypt, against Pharaoh and all his officials.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":10,"text":"He struck down many nations and slaughtered mighty kings:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":11,"text":"Sihon king of the Amorites, Og king of Bashan, and all the kings of Canaan.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":12,"text":"He gave their land as an inheritance, an inheritance to his people Israel.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":13,"text":"Lord, your name endures forever, your reputation, Lord, through all generations.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":14,"text":"For the Lord will vindicate his people and have compassion on his servants.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:135:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":135,"verse":15,"text":"The idols of the nations are of silver and gold, made by human hands.","textR