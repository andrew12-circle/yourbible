eId":"a556c5305ee15c3f-01:Psa:73:18","parts":[{"kind":"text","text":"Indeed, you put them in slippery places;"},{"kind":"text","text":" you make them fall into ruin. "},{"kind":"crossref","label":"Ps 35:6","book":"Psa","chapter":35,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 35:8","book":"Psa","chapter":35,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Ps 35:6","book":"Psa","chapter":35,"verse":6},{"label":"Ps 35:8","book":"Psa","chapter":35,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:19","parts":[{"kind":"text","text":"How suddenly they become a desolation!"},{"kind":"text","text":" They come to an end, swept away by terrors. "},{"kind":"crossref","label":"Nm 16:21","book":"Num","chapter":16,"verse":21,"letter":"a"},{"kind":"crossref","label":"Jb 18:11","book":"Job","chapter":18,"verse":11,"letter":"b"},{"kind":"crossref","label":"Is 47:11","book":"Isa","chapter":47,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Nm 16:21","book":"Num","chapter":16,"verse":21},{"label":"Jb 18:11","book":"Job","chapter":18,"verse":11},{"label":"Is 47:11","book":"Isa","chapter":47,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:20","parts":[{"kind":"text","text":"Like one waking from a dream,"},{"kind":"text","text":" Lord, when arising, you will despise their image. "},{"kind":"crossref","label":"Ps 35:23","book":"Psa","chapter":35,"verse":23,"letter":"a"},{"kind":"crossref","label":"Ps 59:5","book":"Psa","chapter":59,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 78:65","book":"Psa","chapter":78,"verse":65,"letter":"c"}],"crossRefs":[{"label":"Ps 35:23","book":"Psa","chapter":35,"verse":23},{"label":"Ps 59:5","book":"Psa","chapter":59,"verse":5},{"label":"Ps 78:65","book":"Psa","chapter":78,"verse":65}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:21","parts":[{"kind":"text","text":"When I became embittered"},{"kind":"text","text":" and my innermost being "},{"kind":"footnote","marker":1,"text":"Lit my kidneys"},{"kind":"text","text":" was wounded, "},{"kind":"crossref","label":"Ps 109:22","book":"Psa","chapter":109,"verse":22,"letter":"a"}],"crossRefs":[{"label":"Ps 109:22","book":"Psa","chapter":109,"verse":22}],"footnotes":[{"marker":1,"text":"Lit my kidneys"}]},{"verseId":"a556c5305ee15c3f-01:Psa:73:22","parts":[{"kind":"text","text":"I was stupid and didn’t understand;"},{"kind":"text","text":" I was an unthinking animal toward you. "},{"kind":"crossref","label":"Jb 11:12","book":"Job","chapter":11,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ps 92:6","book":"Psa","chapter":92,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Jb 11:12","book":"Job","chapter":11,"verse":12},{"label":"Ps 92:6","book":"Psa","chapter":92,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:23","parts":[{"kind":"text","text":"Yet I am always with you;"},{"kind":"text","text":" you hold my right hand. "},{"kind":"crossref","label":"Ps 63:8","book":"Psa","chapter":63,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Ps 63:8","book":"Psa","chapter":63,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:24","parts":[{"kind":"text","text":"You guide me with your counsel,"},{"kind":"text","text":" and afterward you will take me up in glory. "},{"kind":"footnote","marker":1,"text":"Or will receive me with honor"},{"kind":"crossref","label":"Ps 49:15","book":"Psa","chapter":49,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 58:11","book":"Isa","chapter":58,"verse":11,"letter":"b"}],"crossRefs":[{"label":"Ps 49:15","book":"Psa","chapter":49,"verse":15},{"label":"Is 58:11","book":"Isa","chapter":58,"verse":11}],"footnotes":[{"marker":1,"text":"Or will receive me with honor"}]},{"verseId":"a556c5305ee15c3f-01:Psa:73:25","parts":[{"kind":"text","text":"Who do I have in heaven but you?"},{"kind":"text","text":" And I desire nothing on earth but you. "},{"kind":"crossref","label":"Ps 16:2","book":"Psa","chapter":16,"verse":2,"letter":"a"},{"kind":"crossref","label":"Php 3:8","book":"Php","chapter":3,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Ps 16:2","book":"Psa","chapter":16,"verse":2},{"label":"Php 3:8","book":"Php","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:26","parts":[{"kind":"text","text":"My flesh and my heart may fail,"},{"kind":"text","text":" but God is the strength "},{"kind":"footnote","marker":1,"text":"Lit rock"},{"kind":"text","text":" of my heart,"},{"kind":"text","text":" my portion forever. "},{"kind":"crossref","label":"Ps 16:5","book":"Psa","chapter":16,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 38:10","book":"Psa","chapter":38,"verse":10,"letter":"b"},{"kind":"crossref","label":"Ps 84:2","book":"Psa","chapter":84,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Ps 16:5","book":"Psa","chapter":16,"verse":5},{"label":"Ps 38:10","book":"Psa","chapter":38,"verse":10},{"label":"Ps 84:2","book":"Psa","chapter":84,"verse":2}],"footnotes":[{"marker":1,"text":"Lit rock"}]},{"verseId":"a556c5305ee15c3f-01:Psa:73:27","parts":[{"kind":"text","text":"Those far from you will certainly perish;"},{"kind":"text","text":" you destroy all who are unfaithful to you. "},{"kind":"crossref","label":"1Ch 5:25","book":"1Ch","chapter":5,"verse":25,"letter":"a"},{"kind":"crossref","label":"Ps 37:20","book":"Psa","chapter":37,"verse":20,"letter":"b"}],"crossRefs":[{"label":"1Ch 5:25","book":"1Ch","chapter":5,"verse":25},{"label":"Ps 37:20","book":"Psa","chapter":37,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:73:28","parts":[{"kind":"text","text":"But as for me, God’s presence is my good."},{"kind":"text","text":" I have made the Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" my refuge,"},{"kind":"text","text":" so I can tell about all you do. "},{"kind":"crossref","label":"Ps 40:5","book":"Psa","chapter":40,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 118:17","book":"Psa","chapter":118,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Ps 40:5","book":"Psa","chapter":40,"verse":5},{"label":"Ps 118:17","book":"Psa","chapter":118,"verse":17}],"footnotes":[]}]},"cachedAt":1783279500361}