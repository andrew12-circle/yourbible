erstand?"},{"kind":"text","text":" They consume my people as they consume bread; "},{"kind":"crossref","label":"Ps 27:2","book":"Psa","chapter":27,"verse":2,"letter":"a"},{"kind":"crossref","label":"Mc 3:3","book":"Mic","chapter":3,"verse":3,"letter":"b"},{"kind":"text","text":" they do not call on God. "},{"kind":"crossref","label":"Is 64:7","book":"Isa","chapter":64,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 27:2","book":"Psa","chapter":27,"verse":2},{"label":"Mc 3:3","book":"Mic","chapter":3,"verse":3},{"label":"Is 64:7","book":"Isa","chapter":64,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:53:5","parts":[{"kind":"text","text":"Then they will be filled with dread —"},{"kind":"text","text":" dread like no other "},{"kind":"crossref","label":"Lv 26:36","book":"Lev","chapter":26,"verse":36,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" because God will scatter"},{"kind":"text","text":" the bones of those who besiege you. "},{"kind":"crossref","label":"Jr 8:1–2","book":"Jer","chapter":8,"verse":1,"letter":"a"},{"kind":"text","text":" You will put them to shame,"},{"kind":"text","text":" for God has rejected them. "},{"kind":"crossref","label":"Ps 44:7","book":"Psa","chapter":44,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Lv 26:36","book":"Lev","chapter":26,"verse":36},{"label":"Jr 8:1–2","book":"Jer","chapter":8,"verse":1},{"label":"Ps 44:7","book":"Psa","chapter":44,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:53:6","parts":[{"kind":"text","text":"Oh, that Israel’s deliverance would come from Zion!"},{"kind":"text","text":" When God restores the fortunes of his people, "},{"kind":"footnote","marker":1,"text":"Or restores his captive people"},{"kind":"text","text":" let Jacob rejoice, let Israel be glad. "},{"kind":"crossref","label":"Ps 14:7","book":"Psa","chapter":14,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 52:7–9","book":"Isa","chapter":52,"verse":7,"letter":"b"},{"kind":"crossref",