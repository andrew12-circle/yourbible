{"key":"a556c5305ee15c3f-01|Psa|127","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":127,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:127:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":127,"verse":1,"text":"Unless the Lord builds a house, its builders labor over it in vain; unless the Lord watches over a city, the watchman stays alert in vain.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:127:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":127,"verse":2,"text":"In vain you get up early and stay up late, working hard to have enough food — yes, he gives sleep to the one he loves.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:127:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":127,"verse":3,"text":"Sons are indeed a heritage from the Lord, offspring, a reward.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:127:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":127,"verse":4,"text":"Like arrows in the hand of a warrior are the sons born in one’s youth.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:127:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":127,"verse":5,"text":"Happy is the man who has filled his quiver with them. They will never be put to shame when they speak with their enemies at the city gate.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":127,"paragraphStarts":[1,2,3,4,5],"headings":[{"beforeVerse":1,"text":"A song of ascents. Of Solomon."}],"poetryBlocks":[{"beforeVerse":1,"level":1},{"beforeVerse":2,"level":1},{"beforeVerse":3,"level":1},{"beforeVerse":4,"level":1},{"beforeVerse":5,"level":1}],"studyByVerse":[{"verseId":"a556c5305ee15c3f-01:Psa:127:1","parts":[{"kind":"text",