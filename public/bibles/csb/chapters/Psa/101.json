{"key":"a556c5305ee15c3f-01|Psa|101","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":101,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:101:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":1,"text":"I will sing of faithful love and justice; I will sing praise to you, Lord.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":2,"text":"I will pay attention to the way of integrity. When will you come to me? I will live with a heart of integrity in my house.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":3,"text":"I will not let anything worthless guide me. I hate the practice of transgression; it will not cling to me.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":4,"text":"A devious heart will be far from me; I will not be involved with evil.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":5,"text":"I will destroy anyone who secretly slanders his neighbor; I cannot tolerate anyone with haughty eyes or an arrogant heart.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":6,"text":"My eyes favor the faithful of the land so that they may sit down with me. The one who follows the way of integrity may serve me.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:101:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":101,"verse":7,"text":"No