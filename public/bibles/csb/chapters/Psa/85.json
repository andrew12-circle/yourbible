{"key":"a556c5305ee15c3f-01|Psa|85","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":85,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:85:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":1,"text":"Lord, you showed favor to your land; you restored the fortunes of Jacob.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":2,"text":"You forgave your people’s guilt; you covered all their sin. Selah","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":3,"text":"You withdrew all your fury; you turned from your burning anger.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":4,"text":"Return to us, God of our salvation, and abandon your displeasure with us.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":5,"text":"Will you be angry with us forever? Will you prolong your anger for all generations?","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":6,"text":"Will you not revive us again so that your people may rejoice in you?","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":85,"verse":7,"text":"Show us your faithful love, Lord, and give us your salvation.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:85:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":