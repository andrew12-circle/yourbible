:14","parts":[{"kind":"text","text":"He causes grass to grow for the livestock"},{"kind":"text","text":" and provides crops for man to cultivate,"},{"kind":"text","text":" producing food from the earth, "},{"kind":"crossref","label":"Jb 28:5","book":"Job","chapter":28,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 147:8","book":"Psa","chapter":147,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Jb 28:5","book":"Job","chapter":28,"verse":5},{"label":"Ps 147:8","book":"Psa","chapter":147,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:15","parts":[{"kind":"text","text":"wine that makes human hearts glad —"},{"kind":"text","text":" making his face shine with oil —"},{"kind":"text","text":" and bread that sustains human hearts. "},{"kind":"crossref","label":"Gn 18:5","book":"Gen","chapter":18,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 141:5","book":"Psa","chapter":141,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Gn 18:5","book":"Gen","chapter":18,"verse":5},{"label":"Ps 141:5","book":"Psa","chapter":141,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:16","parts":[{"kind":"text","text":"The trees of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" flourish, "},{"kind":"footnote","marker":1,"text":"Lit are satisfied"},{"kind":"text","text":" the cedars of Lebanon that he planted. "},{"kind":"crossref","label":"Nm 24:6","book":"Num","chapter":24,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Nm 24:6","book":"Num","chapter":24,"verse":6}],"footnotes":[{"marker":1,"text":"Lit are satisfied"}]},{"verseId":"a556c5305ee15c3f-01:Psa:104:17","parts":[{"kind":"text","text":"There the birds make their nests;"},{"kind":"text","text":" storks make their homes in the pine trees. "},{"kind":"crossref","label":"Lv 11:19","book":"Lev","chapter":11,"verse":19,"letter":"a"}],"crossRefs":[{"label":"Lv 11:19","book":"Lev","chapter":11,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:18","parts":[{"kind":"text","text":"The high mountains are for the wild goats;"},{"kind":"text","text":" the cliffs are a refuge for hyraxes. "},{"kind":"crossref","label":"Lv 11:5","book":"Lev","chapter":11,"verse":5,"letter":"a"},{"kind":"crossref","label":"Pr 30:26","book":"Pro","chapter":30,"verse":26,"letter":"b"}],"crossRefs":[{"label":"Lv 11:5","book":"Lev","chapter":11,"verse":5},{"label":"Pr 30:26","book":"Pro","chapter":30,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:19","parts":[{"kind":"text","text":"He made the moon to mark the "},{"kind":"footnote","marker":1,"text":"Lit moon for"},{"kind":"text","text":" festivals; "},{"kind":"footnote","marker":2,"text":"Or the appointed times"},{"kind":"text","text":" the sun knows when to set. "},{"kind":"crossref","label":"Gn 1:14","book":"Gen","chapter":1,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ps 19:6","book":"Psa","chapter":19,"verse":6,"letter":"b"},{"kind":"crossref","label":"Ps 74:16","book":"Psa","chapter":74,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Gn 1:14","book":"Gen","chapter":1,"verse":14},{"label":"Ps 19:6","book":"Psa","chapter":19,"verse":6},{"label":"Ps 74:16","book":"Psa","chapter":74,"verse":16}],"footnotes":[{"marker":1,"text":"Lit moon for"},{"marker":2,"text":"Or the appointed times"}]},{"verseId":"a556c5305ee15c3f-01:Psa:104:20","parts":[{"kind":"text","text":"You bring darkness, and it becomes night,"},{"kind":"text","text":" when all the forest animals stir. "},{"kind":"crossref","label":"Is 45:17","book":"Isa","chapter":45,"verse":17,"letter":"a"}],"crossRefs":[{"label":"Is 45:17","book":"Isa","chapter":45,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:21","parts":[{"kind":"text","text":"The young lions roar for their prey"},{"kind":"text","text":" and seek their food from God. "},{"kind":"crossref","label":"Jb 38:39","book":"Job","chapter":38,"verse":39,"letter":"a"}],"crossRefs":[{"label":"Jb 38:39","book":"Job","chapter":38,"verse":39}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:22","parts":[{"kind":"text","text":"The sun rises; they go back"},{"kind":"text","text":" and lie down in their dens. "},{"kind":"crossref","label":"Jb 37:8","book":"Job","chapter":37,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Jb 37:8","book":"Job","chapter":37,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:23","parts":[{"kind":"text","text":"Man goes out to his work"},{"kind":"text","text":" and to his labor until evening. "},{"kind":"crossref","label":"Gn 3:19","book":"Gen","chapter":3,"verse":19,"letter":"a"}],"crossRefs":[{"label":"Gn 3:19","book":"Gen","chapter":3,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:24","parts":[{"kind":"text","text":"How countless are your works, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"!"},{"kind":"text","text":" In wisdom you have made them all;"},{"kind":"text","text":" the earth is full of your creatures. "},{"kind":"footnote","marker":1,"text":"Lit possessions"},{"kind":"crossref","label":"Pr 3:19","book":"Pro","chapter":3,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jr 10:12","book":"Jer","chapter":10,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jr 51:15","book":"Jer","chapter":51,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Pr 3:19","book":"Pro","chapter":3,"verse":19},{"label":"Jr 10:12","book":"Jer","chapter":10,"verse":12},{"label":"Jr 51:15","book":"Jer","chapter":51,"verse":15}],"footnotes":[{"marker":1,"text":"Lit possessions"}]},{"verseId":"a556c5305ee15c3f-01:Psa:104:25","parts":[{"kind":"text","text":"Here is the sea, vast and wide,"},{"kind":"text","text":" teeming with creatures beyond number —"},{"kind":"text","text":" living things both large and small. "},{"kind":"crossref","label":"Gn 1:21","book":"Gen","chapter":1,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 69:34","book":"Psa","chapter":69,"verse":34,"letter":"b"}],"crossRefs":[{"label":"Gn 1:21","book":"Gen","chapter":1,"verse":21},{"label":"Ps 69:34","book":"Psa","chapter":69,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:26","parts":[{"kind":"text","text":"There the ships move about,"},{"kind":"text","text":" and Leviathan, which you formed to play there. "},{"kind":"crossref","label":"Jb 41:1","book":"Job","chapter":41,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 74:14","book":"Psa","chapter":74,"verse":14,"letter":"b"},{"kind":"crossref","label":"Is 27:1","book":"Isa","chapter":27,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Jb 41:1","book":"Job","chapter":41,"verse":1},{"label":"Ps 74:14","book":"Psa","chapter":74,"verse":14},{"label":"Is 27:1","book":"Isa","chapter":27,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:27","parts":[{"kind":"text","text":"All of them wait for you"},{"kind":"text","text":" to give them their food at the right time. "},{"kind":"crossref","label":"Gn 1:30","book":"Gen","chapter":1,"verse":30,"letter":"a"},{"kind":"crossref","label":"Ps 136:25","book":"Psa","chapter":136,"verse":25,"letter":"b"},{"kind":"crossref","label":"Ps 145:15","book":"Psa","chapter":145,"verse":15,"letter":"c"},{"kind":"crossref","label":"Ps 147:9","book":"Psa","chapter":147,"verse":9,"letter":"d"}],"crossRefs":[{"label":"Gn 1:30","book":"Gen","chapter":1,"verse":30},{"label":"Ps 136:25","book":"Psa","chapter":136,"verse":25},{"label":"Ps 145:15","book":"Psa","chapter":145,"verse":15},{"label":"Ps 147:9","book":"Psa","chapter":147,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:28","parts":[{"kind":"text","text":"When you give it to them,"},{"kind":"text","text":" they gather it;"},{"kind":"text","text":" when you open your hand,"},{"kind":"text","text":" they are satisfied with good things. "},{"kind":"crossref","label":"Ps 145:16","book":"Psa","chapter":145,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Ps 145:16","book":"Psa","chapter":145,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:29","parts":[{"kind":"text","text":"When you hide your face,"},{"kind":"text","text":" they are terrified;"},{"kind":"text","text":" when you take away their breath,"},{"kind":"text","text":" they die and return to the dust. "},{"kind":"crossref","label":"Jb 10:9","book":"Job","chapter":10,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 90:3","book":"Psa","chapter":90,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Jb 10:9","book":"Job","chapter":10,"verse":9},{"label":"Ps 90:3","book":"Psa","chapter":90,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:30","parts":[{"kind":"text","text":"When you send your breath, "},{"kind":"footnote","marker":1,"text":"Or Spirit"},{"kind":"text","text":" they are created, "},{"kind":"crossref","label":"Gn 2:7","book":"Gen","chapter":2,"verse":7,"letter":"a"},{"kind":"text","text":" and you renew the surface of the ground. "},{"kind":"crossref","label":"Jb 33:4","book":"Job","chapter":33,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Gn 2:7","book":"Gen","chapter":2,"verse":7},{"label":"Jb 33:4","book":"Job","chapter":33,"verse":4}],"footnotes":[{"marker":1,"text":"Or Spirit"}]},{"verseId":"a556c5305ee15c3f-01:Psa:104:31","parts":[{"kind":"text","text":"May the glory of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" endure forever;"},{"kind":"text","text":" may the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" rejoice in his works. "},{"kind":"crossref","label":"Ps 72:17","book":"Psa","chapter":72,"verse":17,"letter":"a"}],"crossRefs":[{"label":"Ps 72:17","book":"Psa","chapter":72,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:32","parts":[{"kind":"text","text":"He looks at the earth, and it trembles;"},{"kind":"text","text":" he touches the mountains,"},{"kind":"text","text":" and they pour out smoke. "},{"kind":"crossref","label":"Ex 19:18","book":"Exo","chapter":19,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ps 144:5","book":"Psa","chapter":144,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ex 19:18","book":"Exo","chapter":19,"verse":18},{"label":"Ps 144:5","book":"Psa","chapter":144,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:33","parts":[{"kind":"text","text":"I will sing to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" all my life;"},{"kind":"text","text":" I will sing praise to my God while I live. "},{"kind":"crossref","label":"Ps 63:4","book":"Psa","chapter":63,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 146:2","book":"Psa","chapter":146,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Ps 63:4","book":"Psa","chapter":63,"verse":4},{"label":"Ps 146:2","book":"Psa","chapter":146,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:34","parts":[{"kind":"text","text":"May my meditation be pleasing to him;"},{"kind":"text","text":" I will rejoice in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Ps 19:14","book":"Psa","chapter":19,"verse":14,"letter":"a"}],"crossRefs":[{"label":"Ps 19:14","book":"Psa","chapter":19,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:104:35","parts":[{"kind":"text","text":"May sinners vanish from the earth"},{"kind":"text","text":" and wicked people be no more. "},{"kind":"crossref","label":"Ps 37:10","book":"Psa","chapter":37,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ps 59:13","book":"Psa","chapter":59,"verse":13,"letter":"b"},{"kind":"text","text":" My soul, bless the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"!"},{"kind":"text","text":" Hallelujah!"}],"crossRefs":[{"label":"Ps 37:10","book":"Psa","chapter":37,"verse":10},{"label":"Ps 59:13","book":"Psa","chapter":59,"verse":13}],"footnotes":[]}]},"cachedAt":1783279509540}