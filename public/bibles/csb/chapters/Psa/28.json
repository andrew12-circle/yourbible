{"key":"a556c5305ee15c3f-01|Psa|28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":28,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:28:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":1,"text":"Lord, I call to you; my rock, do not be deaf to me. If you remain silent to me, I will be like those going down to the Pit.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":2,"text":"Listen to the sound of my pleading when I cry to you for help, when I lift up my hands toward your holy sanctuary.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":3,"text":"Do not drag me away with the wicked, with the evildoers, who speak in friendly ways with their neighbors while malice is in their hearts.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":4,"text":"Repay them according to what they have done — according to the evil of their deeds. Repay them according to the work of their hands; give them back what they deserve.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":5,"text":"Because they do not consider what the Lord has done or the work of his hands, he will tear them down and not rebuild them.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":6,"text":"Blessed be the Lord, for he has heard the sound of my pleading.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":7,"text":"The Lord is my strength and my shield; my heart trusts in him, and I am helped. Therefore my heart celebrates, and I give thanks to him with my song.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":8,"text":"The Lord is the strength of his people; he is a stronghold of salvation for his anointed.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:28:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":28,"verse":9,"text":"Save your people, bless your possession, shepherd them, and carry them forever.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":28,"paragraphStarts":[1,2,3,4,5,6,7,8,9],"headings":[{"beforeVerse":1,"text":"Of David."}],"poetryBlocks":[{"beforeVerse":1,"level":1},{"beforeVerse":2,"level":1},{"beforeVerse":3,"level":1},{"beforeVerse":4,"level":1},{"beforeVerse":5,"level":1},{"beforeVerse":6,"level":1},{"beforeVerse":7,"level":1},{"beforeVerse":8,"level":1},{"beforeVerse":9,"level":1}],"studyByVerse":[{"verseId":"a556c5305ee15c3f-01:Psa:28:1","parts":[{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", I call to you;"},{"kind":"text","text":" my rock, do not be deaf to me. "},{"kind":"crossref","label":"Ps 83:1","book":"Psa","chapter":83,"verse":1,"letter":"a"},{"kind":"text","text":" If you remain silent to me,"},{"kind":"text","text":" I will be like those going down to the Pit. "},{"kind":"crossref","label":"Ps 88:4","book":"Psa","chapter":88,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 143:7","book":"Psa","chapter":143,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Ps 83:1","book":"Psa","chapter":83,"verse":1},{"label":"Ps 88:4","book":"Psa","chapter":88,"verse":4},{"label":"Ps 143:7","book":"Psa","chapter":143,"v