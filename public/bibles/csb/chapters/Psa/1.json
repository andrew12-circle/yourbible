{"key":"a556c5305ee15c3f-01|Psa|1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":1,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:1:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":1,"text":"How happy is the one who does not walk in the advice of the wicked or stand in the pathway with sinners or sit in the company of mockers!","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:1:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":2,"text":"Instead, his delight is in the Lord’s instruction, and he meditates on it day and night.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:1:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":3,"text":"He is like a tree planted beside flowing streams that bears its fruit in its season, and its leaf does not wither. Whatever he does prospers.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:1:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":4,"text":"The wicked are not like this; instead, they are like chaff that the wind blows away.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:1:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":5,"text":"Therefore the wicked will not stand up in the judgment, nor sinners in the assembly of the righteous.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:1:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":1,"verse":6,"text":"For the Lord watches over the way of the righteous, but the way of the wicked leads to ruin.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":1,"paragraphStarts":[1,2,3,4,5,6],"headings":[{"beforeVerse":1,"text":"The Two