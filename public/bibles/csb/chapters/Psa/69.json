ootnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:12","parts":[{"kind":"text","text":"Those who sit at the city gate talk about me,"},{"kind":"text","text":" and drunkards make up songs about me. "},{"kind":"crossref","label":"Jb 17:6","book":"Job","chapter":17,"verse":6,"letter":"a"},{"kind":"crossref","label":"Jb 30:9","book":"Job","chapter":30,"verse":9,"letter":"b"},{"kind":"crossref","label":"Ps 44:14","book":"Psa","chapter":44,"verse":14,"letter":"c"},{"kind":"crossref","label":"Jr 24:9","book":"Jer","chapter":24,"verse":9,"letter":"d"}],"crossRefs":[{"label":"Jb 17:6","book":"Job","chapter":17,"verse":6},{"label":"Jb 30:9","book":"Job","chapter":30,"verse":9},{"label":"Ps 44:14","book":"Psa","chapter":44,"verse":14},{"label":"Jr 24:9","book":"Jer","chapter":24,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:13","parts":[{"kind":"text","text":"But as for me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" my prayer to you is for a time of favor."},{"kind":"text","text":" In your abundant, faithful love, God,"},{"kind":"text","text":" answer me with your sure salvation. "},{"kind":"crossref","label":"Ps 109:4","book":"Psa","chapter":109,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 49:8","book":"Isa","chapter":49,"verse":8,"letter":"b"},{"kind":"crossref","label":"2Co 6:2","book":"2Co","chapter":6,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Ps 109:4","book":"Psa","chapter":109,"verse":4},{"label":"Is 49:8","book":"Isa","chapter":49,"verse":8},{"label":"2Co 6:2","book":"2Co","chapter":6,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:14","parts":[{"kind":"text","text":"Rescue me from the miry mud; don’t let me sink."},{"kind":"text","text":" Let me be rescued from those who hate me"},{"kind":"text","text":" and from the deep water. "},{"kind":"crossref","label":"Ps 144:7","book":"Psa","chapter":144,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 144:7","book":"Psa","chapter":144,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:15","parts":[{"kind":"text","text":"Don’t let the floodwaters sweep over me"},{"kind":"text","text":" or the deep swallow me up;"},{"kind":"text","text":" don’t let the Pit close its mouth over me. "},{"kind":"crossref","label":"Nm 16:33","book":"Num","chapter":16,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ps 55:23","book":"Psa","chapter":55,"verse":23,"letter":"b"}],"crossRefs":[{"label":"Nm 16:33","book":"Num","chapter":16,"verse":33},{"label":"Ps 55:23","book":"Psa","chapter":55,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:16","parts":[{"kind":"text","text":"Answer me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" for your faithful love is good."},{"kind":"text","text":" In keeping with your abundant compassion,"},{"kind":"text","text":" turn to me. "},{"kind":"crossref","label":"Ps 25:16","book":"Psa","chapter":25,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ps 109:21","book":"Psa","chapter":109,"verse":21,"letter":"b"}],"crossRefs":[{"label":"Ps 25:16","book":"Psa","chapter":25,"verse":16},{"label":"Ps 109:21","book":"Psa","chapter":109,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:17","parts":[{"kind":"text","text":"Don’t hide your face from your servant,"},{"kind":"text","text":" for I am in distress."},{"kind":"text","text":" Answer me quickly! "},{"kind":"crossref","label":"Ps 27:9","book":"Psa","chapter":27,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 102:2","book":"Psa","chapter":102,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Ps 27:9","book":"Psa","chapter":27,"verse":9},{"label":"Ps 102:2","book":"Psa","chapter":102,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:18","parts":[{"kind":"text","text":"Come near to me and redeem me;"},{"kind":"text","text":" ransom me because of my enemies. "},{"kind":"crossref","label":"Ps 119:134","book":"Psa","chapter":119,"verse":134,"letter":"a"}],"crossRefs":[{"label":"Ps 119:134","book":"Psa","chapter":119,"verse":134}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:19","parts":[{"kind":"text","text":"You know the insults I endure —"},{"kind":"text","text":" my shame and disgrace."},{"kind":"text","text":" You are aware of all my adversaries. "},{"kind":"crossref","label":"Jr 15:15","book":"Jer","chapter":15,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Jr 15:15","book":"Jer","chapter":15,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:20","parts":[{"kind":"text","text":"Insults have broken my heart,"},{"kind":"text","text":" and I am in despair."},{"kind":"text","text":" I waited for sympathy,"},{"kind":"text","text":" but there was none;"},{"kind":"text","text":" for comforters, but found no one. "},{"kind":"crossref","label":"Ps 142:4","book":"Psa","chapter":142,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 63:5","book":"Isa","chapter":63,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 142:4","book":"Psa","chapter":142,"verse":4},{"label":"Is 63:5","book":"Isa","chapter":63,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:21","parts":[{"kind":"text","text":"Instead, they gave me gall for my food,"},{"kind":"text","text":" and for my thirst"},{"kind":"text","text":" they gave me vinegar to drink. "},{"kind":"crossref","label":"Mt 27:34","book":"Mat","chapter":27,"verse":34,"letter":"a"},{"kind":"crossref","label":"Mt 27:48","book":"Mat","chapter":27,"verse":48,"letter":"b"},{"kind":"crossref","label":"Jn 19:29","book":"Jhn","chapter":19,"verse":29,"letter":"c"}],"crossRefs":[{"label":"Mt 27:34","book":"Mat","chapter":27,"verse":34},{"label":"Mt 27:48","book":"Mat","chapter":27,"verse":48},{"label":"Jn 19:29","book":"Jhn","chapter":19,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:22","parts":[{"kind":"text","text":"Let their table set before them be a snare,"},{"kind":"text","text":" and let it be a trap for their allies. "},{"kind":"crossref","label":"Ps 35:4–8","book":"Psa","chapter":35,"verse":4,"letter":"a"},{"kind":"crossref","label":"Rm 11:9–10","book":"Rom","chapter":11,"verse":9,"letter":"b"},{"kind":"crossref","label":"1Th 5:3","book":"1Th","chapter":5,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Ps 35:4–8","book":"Psa","chapter":35,"verse":4},{"label":"Rm 11:9–10","book":"Rom","chapter":11,"verse":9},{"label":"1Th 5:3","book":"1Th","chapter":5,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:23","parts":[{"kind":"text","text":"Let their eyes grow too dim to see,"},{"kind":"text","text":" and let their hips continually quake. "},{"kind":"crossref","label":"Is 6:10","book":"Isa","chapter":6,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ezk 29:7","book":"Ezk","chapter":29,"verse":7,"letter":"b"},{"kind":"crossref","label":"Dn 5:6","book":"Dan","chapter":5,"verse":6,"letter":"c"}],"crossRefs":[{"label":"Is 6:10","book":"Isa","chapter":6,"verse":10},{"label":"Ezk 29:7","book":"Ezk","chapter":29,"verse":7},{"label":"Dn 5:6","book":"Dan","chapter":5,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:24","parts":[{"kind":"text","text":"Pour out your rage on them,"},{"kind":"text","text":" and let your burning anger overtake them. "},{"kind":"crossref","label":"Ps 79:6","book":"Psa","chapter":79,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ezk 21:31","book":"Ezk","chapter":21,"verse":31,"letter":"b"},{"kind":"crossref","label":"Zp 3:8","book":"Zep","chapter":3,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Ps 79:6","book":"Psa","chapter":79,"verse":6},{"label":"Ezk 21:31","book":"Ezk","chapter":21,"verse":31},{"label":"Zp 3:8","book":"Zep","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:25","parts":[{"kind":"text","text":"Make their fortification desolate;"},{"kind":"text","text":" may no one live in their tents. "},{"kind":"crossref","label":"Mt 23:38","book":"Mat","chapter":23,"verse":38,"letter":"a"},{"kind":"crossref","label":"Lk 13:35","book":"Luk","chapter":13,"verse":35,"letter":"b"},{"kind":"crossref","label":"Ac 1:20","book":"Act","chapter":1,"verse":20,"letter":"c"}],"crossRefs":[{"label":"Mt 23:38","book":"Mat","chapter":23,"verse":38},{"label":"Lk 13:35","book":"Luk","chapter":13,"verse":35},{"label":"Ac 1:20","book":"Act","chapter":1,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:26","parts":[{"kind":"text","text":"For they persecute the one you struck"},{"kind":"text","text":" and talk about the pain of those you wounded. "},{"kind":"crossref","label":"2Ch 28:9","book":"2Ch","chapter":28,"verse":9,"letter":"a"},{"kind":"crossref","label":"Is 53:4","book":"Isa","chapter":53,"verse":4,"letter":"b"},{"kind":"crossref","label":"Zch 1:15","book":"Zec","chapter":1,"verse":15,"letter":"c"}],"crossRefs":[{"label":"2Ch 28:9","book":"2Ch","chapter":28,"verse":9},{"label":"Is 53:4","book":"Isa","chapter":53,"verse":4},{"label":"Zch 1:15","book":"Zec","chapter":1,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:27","parts":[{"kind":"text","text":"Charge them with crime on top of crime;"},{"kind":"text","text":" do not let them share in your righteousness. "},{"kind":"crossref","label":"Neh 4:5","book":"Neh","chapter":4,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 109:14","book":"Psa","chapter":109,"verse":14,"letter":"b"}],"crossRefs":[{"label":"Neh 4:5","book":"Neh","chapter":4,"verse":5},{"label":"Ps 109:14","book":"Psa","chapter":109,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:28","parts":[{"kind":"text","text":"Let them be erased from the book of life"},{"kind":"text","text":" and not be recorded with the righteous. "},{"kind":"crossref","label":"Ex 32:32","book":"Exo","chapter":32,"verse":32,"letter":"a"},{"kind":"crossref","label":"Dn 12:1","book":"Dan","chapter":12,"verse":1,"letter":"b"},{"kind":"crossref","label":"Rv 3:5","book":"Rev","chapter":3,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Ex 32:32","book":"Exo","chapter":32,"verse":32},{"label":"Dn 12:1","book":"Dan","chapter":12,"verse":1},{"label":"Rv 3:5","book":"Rev","chapter":3,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:29","parts":[{"kind":"text","text":"But as for me —poor and in pain —"},{"kind":"text","text":" let your salvation protect me, God. "},{"kind":"crossref","label":"Ps 20:1","book":"Psa","chapter":20,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 70:5","book":"Psa","chapter":70,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 20:1","book":"Psa","chapter":20,"verse":1},{"label":"Ps 70:5","book":"Psa","chapter":70,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:30","parts":[{"kind":"text","text":"I will praise God’s name with song"},{"kind":"text","text":" and exalt him with thanksgiving. "},{"kind":"crossref","label":"Ps 100:4","book":"Psa","chapter":100,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 107:22","book":"Psa","chapter":107,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Ps 100:4","book":"Psa","chapter":100,"verse":4},{"label":"Ps 107:22","book":"Psa","chapter":107,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:31","parts":[{"kind":"text","text":"That will please the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" more than an ox,"},{"kind":"text","text":" more than a bull with horns and hooves. "},{"kind":"crossref","label":"Ps 50:13–14","book":"Psa","chapter":50,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 51:16","book":"Psa","chapter":51,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Ps 50:13–14","book":"Psa","chapter":50,"verse":13},{"label":"Ps 51:16","book":"Psa","chapter":51,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:32","parts":[{"kind":"text","text":"The humble will see it and rejoice."},{"kind":"text","text":" You who seek God, take heart! "},{"kind":"crossref","label":"Ps 22:26","book":"Psa","chapter":22,"verse":26,"letter":"a"},{"kind":"crossref","label":"Ps 34:2","book":"Psa","chapter":34,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Ps 22:26","book":"Psa","chapter":22,"verse":26},{"label":"Ps 34:2","book":"Psa","chapter":34,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:33","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" listens to the needy"},{"kind":"text","text":" and does not despise"},{"kind":"text","text":" his own who are prisoners. "},{"kind":"crossref","label":"Ps 12:5","book":"Psa","chapter":12,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 68:6","book":"Psa","chapter":68,"verse":6,"letter":"b"},{"kind":"crossref","label":"Ps 146:7","book":"Psa","chapter":146,"verse":7,"letter":"c"}],"crossRefs":[{"label":"Ps 12:5","book":"Psa","chapter":12,"verse":5},{"label":"Ps 68:6","book":"Psa","chapter":68,"verse":6},{"label":"Ps 146:7","book":"Psa","chapter":146,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:34","parts":[{"kind":"text","text":"Let heaven and earth praise him,"},{"kind":"text","text":" the seas and everything that moves in them, "},{"kind":"crossref","label":"Ps 96:11","book":"Psa","chapter":96,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 44:23","book":"Isa","chapter":44,"verse":23,"letter":"b"},{"kind":"crossref","label":"Is 49:13","book":"Isa","chapter":49,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Ps 96:11","book":"Psa","chapter":96,"verse":11},{"label":"Is 44:23","book":"Isa","chapter":44,"verse":23},{"label":"Is 49:13","book":"Isa","chapter":49,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:35","parts":[{"kind":"text","text":"for God will save Zion"},{"kind":"text","text":" and build up "},{"kind":"footnote","marker":1,"text":"Or and rebuild"},{"kind":"text","text":" the cities of Judah."},{"kind":"text","text":" They will live there and possess it. "},{"kind":"crossref","label":"Ps 147:2","book":"Psa","chapter":147,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 44:26","book":"Isa","chapter":44,"verse":26,"letter":"b"}],"crossRefs":[{"label":"Ps 147:2","book":"Psa","chapter":147,"verse":2},{"label":"Is 44:26","book":"Isa","chapter":44,"verse":26}],"footnotes":[{"marker":1,"text":"Or and rebuild"}]},{"verseId":"a556c5305ee15c3f-01:Psa:69:36","parts":[{"kind":"text","text":"The descendants of his servants will inherit it,"},{"kind":"text","text":" and those who love his name will live in it. "},{"kind":"crossref","label":"Ps 102:28","book":"Psa","chapter":102,"verse":28,"letter":"a"},{"kind":"crossref","label":"Is 65:9","book":"Isa","chapter":65,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Ps 102:28","book":"Psa","chapter":102,"verse":28},{"label":"Is 65:9","book":"Isa","chapter":65,"verse":9}],"footnotes":[]}]},"cachedAt":1783279499187}