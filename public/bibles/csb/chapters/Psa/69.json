":"Psa","chapter":40,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 124:4","book":"Psa","chapter":124,"verse":4,"letter":"b"},{"kind":"crossref","label":"Jnh 2:3","book":"Jon","chapter":2,"verse":3,"letter":"c"}],"crossRefs":[{"label":"Ps 40:2","book":"Psa","chapter":40,"verse":2},{"label":"Ps 124:4","book":"Psa","chapter":124,"verse":4},{"label":"Jnh 2:3","book":"Jon","chapter":2,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:3","parts":[{"kind":"text","text":"I am weary from my crying;"},{"kind":"text","text":" my throat is parched."},{"kind":"text","text":" My eyes fail, looking for my God. "},{"kind":"crossref","label":"Ps 6:6","book":"Psa","chapter":6,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 38:10","book":"Psa","chapter":38,"verse":10,"letter":"b"},{"kind":"crossref","label":"Ps 119:82","book":"Psa","chapter":119,"verse":82,"letter":"c"},{"kind":"crossref","label":"Ps 119:123","book":"Psa","chapter":119,"verse":123,"letter":"d"}],"crossRefs":[{"label":"Ps 6:6","book":"Psa","chapter":6,"verse":6},{"label":"Ps 38:10","book":"Psa","chapter":38,"verse":10},{"label":"Ps 119:82","book":"Psa","chapter":119,"verse":82},{"label":"Ps 119:123","book":"Psa","chapter":119,"verse":123}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:69:4","parts":[{"kind":"text","text":"Those who hate me without cause"},{"kind":"text","text":" are more numerous than the hairs of my head;"},{"kind":"text","text":" my deceitful enemies, who would destroy me,"},{"kind":"text","text":" are powerful. "},{"kind":"crossref","label":"Ps 38:19","book":"Psa","chapter":38,"verse":19,"letter":"a"},{"kind":"text","text":" Though I did not steal, I must repay. "},{"kind":"crossref","label":"Lv 6:2","book":"Lev","chapter":6,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 35:19","book":"Psa","chapter":35,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jn 15:25","book":"Jhn","chapter":15,"verse":25,"letter":"c"}],"crossRefs":[{"label":"Ps 38:19","boo