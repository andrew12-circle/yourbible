Let them"},{"marker":1,"text":"Or cut off"}]},{"verseId":"a556c5305ee15c3f-01:Psa:109:16","parts":[{"kind":"text","text":"For he did not think to show kindness,"},{"kind":"text","text":" but pursued the suffering, needy, and brokenhearted"},{"kind":"text","text":" in order to put them to death. "},{"kind":"crossref","label":"Ps 34:18","book":"Psa","chapter":34,"verse":18,"letter":"a"},{"kind":"crossref","label":"Ps 94:6","book":"Psa","chapter":94,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Ps 34:18","book":"Psa","chapter":34,"verse":18},{"label":"Ps 94:6","book":"Psa","chapter":94,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:17","parts":[{"kind":"text","text":"He loved cursing —let it fall on him;"},{"kind":"text","text":" he took no delight in blessing —let it be far from him. "},{"kind":"crossref","label":"Pr 14:14","book":"Pro","chapter":14,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ezk 35:6","book":"Ezk","chapter":35,"verse":6,"letter":"b"},{"kind":"crossref","label":"Mt 7:2","book":"Mat","chapter":7,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Pr 14:14","book":"Pro","chapter":14,"verse":14},{"label":"Ezk 35:6","book":"Ezk","chapter":35,"verse":6},{"label":"Mt 7:2","book":"Mat","chapter":7,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:18","parts":[{"kind":"text","text":"He wore cursing like his coat —"},{"kind":"text","text":" let it enter his body like water"},{"kind":"text","text":" and go into his bones like oil. "},{"kind":"crossref","label":"Nm 5:22","book":"Num","chapter":5,"verse":22,"letter":"a"}],"crossRefs":[{"label":"Nm 5:22","book":"Num","chapter":5,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:19","parts":[{"kind":"text","text":"Let it be like a robe he wraps around himself,"},{"kind":"text","text":" like a belt he always wears. "},{"kind":"crossref","label":"Ps 73:26","book":"Psa","chapter":73,"verse":26,"letter":"a"}],"crossRefs":[{"label":"Ps 73:26","book":"Psa","chapter":73,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:20","parts":[{"kind":"text","text":"Let this be the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s payment to my accusers,"},{"kind":"text","text":" to those who speak evil against me. "},{"kind":"crossref","label":"Ps 54:5","book":"Psa","chapter":54,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 94:23","book":"Psa","chapter":94,"verse":23,"letter":"b"},{"kind":"crossref","label":"Is 3:11","book":"Isa","chapter":3,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Ps 54:5","book":"Psa","chapter":54,"verse":5},{"label":"Ps 94:23","book":"Psa","chapter":94,"verse":23},{"label":"Is 3:11","book":"Isa","chapter":3,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:21","parts":[{"kind":"text","text":"But you, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", my Lord,"},{"kind":"text","text":" deal kindly with me for your name’s sake; "},{"kind":"crossref","label":"Ps 79:9","book":"Psa","chapter":79,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 106:8","book":"Psa","chapter":106,"verse":8,"letter":"b"},{"kind":"text","text":" because your faithful love is good, rescue me. "},{"kind":"crossref","label":"Ps 69:16","book":"Psa","chapter":69,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Ps 79:9","book":"Psa","chapter":79,"verse":9},{"label":"Ps 106:8","book":"Psa","chapter":106,"verse":8},{"label":"Ps 69:16","book":"Psa","chapter":69,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:22","parts":[{"kind":"text","text":"For I am suffering and needy; "},{"kind":"crossref","label":"Ps 40:17","book":"Psa","chapter":40,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ps 86:1","book":"Psa","chapter":86,"verse":1,"letter":"b"},{"kind":"text","text":" my heart is wounded within me. "},{"kind":"crossref","label":"Ps 143:4","book":"Psa","chapter":143,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Ps 40:17","book":"Psa","chapter":40,"verse":17},{"label":"Ps 86:1","book":"Psa","chapter":86,"verse":1},{"label":"Ps 143:4","book":"Psa","chapter":143,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:23","parts":[{"kind":"text","text":"I fade away like a lengthening shadow; "},{"kind":"crossref","label":"Ps 102:11","book":"Psa","chapter":102,"verse":11,"letter":"a"},{"kind":"text","text":" I am shaken off like a locust."}],"crossRefs":[{"label":"Ps 102:11","book":"Psa","chapter":102,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:24","parts":[{"kind":"text","text":"My knees are weak from fasting,"},{"kind":"text","text":" and my body is emaciated. "},{"kind":"footnote","marker":1,"text":"Lit denied from fat"},{"kind":"crossref","label":"Jb 16:8","book":"Job","chapter":16,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 35:13","book":"Psa","chapter":35,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Jb 16:8","book":"Job","chapter":16,"verse":8},{"label":"Ps 35:13","book":"Psa","chapter":35,"verse":13}],"footnotes":[{"marker":1,"text":"Lit denied from fat"}]},{"verseId":"a556c5305ee15c3f-01:Psa:109:25","parts":[{"kind":"text","text":"I have become an object of ridicule to my accusers; "},{"kind":"footnote","marker":1,"text":"Lit to them"},{"kind":"text","text":" when they see me, they shake their heads in scorn. "},{"kind":"crossref","label":"Ps 22:6–7","book":"Psa","chapter":22,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 69:19","book":"Psa","chapter":69,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Ps 22:6–7","book":"Psa","chapter":22,"verse":6},{"label":"Ps 69:19","book":"Psa","chapter":69,"verse":19}],"footnotes":[{"marker":1,"text":"Lit to them"}]},{"verseId":"a556c5305ee15c3f-01:Psa:109:26","parts":[{"kind":"text","text":"Help me, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" my God;"},{"kind":"text","text":" save me according to your faithful love "},{"kind":"crossref","label":"Ps 119:86","book":"Psa","chapter":119,"verse":86,"letter":"a"}],"crossRefs":[{"label":"Ps 119:86","book":"Psa","chapter":119,"verse":86}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:27","parts":[{"kind":"text","text":"so they may know that this is your hand"},{"kind":"text","text":" and that you, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", have done it. "},{"kind":"crossref","label":"Jb 37:7","book":"Job","chapter":37,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Jb 37:7","book":"Job","chapter":37,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:28","parts":[{"kind":"text","text":"Though they curse, you will bless."},{"kind":"text","text":" When they rise up, they will be put to shame,"},{"kind":"text","text":" but your servant will rejoice. "},{"kind":"crossref","label":"2Sm 16:11","book":"2Sa","chapter":16,"verse":11,"letter":"a"},{"kind":"crossref","label":"Is 65:14","book":"Isa","chapter":65,"verse":14,"letter":"b"}],"crossRefs":[{"label":"2Sm 16:11","book":"2Sa","chapter":16,"verse":11},{"label":"Is 65:14","book":"Isa","chapter":65,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:29","parts":[{"kind":"text","text":"My accusers will be clothed with disgrace;"},{"kind":"text","text":" they will wear their shame like a cloak. "},{"kind":"crossref","label":"Jb 8:22","book":"Job","chapter":8,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ps 35:26","book":"Psa","chapter":35,"verse":26,"letter":"b"},{"kind":"crossref","label":"Ps 132:18","book":"Psa","chapter":132,"verse":18,"letter":"c"}],"crossRefs":[{"label":"Jb 8:22","book":"Job","chapter":8,"verse":22},{"label":"Ps 35:26","book":"Psa","chapter":35,"verse":26},{"label":"Ps 132:18","book":"Psa","chapter":132,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:30","parts":[{"kind":"text","text":"I will fervently thank the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" with my mouth;"},{"kind":"text","text":" I will praise him in the presence of many. "},{"kind":"crossref","label":"Ps 22:22","book":"Psa","chapter":22,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ps 22:25","book":"Psa","chapter":22,"verse":25,"letter":"b"},{"kind":"crossref","label":"Ps 35:18","book":"Psa","chapter":35,"verse":18,"letter":"c"},{"kind":"crossref","label":"Ps 111:1","book":"Psa","chapter":111,"verse":1,"letter":"d"}],"crossRefs":[{"label":"Ps 22:22","book":"Psa","chapter":22,"verse":22},{"label":"Ps 22:25","book":"Psa","chapter":22,"verse":25},{"label":"Ps 35:18","book":"Psa","chapter":35,"verse":18},{"label":"Ps 111:1","book":"Psa","chapter":111,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:109:31","parts":[{"kind":"text","text":"For he stands at the right hand of the needy"},{"kind":"text","text":" to save him from those who would condemn him. "},{"kind":"crossref","label":"Ps 16:8","book":"Psa","chapter":16,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 110:5","book":"Psa","chapter":110,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 121:5","book":"Psa","chapter":121,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Ps 16:8","book":"Psa","chapter":16,"verse":8},{"label":"Ps 110:5","book":"Psa","chapter":110,"verse":5},{"label":"Ps 121:5","book":"Psa","chapter":121,"verse":5}],"footnotes":[]}]},"cachedAt":1783279511115}