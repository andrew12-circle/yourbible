6","book":"Job","chapter":3,"verse":16,"letter":"a"},{"kind":"crossref","label":"Ec 6:3","book":"Ecc","chapter":6,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Jb 3:16","book":"Job","chapter":3,"verse":16},{"label":"Ec 6:3","book":"Ecc","chapter":6,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:58:9","parts":[{"kind":"text","text":"Before your pots can feel the heat of the thorns —"},{"kind":"text","text":" whether green or burning —"},{"kind":"text","text":" he will sweep them away. "},{"kind":"footnote","marker":1,"text":"Or thorns, he will sweep it away, whether raw or cooking"},{"kind":"crossref","label":"Jb 27:21","book":"Job","chapter":27,"verse":21,"letter":"a"},{"kind":"crossref","label":"Pr 10:25","book":"Pro","chapter":10,"verse":25,"letter":"b"},{"kind":"crossref","label":"Ec 7:6","book":"Ecc","chapter":7,"verse":6,"letter":"c"}],"crossRefs":[{"label":"Jb 27:21","book":"Job","chapter":27,"verse":21},{"label":"Pr 10:25","book":"Pro","chapter":10,"verse":25},{"label":"Ec 7:6","book":"Ecc","chapter":7,"verse":6}],"footnotes":[{"marker":1,"text":"Or thorns, he will sweep it away, whether raw or cooking"}]},{"verseId":"a556c5305ee15c3f-01:Psa:58:10","parts":[{"kind":"text","text":"The righteous one will rejoice"},{"kind":"text","text":" when he sees the retribution; "},{"kind":"crossref","label":"Jb 22:19","book":"Job","chapter":22,"verse":19,"letter":"a"},{"kind":"text","text":" he will wash his feet in the blood of the wicked. "},{"kind":"crossref","label":"Ps 68:23","book":"Psa","chapter":68,"verse":23,"letter":"a"},{"kind":"crossref","label":"Jr 11:20","book":"Jer","chapter":11,"verse":20,"letter":"b"},{"kind":"crossref","label":"Jr 20:12","book":"Jer","chapter":20,"verse":12,"letter":"c"}],"crossRefs":[{"label":"Jb 22:19","book":"Job","chapter":22,"verse":19},{"label":"Ps 68:23","book":"Psa","chapter":68,"verse":23},{"label":"Jr 11:20","book":"Jer","chapter":11,"verse":20},{"label":"Jr 20:12","book":"Jer","chapter":20,"verse":12}],"foot