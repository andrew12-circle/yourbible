{"key":"a556c5305ee15c3f-01|Psa|47","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":47,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:47:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":1,"text":"Clap your hands, all you peoples; shout to God with a jubilant cry.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":2,"text":"For the Lord, the Most High, is awe-inspiring, a great King over the whole earth.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":3,"text":"He subdues peoples under us and nations under our feet.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":4,"text":"He chooses for us our inheritance — the pride of Jacob, whom he loves. Selah","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":5,"text":"God ascends among shouts of joy, the Lord, with the sound of a ram’s horn.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":6,"text":"Sing praise to God, sing praise; sing praise to our King, sing praise!","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"verse":7,"text":"Sing a song of wisdom, for God is King of the whole earth.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:47:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":47,"