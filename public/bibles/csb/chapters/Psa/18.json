nemies. "},{"kind":"crossref","label":"Ps 138:7","book":"Psa","chapter":138,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 48:1","book":"Psa","chapter":48,"verse":1},{"label":"Ps 96:4","book":"Psa","chapter":96,"verse":4},{"label":"Ps 145:3","book":"Psa","chapter":145,"verse":3},{"label":"Ps 138:7","book":"Psa","chapter":138,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:4","parts":[{"kind":"text","text":"The ropes of death were wrapped around me;"},{"kind":"text","text":" the torrents of destruction terrified me. "},{"kind":"crossref","label":"Ps 124:4","book":"Psa","chapter":124,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Ps 124:4","book":"Psa","chapter":124,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:5","parts":[{"kind":"text","text":"The ropes of Sheol entangled me;"},{"kind":"text","text":" the snares of death confronted me. "},{"kind":"crossref","label":"Ps 116:3","book":"Psa","chapter":116,"verse":3,"letter":"a"}],"crossRefs":[{"label":"Ps 116:3","book":"Psa","chapter":116,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:6","parts":[{"kind":"text","text":"I called to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" in my distress,"},{"kind":"text","text":" and I cried to my God for help."},{"kind":"text","text":" From his temple he heard my voice, "},{"kind":"crossref","label":"Ps 3:4","book":"Psa","chapter":3,"verse":4,"letter":"a"},{"kind":"text","text":" and my cry to him reached his ears. "},{"kind":"crossref","label":"Ps 34:15","book":"Psa","chapter":34,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Ps 3:4","book":"Psa","chapter":3,"verse":4},{"label":"Ps 34:15","book":"Psa","chapter":34,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:7","parts":[{"kind":"text","text":"Then the earth shook and quaked;"},{"kind":"text","text":" the foundations of the mountains trembled; "},{"kind":"crossref","label":"Is 13:13","book":"Isa","chapter":13,"verse":13,"letter":"a"},{"kind":"crossref","label":"Hg 2:6","book":"Hag","chapter":2,"verse":6,"letter":"b"},{"kind":"text","text":" they shook because he burned with anger."}],"crossRefs":[{"label":"Is 13:13","book":"Isa","chapter":13,"verse":13},{"label":"Hg 2:6","book":"Hag","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:8","parts":[{"kind":"text","text":"Smoke rose from his nostrils,"},{"kind":"text","text":" and consuming fire came from his mouth;"},{"kind":"text","text":" coals were set ablaze by it. "},{"kind":"footnote","marker":1,"text":"Or him"},{"kind":"crossref","label":"Ps 21:9","book":"Psa","chapter":21,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 50:3","book":"Psa","chapter":50,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Ps 21:9","book":"Psa","chapter":21,"verse":9},{"label":"Ps 50:3","book":"Psa","chapter":50,"verse":3}],"footnotes":[{"marker":1,"text":"Or him"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:9","parts":[{"kind":"text","text":"He bent the heavens and came down, "},{"kind":"crossref","label":"Ps 144:5","book":"Psa","chapter":144,"verse":5,"letter":"a"},{"kind":"crossref","label":"Is 64:1","book":"Isa","chapter":64,"verse":1,"letter":"b"},{"kind":"text","text":" total darkness beneath his feet."}],"crossRefs":[{"label":"Ps 144:5","book":"Psa","chapter":144,"verse":5},{"label":"Is 64:1","book":"Isa","chapter":64,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:10","parts":[{"kind":"text","text":"He rode on a cherub and flew,"},{"kind":"text","text":" soaring on the wings of the wind. "},{"kind":"crossref","label":"Ps 104:3","book":"Psa","chapter":104,"verse":3,"letter":"a"}],"crossRefs":[{"label":"Ps 104:3","book":"Psa","chapter":104,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:11","parts":[{"kind":"text","text":"He made darkness his hiding place,"},{"kind":"text","text":" dark storm clouds his canopy around him. "},{"kind":"crossref","label":"Ps 97:2","book":"Psa","chapter":97,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Ps 97:2","book":"Psa","chapter":97,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:12","parts":[{"kind":"text","text":"From the radiance of his presence, "},{"kind":"crossref","label":"Ps 50:2","book":"Psa","chapter":50,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 60:3","book":"Isa","chapter":60,"verse":3,"letter":"b"},{"kind":"text","text":" his clouds swept onward with hail and blazing coals."}],"crossRefs":[{"label":"Ps 50:2","book":"Psa","chapter":50,"verse":2},{"label":"Is 60:3","book":"Isa","chapter":60,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:13","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" thundered from "},{"kind":"footnote","marker":1,"text":"Some Hb mss, LXX, Tg, Jer; other Hb mss read in"},{"kind":"text","text":" heaven;"},{"kind":"text","text":" the Most High made his voice heard. "},{"kind":"footnote","marker":1,"text":"Some Hb mss read voice, with hail and blazing coals"},{"kind":"crossref","label":"Ps 29:3","book":"Psa","chapter":29,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 104:7","book":"Psa","chapter":104,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Ps 29:3","book":"Psa","chapter":29,"verse":3},{"label":"Ps 104:7","book":"Psa","chapter":104,"verse":7}],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX, Tg, Jer; other Hb mss read in"},{"marker":1,"text":"Some Hb mss read voice, with hail and blazing coals"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:14","parts":[{"kind":"text","text":"He shot his arrows and scattered them;"},{"kind":"text","text":" he hurled "},{"kind":"footnote","marker":1,"text":"Or multiplied"},{"kind":"text","text":" lightning bolts and routed them. "},{"kind":"crossref","label":"Ps 144:6","book":"Psa","chapter":144,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Ps 144:6","book":"Psa","chapter":144,"verse":6}],"footnotes":[{"marker":1,"text":"Or multiplied"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:15","parts":[{"kind":"text","text":"The depths of the sea became visible,"},{"kind":"text","text":" the foundations of the world were exposed,"},{"kind":"text","text":" at your rebuke, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" at the blast of the breath of your nostrils. "},{"kind":"crossref","label":"Ex 15:8","book":"Exo","chapter":15,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 106:9","book":"Psa","chapter":106,"verse":9,"letter":"b"},{"kind":"crossref","label":"Nah 1:4","book":"Nam","chapter":1,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Ex 15:8","book":"Exo","chapter":15,"verse":8},{"label":"Ps 106:9","book":"Psa","chapter":106,"verse":9},{"label":"Nah 1:4","book":"Nam","chapter":1,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:16","parts":[{"kind":"text","text":"He reached down from on high"},{"kind":"text","text":" and took hold of me;"},{"kind":"text","text":" he pulled me out of deep water. "},{"kind":"crossref","label":"Ps 144:7","book":"Psa","chapter":144,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 144:7","book":"Psa","chapter":144,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:17","parts":[{"kind":"text","text":"He rescued me from my powerful enemy"},{"kind":"text","text":" and from those who hated me,"},{"kind":"text","text":" for they were too strong for me. "},{"kind":"crossref","label":"Ps 35:10","book":"Psa","chapter":35,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ps 59:1","book":"Psa","chapter":59,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ps 142:6","book":"Psa","chapter":142,"verse":6,"letter":"c"}],"crossRefs":[{"label":"Ps 35:10","book":"Psa","chapter":35,"verse":10},{"label":"Ps 59:1","book":"Psa","chapter":59,"verse":1},{"label":"Ps 142:6","book":"Psa","chapter":142,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:18","parts":[{"kind":"text","text":"They confronted me in the day of my calamity,"},{"kind":"text","text":" but the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" was my support. "},{"kind":"crossref","label":"Ps 55:22","book":"Psa","chapter":55,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ps 59:16","book":"Psa","chapter":59,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Ps 55:22","book":"Psa","chapter":55,"verse":22},{"label":"Ps 59:16","book":"Psa","chapter":59,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:19","parts":[{"kind":"text","text":"He brought me out to a spacious place; "},{"kind":"crossref","label":"Ps 31:8","book":"Psa","chapter":31,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 118:5","book":"Psa","chapter":118,"verse":5,"letter":"b"},{"kind":"text","text":" he rescued me because he delighted in me. "},{"kind":"crossref","label":"Ps 41:11","book":"Psa","chapter":41,"verse":11,"letter":"a"}],"crossRefs":[{"label":"Ps 31:8","book":"Psa","chapter":31,"verse":8},{"label":"Ps 118:5","book":"Psa","chapter":118,"verse":5},{"label":"Ps 41:11","book":"Psa","chapter":41,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:20","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" rewarded me"},{"kind":"text","text":" according to my righteousness; "},{"kind":"crossref","label":"Ps 7:8","book":"Psa","chapter":7,"verse":8,"letter":"a"},{"kind":"text","text":" he repaid me"},{"kind":"text","text":" according to the cleanness of my hands. "},{"kind":"crossref","label":"Ps 24:4","book":"Psa","chapter":24,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Ps 7:8","book":"Psa","chapter":7,"verse":8},{"label":"Ps 24:4","book":"Psa","chapter":24,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:21","parts":[{"kind":"text","text":"For I have kept the ways of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" and have not turned from my God to wickedness. "},{"kind":"crossref","label":"Jb 23:11","book":"Job","chapter":23,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 119:101","book":"Psa","chapter":119,"verse":101,"letter":"b"}],"crossRefs":[{"label":"Jb 23:11","book":"Job","chapter":23,"verse":11},{"label":"Ps 119:101","book":"Psa","chapter":119,"verse":101}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:22","parts":[{"kind":"text","text":"Indeed, I let all his ordinances guide me "},{"kind":"footnote","marker":1,"text":"Lit Indeed, all his ordinances have been in front of me"},{"kind":"text","text":" and have not disregarded his statutes. "},{"kind":"crossref","label":"Lv 18:4","book":"Lev","chapter":18,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Lv 18:4","book":"Lev","chapter":18,"verse":4}],"footnotes":[{"marker":1,"text":"Lit Indeed, all his ordinances have been in front of me"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:23","parts":[{"kind":"text","text":"I was blameless toward him "},{"kind":"crossref","label":"Dt 18:13","book":"Deu","chapter":18,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 37:18","book":"Psa","chapter":37,"verse":18,"letter":"b"},{"kind":"crossref","label":"Ps 119:1","book":"Psa","chapter":119,"verse":1,"letter":"c"},{"kind":"text","text":" and kept myself from my iniquity."}],"crossRefs":[{"label":"Dt 18:13","book":"Deu","chapter":18,"verse":13},{"label":"Ps 37:18","book":"Psa","chapter":37,"verse":18},{"label":"Ps 119:1","book":"Psa","chapter":119,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:24","parts":[{"kind":"text","text":"So the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" repaid me"},{"kind":"text","text":" according to my righteousness, "},{"kind":"crossref","label":"2Ch 6:23","book":"2Ch","chapter":6,"verse":23,"letter":"a"},{"kind":"text","text":" according to the cleanness of my hands in his sight. "},{"kind":"crossref","label":"Ps 24:4","book":"Psa","chapter":24,"verse":4,"letter":"a"}],"crossRefs":[{"label":"2Ch 6:23","book":"2Ch","chapter":6,"verse":23},{"label":"Ps 24:4","book":"Psa","chapter":24,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:25","parts":[{"kind":"text","text":"With the faithful"},{"kind":"text","text":" you prove yourself faithful,"},{"kind":"text","text":" with the blameless"},{"kind":"text","text":" you prove yourself blameless,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:26","parts":[{"kind":"text","text":"with the pure"},{"kind":"text","text":" you prove yourself pure,"},{"kind":"text","text":" but with the crooked"},{"kind":"text","text":" you prove yourself shrewd. "},{"kind":"crossref","label":"Mt 16:27","book":"Mat","chapter":16,"verse":27,"letter":"a"},{"kind":"crossref","label":"Rv 22:12","book":"Rev","chapter":22,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Mt 16:27","book":"Mat","chapter":16,"verse":27},{"label":"Rv 22:12","book":"Rev","chapter":22,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:27","parts":[{"kind":"text","text":"For you rescue an oppressed people, "},{"kind":"crossref","label":"Ps 72:12","book":"Psa","chapter":72,"verse":12,"letter":"a"},{"kind":"text","text":" but you humble those with haughty eyes. "},{"kind":"crossref","label":"Ps 138:6","book":"Psa","chapter":138,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Ps 72:12","book":"Psa","chapter":72,"verse":12},{"label":"Ps 138:6","book":"Psa","chapter":138,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:28","parts":[{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", you light my lamp;"},{"kind":"text","text":" my God illuminates my darkness. "},{"kind":"crossref","label":"Ps 112:4","book":"Psa","chapter":112,"verse":4,"letter":"a"},{"kind":"crossref","label":"Is 42:16","book":"Isa","chapter":42,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Ps 112:4","book":"Psa","chapter":112,"verse":4},{"label":"Is 42:16","book":"Isa","chapter":42,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:29","parts":[{"kind":"text","text":"With you I can attack a barricade, "},{"kind":"footnote","marker":1,"text":"Or a ridge, or raiders"},{"kind":"text","text":" and with my God I can leap over a wall. "},{"kind":"crossref","label":"Mt 19:26","book":"Mat","chapter":19,"verse":26,"letter":"a"},{"kind":"crossref","label":"Php 4:13","book":"Php","chapter":4,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Mt 19:26","book":"Mat","chapter":19,"verse":26},{"label":"Php 4:13","book":"Php","chapter":4,"verse":13}],"footnotes":[{"marker":1,"text":"Or a ridge, or raiders"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:30","parts":[{"kind":"text","text":"God —his way is perfect; "},{"kind":"crossref","label":"Dt 32:4","book":"Deu","chapter":32,"verse":4,"letter":"a"},{"kind":"text","text":" the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" is pure. "},{"kind":"crossref","label":"Ps 19:7","book":"Psa","chapter":19,"verse":7,"letter":"a"},{"kind":"text","text":" He is a shield to all who take refuge in him. "},{"kind":"crossref","label":"Ps 91:4","book":"Psa","chapter":91,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 144:2","book":"Psa","chapter":144,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Dt 32:4","book":"Deu","chapter":32,"verse":4},{"label":"Ps 19:7","book":"Psa","chapter":19,"verse":7},{"label":"Ps 91:4","book":"Psa","chapter":91,"verse":4},{"label":"Ps 144:2","book":"Psa","chapter":144,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:31","parts":[{"kind":"text","text":"For who is God besides the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"? "},{"kind":"crossref","label":"Dt 32:39","book":"Deu","chapter":32,"verse":39,"letter":"a"},{"kind":"crossref","label":"1Sm 2:2","book":"1Sa","chapter":2,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ps 86:8","book":"Psa","chapter":86,"verse":8,"letter":"c"},{"kind":"text","text":" And who is a rock? Only our God. "},{"kind":"crossref","label":"Ps 62:2","book":"Psa","chapter":62,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Dt 32:39","book":"Deu","chapter":32,"verse":39},{"label":"1Sm 2:2","book":"1Sa","chapter":2,"verse":2},{"label":"Ps 86:8","book":"Psa","chapter":86,"verse":8},{"label":"Ps 62:2","book":"Psa","chapter":62,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:32","parts":[{"kind":"text","text":"God —he clothes me with strength "},{"kind":"crossref","label":"Is 45:5","book":"Isa","chapter":45,"verse":5,"letter":"a"},{"kind":"text","text":" and makes my way perfect."}],"crossRefs":[{"label":"Is 45:5","book":"Isa","chapter":45,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:33","parts":[{"kind":"text","text":"He makes my feet like the feet of a deer "},{"kind":"crossref","label":"Hab 3:19","book":"Hab","chapter":3,"verse":19,"letter":"a"},{"kind":"text","text":" and sets me securely on the heights. "},{"kind":"footnote","marker":1,"text":"Or on my high places"},{"kind":"crossref","label":"Dt 32:13","book":"Deu","chapter":32,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 58:14","book":"Isa","chapter":58,"verse":14,"letter":"b"}],"crossRefs":[{"label":"Hab 3:19","book":"Hab","chapter":3,"verse":19},{"label":"Dt 32:13","book":"Deu","chapter":32,"verse":13},{"label":"Is 58:14","book":"Isa","chapter":58,"verse":14}],"footnotes":[{"marker":1,"text":"Or on my high places"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:34","parts":[{"kind":"text","text":"He trains my hands for war; "},{"kind":"crossref","label":"Ps 144:1","book":"Psa","chapter":144,"verse":1,"letter":"a"},{"kind":"text","text":" my arms can bend a bow of bronze. "},{"kind":"crossref","label":"Jb 29:20","book":"Job","chapter":29,"verse":20,"letter":"a"}],"crossRefs":[{"label":"Ps 144:1","book":"Psa","chapter":144,"verse":1},{"label":"Jb 29:20","book":"Job","chapter":29,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:35","parts":[{"kind":"text","text":"You have given me the shield of your salvation;"},{"kind":"text","text":" your right hand upholds me, "},{"kind":"crossref","label":"Ps 89:21","book":"Psa","chapter":89,"verse":21,"letter":"a"},{"kind":"text","text":" and your humility exalts me."}],"crossRefs":[{"label":"Ps 89:21","book":"Psa","chapter":89,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:36","parts":[{"kind":"text","text":"You make a spacious place beneath me for my steps, "},{"kind":"crossref","label":"Ps 31:8","book":"Psa","chapter":31,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 118:5","book":"Psa","chapter":118,"verse":5,"letter":"b"},{"kind":"text","text":" and my ankles do not give way. "},{"kind":"crossref","label":"Ps 66:9","book":"Psa","chapter":66,"verse":9,"letter":"a"},{"kind":"crossref","label":"Pr 4:12","book":"Pro","chapter":4,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Ps 31:8","book":"Psa","chapter":31,"verse":8},{"label":"Ps 118:5","book":"Psa","chapter":118,"verse":5},{"label":"Ps 66:9","book":"Psa","chapter":66,"verse":9},{"label":"Pr 4:12","book":"Pro","chapter":4,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:37","parts":[{"kind":"text","text":"I pursue my enemies and overtake them;"},{"kind":"text","text":" I do not turn back until they are wiped out. "},{"kind":"crossref","label":"Ps 44:5","book":"Psa","chapter":44,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Ps 44:5","book":"Psa","chapter":44,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:38","parts":[{"kind":"text","text":"I crush them, and they cannot get up;"},{"kind":"text","text":" they fall beneath my feet. "},{"kind":"crossref","label":"Ps 36:12","book":"Psa","chapter":36,"verse":12,"letter":"a"}],"crossRefs":[{"label":"Ps 36:12","book":"Psa","chapter":36,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:39","parts":[{"kind":"text","text":"You have clothed me with strength for battle; "},{"kind":"crossref","label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4,"letter":"a"},{"kind":"text","text":" you subdue my adversaries beneath me. "},{"kind":"crossref","label":"1Ch 17:10","book":"1Ch","chapter":17,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ps 81:14","book":"Psa","chapter":81,"verse":14,"letter":"b"}],"crossRefs":[{"label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4},{"label":"1Ch 17:10","book":"1Ch","chapter":17,"verse":10},{"label":"Ps 81:14","book":"Psa","chapter":81,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:40","parts":[{"kind":"text","text":"You have made my enemies retreat before me; "},{"kind":"footnote","marker":1,"text":"Or You gave me the necks of my enemies"},{"kind":"crossref","label":"Ex 23:27","book":"Exo","chapter":23,"verse":27,"letter":"a"},{"kind":"text","text":" I annihilate those who hate me. "},{"kind":"crossref","label":"Dt 7:10","book":"Deu","chapter":7,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Ex 23:27","book":"Exo","chapter":23,"verse":27},{"label":"Dt 7:10","book":"Deu","chapter":7,"verse":10}],"footnotes":[{"marker":1,"text":"Or You gave me the necks of my enemies"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:41","parts":[{"kind":"text","text":"They cry for help, but there is no one to save them "},{"kind":"crossref","label":"Ps 50:22","book":"Psa","chapter":50,"verse":22,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" they cry to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", but he does not answer them. "},{"kind":"crossref","label":"Mc 3:4","book":"Mic","chapter":3,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Ps 50:22","book":"Psa","chapter":50,"verse":22},{"label":"Mc 3:4","book":"Mic","chapter":3,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:42","parts":[{"kind":"text","text":"I pulverize them like dust before the wind; "},{"kind":"crossref","label":"2Kg 13:7","book":"2Ki","chapter":13,"verse":7,"letter":"a"},{"kind":"text","text":" I trample them "},{"kind":"footnote","marker":1,"text":"Some Hb mss, LXX, Syr, Tg; other Hb mss read I poured them out"},{"kind":"text","text":" like mud in the streets. "},{"kind":"crossref","label":"Is 10:6","book":"Isa","chapter":10,"verse":6,"letter":"a"},{"kind":"crossref","label":"Mc 7:10","book":"Mic","chapter":7,"verse":10,"letter":"b"}],"crossRefs":[{"label":"2Kg 13:7","book":"2Ki","chapter":13,"verse":7},{"label":"Is 10:6","book":"Isa","chapter":10,"verse":6},{"label":"Mc 7:10","book":"Mic","chapter":7,"verse":10}],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX, Syr, Tg; other Hb mss read I poured them out"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:43","parts":[{"kind":"text","text":"You have freed me from the feuds among the people;"},{"kind":"text","text":" you have appointed me the head of nations; "},{"kind":"crossref","label":"2Sm 8:1","book":"2Sa","chapter":8,"verse":1,"letter":"a"},{"kind":"text","text":" a people I had not known serve me. "},{"kind":"crossref","label":"Is 55:5","book":"Isa","chapter":55,"verse":5,"letter":"a"}],"crossRefs":[{"label":"2Sm 8:1","book":"2Sa","chapter":8,"verse":1},{"label":"Is 55:5","book":"Isa","chapter":55,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:44","parts":[{"kind":"text","text":"Foreigners submit to me cringing;"},{"kind":"text","text":" as soon as they hear they obey me. "},{"kind":"crossref","label":"Dt 33:29","book":"Deu","chapter":33,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ps 66:3","book":"Psa","chapter":66,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Dt 33:29","book":"Deu","chapter":33,"verse":29},{"label":"Ps 66:3","book":"Psa","chapter":66,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:45","parts":[{"kind":"text","text":"Foreigners lose heart"},{"kind":"text","text":" and come trembling from their fortifications. "},{"kind":"crossref","label":"Mc 7:17","book":"Mic","chapter":7,"verse":17,"letter":"a"}],"crossRefs":[{"label":"Mc 7:17","book":"Mic","chapter":7,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:46","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" lives —blessed be my rock!"},{"kind":"text","text":" The God of my salvation is exalted. "},{"kind":"crossref","label":"Ps 62:2","book":"Psa","chapter":62,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 62:6","book":"Psa","chapter":62,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Ps 62:2","book":"Psa","chapter":62,"verse":2},{"label":"Ps 62:6","book":"Psa","chapter":62,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:47","parts":[{"kind":"text","text":"God —he grants me vengeance "},{"kind":"crossref","label":"2Sm 4:8","book":"2Sa","chapter":4,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 94:1","book":"Psa","chapter":94,"verse":1,"letter":"b"},{"kind":"text","text":" and subdues peoples under me. "},{"kind":"crossref","label":"Ps 47:3","book":"Psa","chapter":47,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 144:2","book":"Psa","chapter":144,"verse":2,"letter":"b"}],"crossRefs":[{"label":"2Sm 4:8","book":"2Sa","chapter":4,"verse":8},{"label":"Ps 94:1","book":"Psa","chapter":94,"verse":1},{"label":"Ps 47:3","book":"Psa","chapter":47,"verse":3},{"label":"Ps 144:2","book":"Psa","chapter":144,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:48","parts":[{"kind":"text","text":"He frees me from my enemies."},{"kind":"text","text":" You exalt me above my adversaries;"},{"kind":"text","text":" you rescue me from violent men. "},{"kind":"crossref","label":"Ps 59:1","book":"Psa","chapter":59,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 140:1","book":"Psa","chapter":140,"verse":1,"letter":"b"}],"crossRefs":[{"label":"Ps 59:1","book":"Psa","chapter":59,"verse":1},{"label":"Ps 140:1","book":"Psa","chapter":140,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:49","parts":[{"kind":"text","text":"Therefore I will give thanks to you among the nations, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"},{"kind":"text","text":" I will sing praises about your name. "},{"kind":"crossref","label":"Rm 15:9","book":"Rom","chapter":15,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Rm 15:9","book":"Rom","chapter":15,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:50","parts":[{"kind":"text","text":"He gives great victories to his king; "},{"kind":"crossref","label":"Ps 144:10","book":"Psa","chapter":144,"verse":10,"letter":"a"},{"kind":"text","text":" he shows loyalty to his anointed,"},{"kind":"text","text":" to David and his descendants forever. "},{"kind":"crossref","label":"2Sm 7:12","book":"2Sa","chapter":7,"verse":12,"letter":"a"},{"kind":"crossref","label":"Ps 89:4","book":"Psa","chapter":89,"verse":4,"letter":"b"},{"kind":"crossref","label":"Ps 89:29","book":"Psa","chapter":89,"verse":29,"letter":"c"}],"crossRefs":[{"label":"Ps 144:10","book":"Psa","chapter":144,"verse":10},{"label":"2Sm 7:12","book":"2Sa","chapter":7,"verse":12},{"label":"Ps 89:4","book":"Psa","chapter":89,"verse":4},{"label":"Ps 89:29","book":"Psa","chapter":89,"verse":29}],"footnotes":[]}]},"cachedAt":1783279483293}