hapter":32,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:31","parts":[{"kind":"text","text":"For who is God besides the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"? "},{"kind":"crossref","label":"Dt 32:39","book":"Deu","chapter":32,"verse":39,"letter":"a"},{"kind":"crossref","label":"1Sm 2:2","book":"1Sa","chapter":2,"verse":2,"letter":"b"},{"kind":"crossref","label":"Ps 86:8","book":"Psa","chapter":86,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Dt 32:39","book":"Deu","chapter":32,"verse":39},{"label":"1Sm 2:2","book":"1Sa","chapter":2,"verse":2},{"label":"Ps 86:8","book":"Psa","chapter":86,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:32","parts":[{"kind":"text","text":"God —he clothes me with strength "},{"kind":"crossref","label":"Is 45:5","book":"Isa","chapter":45,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Is 45:5","book":"Isa","chapter":45,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:33","parts":[{"kind":"text","text":"He makes my feet like the feet of a deer "},{"kind":"crossref","label":"Hab 3:19","book":"Hab","chapter":3,"verse":19,"letter":"a"}],"crossRefs":[{"label":"Hab 3:19","book":"Hab","chapter":3,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:34","parts":[{"kind":"text","text":"He trains my hands for war; "},{"kind":"crossref","label":"Ps 144:1","book":"Psa","chapter":144,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Ps 144:1","book":"Psa","chapter":144,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:35","parts":[{"kind":"text","text":"You have given me the shield of your salvation;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:36","parts":[{"kind":"text","text":"You make a spacious place beneath me for my steps, "},{"kind":"crossref","label":"Ps 31:8","book":"Psa","chapter":31,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 118:5","book":"Psa","chapter":118,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 31:8","book":"Psa","chapter":31,"verse":8},{"label":"Ps 118:5","book":"Psa","chapter":118,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:37","parts":[{"kind":"text","text":"I pursue my enemies and overtake them;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:38","parts":[{"kind":"text","text":"I crush them, and they cannot get up;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:39","parts":[{"kind":"text","text":"You have clothed me with strength for battle; "},{"kind":"crossref","label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4,"letter":"a"}],"crossRefs":[{"label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:40","parts":[{"kind":"text","text":"You have made my enemies retreat before me; "},{"kind":"footnote","marker":1,"text":"Or You gave me the necks of my enemies"},{"kind":"crossref","label":"Ex 23:27","book":"Exo","chapter":23,"verse":27,"letter":"a"}],"crossRefs":[{"label":"Ex 23:27","book":"Exo","chapter":23,"verse":27}],"footnotes":[{"marker":1,"text":"Or You gave me the necks of my enemies"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:41","parts":[{"kind":"text","text":"They cry for help, but there is no one to save them "},{"kind":"crossref","label":"Ps 50:22","book":"Psa","chapter":50,"verse":22,"letter":"a"},{"kind":"text","text":" —"}],"crossRefs":[{"label":"Ps 50:22","book":"Psa","chapter":50,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:42","parts":[{"kind":"text","text":"I pulverize them like dust before the wind; "},{"kind":"crossref","label":"2Kg 13:7","book":"2Ki","chapter":13,"verse":7,"letter":"a"}],"crossRefs":[{"label":"2Kg 13:7","book":"2Ki","chapter":13,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:43","parts":[{"kind":"text","text":"You have freed me from the feuds among the people;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:44","parts":[{"kind":"text","text":"Foreigners submit to me cringing;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:45","parts":[{"kind":"text","text":"Foreigners lose heart"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:46","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" lives —blessed be my rock!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:47","parts":[{"kind":"text","text":"God —he grants me vengeance "},{"kind":"crossref","label":"2Sm 4:8","book":"2Sa","chapter":4,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 94:1","book":"Psa","chapter":94,"verse":1,"letter":"b"}],"crossRefs":[{"label":"2Sm 4:8","book":"2Sa","chapter":4,"verse":8},{"label":"Ps 94:1","book":"Psa","chapter":94,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:48","parts":[{"kind":"text","text":"He frees me from my enemies."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:49","parts":[{"kind":"text","text":"Therefore I will give thanks to you among the nations, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:50","parts":[{"kind":"text","text":"He gives great victories to his king; "},{"kind":"crossref","label":"Ps 144:10","book":"Psa","chapter":144,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Ps 144:10","book":"Psa","chapter":144,"verse":10}],"footnotes":[]}]},"cachedAt":1783099364834}