":"text","text":" heaven;"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Some Hb mss, LXX, Tg, Jer; other Hb mss read in"}]},{"verseId":"a556c5305ee15c3f-01:Psa:18:14","parts":[{"kind":"text","text":"He shot his arrows and scattered them;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:15","parts":[{"kind":"text","text":"The depths of the sea became visible,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:16","parts":[{"kind":"text","text":"He reached down from on high"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:17","parts":[{"kind":"text","text":"He rescued me from my powerful enemy"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:18","parts":[{"kind":"text","text":"They confronted me in the day of my calamity,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:19","parts":[{"kind":"text","text":"He brought me out to a spacious place; "},{"kind":"crossref","label":"Ps 31:8","book":"Psa","chapter":31,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 118:5","book":"Psa","chapter":118,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 31:8","book":"Psa","chapter":31,"verse":8},{"label":"Ps 118:5","book":"Psa","chapter":118,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:20","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" rewarded me"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:21","parts":[{"kind":"text","text":"For I have kept the ways of the "},{"kind":"text","text":"Lord","style":"divine"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:18:22","parts":[{"kind":"text","text":"Indeed, I let all his ordinances guide me "},{"kind":"footnote","marker":1,"text":"Lit Indeed, all his ordinances have been in front of me"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit Indeed, all his ordinances have been in fr