":"Psa","bookOrder":18,"chapter":78,"verse":28,"text":"He made them fall in the camp,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":29,"text":"The people ate and were completely satisfied,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":30,"text":"Before they had turned from what they craved,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":31,"text":"God’s anger flared up against them,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":32,"text":"Despite all this, they kept sinning","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":33,"text":"He made their days end in futility,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":34,"text":"When he killed some of them,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":35,"text":"They remembered that God was their rock,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":36,"text":"But they deceived him with their mouths,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:78:37","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":78,"verse":37,"text":"their hear