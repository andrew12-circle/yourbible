ind":"text","text":" will inherit the land. "},{"kind":"crossref","label":"Pr 2:21","book":"Pro","chapter":2,"verse":21,"letter":"a"},{"kind":"crossref","label":"Is 57:13","book":"Isa","chapter":57,"verse":13,"letter":"b"},{"kind":"crossref","label":"Is 60:21","book":"Isa","chapter":60,"verse":21,"letter":"c"}],"crossRefs":[{"label":"Pr 2:21","book":"Pro","chapter":2,"verse":21},{"label":"Is 57:13","book":"Isa","chapter":57,"verse":13},{"label":"Is 60:21","book":"Isa","chapter":60,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:10","parts":[{"kind":"text","text":"A little while, and the wicked person will be no more;"},{"kind":"text","text":" though you look for him, he will not be there. "},{"kind":"crossref","label":"Jb 7:10","book":"Job","chapter":7,"verse":10,"letter":"a"},{"kind":"crossref","label":"Jb 24:24","book":"Job","chapter":24,"verse":24,"letter":"b"},{"kind":"crossref","label":"Ps 37:35–36","book":"Psa","chapter":37,"verse":35,"letter":"c"}],"crossRefs":[{"label":"Jb 7:10","book":"Job","chapter":7,"verse":10},{"label":"Jb 24:24","book":"Job","chapter":24,"verse":24},{"label":"Ps 37:35–36","book":"Psa","chapter":37,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:11","parts":[{"kind":"text","text":"But the humble will inherit the land "},{"kind":"crossref","label":"Mt 5:5","book":"Mat","chapter":5,"verse":5,"letter":"a"},{"kind":"text","text":" and will enjoy abundant prosperity. "},{"kind":"crossref","label":"Ps 72:7","book":"Psa","chapter":72,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Mt 5:5","book":"Mat","chapter":5,"verse":5},{"label":"Ps 72:7","book":"Psa","chapter":72,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:12","parts":[{"kind":"text","text":"The wicked person schemes against the righteous"},{"kind":"text","text":" and gnashes his teeth at him. "},{"kind":"crossref","label":"Ps 31:13","book":"Psa","chapter":31,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 31:20","book":"Psa","chapter":31,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ps 35:16","book":"Psa","chapter":35,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Ps 31:13","book":"Psa","chapter":31,"verse":13},{"label":"Ps 31:20","book":"Psa","chapter":31,"verse":20},{"label":"Ps 35:16","book":"Psa","chapter":35,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:13","parts":[{"kind":"text","text":"The Lord laughs at him "},{"kind":"crossref","label":"Ps 2:4","book":"Psa","chapter":2,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 59:8","book":"Psa","chapter":59,"verse":8,"letter":"b"},{"kind":"crossref","label":"Hab 1:10","book":"Hab","chapter":1,"verse":10,"letter":"c"},{"kind":"text","text":" because he sees that his day is coming. "},{"kind":"crossref","label":"1Sm 26:10","book":"1Sa","chapter":26,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Ps 2:4","book":"Psa","chapter":2,"verse":4},{"label":"Ps 59:8","book":"Psa","chapter":59,"verse":8},{"label":"Hab 1:10","book":"Hab","chapter":1,"verse":10},{"label":"1Sm 26:10","book":"1Sa","chapter":26,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:14","parts":[{"kind":"text","text":"The wicked have drawn the sword and strung the "},{"kind":"footnote","marker":1,"text":"Lit their"},{"kind":"text","text":" bow"},{"kind":"text","text":" to bring down the poor and needy"},{"kind":"text","text":" and to slaughter those whose way is upright. "},{"kind":"crossref","label":"Ps 11:2","book":"Psa","chapter":11,"verse":2,"letter":"a"},{"kind":"crossref","label":"Lm 2:4","book":"Lam","chapter":2,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Ps 11:2","book":"Psa","chapter":11,"verse":2},{"label":"Lm 2:4","book":"Lam","chapter":2,"verse":4}],"footnotes":[{"marker":1,"text":"Lit their"}]},{"verseId":"a556c5305ee15c3f-01:Psa:37:15","parts":[{"kind":"text","text":"Their swords will enter their own hearts,"},{"kind":"text","text":" and their bows will be broken. "},{"kind":"crossref","label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 46:9","book":"Psa","chapter":46,"verse":9,"letter":"b"}],"crossRefs":[{"label":"1Sm 2:4","book":"1Sa","chapter":2,"verse":4},{"label":"Ps 46:9","book":"Psa","chapter":46,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:16","parts":[{"kind":"text","text":"The little that the righteous person has is better"},{"kind":"text","text":" than the abundance of many wicked people. "},{"kind":"crossref","label":"Pr 15:16","book":"Pro","chapter":15,"verse":16,"letter":"a"},{"kind":"crossref","label":"Pr 16:8","book":"Pro","chapter":16,"verse":8,"letter":"b"}],"crossRefs":[{"label":"Pr 15:16","book":"Pro","chapter":15,"verse":16},{"label":"Pr 16:8","book":"Pro","chapter":16,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:17","parts":[{"kind":"text","text":"For the arms of the wicked will be broken, "},{"kind":"crossref","label":"Ps 10:15","book":"Psa","chapter":10,"verse":15,"letter":"a"},{"kind":"text","text":" but the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" supports the righteous. "},{"kind":"crossref","label":"Ps 145:14","book":"Psa","chapter":145,"verse":14,"letter":"a"}],"crossRefs":[{"label":"Ps 10:15","book":"Psa","chapter":10,"verse":15},{"label":"Ps 145:14","book":"Psa","chapter":145,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:18","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" watches over the blameless all their days,"},{"kind":"text","text":" and their inheritance will last forever. "},{"kind":"crossref","label":"Ps 1:6","book":"Psa","chapter":1,"verse":6,"letter":"a"}],"crossRefs":[{"label":"Ps 1:6","book":"Psa","chapter":1,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:19","parts":[{"kind":"text","text":"They will not be disgraced in times of adversity;"},{"kind":"text","text":" they will be satisfied in days of hunger. "},{"kind":"crossref","label":"Jb 5:20","book":"Job","chapter":5,"verse":20,"letter":"a"},{"kind":"crossref","label":"Ps 33:19","book":"Psa","chapter":33,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Jb 5:20","book":"Job","chapter":5,"verse":20},{"label":"Ps 33:19","book":"Psa","chapter":33,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:20","parts":[{"kind":"text","text":"But the wicked will perish;"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s enemies, like the glory of the pastures,"},{"kind":"text","text":" will fade away —"},{"kind":"text","text":" they will fade away like smoke. "},{"kind":"crossref","label":"Ps 68:2","book":"Psa","chapter":68,"verse":2,"letter":"a"},{"kind":"crossref","label":"Hs 13:3","book":"Hos","chapter":13,"verse":3,"letter":"b"}],"crossRefs":[{"label":"Ps 68:2","book":"Psa","chapter":68,"verse":2},{"label":"Hs 13:3","book":"Hos","chapter":13,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:21","parts":[{"kind":"text","text":"The wicked person borrows and does not repay,"},{"kind":"text","text":" but the righteous one is gracious and giving. "},{"kind":"crossref","label":"Ps 112:5","book":"Psa","chapter":112,"verse":5,"letter":"a"},{"kind":"crossref","label":"Ps 112:9","book":"Psa","chapter":112,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Ps 112:5","book":"Psa","chapter":112,"verse":5},{"label":"Ps 112:9","book":"Psa","chapter":112,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:22","parts":[{"kind":"text","text":"Those who are blessed by the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will inherit the land,"},{"kind":"text","text":" but those cursed by him will be destroyed. "},{"kind":"crossref","label":"Pr 3:33","book":"Pro","chapter":3,"verse":33,"letter":"a"}],"crossRefs":[{"label":"Pr 3:33","book":"Pro","chapter":3,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:23","parts":[{"kind":"text","text":"A person’s steps are established by the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" and he takes pleasure in his way. "},{"kind":"crossref","label":"1Sm 2:9","book":"1Sa","chapter":2,"verse":9,"letter":"a"},{"kind":"crossref","label":"Ps 66:9","book":"Psa","chapter":66,"verse":9,"letter":"b"}],"crossRefs":[{"label":"1Sm 2:9","book":"1Sa","chapter":2,"verse":9},{"label":"Ps 66:9","book":"Psa","chapter":66,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:24","parts":[{"kind":"text","text":"Though he falls, he will not be overwhelmed,"},{"kind":"text","text":" because the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" supports him with his hand. "},{"kind":"crossref","label":"Ps 145:14","book":"Psa","chapter":145,"verse":14,"letter":"a"},{"kind":"crossref","label":"Pr 24:16","book":"Pro","chapter":24,"verse":16,"letter":"b"},{"kind":"crossref","label":"Mc 7:8","book":"Mic","chapter":7,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Ps 145:14","book":"Psa","chapter":145,"verse":14},{"label":"Pr 24:16","book":"Pro","chapter":24,"verse":16},{"label":"Mc 7:8","book":"Mic","chapter":7,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:25","parts":[{"kind":"text","text":"I have been young and now I am old,"},{"kind":"text","text":" yet I have not seen the righteous abandoned"},{"kind":"text","text":" or his children begging for bread. "},{"kind":"crossref","label":"Pr 10:3","book":"Pro","chapter":10,"verse":3,"letter":"a"},{"kind":"crossref","label":"Is 41:17","book":"Isa","chapter":41,"verse":17,"letter":"b"}],"crossRefs":[{"label":"Pr 10:3","book":"Pro","chapter":10,"verse":3},{"label":"Is 41:17","book":"Isa","chapter":41,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:26","parts":[{"kind":"text","text":"He is always generous, always lending,"},{"kind":"text","text":" and his children are a blessing. "},{"kind":"crossref","label":"Dt 15:8","book":"Deu","chapter":15,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 112:5","book":"Psa","chapter":112,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 112:9","book":"Psa","chapter":112,"verse":9,"letter":"c"},{"kind":"crossref","label":"Mt 5:42","book":"Mat","chapter":5,"verse":42,"letter":"d"}],"crossRefs":[{"label":"Dt 15:8","book":"Deu","chapter":15,"verse":8},{"label":"Ps 112:5","book":"Psa","chapter":112,"verse":5},{"label":"Ps 112:9","book":"Psa","chapter":112,"verse":9},{"label":"Mt 5:42","book":"Mat","chapter":5,"verse":42}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:27","parts":[{"kind":"text","text":"Turn away from evil, do what is good,"},{"kind":"text","text":" and settle permanently. "},{"kind":"crossref","label":"Ps 34:14","book":"Psa","chapter":34,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ps 102:28","book":"Psa","chapter":102,"verse":28,"letter":"b"}],"crossRefs":[{"label":"Ps 34:14","book":"Psa","chapter":34,"verse":14},{"label":"Ps 102:28","book":"Psa","chapter":102,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:28","parts":[{"kind":"text","text":"For the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" loves justice"},{"kind":"text","text":" and will not abandon his faithful ones. "},{"kind":"crossref","label":"Dt 31:6","book":"Deu","chapter":31,"verse":6,"letter":"a"},{"kind":"crossref","label":"Heb 13:5","book":"Heb","chapter":13,"verse":5,"letter":"b"},{"kind":"text","text":" They are kept safe forever,"},{"kind":"text","text":" but the children of the wicked will be destroyed. "},{"kind":"crossref","label":"Ps 21:10","book":"Psa","chapter":21,"verse":10,"letter":"a"},{"kind":"crossref","label":"Pr 2:22","book":"Pro","chapter":2,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Dt 31:6","book":"Deu","chapter":31,"verse":6},{"label":"Heb 13:5","book":"Heb","chapter":13,"verse":5},{"label":"Ps 21:10","book":"Psa","chapter":21,"verse":10},{"label":"Pr 2:22","book":"Pro","chapter":2,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:29","parts":[{"kind":"text","text":"The righteous will inherit the land"},{"kind":"text","text":" and dwell in it permanently. "},{"kind":"crossref","label":"Pr 2:21","book":"Pro","chapter":2,"verse":21,"letter":"a"},{"kind":"crossref","label":"Is 60:21","book":"Isa","chapter":60,"verse":21,"letter":"b"}],"crossRefs":[{"label":"Pr 2:21","book":"Pro","chapter":2,"verse":21},{"label":"Is 60:21","book":"Isa","chapter":60,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:30","parts":[{"kind":"text","text":"The mouth of the righteous utters wisdom;"},{"kind":"text","text":" his tongue speaks what is just. "},{"kind":"crossref","label":"Ps 49:3","book":"Psa","chapter":49,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ps 119:13","book":"Psa","chapter":119,"verse":13,"letter":"b"},{"kind":"crossref","label":"Pr 10:13","book":"Pro","chapter":10,"verse":13,"letter":"c"}],"crossRefs":[{"label":"Ps 49:3","book":"Psa","chapter":49,"verse":3},{"label":"Ps 119:13","book":"Psa","chapter":119,"verse":13},{"label":"Pr 10:13","book":"Pro","chapter":10,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:31","parts":[{"kind":"text","text":"The instruction of his God is in his heart;"},{"kind":"text","text":" his steps do not falter. "},{"kind":"crossref","label":"Dt 6:6","book":"Deu","chapter":6,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 40:8","book":"Psa","chapter":40,"verse":8,"letter":"b"},{"kind":"crossref","label":"Ps 119:11","book":"Psa","chapter":119,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Dt 6:6","book":"Deu","chapter":6,"verse":6},{"label":"Ps 40:8","book":"Psa","chapter":40,"verse":8},{"label":"Ps 119:11","book":"Psa","chapter":119,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:32","parts":[{"kind":"text","text":"The wicked one lies in wait for the righteous"},{"kind":"text","text":" and intends to kill him; "},{"kind":"crossref","label":"Ps 10:8","book":"Psa","chapter":10,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 17:11","book":"Psa","chapter":17,"verse":11,"letter":"b"}],"crossRefs":[{"label":"Ps 10:8","book":"Psa","chapter":10,"verse":8},{"label":"Ps 17:11","book":"Psa","chapter":17,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:33","parts":[{"kind":"text","text":"the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will not leave him"},{"kind":"text","text":" in the power of the wicked one"},{"kind":"text","text":" or allow him to be condemned when he is judged. "},{"kind":"crossref","label":"Ps 34:22","book":"Psa","chapter":34,"verse":22,"letter":"a"},{"kind":"crossref","label":"Ps 109:31","book":"Psa","chapter":109,"verse":31,"letter":"b"},{"kind":"crossref","label":"2Pt 2:9","book":"2Pe","chapter":2,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Ps 34:22","book":"Psa","chapter":34,"verse":22},{"label":"Ps 109:31","book":"Psa","chapter":109,"verse":31},{"label":"2Pt 2:9","book":"2Pe","chapter":2,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:34","parts":[{"kind":"text","text":"Wait for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" and keep his way,"},{"kind":"text","text":" and he will exalt you to inherit the land."},{"kind":"text","text":" You will watch when the wicked are destroyed. "},{"kind":"crossref","label":"Ps 27:14","book":"Psa","chapter":27,"verse":14,"letter":"a"},{"kind":"crossref","label":"Ps 52:5–6","book":"Psa","chapter":52,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 91:8","book":"Psa","chapter":91,"verse":8,"letter":"c"}],"crossRefs":[{"label":"Ps 27:14","book":"Psa","chapter":27,"verse":14},{"label":"Ps 52:5–6","book":"Psa","chapter":52,"verse":5},{"label":"Ps 91:8","book":"Psa","chapter":91,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:35","parts":[{"kind":"text","text":"I have seen a wicked, violent person"},{"kind":"text","text":" well-rooted, "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"text","text":" like a flourishing native tree. "},{"kind":"crossref","label":"Jb 5:3","book":"Job","chapter":5,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 12:2","book":"Jer","chapter":12,"verse":2,"letter":"b"}],"crossRefs":[{"label":"Jb 5:3","book":"Job","chapter":5,"verse":3},{"label":"Jr 12:2","book":"Jer","chapter":12,"verse":2}],"footnotes":[{"marker":1,"text":"Hb obscure"}]},{"verseId":"a556c5305ee15c3f-01:Psa:37:36","parts":[{"kind":"text","text":"Then I "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Vg, Jer; MT reads he"},{"kind":"text","text":" passed by and noticed he was gone;"},{"kind":"text","text":" I searched for him, but he could not be found. "},{"kind":"crossref","label":"Jb 20:5","book":"Job","chapter":20,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Jb 20:5","book":"Job","chapter":20,"verse":5}],"footnotes":[{"marker":1,"text":"LXX, Syr, Vg, Jer; MT reads he"}]},{"verseId":"a556c5305ee15c3f-01:Psa:37:37","parts":[{"kind":"text","text":"Watch the blameless and observe the upright,"},{"kind":"text","text":" for the person of peace will have a future. "},{"kind":"footnote","marker":1,"text":"Or posterity, also in v. 38"},{"kind":"crossref","label":"Is 57:1–2","book":"Isa","chapter":57,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Is 57:1–2","book":"Isa","chapter":57,"verse":1}],"footnotes":[{"marker":1,"text":"Or posterity, also in v. 38"}]},{"verseId":"a556c5305ee15c3f-01:Psa:37:38","parts":[{"kind":"text","text":"But transgressors will all be eliminated;"},{"kind":"text","text":" the future of the wicked will be destroyed. "},{"kind":"crossref","label":"Ps 1:4–6","book":"Psa","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Pr 2:22","book":"Pro","chapter":2,"verse":22,"letter":"b"}],"crossRefs":[{"label":"Ps 1:4–6","book":"Psa","chapter":1,"verse":4},{"label":"Pr 2:22","book":"Pro","chapter":2,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:39","parts":[{"kind":"text","text":"The salvation of the righteous is from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":","},{"kind":"text","text":" their refuge in a time of distress. "},{"kind":"crossref","label":"Ps 3:8","book":"Psa","chapter":3,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 9:9","book":"Psa","chapter":9,"verse":9,"letter":"b"},{"kind":"crossref","label":"Ps 62:1","book":"Psa","chapter":62,"verse":1,"letter":"c"}],"crossRefs":[{"label":"Ps 3:8","book":"Psa","chapter":3,"verse":8},{"label":"Ps 9:9","book":"Psa","chapter":9,"verse":9},{"label":"Ps 62:1","book":"Psa","chapter":62,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:37:40","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" helps and delivers them;"},{"kind":"text","text":" he will deliver them from the wicked and will save them"},{"kind":"text","text":" because they take refuge in him. "},{"kind":"crossref","label":"Ps 22:4","book":"Psa","chapter":22,"verse":4,"letter":"a"},{"kind":"crossref","label":"Ps 34:22","book":"Psa","chapter":34,"verse":22,"letter":"b"},{"kind":"crossref","label":"Ps 54:4","book":"Psa","chapter":54,"verse":4,"letter":"c"}],"crossRefs":[{"label":"Ps 22:4","book":"Psa","chapter":22,"verse":4},{"label":"Ps 34:22","book":"Psa","chapter":34,"verse":22},{"label":"Ps 54:4","book":"Psa","chapter":54,"verse":4}],"footnotes":[]}]},"cachedAt":1783279490045}