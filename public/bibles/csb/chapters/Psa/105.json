ok":"Gen","chapter":28,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:11","parts":[{"kind":"text","text":"“I will give the land of Canaan to you"},{"kind":"text","text":" as your inherited portion.” "},{"kind":"crossref","label":"Gn 13:15","book":"Gen","chapter":13,"verse":15,"letter":"a"},{"kind":"crossref","label":"Gn 15:18","book":"Gen","chapter":15,"verse":18,"letter":"b"},{"kind":"crossref","label":"Ps 78:55","book":"Psa","chapter":78,"verse":55,"letter":"c"}],"crossRefs":[{"label":"Gn 13:15","book":"Gen","chapter":13,"verse":15},{"label":"Gn 15:18","book":"Gen","chapter":15,"verse":18},{"label":"Ps 78:55","book":"Psa","chapter":78,"verse":55}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:12","parts":[{"kind":"text","text":"When they were few in number,"},{"kind":"text","text":" very few indeed,"},{"kind":"text","text":" and resident aliens in Canaan, "},{"kind":"crossref","label":"Gn 34:30","book":"Gen","chapter":34,"verse":30,"letter":"a"},{"kind":"crossref","label":"Dt 7:7","book":"Deu","chapter":7,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Gn 34:30","book":"Gen","chapter":34,"verse":30},{"label":"Dt 7:7","book":"Deu","chapter":7,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:13","parts":[{"kind":"text","text":"wandering from nation to nation"},{"kind":"text","text":" and from one kingdom to another, "},{"kind":"crossref","label":"Dt 26:5","book":"Deu","chapter":26,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Dt 26:5","book":"Deu","chapter":26,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:14","parts":[{"kind":"text","text":"he allowed no one to oppress them;"},{"kind":"text","text":" he rebuked kings on their behalf: "},{"kind":"crossref","label":"Gn 12:17","book":"Gen","chapter":12,"verse":17,"letter":"a"},{"kind":"crossref","label":"Gn 20:3","book":"Gen","chapter":20,"verse":3,"letter":"b"},{"kind":"crossref","label":"Gn 20:7","book":"Gen","chapter":20,"verse":7,"letter":"c"}],"crossRefs":[{"label":"Gn 12:17","book":"Gen","chapter":12,"verse":17},{"label":"Gn 20:3","book":"Gen","chapter":20,"verse":3},{"label":"Gn 20:7","book":"Gen","chapter":20,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:15","parts":[{"kind":"text","text":"“Do not touch my anointed ones, "},{"kind":"crossref","label":"Gn 20:6–7","book":"Gen","chapter":20,"verse":6,"letter":"a"},{"kind":"crossref","label":"Gn 26:11","book":"Gen","chapter":26,"verse":11,"letter":"b"},{"kind":"text","text":" or harm my prophets.” "},{"kind":"crossref","label":"1Ch 16:8–22","book":"1Ch","chapter":16,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Gn 20:6–7","book":"Gen","chapter":20,"verse":6},{"label":"Gn 26:11","book":"Gen","chapter":26,"verse":11},{"label":"1Ch 16:8–22","book":"1Ch","chapter":16,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:16","parts":[{"kind":"text","text":"He called down famine against the land"},{"kind":"text","text":" and destroyed the entire food supply. "},{"kind":"crossref","label":"Gn 41:54","book":"Gen","chapter":41,"verse":54,"letter":"a"},{"kind":"crossref","label":"Lv 26:26","book":"Lev","chapter":26,"verse":26,"letter":"b"},{"kind":"crossref","label":"Ezk 4:16","book":"Ezk","chapter":4,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Gn 41:54","book":"Gen","chapter":41,"verse":54},{"label":"Lv 26:26","book":"Lev","chapter":26,"verse":26},{"label":"Ezk 4:16","book":"Ezk","chapter":4,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:17","parts":[{"kind":"text","text":"He had sent a man ahead of them —"},{"kind":"text","text":" Joseph, who was sold as a slave. "},{"kind":"crossref","label":"Gn 37:28–36","book":"Gen","chapter":37,"verse":28,"letter":"a"},{"kind":"crossref","label":"Gn 45:5","book":"Gen","chapter":45,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ac 7:9","book":"Act","chapter":7,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Gn 37:28–36","book":"Gen","chapter":37,"verse":28},{"label":"Gn 45:5","book":"Gen","chapter":45,"verse":5},{"label":"Ac 7:9","book":"Act","chapter":7,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:18","parts":[{"kind":"text","text":"They hurt his feet with shackles;"},{"kind":"text","text":" his neck was put in an iron collar. "},{"kind":"crossref","label":"Gn 39:20","book":"Gen","chapter":39,"verse":20,"letter":"a"}],"crossRefs":[{"label":"Gn 39:20","book":"Gen","chapter":39,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:19","parts":[{"kind":"text","text":"Until the time his prediction came true,"},{"kind":"text","text":" the word of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" tested him. "},{"kind":"crossref","label":"Gn 40:20–21","book":"Gen","chapter":40,"verse":20,"letter":"a"}],"crossRefs":[{"label":"Gn 40:20–21","book":"Gen","chapter":40,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:20","parts":[{"kind":"text","text":"The king sent for him and released him;"},{"kind":"text","text":" the ruler of peoples set him free. "},{"kind":"crossref","label":"Gn 41:14","book":"Gen","chapter":41,"verse":14,"letter":"a"}],"crossRefs":[{"label":"Gn 41:14","book":"Gen","chapter":41,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:21","parts":[{"kind":"text","text":"He made him master of his household,"},{"kind":"text","text":" ruler over all his possessions "},{"kind":"crossref","label":"Gn 41:40–43","book":"Gen","chapter":41,"verse":40,"letter":"a"},{"kind":"text","text":" —"}],"crossRefs":[{"label":"Gn 41:40–43","book":"Gen","chapter":41,"verse":40}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:22","parts":[{"kind":"text","text":"binding "},{"kind":"footnote","marker":1,"text":"LXX, Syr, Vg read teaching"},{"kind":"text","text":" his officials at will"},{"kind":"text","text":" and instructing his elders. "},{"kind":"crossref","label":"Gn 41:44","book":"Gen","chapter":41,"verse":44,"letter":"a"}],"crossRefs":[{"label":"Gn 41:44","book":"Gen","chapter":41,"verse":44}],"footnotes":[{"marker":1,"text":"LXX, Syr, Vg read teaching"}]},{"verseId":"a556c5305ee15c3f-01:Psa:105:23","parts":[{"kind":"text","text":"Then Israel went to Egypt;"},{"kind":"text","text":" Jacob lived as an alien in the land of Ham. "},{"kind":"footnote","marker":1,"text":"= Egypt, also in v. 27"},{"kind":"crossref","label":"Gn 46:6","book":"Gen","chapter":46,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ac 7:15","book":"Act","chapter":7,"verse":15,"letter":"b"},{"kind":"crossref","label":"Ac 13:17","book":"Act","chapter":13,"verse":17,"letter":"c"}],"crossRefs":[{"label":"Gn 46:6","book":"Gen","chapter":46,"verse":6},{"label":"Ac 7:15","book":"Act","chapter":7,"verse":15},{"label":"Ac 13:17","book":"Act","chapter":13,"verse":17}],"footnotes":[{"marker":1,"text":"= Egypt, also in v. 27"}]},{"verseId":"a556c5305ee15c3f-01:Psa:105:24","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"footnote","marker":1,"text":"Lit He"},{"kind":"text","text":" made his people very fruitful;"},{"kind":"text","text":" he made them more numerous than their foes, "},{"kind":"crossref","label":"Ex 1:7","book":"Exo","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ex 1:9","book":"Exo","chapter":1,"verse":9,"letter":"b"},{"kind":"crossref","label":"Dt 26:5","book":"Deu","chapter":26,"verse":5,"letter":"c"}],"crossRefs":[{"label":"Ex 1:7","book":"Exo","chapter":1,"verse":7},{"label":"Ex 1:9","book":"Exo","chapter":1,"verse":9},{"label":"Dt 26:5","book":"Deu","chapter":26,"verse":5}],"footnotes":[{"marker":1,"text":"Lit He"}]},{"verseId":"a556c5305ee15c3f-01:Psa:105:25","parts":[{"kind":"text","text":"whose hearts he turned to hate his people"},{"kind":"text","text":" and to deal deceptively with his servants. "},{"kind":"crossref","label":"Ex 1:8–14","book":"Exo","chapter":1,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ac 7:19","book":"Act","chapter":7,"verse":19,"letter":"b"}],"crossRefs":[{"label":"Ex 1:8–14","book":"Exo","chapter":1,"verse":8},{"label":"Ac 7:19","book":"Act","chapter":7,"verse":19}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:26","parts":[{"kind":"text","text":"He sent Moses his servant,"},{"kind":"text","text":" and Aaron, whom he had chosen. "},{"kind":"crossref","label":"Ex 3:10","book":"Exo","chapter":3,"verse":10,"letter":"a"},{"kind":"crossref","label":"Ex 4:12","book":"Exo","chapter":4,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ex 4:14","book":"Exo","chapter":4,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Ex 3:10","book":"Exo","chapter":3,"verse":10},{"label":"Ex 4:12","book":"Exo","chapter":4,"verse":12},{"label":"Ex 4:14","book":"Exo","chapter":4,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:27","parts":[{"kind":"text","text":"They performed his miraculous signs among them"},{"kind":"text","text":" and wonders in the land of Ham. "},{"kind":"crossref","label":"Ex 7:3","book":"Exo","chapter":7,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ex 11:9–10","book":"Exo","chapter":11,"verse":9,"letter":"b"},{"kind":"crossref","label":"Ps 78:43–51","book":"Psa","chapter":78,"verse":43,"letter":"c"}],"crossRefs":[{"label":"Ex 7:3","book":"Exo","chapter":7,"verse":3},{"label":"Ex 11:9–10","book":"Exo","chapter":11,"verse":9},{"label":"Ps 78:43–51","book":"Psa","chapter":78,"verse":43}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:28","parts":[{"kind":"text","text":"He sent darkness, and it became dark —"},{"kind":"text","text":" for did they not defy his commands? "},{"kind":"crossref","label":"Ex 10:21–23","book":"Exo","chapter":10,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 99:7","book":"Psa","chapter":99,"verse":7,"letter":"b"}],"crossRefs":[{"label":"Ex 10:21–23","book":"Exo","chapter":10,"verse":21},{"label":"Ps 99:7","book":"Psa","chapter":99,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:29","parts":[{"kind":"text","text":"He turned their water into blood"},{"kind":"text","text":" and caused their fish to die. "},{"kind":"crossref","label":"Ex 7:20–21","book":"Exo","chapter":7,"verse":20,"letter":"a"}],"crossRefs":[{"label":"Ex 7:20–21","book":"Exo","chapter":7,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:30","parts":[{"kind":"text","text":"Their land was overrun with frogs,"},{"kind":"text","text":" even in their royal chambers. "},{"kind":"crossref","label":"Ex 8:3","book":"Exo","chapter":8,"verse":3,"letter":"a"},{"kind":"crossref","label":"Ex 8:6","book":"Exo","chapter":8,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Ex 8:3","book":"Exo","chapter":8,"verse":3},{"label":"Ex 8:6","book":"Exo","chapter":8,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:31","parts":[{"kind":"text","text":"He spoke, and insects came "},{"kind":"crossref","label":"Ex 8:21","book":"Exo","chapter":8,"verse":21,"letter":"a"},{"kind":"text","text":" —"},{"kind":"text","text":" gnats throughout their country. "},{"kind":"crossref","label":"Ex 8:16–17","book":"Exo","chapter":8,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Ex 8:21","book":"Exo","chapter":8,"verse":21},{"label":"Ex 8:16–17","book":"Exo","chapter":8,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:32","parts":[{"kind":"text","text":"He gave them hail for rain,"},{"kind":"text","text":" and lightning throughout their land. "},{"kind":"crossref","label":"Ex 9:23–25","book":"Exo","chapter":9,"verse":23,"letter":"a"}],"crossRefs":[{"label":"Ex 9:23–25","book":"Exo","chapter":9,"verse":23}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:33","parts":[{"kind":"text","text":"He struck their vines and fig trees"},{"kind":"text","text":" and shattered the trees of their territory. "},{"kind":"crossref","label":"Ps 78:47","book":"Psa","chapter":78,"verse":47,"letter":"a"}],"crossRefs":[{"label":"Ps 78:47","book":"Psa","chapter":78,"verse":47}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:34","parts":[{"kind":"text","text":"He spoke, and locusts came —"},{"kind":"text","text":" young locusts without number."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:35","parts":[{"kind":"text","text":"They devoured all the vegetation in their land"},{"kind":"text","text":" and consumed the produce of their land. "},{"kind":"crossref","label":"Ex 10:12–15","book":"Exo","chapter":10,"verse":12,"letter":"a"}],"crossRefs":[{"label":"Ex 10:12–15","book":"Exo","chapter":10,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:36","parts":[{"kind":"text","text":"He struck all the firstborn in their land,"},{"kind":"text","text":" all their first progeny. "},{"kind":"crossref","label":"Ex 12:29","book":"Exo","chapter":12,"verse":29,"letter":"a"},{"kind":"crossref","label":"Ex 13:15","book":"Exo","chapter":13,"verse":15,"letter":"b"},{"kind":"crossref","label":"Ps 78:51","book":"Psa","chapter":78,"verse":51,"letter":"c"}],"crossRefs":[{"label":"Ex 12:29","book":"Exo","chapter":12,"verse":29},{"label":"Ex 13:15","book":"Exo","chapter":13,"verse":15},{"label":"Ps 78:51","book":"Psa","chapter":78,"verse":51}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:37","parts":[{"kind":"text","text":"Then he brought Israel out with silver and gold,"},{"kind":"text","text":" and no one among his tribes stumbled. "},{"kind":"crossref","label":"Ex 12:35–36","book":"Exo","chapter":12,"verse":35,"letter":"a"}],"crossRefs":[{"label":"Ex 12:35–36","book":"Exo","chapter":12,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:38","parts":[{"kind":"text","text":"Egypt was glad when they left,"},{"kind":"text","text":" for the dread of Israel "},{"kind":"footnote","marker":1,"text":"Lit them"},{"kind":"text","text":" had fallen on them. "},{"kind":"crossref","label":"Ex 12:33","book":"Exo","chapter":12,"verse":33,"letter":"a"},{"kind":"crossref","label":"Ex 15:16","book":"Exo","chapter":15,"verse":16,"letter":"b"}],"crossRefs":[{"label":"Ex 12:33","book":"Exo","chapter":12,"verse":33},{"label":"Ex 15:16","book":"Exo","chapter":15,"verse":16}],"footnotes":[{"marker":1,"text":"Lit them"}]},{"verseId":"a556c5305ee15c3f-01:Psa:105:39","parts":[{"kind":"text","text":"He spread a cloud as a covering"},{"kind":"text","text":" and gave a fire to light up the night. "},{"kind":"crossref","label":"Ex 13:21","book":"Exo","chapter":13,"verse":21,"letter":"a"},{"kind":"crossref","label":"Neh 9:12","book":"Neh","chapter":9,"verse":12,"letter":"b"},{"kind":"crossref","label":"Ps 78:14","book":"Psa","chapter":78,"verse":14,"letter":"c"}],"crossRefs":[{"label":"Ex 13:21","book":"Exo","chapter":13,"verse":21},{"label":"Neh 9:12","book":"Neh","chapter":9,"verse":12},{"label":"Ps 78:14","book":"Psa","chapter":78,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:40","parts":[{"kind":"text","text":"They asked, and he brought quail"},{"kind":"text","text":" and satisfied them with bread from heaven. "},{"kind":"crossref","label":"Ex 16:15","book":"Exo","chapter":16,"verse":15,"letter":"a"},{"kind":"crossref","label":"Ps 78:24","book":"Psa","chapter":78,"verse":24,"letter":"b"}],"crossRefs":[{"label":"Ex 16:15","book":"Exo","chapter":16,"verse":15},{"label":"Ps 78:24","book":"Psa","chapter":78,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:41","parts":[{"kind":"text","text":"He opened a rock, and water gushed out;"},{"kind":"text","text":" it flowed like a stream in the desert. "},{"kind":"crossref","label":"Ex 17:6","book":"Exo","chapter":17,"verse":6,"letter":"a"},{"kind":"crossref","label":"Nm 20:11","book":"Num","chapter":20,"verse":11,"letter":"b"},{"kind":"crossref","label":"Ps 78:15","book":"Psa","chapter":78,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Ex 17:6","book":"Exo","chapter":17,"verse":6},{"label":"Nm 20:11","book":"Num","chapter":20,"verse":11},{"label":"Ps 78:15","book":"Psa","chapter":78,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:42","parts":[{"kind":"text","text":"For he remembered his holy promise"},{"kind":"text","text":" to Abraham his servant. "},{"kind":"crossref","label":"Ex 2:24","book":"Exo","chapter":2,"verse":24,"letter":"a"}],"crossRefs":[{"label":"Ex 2:24","book":"Exo","chapter":2,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:43","parts":[{"kind":"text","text":"He brought his people out with rejoicing,"},{"kind":"text","text":" his chosen ones with shouts of joy. "},{"kind":"crossref","label":"Ex 15:1","book":"Exo","chapter":15,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 106:12","book":"Psa","chapter":106,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Ex 15:1","book":"Exo","chapter":15,"verse":1},{"label":"Ps 106:12","book":"Psa","chapter":106,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:44","parts":[{"kind":"text","text":"He gave them the lands of the nations,"},{"kind":"text","text":" and they inherited"},{"kind":"text","text":" what other peoples had worked for. "},{"kind":"crossref","label":"Jos 24:13","book":"Jos","chapter":24,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 78:55","book":"Psa","chapter":78,"verse":55,"letter":"b"}],"crossRefs":[{"label":"Jos 24:13","book":"Jos","chapter":24,"verse":13},{"label":"Ps 78:55","book":"Psa","chapter":78,"verse":55}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:105:45","parts":[{"kind":"text","text":"All this happened"},{"kind":"text","text":" so that they might keep his statutes"},{"kind":"text","text":" and obey his instructions. "},{"kind":"crossref","label":"Dt 4:1","book":"Deu","chapter":4,"verse":1,"letter":"a"},{"kind":"crossref","label":"Dt 4:40","book":"Deu","chapter":4,"verse":40,"letter":"b"},{"kind":"crossref","label":"Ps 78:7","book":"Psa","chapter":78,"verse":7,"letter":"c"},{"kind":"text","text":" Hallelujah!"}],"crossRefs":[{"label":"Dt 4:1","book":"Deu","chapter":4,"verse":1},{"label":"Dt 4:40","book":"Deu","chapter":4,"verse":40},{"label":"Ps 78:7","book":"Psa","chapter":78,"verse":7}],"footnotes":[]}]},"cachedAt":1783279509874}