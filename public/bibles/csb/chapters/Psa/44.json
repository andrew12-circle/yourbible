ace, "},{"kind":"crossref","label":"2Ch 32:21","book":"2Ch","chapter":32,"verse":21,"letter":"a"},{"kind":"crossref","label":"Ps 69:7","book":"Psa","chapter":69,"verse":7,"letter":"b"}],"crossRefs":[{"label":"2Ch 32:21","book":"2Ch","chapter":32,"verse":21},{"label":"Ps 69:7","book":"Psa","chapter":69,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:44:16","parts":[{"kind":"text","text":"because of the taunts "},{"kind":"footnote","marker":1,"text":"Lit voice"},{"kind":"text","text":" of the scorner and reviler,"},{"kind":"text","text":" because of the enemy and avenger. "},{"kind":"crossref","label":"Ps 8:2","book":"Psa","chapter":8,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ps 74:10","book":"Psa","chapter":74,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Ps 8:2","book":"Psa","chapter":8,"verse":2},{"label":"Ps 74:10","book":"Psa","chapter":74,"verse":10}],"footnotes":[{"marker":1,"text":"Lit voice"}]},{"verseId":"a556c5305ee15c3f-01:Psa:44:17","parts":[{"kind":"text","text":"All this has happened to us,"},{"kind":"text","text":" but we have not forgotten you"},{"kind":"text","text":" or betrayed your covenant. "},{"kind":"crossref","label":"Ps 119:61","book":"Psa","chapter":119,"verse":61,"letter":"a"},{"kind":"crossref","label":"Ps 119:153","book":"Psa","chapter":119,"verse":153,"letter":"b"}],"crossRefs":[{"label":"Ps 119:61","book":"Psa","chapter":119,"verse":61},{"label":"Ps 119:153","book":"Psa","chapter":119,"verse":153}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:44:18","parts":[{"kind":"text","text":"Our hearts have not turned back;"},{"kind":"text","text":" our steps have not strayed from your path. "},{"kind":"crossref","label":"Jb 23:11","book":"Job","chapter":23,"verse":11,"letter":"a"},{"kind":"crossref","label":"Ps 37:31","book":"Psa","chapter":37,"verse":31,"letter":"b"},{"kind":"crossref","label":"Ps 119:51","book":"Psa","chapter":119,"verse":51,"letter":"c"},{"kind":"crossref","label":"Ps 119:157","book":"Psa","