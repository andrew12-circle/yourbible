":"Jb 8:13","book":"Job","chapter":8,"verse":13},{"label":"Ps 9:17","book":"Psa","chapter":9,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Psa:50:23","parts":[{"kind":"text","text":"Whoever offers a thanksgiving sacrifice honors me,"},{"kind":"text","text":" and whoever orders his conduct,"},{"kind":"text","text":" I will show him the salvation of God.” "},{"kind":"crossref","label":"Ps 85:13","book":"Psa","chapter":85,"verse":13,"letter":"a"},{"kind":"crossref","label":"Ps 91:16","book":"Psa","chapter":91,"verse":16,"letter":"b"},{"kind":"crossref","label":"Gl 6:16","book":"Gal","chapter":6,"verse":16,"letter":"c"}],"crossRefs":[{"label":"Ps 85:13","book":"Psa","chapter":85,"verse":13},{"label":"Ps 91:16","book":"Psa","chapter":91,"verse":16},{"label":"Gl 6:16","book":"Gal","chapter":6,"verse":16}],"footnotes":[]}]},"cachedAt":1783279493816}