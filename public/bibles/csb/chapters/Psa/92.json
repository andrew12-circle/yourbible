{"key":"a556c5305ee15c3f-01|Psa|92","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":92,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:92:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":1,"text":"It is good to give thanks to the Lord, to sing praise to your name, Most High,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":2,"text":"to declare your faithful love in the morning and your faithfulness at night,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":3,"text":"with a ten-stringed harp and the music of a lyre.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":4,"text":"For you have made me rejoice, Lord, by what you have done; I will shout for joy because of the works of your hands.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":5,"text":"How magnificent are your works, Lord, how profound your thoughts!","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":6,"text":"A stupid person does not know, a fool does not understand this:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":7,"text":"though the wicked sprout like grass and all evildoers flourish, they will be eternally destroyed.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":8,"text":"But you, Lord, are exalted forever.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":9,"text":"For indeed, Lord, your enemies — indeed, your enemies will perish; all evildoers will be scattered.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":10,"text":"You have lifted up my horn like that of a wild ox; I have been anointed with the finest oil.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":11,"text":"My eyes look at my enemies; when evildoers rise against me, my ears hear them.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":12,"text":"The righteous thrive like a palm tree and grow like a cedar tree in Lebanon.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":13,"text":"Planted in the house of the Lord, they thrive in the courts of our God.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":14,"text":"They will still bear fruit in old age, healthy and green,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:92:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":92,"verse":15,"text":"to declare, “The Lord is just; he is my rock, and there is no unrighteousness in him.”","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","