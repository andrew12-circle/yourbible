{"key":"a556c5305ee15c3f-01|Psa|138","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":138,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:Psa:138:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":1,"text":"I will give you thanks with all my heart; I will sing your praise before the heavenly beings.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":2,"text":"I will bow down toward your holy temple and give thanks to your name for your constant love and truth. You have exalted your name and your promise above everything else.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":3,"text":"On the day I called, you answered me; you increased strength within me.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":4,"text":"All the kings on earth will give you thanks, Lord, when they hear what you have promised.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":5,"text":"They will sing of the Lord’s ways, for the Lord’s glory is great.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":6,"text":"Though the Lord is exalted, he takes note of the humble; but he knows the haughty from a distance.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":7,"text":"If I walk into the thick of danger, you will preserve my life from the anger of my enemies. You will extend your hand; your right hand will save me.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Psa:138:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","bookOrder":18,"chapter":138,"verse":8,"text":"The Lord will fulfill his purpose for me. Lord, your faithful love endures forever; do not abandon the work of your hands.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Psa","chapter":138,"paragraphStarts":[1,2,3,4,5,6,7,8],"headings":[{"beforeVerse":1,"text":"Of David."}],"poetryBlocks":[{"beforeVerse":1,"level":1},{"beforeVerse":2,"level":1},{"beforeVerse":3,"level":1},{"beforeVerse":4,"level":1},{"beforeVerse":5,"level":1},{"beforeVerse":6,"level":1},{"beforeVerse":7,"level":1},{"beforeVerse":8,"level":1}],"studyByVerse":[{"verseId":"a556c5305ee15c3f-01:Psa:138:1","parts":[{"kind":"text","text":"I will give you thanks with all my heart; "},{"kind":"crossref","label":"Ps 111:1","book":"Psa","chapter":111,"verse":1,"letter":"a"},{"kind":"text","text":" I will sing your praise before the heavenly beings. "},{"kind":"footnote","marker":1,"text":"Or before the gods, or before judges, or before kings; Hb elohim"},{"kind":"crossref","label":"Ps 82:1","book":"Psa","chapter":82,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 82:6","book":"Psa","chapter":82,"verse":6,"letter":"b"},{"kind":"crossref","label":"Ps 95:3","book":"Psa","chapter":95,"verse":3,"letter":"c"},{"kind":"crossref","label":"Ps 96:5","book":"Psa","chapter":96,"verse":5,"letter":"d"}],"crossRefs":[{"label":"Ps 111:1","book":"Psa","chapter":111,"verse":1},{"label":"Ps 82:1","book":"Psa","chapter":82,"verse":1},{"label":"Ps 82:6","book":"Psa","chapter":82,"verse":6},{"label":"Ps 95:3","book":"Psa","chapter":95,"verse":3},{"label":"Ps 96:5","book":"Psa","chapter":96,"verse":5}],"footnotes":[{"marker":1,"text":"Or before the gods, or before judges, or before kings; Hb elohim