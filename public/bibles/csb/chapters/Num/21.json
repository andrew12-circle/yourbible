1Co 10:9","book":"1Co","chapter":10,"verse":9}],"footnotes":[{"marker":1,"text":"Lit Burning"}]},{"verseId":"a556c5305ee15c3f-01:Num:21:7","parts":[{"kind":"text","text":"The people then came to Moses and said, “We have sinned by speaking against the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" and against you. Intercede with the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" so that he will take the snakes away from us.” And Moses interceded for the people."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:8","parts":[{"kind":"text","text":"Then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said to Moses, “Make a snake image and mount it on a pole. When anyone who is bitten looks at it, he will recover.” "},{"kind":"crossref","label":"2Kg 18:4","book":"2Ki","chapter":18,"verse":4,"letter":"a"},{"kind":"crossref","label":"Jn 3:14–15","book":"Jhn","chapter":3,"verse":14,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Kg 18:4","book":"2Ki","chapter":18,"verse":4},{"label":"Jn 3:14–15","book":"Jhn","chapter":3,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:9","parts":[{"kind":"text","text":"So Moses made a bronze snake and mounted it on a pole. Whenever someone was bitten, and he looked at the bronze snake, he recovered."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:10","parts":[{"kind":"text","text":"The Israelites set out and camped at Oboth. "},{"kind":"crossref","label":"Nm 33:43","book":"Num","chapter":33,"verse":43,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 33:43","book":"Num","chapter":33,"verse":43}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:11","parts":[{"kind":"text","text":"They set out from Oboth and camped at Iye-abarim in the wilderness that borders Moab on the east. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:12","parts":[{"kind":"text","text":"From there they went and camped at Zered Valley. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:13","parts":[{"kind":"text","text":"They set out from there and camped on the other side of the Arnon River, in the wilderness that extends from the Amorite border, because the Arnon was the Moabite border between Moab and the Amorites. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:14","parts":[{"kind":"text","text":"Therefore it is stated in the Book of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s Wars:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:15","parts":[{"kind":"text","text":"even the slopes of the ravines"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:16","parts":[{"kind":"text","text":"From there they went to Beer, "},{"kind":"footnote","marker":1,"text":"= Well"},{"kind":"text","text":" the well the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" told Moses about, “Gather the people so I may give them water.” "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"= Well"}]},{"verseId":"a556c5305ee15c3f-01:Num:21:17","parts":[{"kind":"text","text":"Then Israel sang this song:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:18","parts":[{"kind":"text","text":"The princes dug the well;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:19","parts":[{"kind":"text","text":"from Mattanah to Nahaliel, from Nahaliel to Bamoth, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:20","parts":[{"kind":"text","text":"from Bamoth to the valley in the territory of Moab near the Pisgah highlands "},{"kind":"crossref","label":"Nm 23:14","book":"Num","chapter":23,"verse":14,"letter":"a"},{"kind":"crossref","label":"Dt 3:17","book":"Deu","chapter":3,"verse":17,"letter":"b"},{"kind":"crossref","label":"Dt 3:27","book":"Deu","chapter":3,"verse":27,"letter":"c"},{"kind":"crossref","label":"Dt 4:49","book":"Deu","chapter":4,"verse":49,"letter":"d"},{"kind":"crossref","label":"Dt 34:1","book":"Deu","chapter":34,"verse":1,"letter":"e"},{"kind":"crossref","label":"Jos 12:3","book":"Jos","chapter":12,"verse":3,"letter":"f"},{"kind":"crossref","label":"Jos 13:20","book":"Jos","chapter":13,"verse":20,"letter":"g"},{"kind":"text","text":" that overlook the wasteland. "},{"kind":"footnote","marker":1,"text":"Or overlook Jeshimon"},{"kind":"crossref","label":"Nm 23:28","book":"Num","chapter":23,"verse":28,"letter":"h"}],"crossRefs":[{"label":"Nm 23:14","book":"Num","chapter":23,"verse":14},{"label":"Dt 3:17","book":"Deu","chapter":3,"verse":17},{"label":"Dt 3:27","book":"Deu","chapter":3,"verse":27},{"label":"Dt 4:49","book":"Deu","chapter":4,"verse":49},{"label":"Dt 34:1","book":"Deu","chapter":34,"verse":1},{"label":"Jos 12:3","book":"Jos","chapter":12,"verse":3},{"label":"Jos 13:20","book":"Jos","chapter":13,"verse":20},{"label":"Nm 23:28","book":"Num","chapter":23,"verse":28}],"footnotes":[{"marker":1,"text":"Or overlook Jeshimon"}]},{"verseId":"a556c5305ee15c3f-01:Num:21:21","parts":[{"kind":"text","text":"Israel sent messengers to say to King Sihon "},{"kind":"crossref","label":"Nm 32:33","book":"Num","chapter":32,"verse":33,"letter":"a"},{"kind":"crossref","label":"Dt 1:4","book":"Deu","chapter":1,"verse":4,"letter":"b"},{"kind":"crossref","label":"Dt 2:24–4:46","book":"Deu","chapter":2,"verse":24,"letter":"c"},{"kind":"text","text":" of the Amorites, "}],"crossRefs":[{"label":"Nm 32:33","book":"Num","chapter":32,"verse":33},{"label":"Dt 1:4","book":"Deu","chapter":1,"verse":4},{"label":"Dt 2:24–4:46","book":"Deu","chapter":2,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:22","parts":[{"kind":"text","text":"“Let us travel through your land. We won’t go into the fields or vineyards. We won’t drink any well water. We will travel the King’s Highway until we have traveled through your territory.” "},{"kind":"crossref","label":"Nm 20:17","book":"Num","chapter":20,"verse":17,"letter":"a"},{"kind":"crossref","label":"Dt 2:26","book":"Deu","chapter":2,"verse":26,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 20:17","book":"Num","chapter":20,"verse":17},{"label":"Dt 2:26","book":"Deu","chapter":2,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:23","parts":[{"kind":"text","text":"But Sihon would not let Israel travel through his territory. Instead, he gathered his whole army and went out to confront Israel in the wilderness. When he came to Jahaz, "},{"kind":"crossref","label":"Dt 2:32","book":"Deu","chapter":2,"verse":32,"letter":"a"},{"kind":"crossref","label":"Jdg 11:20","book":"Jdg","chapter":11,"verse":20,"letter":"b"},{"kind":"crossref","label":"1Ch 6:78","book":"1Ch","chapter":6,"verse":78,"letter":"c"},{"kind":"text","text":" he fought against Israel. "}],"crossRefs":[{"label":"Dt 2:32","book":"Deu","chapter":2,"verse":32},{"label":"Jdg 11:20","book":"Jdg","chapter":11,"verse":20},{"label":"1Ch 6:78","book":"1Ch","chapter":6,"verse":78}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:24","parts":[{"kind":"text","text":"Israel struck him with the sword and took possession of his land from the Arnon to the Jabbok, "},{"kind":"crossref","label":"Jdg 11:19–22","book":"Jdg","chapter":11,"verse":19,"letter":"a"},{"kind":"text","text":" but only up to the Ammonite border, because it was fortified. "},{"kind":"footnote","marker":1,"text":"LXX reads because the Ammonite border was Jazer"}],"crossRefs":[{"label":"Jdg 11:19–22","book":"Jdg","chapter":11,"verse":19}],"footnotes":[{"marker":1,"text":"LXX reads because the Ammonite border was Jazer"}]},{"verseId":"a556c5305ee15c3f-01:Num:21:25","parts":[{"kind":"text","text":"Israel took all the cities and lived in all these Amorite cities, including Heshbon and all its surrounding villages. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:26","parts":[{"kind":"text","text":"Heshbon was the city of King Sihon of the Amorites, who had fought against the former king of Moab and had taken control of all his land as far as the Arnon. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:27","parts":[{"kind":"text","text":"Therefore the poets "},{"kind":"footnote","marker":1,"text":"Lit ones who speak proverbs"},{"kind":"text","text":" say:"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit ones who speak proverbs"}]},{"verseId":"a556c5305ee15c3f-01:Num:21:28","parts":[{"kind":"text","text":"For fire came out of Heshbon,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:29","parts":[{"kind":"text","text":"Woe to you, Moab!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:30","parts":[{"kind":"text","text":"We threw them down;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:31","parts":[{"kind":"text","text":"So Israel lived in the Amorites’ land. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:32","parts":[{"kind":"text","text":"After Moses sent spies to Jazer, Israel captured its surrounding villages and drove out the Amorites who were there."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:33","parts":[{"kind":"text","text":"Then they turned and went up the road to Bashan, and King Og of Bashan "},{"kind":"crossref","label":"Nm 32:33","book":"Num","chapter":32,"verse":33,"letter":"a"},{"kind":"crossref","label":"Dt 3:1","book":"Deu","chapter":3,"verse":1,"letter":"b"},{"kind":"crossref","label":"Dt 4:47","book":"Deu","chapter":4,"verse":47,"letter":"c"},{"kind":"text","text":" came out against them with his whole army to do battle at Edrei. "},{"kind":"crossref","label":"Dt 3:1","book":"Deu","chapter":3,"verse":1,"letter":"d"},{"kind":"crossref","label":"Dt 3:10","book":"Deu","chapter":3,"verse":10,"letter":"e"},{"kind":"crossref","label":"Jos 12:4","book":"Jos","chapter":12,"verse":4,"letter":"f"},{"kind":"crossref","label":"Jos 13:12","book":"Jos","chapter":13,"verse":12,"letter":"g"},{"kind":"crossref","label":"Jos 13:31","book":"Jos","chapter":13,"verse":31,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 32:33","book":"Num","chapter":32,"verse":33},{"label":"Dt 3:1","book":"Deu","chapter":3,"verse":1},{"label":"Dt 4:47","book":"Deu","chapter":4,"verse":47},{"label":"Dt 3:1","book":"Deu","chapter":3,"verse":1},{"label":"Dt 3:10","book":"Deu","chapter":3,"verse":10},{"label":"Jos 12:4","book":"Jos","chapter":12,"verse":4},{"label":"Jos 13:12","book":"Jos","chapter":13,"verse":12},{"label":"Jos 13:31","book":"Jos","chapter":13,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:34","parts":[{"kind":"text","text":"But the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" said to Moses, “Do not fear him, for I have handed him over to you along with his whole army and his land. Do to him as you did to King Sihon of the Amorites, who lived in Heshbon.” "},{"kind":"crossref","label":"Dt 3:2","book":"Deu","chapter":3,"verse":2,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Dt 3:2","book":"Deu","chapter":3,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:21:35","parts":[{"kind":"text","text":"So they struck him, his sons, and his whole army until no one was left, "},{"kind":"footnote","marker":1,"text":"Lit left to him"},{"kind":"text","text":" and they took possession of his land. "},{"kind":"crossref","label":"Ps 135:10–11","book":"Psa","chapter":135,"verse":10,"letter":"a"}],"crossRefs":[{"label":"Ps 135:10–11","book":"Psa","chapter":135,"verse":10}],"footnotes":[{"marker":1,"text":"Lit left to him"}]}]},"cachedAt":1783099254057}