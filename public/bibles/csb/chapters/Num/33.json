49,"letter":"d"},{"kind":"crossref","label":"Dt 34:1","book":"Deu","chapter":34,"verse":1,"letter":"e"}],"crossRefs":[{"label":"Nm 27:12","book":"Num","chapter":27,"verse":12},{"label":"Dt 32:49","book":"Deu","chapter":32,"verse":49},{"label":"Jr 22:20","book":"Jer","chapter":22,"verse":20},{"label":"Dt 32:49","book":"Deu","chapter":32,"verse":49},{"label":"Dt 34:1","book":"Deu","chapter":34,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:48","parts":[{"kind":"text","text":"They traveled from the Abarim range and camped on the plains of Moab by the Jordan across from Jericho. "},{"kind":"crossref","label":"Nm 22:1","book":"Num","chapter":22,"verse":1,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 22:1","book":"Num","chapter":22,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:49","parts":[{"kind":"text","text":"They camped by the Jordan from Beth-jeshimoth "},{"kind":"crossref","label":"Jos 12:3","book":"Jos","chapter":12,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jos 13:20","book":"Jos","chapter":13,"verse":20,"letter":"b"},{"kind":"crossref","label":"Ezk 25:9","book":"Ezk","chapter":25,"verse":9,"letter":"c"},{"kind":"text","text":" to the Acacia Meadow "},{"kind":"footnote","marker":1,"text":"Or to Abel-shittim"},{"kind":"crossref","label":"Nm 25:1","book":"Num","chapter":25,"verse":1,"letter":"d"},{"kind":"crossref","label":"Jos 2:1","book":"Jos","chapter":2,"verse":1,"letter":"e"},{"kind":"crossref","label":"Jos 3:1","book":"Jos","chapter":3,"verse":1,"letter":"f"},{"kind":"crossref","label":"Jl 3:18","book":"Jol","chapter":3,"verse":18,"letter":"g"},{"kind":"crossref","label":"Mc 6:5","book":"Mic","chapter":6,"verse":5,"letter":"h"},{"kind":"text","text":" on the plains of Moab."}],"crossRefs":[{"label":"Jos 12:3","book":"Jos","chapter":12,"verse":3},{"label":"Jos 13:20","book":"Jos","chapter":13,"verse":20},{"label":"Ezk 25:9","book":"Ezk","chapter":25,"verse":9},{"label":"Nm 25:1","book":"Num","chapter":25,"verse":1},{"label":"Jos 2:1","book":"Jos","chapter":2,"verse":1},{"label":"Jos 3:1","book":"Jos","chapter":3,"verse":1},{"label":"Jl 3:18","book":"Jol","chapter":3,"verse":18},{"label":"Mc 6:5","book":"Mic","chapter":6,"verse":5}],"footnotes":[{"marker":1,"text":"Or to Abel-shittim"}]},{"verseId":"a556c5305ee15c3f-01:Num:33:50","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" spoke to Moses in the plains of Moab by the Jordan across from Jericho, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:51","parts":[{"kind":"text","text":"“Tell the Israelites: When you cross the Jordan into the land of Canaan, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:52","parts":[{"kind":"text","text":"you must drive out all the inhabitants of the land before you, destroy all their stone images "},{"kind":"crossref","label":"Lv 26:1","book":"Lev","chapter":26,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ezk 8:12","book":"Ezk","chapter":8,"verse":12,"letter":"b"},{"kind":"text","text":" and cast images, "},{"kind":"crossref","label":"Ex 32:4","book":"Exo","chapter":32,"verse":4,"letter":"c"},{"kind":"crossref","label":"Ex 32:8","book":"Exo","chapter":32,"verse":8,"letter":"d"},{"kind":"crossref","label":"Ex 34:17","book":"Exo","chapter":34,"verse":17,"letter":"e"},{"kind":"crossref","label":"Lv 19:4","book":"Lev","chapter":19,"verse":4,"letter":"f"},{"kind":"crossref","label":"Dt 27:15","book":"Deu","chapter":27,"verse":15,"letter":"g"},{"kind":"text","text":" and demolish all their high places. "}],"crossRefs":[{"label":"Lv 26:1","book":"Lev","chapter":26,"verse":1},{"label":"Ezk 8:12","book":"Ezk","chapter":8,"verse":12},{"label":"Ex 32:4","book":"Exo","chapter":32,"verse":4},{"label":"Ex 32:8","book":"Exo","chapter":32,"verse":8},{"label":"Ex 34:17","book":"Exo","chapter":34,"verse":17},{"label":"Lv 19:4","book":"Lev","chapter":19,"verse":4},{"label":"Dt 27:15","book":"Deu","chapter":27,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:53","parts":[{"kind":"text","text":"You are to take possession of the land and settle in it because I have given you the land "},{"kind":"crossref","label":"Gn 12:7","book":"Gen","chapter":12,"verse":7,"letter":"a"},{"kind":"crossref","label":"Gn 15:18","book":"Gen","chapter":15,"verse":18,"letter":"b"},{"kind":"crossref","label":"Gn 24:7","book":"Gen","chapter":24,"verse":7,"letter":"c"},{"kind":"crossref","label":"Gn 35:12","book":"Gen","chapter":35,"verse":12,"letter":"d"},{"kind":"text","text":" to possess. "}],"crossRefs":[{"label":"Gn 12:7","book":"Gen","chapter":12,"verse":7},{"label":"Gn 15:18","book":"Gen","chapter":15,"verse":18},{"label":"Gn 24:7","book":"Gen","chapter":24,"verse":7},{"label":"Gn 35:12","book":"Gen","chapter":35,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:54","parts":[{"kind":"text","text":"You are to receive the land as an inheritance by lot according to your clans. Increase the inheritance for a large clan and decrease it for a small one. Whatever place the lot indicates for someone will be his. You will receive an inheritance according to your ancestral tribes. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:55","parts":[{"kind":"text","text":"But if you don’t drive out the inhabitants of the land before you, those you allow to remain will become barbs for your eyes and thorns for your sides; they will harass you in the land where you will live. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:33:56","parts":[{"kind":"text","text":"And what I had planned to do to them, I will do to you.” "},{"kind":"crossref","label":"Dt 28:15","book":"Deu","chapter":28,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Dt 28:15","book":"Deu","chapter":28,"verse":15}],"footnotes":[]}]},"cachedAt":1783099257726}