ll those registered numbered 603,550. "},{"kind":"crossref","label":"Ex 12:37","book":"Exo","chapter":12,"verse":37,"letter":"a"},{"kind":"crossref","label":"Nm 26:51","book":"Num","chapter":26,"verse":51,"letter":"b"}],"crossRefs":[{"label":"Ex 12:37","book":"Exo","chapter":12,"verse":37},{"label":"Nm 26:51","book":"Num","chapter":26,"verse":51}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:1:47","parts":[{"kind":"text","text":"But the Levites "},{"kind":"crossref","label":"Gn 34:25","book":"Gen","chapter":34,"verse":25,"letter":"a"},{"kind":"crossref","label":"Gn 34:30","book":"Gen","chapter":34,"verse":30,"letter":"b"},{"kind":"crossref","label":"Gn 49:5–7","book":"Gen","chapter":49,"verse":5,"letter":"c"},{"kind":"crossref","label":"Ex 32:26–29","book":"Exo","chapter":32,"verse":26,"letter":"d"},{"kind":"crossref","label":"Nm 3:6","book":"Num","chapter":3,"verse":6,"letter":"e"},{"kind":"crossref","label":"Nm 3:12","book":"Num","chapter":3,"verse":12,"letter":"f"},{"kind":"crossref","label":"Nm 3:40","book":"Num","chapter":3,"verse":40,"letter":"g"},{"kind":"crossref","label":"Nm 8:16–19","book":"Num","chapter":8,"verse":16,"letter":"h"},{"kind":"crossref","label":"Nm 18:1","book":"Num","chapter":18,"verse":1,"letter":"i"},{"kind":"crossref","label":"Dt 10:8","book":"Deu","chapter":10,"verse":8,"letter":"j"},{"kind":"crossref","label":"Dt 18:1–2","book":"Deu","chapter":18,"verse":1,"letter":"k"},{"kind":"crossref","label":"Dt 21:5","book":"Deu","chapter":21,"verse":5,"letter":"l"},{"kind":"crossref","label":"Jos 13:14","book":"Jos","chapter":13,"verse":14,"letter":"m"},{"kind":"crossref","label":"Jos 13:33","book":"Jos","chapter":13,"verse":33,"letter":"n"},{"kind":"text","text":" were not registered with them by their ancestral tribe. "}],"crossRefs":[{"label":"Gn 34:25","book":"Gen","chapter":34,"verse":25},{"label":"Gn 34:30","book":"Gen","chapter":34,"verse":30},{"label":"Gn 49:5–7","book":"Gen","chapter":49,"verse":5},{"label":"Ex 32:26–29","book":"E