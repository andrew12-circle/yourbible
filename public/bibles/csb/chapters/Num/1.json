text","text":"Pagiel son of Ochran from Asher;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:1:14","parts":[{"kind":"text","text":"Eliasaph son of Deuel "},{"kind":"footnote","marker":1,"text":"LXX, Syr read Reuel"},{"kind":"text","text":" from Gad;"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"LXX, Syr read Reuel"}]},{"verseId":"a556c5305ee15c3f-01:Num:1:15","parts":[{"kind":"text","text":"Ahira son of Enan from Naphtali."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:1:16","parts":[{"kind":"text","text":"These are the men called from the community; they are leaders of their ancestral tribes, "},{"kind":"crossref","label":"Nm 1:47","book":"Num","chapter":1,"verse":47,"letter":"a"},{"kind":"crossref","label":"Nm 13:2","book":"Num","chapter":13,"verse":2,"letter":"b"},{"kind":"crossref","label":"Nm 26:55","book":"Num","chapter":26,"verse":55,"letter":"c"},{"kind":"crossref","label":"Nm 33:54","book":"Num","chapter":33,"verse":54,"letter":"d"},{"kind":"crossref","label":"Nm 36:4–8","book":"Num","chapter":36,"verse":4,"letter":"e"},{"kind":"text","text":" the heads of Israel’s clans.” "},{"kind":"crossref","label":"Nm 10:4","book":"Num","chapter":10,"verse":4,"letter":"f"},{"kind":"crossref","label":"Jos 22:21","book":"Jos","chapter":22,"verse":21,"letter":"g"},{"kind":"crossref","label":"Jos 22:30","book":"Jos","chapter":22,"verse":30,"letter":"h"}],"crossRefs":[{"label":"Nm 1:47","book":"Num","chapter":1,"verse":47},{"label":"Nm 13:2","book":"Num","chapter":13,"verse":2},{"label":"Nm 26:55","book":"Num","chapter":26,"verse":55},{"label":"Nm 33:54","book":"Num","chapter":33,"verse":54},{"label":"Nm 36:4–8","book":"Num","chapter":36,"verse":4},{"label":"Nm 10:4","book":"Num","chapter":10,"verse":4},{"label":"Jos 22:21","book":"Jos","chapter":22,"verse":21},{"label":"Jos 22:30","book":"Jos","chapter":22,"verse":30}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:1:17","parts":[{"kind":"text","text":"So Moses and A