se":28,"letter":"c"},{"kind":"crossref","label":"Dt 2:10–11","book":"Deu","chapter":2,"verse":10,"letter":"d"},{"kind":"crossref","label":"Dt 2:21","book":"Deu","chapter":2,"verse":21,"letter":"e"},{"kind":"text","text":" were living. Hebron was built seven years before Zoan "},{"kind":"crossref","label":"Ps 78:12","book":"Psa","chapter":78,"verse":12,"letter":"f"},{"kind":"crossref","label":"Is 19:11","book":"Isa","chapter":19,"verse":11,"letter":"g"},{"kind":"crossref","label":"Is 30:4","book":"Isa","chapter":30,"verse":4,"letter":"h"},{"kind":"crossref","label":"Ezk 30:14","book":"Ezk","chapter":30,"verse":14,"letter":"i"},{"kind":"text","text":" in Egypt. "}],"crossRefs":[{"label":"Nm 13:28","book":"Num","chapter":13,"verse":28},{"label":"Nm 13:33","book":"Num","chapter":13,"verse":33},{"label":"Dt 1:28","book":"Deu","chapter":1,"verse":28},{"label":"Dt 2:10–11","book":"Deu","chapter":2,"verse":10},{"label":"Dt 2:21","book":"Deu","chapter":2,"verse":21},{"label":"Ps 78:12","book":"Psa","chapter":78,"verse":12},{"label":"Is 19:11","book":"Isa","chapter":19,"verse":11},{"label":"Is 30:4","book":"Isa","chapter":30,"verse":4},{"label":"Ezk 30:14","book":"Ezk","chapter":30,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:23","parts":[{"kind":"text","text":"When they came to Eshcol "},{"kind":"crossref","label":"Nm 32:9","book":"Num","chapter":32,"verse":9,"letter":"a"},{"kind":"crossref","label":"Dt 1:24","book":"Deu","chapter":1,"verse":24,"letter":"b"},{"kind":"text","text":" Valley, they cut down a branch with a single cluster of grapes, which was carried on a pole by two men. They also took some pomegranates and figs. "},{"kind":"crossref","label":"Nm 20:5","book":"Num","chapter":20,"verse":5,"letter":"c"},{"kind":"crossref","label":"Dt 8:8","book":"Deu","chapter":8,"verse":8,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 32:9","book":"Num","chapter":32,"verse":9},{"label":"Dt 1:24","book":"Deu","chapter":1,"verse":24},{"label":"Nm 20:5","book":"Num","chapter":20,"verse":5},{"label":"Dt 8:8","book":"Deu","chapter":8,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:24","parts":[{"kind":"text","text":"That place was called Eshcol "},{"kind":"footnote","marker":3,"text":"= Cluster"},{"kind":"text","text":" Valley because of the cluster of grapes the Israelites cut there. "}],"crossRefs":[],"footnotes":[{"marker":3,"text":"= Cluster"}]},{"verseId":"a556c5305ee15c3f-01:Num:13:25","parts":[{"kind":"text","text":"At the end of forty days "},{"kind":"crossref","label":"Nm 14:33","book":"Num","chapter":14,"verse":33,"letter":"a"},{"kind":"crossref","label":"Nm 32:13","book":"Num","chapter":32,"verse":13,"letter":"b"},{"kind":"crossref","label":"Ps 95:10","book":"Psa","chapter":95,"verse":10,"letter":"c"},{"kind":"text","text":" they returned from scouting out the land."}],"crossRefs":[{"label":"Nm 14:33","book":"Num","chapter":14,"verse":33},{"label":"Nm 32:13","book":"Num","chapter":32,"verse":13},{"label":"Ps 95:10","book":"Psa","chapter":95,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:26","parts":[{"kind":"text","text":"The men went back to Moses, Aaron, and the entire Israelite community in the Wilderness of Paran at Kadesh. They brought back a report for them and the whole community, and they showed them the fruit of the land. "},{"kind":"crossref","label":"Nm 32:9","book":"Num","chapter":32,"verse":9,"letter":"a"},{"kind":"crossref","label":"Dt 1:24","book":"Deu","chapter":1,"verse":24,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 32:9","book":"Num","chapter":32,"verse":9},{"label":"Dt 1:24","book":"Deu","chapter":1,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:27","parts":[{"kind":"text","text":"They reported to Moses, “We went into the land where you sent us. Indeed it is flowing with milk and honey, "},{"kind":"crossref","label":"Ex 3:8","book":"Exo","chapter":3,"verse":8,"letter":"a"},{"kind":"crossr