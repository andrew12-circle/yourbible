ook":"Deu","chapter":1,"verse":28},{"label":"Dt 2:10–11","book":"Deu","chapter":2,"verse":10},{"label":"Dt 2:21","book":"Deu","chapter":2,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:29","parts":[{"kind":"text","text":"The Amalekites "},{"kind":"crossref","label":"Ex 17:8–16","book":"Exo","chapter":17,"verse":8,"letter":"a"},{"kind":"crossref","label":"Nm 14:25","book":"Num","chapter":14,"verse":25,"letter":"b"},{"kind":"crossref","label":"Nm 14:43","book":"Num","chapter":14,"verse":43,"letter":"c"},{"kind":"crossref","label":"Nm 14:45","book":"Num","chapter":14,"verse":45,"letter":"d"},{"kind":"crossref","label":"Dt 25:17","book":"Deu","chapter":25,"verse":17,"letter":"e"},{"kind":"text","text":" are living in the land of the Negev; the Hethites, Jebusites, and Amorites live in the hill country; and the Canaanites live by the sea and along the Jordan.”"}],"crossRefs":[{"label":"Ex 17:8–16","book":"Exo","chapter":17,"verse":8},{"label":"Nm 14:25","book":"Num","chapter":14,"verse":25},{"label":"Nm 14:43","book":"Num","chapter":14,"verse":43},{"label":"Nm 14:45","book":"Num","chapter":14,"verse":45},{"label":"Dt 25:17","book":"Deu","chapter":25,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:30","parts":[{"kind":"text","text":"Then Caleb "},{"kind":"crossref","label":"Nm 14:6","book":"Num","chapter":14,"verse":6,"letter":"a"},{"kind":"crossref","label":"Nm 14:24","book":"Num","chapter":14,"verse":24,"letter":"b"},{"kind":"crossref","label":"Nm 14:30","book":"Num","chapter":14,"verse":30,"letter":"c"},{"kind":"crossref","label":"Nm 14:38","book":"Num","chapter":14,"verse":38,"letter":"d"},{"kind":"crossref","label":"Nm 26:65","book":"Num","chapter":26,"verse":65,"letter":"e"},{"kind":"text","text":" quieted the people in the presence of Moses and said, “Let’s go up now and take possession of the land because we can certainly conquer it!”"}],"crossRefs":[{"label":"Nm 14:6","book":"Num","chapter":14,"verse":6},{"label":"Nm 14:24","book":"Num","chapter":14,"verse":24},{"label":"Nm 14:30","book":"Num","chapter":14,"verse":30},{"label":"Nm 14:38","book":"Num","chapter":14,"verse":38},{"label":"Nm 26:65","book":"Num","chapter":26,"verse":65}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:31","parts":[{"kind":"text","text":"But the men who had gone up with him responded, “We can’t attack the people because they are stronger than we are!” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:32","parts":[{"kind":"text","text":"So they gave a negative report to the Israelites about the land they had scouted: “The land we passed through to explore is one that devours its inhabitants, and all the people we saw in it are men of great size. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Num:13:33","parts":[{"kind":"text","text":"We even saw the Nephilim "},{"kind":"crossref","label":"Gn 6:4","book":"Gen","chapter":6,"verse":4,"letter":"a"},{"kind":"text","text":" there —the descendants of Anak come from the Nephilim! "},{"kind":"crossref","label":"Dt 2:10","book":"Deu","chapter":2,"verse":10,"letter":"b"},{"kind":"crossref","label":"Dt 2:20","book":"Deu","chapter":2,"verse":20,"letter":"c"},{"kind":"text","text":" To ourselves we seemed like grasshoppers, and we must have seemed the same to them.”"}],"crossRefs":[{"label":"Gn 6:4","book":"Gen","chapter":6,"verse":4},{"label":"Dt 2:10","book":"Deu","chapter":2,"verse":10},{"label":"Dt 2:20","book":"Deu","chapter":2,"verse":20}],"footnotes":[]}]},"cachedAt":1783099251581}