verse":12},{"label":"Is 14:13–15","book":"Isa","chapter":14,"verse":13}],"footnotes":[{"marker":1,"text":"Or in Sela; probably = Petra"},{"marker":2,"text":"Probably Petra"}]},{"verseId":"a556c5305ee15c3f-01:Oba:1:4","parts":[{"kind":"text","text":"Though you seem to soar "},{"kind":"footnote","marker":1,"text":"Or to build high"},{"kind":"text","text":" like an eagle "},{"kind":"crossref","label":"Jb 20:6","book":"Job","chapter":20,"verse":6,"letter":"a"},{"kind":"crossref","label":"Hab 2:9","book":"Hab","chapter":2,"verse":9,"letter":"b"},{"kind":"text","text":" and make your nest among the stars, "},{"kind":"crossref","label":"Is 14:12–15","book":"Isa","chapter":14,"verse":12,"letter":"a"},{"kind":"text","text":" even from there I will bring you down."}],"crossRefs":[{"label":"Jb 20:6","book":"Job","chapter":20,"verse":6},{"label":"Hab 2:9","book":"Hab","chapter":2,"verse":9},{"label":"Is 14:12–15","book":"Isa","chapter":14,"verse":12}],"footnotes":[{"marker":1,"text":"Or to build high"}]},{"verseId":"a556c5305ee15c3f-01:Oba:1:5","parts":[{"kind":"text","text":"If thieves came to you, "},{"kind":"crossref","label":"Jr 49:9","book":"Jer","chapter":49,"verse":9,"letter":"a"},{"kind":"text","text":" if marauders by night —"},{"kind":"text","text":" how ravaged you would be! —"},{"kind":"text","text":" wouldn’t they steal only what they wanted?"},{"kind":"text","text":" If grape harvesters came to you,"},{"kind":"text","text":" wouldn’t they leave a few grapes? "},{"kind":"crossref","label":"Lv 19:10","book":"Lev","chapter":19,"verse":10,"letter":"a"},{"kind":"crossref","label":"Lv 25:5","book":"Lev","chapter":25,"verse":5,"letter":"b"},{"kind":"crossref","label":"Lv 25:11","book":"Lev","chapter":25,"verse":11,"letter":"c"}],"crossRefs":[{"label":"Jr 49:9","book":"Jer","chapter":49,"verse":9},{"label":"Lv 19:10","book":"Lev","chapter":19,"verse":10},{"label":"Lv 25:5","book":"Lev","chapter":25,"verse":5},{"label":"Lv 25:11","book":"Lev","chapter":25,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Oba:1:6","parts":[{"kind":"text","text":"How Esau will be pillaged, "},{"kind":"crossref","label":"Jr 49:10","book":"Jer","chapter":49,"verse":10,"letter":"a"},{"kind":"text","text":" his hidden treasures searched out! "},{"kind":"crossref","label":"Mal 1:2–3","book":"Mal","chapter":1,"verse":2,"letter":"a"}],"crossRefs":[{"label":"Jr 49:10","book":"Jer","chapter":49,"verse":10},{"label":"Mal 1:2–3","book":"Mal","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Oba:1:7","parts":[{"kind":"text","text":"Everyone who has a treaty with you "},{"kind":"crossref","label":"Ps 55:20","book":"Psa","chapter":55,"verse":20,"letter":"a"},{"kind":"crossref","label":"Jr 30:14","book":"Jer","chapter":30,"verse":14,"letter":"b"},{"kind":"crossref","label":"Am 1:9","book":"Amo","chapter":1,"verse":9,"letter":"c"},{"kind":"text","text":" will drive you to the border;"},{"kind":"text","text":" everyone at peace with you"},{"kind":"text","text":" will deceive and conquer you."},{"kind":"text","text":" Those who eat your bread "},{"kind":"crossref","label":"Ps 41:9","book":"Psa","chapter":41,"verse":9,"letter":"a"},{"kind":"text","text":" will set "},{"kind":"footnote","marker":1,"text":"Some LXX mss, Sym, Tg, Vg; MT reads They will set your bread as"},{"kind":"text","text":" a trap for you."},{"kind":"text","text":" He will be unaware of it. "},{"kind":"crossref","label":"Jr 49:7","book":"Jer","chapter":49,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 55:20","book":"Psa","chapter":55,"verse":20},{"label":"Jr 30:14","book":"Jer","chapter":30,"verse":14},{"label":"Am 1:9","book":"Amo","chapter":1,"verse":9},{"label":"Ps 41:9","book":"Psa","chapter":41,"verse":9},{"label":"Jr 49:7","book":"Jer","chapter":49,"verse":7}],"footnotes":[{"marker":1,"text":"Some LXX mss, Sym, Tg, Vg; MT reads They will set your bread as"}]},{"verseId":"a556c5305ee15c3f-01:Oba:1:8","parts":[{"kind":"text","text":"In that day —"},{"kind":"text","text":" will I not eliminate the wise ones of Edom "},{"kind":"crossref","label":"Jb 4:1","book":"Job","chapter":4,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jb 5:12–14","book":"Job","chapter":5,"verse":12,"letter":"b"},{"kind":"text","text":" and those who understand"},{"kind":"text","text":" from the hill country of Esau?"}],"crossRefs":[{"label":"Jb 4:1","book":"Job","chapter":4,"verse":1},{"label":"Jb 5:12–14","book":"Job","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Oba:1:9","parts":[{"kind":"text","text":"Teman, "},{"kind":"footnote","marker":1,"text":"= a region or city in Edom"},{"kind":"crossref","label":"Gn 36:11","book":"Gen","chapter":36,"verse":11,"letter":"a"},{"kind":"crossref","label":"1Ch 1:45","book":"1Ch","chapter":1,"verse":45,"letter":"b"},{"kind":"crossref","label":"Jb 2:11","book":"Job","chapter":2,"verse":11,"letter":"c"},{"kind":"crossref","label":"Hab 3:3","book":"Hab","chapter":3,"verse":3,"letter":"d"},{"kind":"text","text":" your warriors "},{"kind":"crossref","label":"Jr 49:22","book":"Jer","chapter":49,"verse":22,"letter":"e"},{"kind":"text","text":" will be terrified"},{"kind":"text","text":" so that everyone from the hill country of Esau"},{"kind":"text","text":" will be destroyed by slaughter. "},{"kind":"crossref","label":"Is 34:5–8","book":"Isa","chapter":34,"verse":5,"letter":"a"},{"kind":"crossref","label":"Is 63:1–3","book":"Isa","chapter":63,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jr 49:7","book":"Jer","chapter":49,"verse":7,"letter":"c"},{"kind":"crossref","label":"Jr 49:20","book":"Jer","chapter":49,"verse":20,"letter":"d"},{"kind":"crossref","label":"Ezk 25:13","book":"Ezk","chapter":25,"verse":13,"letter":"e"},{"kind":"crossref","label":"Am 1:12","book":"Amo","chapter":1,"verse":12,"letter":"f"},{"kind":"crossref","label":"Ob 5","book":"Oba","chapter":1,"verse":5,"letter":"g"}],"crossRefs":[{"label":"Gn 36:11","book":"Gen","chapter":36,"verse":11},{"label":"1Ch 1:45","boo