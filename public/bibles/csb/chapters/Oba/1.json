"},{"kind":"text","text":" and cast lots for Jerusalem, "},{"kind":"crossref","label":"Jl 3:3","book":"Jol","chapter":3,"verse":3,"letter":"a"},{"kind":"crossref","label":"Nah 3:10","book":"Nam","chapter":3,"verse":10,"letter":"b"},{"kind":"text","text":" you were just like one of them. "},{"kind":"crossref","label":"2Ch 21:17","book":"2Ch","chapter":21,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ezk 35:10","book":"Ezk","chapter":35,"verse":10,"letter":"b"}],"crossRefs":[{"label":"Ps 83:5–6","book":"Psa","chapter":83,"verse":5},{"label":"Ps 137:7","book":"Psa","chapter":137,"verse":7},{"label":"Am 1:6","book":"Amo","chapter":1,"verse":6},{"label":"Am 1:9","book":"Amo","chapter":1,"verse":9},{"label":"Jl 3:3","book":"Jol","chapter":3,"verse":3},{"label":"Nah 3:10","book":"Nam","chapter":3,"verse":10},{"label":"2Ch 21:17","book":"2Ch","chapter":21,"verse":17},{"label":"Ezk 35:10","book":"Ezk","chapter":35,"verse":10}],"footnotes":[{"marker":1,"text":"Or forces"}]},{"verseId":"a556c5305ee15c3f-01:Oba:1:12","parts":[{"kind":"text","text":"Do not "},{"kind":"footnote","marker":1,"text":"Or You should not throughout vv. 12–14"},{"kind":"text","text":" gloat over your brother "},{"kind":"crossref","label":"Mc 4:11","book":"Mic","chapter":4,"verse":11,"letter":"a"},{"kind":"crossref","label":"Mc 7:10","book":"Mic","chapter":7,"verse":10,"letter":"b"},{"kind":"text","text":" in the day of his calamity;"},{"kind":"text","text":" do not rejoice over the people of Judah "},{"kind":"crossref","label":"Ps 83:1–6","book":"Psa","chapter":83,"verse":1,"letter":"a"},{"kind":"crossref","label":"Ps 137:7–9","book":"Psa","chapter":137,"verse":7,"letter":"b"},{"kind":"crossref","label":"Lm 4:21","book":"Lam","chapter":4,"verse":21,"letter":"c"},{"kind":"crossref","label":"Ezk 35:15","book":"Ezk","chapter":35,"verse":15,"letter":"d"},{"kind":"crossref","label":"Ezk 36:5","book":"Ezk","chapter":36,"verse":5,"letter":"e"},{"kind":"text","text":" in the day of their destruction;"},{