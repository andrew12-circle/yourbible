{"key":"a556c5305ee15c3f-01|Lam|3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","chapter":3,"textRevision":"api-bible-csb-2024","parserRevision":"v10","verses":[{"verseId":"a556c5305ee15c3f-01:Lam:3:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":1,"text":"I am the man who has seen affliction","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":2,"text":"He has driven me away and forced me to walk","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":3,"text":"Yes, he repeatedly turns his hand","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":4,"text":"He has worn away my flesh and skin;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":5,"text":"He has laid siege against me,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":6,"text":"He has made me dwell in darkness","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":7,"text":"He has walled me in so I cannot get out;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":8,"text":"Even when I cry out and plead for help,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":9,"text":"He has walled in my ways with blocks of stone;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":10,"text":"He is a bear waiting in ambush,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":11,"text":"He forced me off my way and tore me to pieces;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":12,"text":"He strung his bow","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":13,"text":"He pierced my kidneys","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":14,"text":"I am a laughingstock to all my people,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":15,"text":"He filled me with bitterness,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:16","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":16,"text":"He ground my teeth with gravel","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:17","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":17,"text":"I have been deprived of peace;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:18","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":18,"text":"Then I thought, “My future is lost,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":19,"text":"Remember my affliction and my homelessness,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":20,"text":"I continually remember them","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":21,"text":"Yet I call this to mind,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":22,"text":"Because of the Lord’s faithful love","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":23,"text":"They are new every morning;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":24,"text":"I say, “The Lord is my portion,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":25,"text":"The Lord is good to those who wait for him,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":26,"text":"It is good to wait quietly","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":27,"text":"It is good for a man to bear the yoke","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":28,"text":"Let him sit alone and be silent,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":29,"text":"Let him put his mouth in the dust —","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":30,"text":"Let him offer his cheek","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":31,"text":"For the Lord","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":32,"text":"Even if he causes suffering,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":33,"text":"For he does not enjoy bringing affliction","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":34,"text":"Crushing all the prisoners of the land","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":35,"text":"denying justice to a man","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":36,"text":"or subverting a person in his lawsuit —","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:37","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":37,"text":"Who is there who speaks and it happens,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:38","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":38,"text":"Do not both adversity and good","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:39","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":39,"text":"Why should any living person complain,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:40","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":40,"text":"Let’s examine and probe our ways,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:41","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":41,"text":"Let’s lift up our hearts and our hands","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:42","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":42,"text":"“We have sinned and rebelled;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:43","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":43,"text":"“You have covered yourself in anger and pursued us;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:44","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":44,"text":"You have covered yourself with a cloud","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:45","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":45,"text":"You have made us disgusting filth","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:46","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":46,"text":"“All our enemies","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:47","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":47,"text":"We have experienced panic and pitfall,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:48","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":48,"text":"My eyes flow with streams of tears","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:49","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":49,"text":"My eyes overflow unceasingly,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:50","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":50,"text":"until the Lord looks down","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:51","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":51,"text":"My eyes bring me grief","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:52","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":52,"text":"For no reason, my enemies","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:53","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":53,"text":"They smothered my life in a pit","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:54","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":54,"text":"Water flooded over my head,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:55","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":55,"text":"I called on your name, Lord,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:56","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":56,"text":"You heard my plea:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:57","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":57,"text":"You came near whenever I called you;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:58","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":58,"text":"You championed my cause, Lord;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:59","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":59,"text":"Lord, you saw the wrong done to me;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:60","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":60,"text":"You saw all their vengefulness,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:61","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":61,"text":"Lord, you heard their insults,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:62","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":62,"text":"The slander and murmuring of my opponents","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:63","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":63,"text":"When they sit and when they rise, look,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:64","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":64,"text":"You will pay them back what they deserve, Lord,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:65","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":65,"text":"You will give them a heart filled with anguish.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:Lam:3:66","bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam","bookOrder":24,"chapter":3,"verse":66,"text":"You will pursue them in anger and destroy them","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"Lam