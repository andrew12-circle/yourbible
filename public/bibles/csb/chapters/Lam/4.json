hen your exile. "},{"kind":"footnote","marker":1,"text":"Or not deport you again"},{"kind":"text","text":" But he will punish your iniquity, Daughter Edom,"},{"kind":"text","text":" and will expose your sins. "},{"kind":"crossref","label":"Ps 137:7","book":"Psa","chapter":137,"verse":7,"letter":"a"},{"kind":"crossref","label":"Ezk 25:12–14","book":"Ezk","chapter":25,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jl 3:19","book":"Jol","chapter":3,"verse":19,"letter":"c"}],"crossRefs":[{"label":"Ps 137:7","book":"Psa","chapter":137,"verse":7},{"label":"Ezk 25:12–14","book":"Ezk","chapter":25,"verse":12},{"label":"Jl 3:19","book":"Jol","chapter":3,"verse":19}],"footnotes":[{"marker":1,"text":"Or not deport you again"}]}]},"cachedAt":1783279574888}