suring line "},{"kind":"crossref","label":"2Kg 21:13","book":"2Ki","chapter":21,"verse":13,"letter":"a"},{"kind":"crossref","label":"Is 28:17","book":"Isa","chapter":28,"verse":17,"letter":"b"},{"kind":"crossref","label":"Is 34:11","book":"Isa","chapter":34,"verse":11,"letter":"c"},{"kind":"crossref","label":"Is 34:17","book":"Isa","chapter":34,"verse":17,"letter":"d"},{"kind":"text","text":" and did not restrain himself from destroying."},{"kind":"text","text":" He made the ramparts and walls grieve;"},{"kind":"text","text":" together they waste away."}],"crossRefs":[{"label":"2Kg 21:13","book":"2Ki","chapter":21,"verse":13},{"label":"Is 28:17","book":"Isa","chapter":28,"verse":17},{"label":"Is 34:11","book":"Isa","chapter":34,"verse":11},{"label":"Is 34:17","book":"Isa","chapter":34,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:2:9","parts":[{"kind":"text","text":"Zion’s gates have fallen to the ground; "},{"kind":"crossref","label":"Neh 1:3","book":"Neh","chapter":1,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 14:2","book":"Jer","chapter":14,"verse":2,"letter":"b"},{"kind":"text","text":" he has destroyed and shattered the bars on her gates."},{"kind":"text","text":" Her king and her leaders live among the nations,"},{"kind":"text","text":" instruction "},{"kind":"footnote","marker":1,"text":"Or the law"},{"kind":"text","text":" is no more,"},{"kind":"text","text":" and even her prophets receive"},{"kind":"text","text":" no vision from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Ezk 7:26","book":"Ezk","chapter":7,"verse":26,"letter":"a"},{"kind":"crossref","label":"Mc 3:6","book":"Mic","chapter":3,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Neh 1:3","book":"Neh","chapter":1,"verse":3},{"label":"Jr 14:2","book":"Jer","chapter":14,"verse":2},{"label":"Ezk 7:26","book":"Ezk","chapter":7,"verse":26},{"label":"Mc 3:6","book":"Mic","chapter":3,"verse":6}],"footnotes":[{"marker":1,"text":"Or the law"}]},{"verseId":"a556c5305ee15c3f-01:Lam:2:10","parts":[{"kind":"text","text":"The elders of Daughter Zion"},{"kind":"text","text":" sit on the ground in silence."},{"kind":"text","text":" They have thrown dust on their heads "},{"kind":"crossref","label":"Gn 37:34","book":"Gen","chapter":37,"verse":34,"letter":"a"},{"kind":"crossref","label":"Jos 7:6","book":"Jos","chapter":7,"verse":6,"letter":"b"},{"kind":"crossref","label":"Neh 9:1","book":"Neh","chapter":9,"verse":1,"letter":"c"},{"kind":"crossref","label":"Jb 2:12","book":"Job","chapter":2,"verse":12,"letter":"d"},{"kind":"crossref","label":"Ezk 27:30","book":"Ezk","chapter":27,"verse":30,"letter":"e"},{"kind":"text","text":" and put on sackcloth."},{"kind":"text","text":" The young women of Jerusalem"},{"kind":"text","text":" have bowed their heads to the ground. "},{"kind":"crossref","label":"Jb 10:15","book":"Job","chapter":10,"verse":15,"letter":"a"},{"kind":"crossref","label":"Is 58:5","book":"Isa","chapter":58,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Gn 37:34","book":"Gen","chapter":37,"verse":34},{"label":"Jos 7:6","book":"Jos","chapter":7,"verse":6},{"label":"Neh 9:1","book":"Neh","chapter":9,"verse":1},{"label":"Jb 2:12","book":"Job","chapter":2,"verse":12},{"label":"Ezk 27:30","book":"Ezk","chapter":27,"verse":30},{"label":"Jb 10:15","book":"Job","chapter":10,"verse":15},{"label":"Is 58:5","book":"Isa","chapter":58,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:2:11","parts":[{"kind":"text","text":"My eyes are worn out from weeping; "},{"kind":"crossref","label":"Ps 69:3","book":"Psa","chapter":69,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jr 9:1","book":"Jer","chapter":9,"verse":1,"letter":"b"},{"kind":"crossref","label":"Jr 14:17","book":"Jer","chapter":14,"verse":17,"letter":"c"},{"kind":"crossref","label":"Lm 3:48","book":"Lam","chapter":3,"verse":48,"letter":"d"},{"kind":"text","text":" I am churning within."},{"kind":"text","text":" My heart is poured out in grief "},{"kind":"footnote","marker":1,"text":"Lit My liver is poured out on the ground"},{"kind":"crossref","label":"Ps 22:14","book":"Psa","chapter":22,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jr 4:19","book":"Jer","chapter":4,"verse":19,"letter":"b"},{"kind":"text","text":" because of the destruction of my dear people, "},{"kind":"crossref","label":"Lm 3:48","book":"Lam","chapter":3,"verse":48,"letter":"a"},{"kind":"text","text":" because infants and nursing babies faint"},{"kind":"text","text":" in the streets of the city. "},{"kind":"crossref","label":"Jr 44:7","book":"Jer","chapter":44,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Ps 69:3","book":"Psa","chapter":69,"verse":3},{"label":"Jr 9:1","book":"Jer","chapter":9,"verse":1},{"label":"Jr 14:17","book":"Jer","chapter":14,"verse":17},{"label":"Lm 3:48","book":"Lam","chapter":3,"verse":48},{"label":"Ps 22:14","book":"Psa","chapter":22,"verse":14},{"label":"Jr 4:19","book":"Jer","chapter":4,"verse":19},{"label":"Lm 3:48","book":"Lam","chapter":3,"verse":48},{"label":"Jr 44:7","book":"Jer","chapter":44,"verse":7}],"footnotes":[{"marker":1,"text":"Lit My liver is poured out on the ground"}]},{"verseId":"a556c5305ee15c3f-01:Lam:2:12","parts":[{"kind":"text","text":"They cry out to their mothers,"},{"kind":"text","text":" “Where is the grain and wine?” "},{"kind":"crossref","label":"Dt 28:51","book":"Deu","chapter":28,"verse":51,"letter":"a"},{"kind":"crossref","label":"Hs 2:8","book":"Hos","chapter":2,"verse":8,"letter":"b"},{"kind":"crossref","label":"Hs 7:14","book":"Hos","chapter":7,"verse":14,"letter":"c"},{"kind":"text","text":" as they faint like the wounded"},{"kind":"text","text":" in the streets of the city,"},{"kind":"text","text":" as their life pours out"},{"kind":"text","text":" in the arms of their mothers."}],"crossRefs":[{"label":"Dt 28:51","book":"Deu","chapter":28,"verse":51},{"label":"Hs 2:8","book":"Hos","chapter":2,"verse":8},{"label":"Hs 7:14","book":"Ho