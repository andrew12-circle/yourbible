ext","text":" All who honored her now despise her,"},{"kind":"text","text":" for they have seen her nakedness."},{"kind":"text","text":" She herself groans and turns away."}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or become impure"}]},{"verseId":"a556c5305ee15c3f-01:Lam:1:9","parts":[{"kind":"text","text":"Her uncleanness stains her skirts. "},{"kind":"crossref","label":"Jr 13:22","book":"Jer","chapter":13,"verse":22,"letter":"a"},{"kind":"crossref","label":"Jr 13:26","book":"Jer","chapter":13,"verse":26,"letter":"b"},{"kind":"crossref","label":"Nah 3:5","book":"Nam","chapter":3,"verse":5,"letter":"c"},{"kind":"text","text":" She never considered her end."},{"kind":"text","text":" Her downfall was astonishing; "},{"kind":"crossref","label":"Dt 28:43","book":"Deu","chapter":28,"verse":43,"letter":"a"},{"kind":"text","text":" there was no one to comfort her."},{"kind":"text","text":" Lord","style":"divine"},{"kind":"text","text":", look on my affliction,"},{"kind":"text","text":" for the enemy boasts."}],"crossRefs":[{"label":"Jr 13:22","book":"Jer","chapter":13,"verse":22},{"label":"Jr 13:26","book":"Jer","chapter":13,"verse":26},{"label":"Nah 3:5","book":"Nam","chapter":3,"verse":5},{"label":"Dt 28:43","book":"Deu","chapter":28,"verse":43}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:1:10","parts":[{"kind":"text","text":"The adversary has seized"},{"kind":"text","text":" all her precious belongings."},{"kind":"text","text":" She has even seen the nations"},{"kind":"text","text":" enter her sanctuary —"},{"kind":"text","text":" those you had forbidden"},{"kind":"text","text":" to enter your assembly. "},{"kind":"crossref","label":"Dt 23:3","book":"Deu","chapter":23,"verse":3,"letter":"a"},{"kind":"crossref","label":"Neh 13:1–3","book":"Neh","chapter":13,"verse":1,"letter":"b"},{"kind":"crossref","label":"Ezk 44:9","book":"Ezk","chapter":44,"verse":9,"letter":"c"}],"crossRefs":[{"label":"Dt 23:3","book":"Deu","chapter":23,"verse":3},{"label":"Neh 13:1–3","book":"Neh","chapter":13,"verse":1},{"label":"Ezk 44:9","book":"Ezk","chapter":44,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:1:11","parts":[{"kind":"text","text":"All her people groan"},{"kind":"text","text":" while they search for bread. "},{"kind":"crossref","label":"Jr 38:9","book":"Jer","chapter":38,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jr 52:6","book":"Jer","chapter":52,"verse":6,"letter":"b"},{"kind":"text","text":" They have traded their precious belongings for food"},{"kind":"text","text":" in order to stay alive. "},{"kind":"crossref","label":"Lm 1:19","book":"Lam","chapter":1,"verse":19,"letter":"a"},{"kind":"crossref","label":"Lm 2:20","book":"Lam","chapter":2,"verse":20,"letter":"b"},{"kind":"crossref","label":"Lm 4:10","book":"Lam","chapter":4,"verse":10,"letter":"c"},{"kind":"text","text":" Lord","style":"divine"},{"kind":"text","text":", look and see"},{"kind":"text","text":" how I have become despised."}],"crossRefs":[{"label":"Jr 38:9","book":"Jer","chapter":38,"verse":9},{"label":"Jr 52:6","book":"Jer","chapter":52,"verse":6},{"label":"Lm 1:19","book":"Lam","chapter":1,"verse":19},{"label":"Lm 2:20","book":"Lam","chapter":2,"verse":20},{"label":"Lm 4:10","book":"Lam","chapter":4,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:1:12","parts":[{"kind":"text","text":"Is this nothing to you, all you who pass by? "},{"kind":"crossref","label":"Ps 89:41","book":"Psa","chapter":89,"verse":41,"letter":"a"},{"kind":"crossref","label":"Jr 22:8","book":"Jer","chapter":22,"verse":8,"letter":"b"},{"kind":"text","text":" Look and see!"},{"kind":"text","text":" Is there any pain like mine,"},{"kind":"text","text":" which was dealt out to me,"},{"kind":"text","text":" which the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" made me suffer"},{"kind":"text","text":" on the day of his burning anger? "},{"kind":"crossref","label":"Am 5:18","book":"Amo","chapter":5,"verse":18,"letter":"a