self is bitter."}],"crossRefs":[{"label":"2Sm 5:7","book":"2Sa","chapter":5,"verse":7},{"label":"Ps 20:2","book":"Psa","chapter":20,"verse":2},{"label":"Jr 51:35","book":"Jer","chapter":51,"verse":35},{"label":"Dt 16:16","book":"Deu","chapter":16,"verse":16},{"label":"2Ch 8:13","book":"2Ch","chapter":8,"verse":13},{"label":"Ps 84:5","book":"Psa","chapter":84,"verse":5},{"label":"Is 1:11–17","book":"Isa","chapter":1,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:1:5","parts":[{"kind":"text","text":"Her adversaries have become her masters; "},{"kind":"crossref","label":"Dt 28:13","book":"Deu","chapter":28,"verse":13,"letter":"a"},{"kind":"crossref","label":"Dt 28:44","book":"Deu","chapter":28,"verse":44,"letter":"b"},{"kind":"text","text":" her enemies are at ease, "},{"kind":"crossref","label":"Jb 3:26","book":"Job","chapter":3,"verse":26,"letter":"a"},{"kind":"crossref","label":"Jb 12:6","book":"Job","chapter":12,"verse":6,"letter":"b"},{"kind":"crossref","label":"Jr 12:1","book":"Jer","chapter":12,"verse":1,"letter":"c"},{"kind":"text","text":" for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has made her suffer"},{"kind":"text","text":" because of her many transgressions."},{"kind":"text","text":" Her children have gone away"},{"kind":"text","text":" as captives before the adversary."}],"crossRefs":[{"label":"Dt 28:13","book":"Deu","chapter":28,"verse":13},{"label":"Dt 28:44","book":"Deu","chapter":28,"verse":44},{"label":"Jb 3:26","book":"Job","chapter":3,"verse":26},{"label":"Jb 12:6","book":"Job","chapter":12,"verse":6},{"label":"Jr 12:1","book":"Jer","chapter":12,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Lam:1:6","parts":[{"kind":"text","text":"All the splendor "},{"kind":"crossref","label":"Ezk 27:10","book":"Ezk","chapter":27,"verse":10,"letter":"a"},{"kind":"text","text":" has vanished"},{"kind":"text","text":" from Daughter Zion. "},{"kind":"crossref","label":"Lm 2:1","book":"Lam","chapte