","chapter":7,"verse":13,"letter":"c"},{"kind":"crossref","label":"Am 2:4","book":"Amo","chapter":2,"verse":4,"letter":"d"},{"kind":"text","text":" the tongues in their mouths are deceitful."},{"kind":"crossref","label":"Is 3:8","book":"Isa","chapter":3,"verse":8,"letter":"a"}],"crossRefs":[{"label":"Is 1:23","book":"Isa","chapter":1,"verse":23},{"label":"Is 5:7","book":"Isa","chapter":5,"verse":7},{"label":"Am 6:3–4","book":"Amo","chapter":6,"verse":3},{"label":"Mc 2:1","book":"Mic","chapter":2,"verse":1},{"label":"Jr 9:2–6","book":"Jer","chapter":9,"verse":2},{"label":"Jr 9:8","book":"Jer","chapter":9,"verse":8},{"label":"Hs 7:13","book":"Hos","chapter":7,"verse":13},{"label":"Am 2:4","book":"Amo","chapter":2,"verse":4},{"label":"Is 3:8","book":"Isa","chapter":3,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mic:6:13","parts":[{"kind":"text","text":"“As a result, I have begun to strike you severely, "},{"kind":"footnote","marker":1,"text":"LXX, Aq, Theod, Syr, Vg; MT reads I have made you sick by striking you down"},{"kind":"crossref","label":"Mc 1:9","book":"Mic","chapter":1,"verse":9,"letter":"a"},{"kind":"text","text":" bringing desolation because of your sins."},{"kind":"crossref","label":"Is 1:7","book":"Isa","chapter":1,"verse":7,"letter":"a"},{"kind":"crossref","label":"Is 6:11","book":"Isa","chapter":6,"verse":11,"letter":"b"}],"crossRefs":[{"label":"Mc 1:9","book":"Mic","chapter":1,"verse":9},{"label":"Is 1:7","book":"Isa","chapter":1,"verse":7},{"label":"Is 6:11","book":"Isa","chapter":6,"verse":11}],"footnotes":[{"marker":1,"text":"LXX, Aq, Theod, Syr, Vg; MT reads I have made you sick by striking you down"}]},{"verseId":"a556c5305ee15c3f-01:Mic:6:14","parts":[{"kind":"text","text":"You will eat but not be satisfied, "},{"kind":"crossref","label":"Is 9:20","book":"Isa","chapter":9,"verse":20,"letter":"a"},{"kind":"text","text":" for there will be hunger within you."},{"kind":"text","text":" What you acquire, you cannot save,"},{"kind":"cros