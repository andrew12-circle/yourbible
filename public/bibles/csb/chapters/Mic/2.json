8","book":"Mic","chapter":7,"verse":18},{"label":"Jr 23:3","book":"Jer","chapter":23,"verse":3},{"label":"Ezk 36:35–38","book":"Ezk","chapter":36,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mic:2:13","parts":[{"kind":"text","text":"One who breaks open the way"},{"kind":"text","text":" will advance before them;"},{"kind":"text","text":" they will break out, pass through the city gate,"},{"kind":"text","text":" and leave by it."},{"kind":"text","text":" Their King will pass through before them,"},{"kind":"text","text":" the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" as their leader."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279604270}