text":" so that anguish grips you like a woman in labor?"}],"crossRefs":[{"label":"Jr 8:19","book":"Jer","chapter":8,"verse":19},{"label":"Is 3:1–3","book":"Isa","chapter":3,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mic:4:10","parts":[{"kind":"text","text":"Writhe and cry out, "},{"kind":"footnote","marker":1,"text":"Hb obscure"},{"kind":"crossref","label":"Mc 5:3","book":"Mic","chapter":5,"verse":3,"letter":"a"},{"kind":"text","text":" Daughter Zion,"},{"kind":"text","text":" like a woman in labor,"},{"kind":"text","text":" for now you will leave the city "},{"kind":"crossref","label":"2Kg 20:18","book":"2Ki","chapter":20,"verse":18,"letter":"a"},{"kind":"crossref","label":"Hs 2:14","book":"Hos","chapter":2,"verse":14,"letter":"b"},{"kind":"text","text":" and camp in the open fields."},{"kind":"text","text":" You will go to Babylon;"},{"kind":"text","text":" there you will be rescued; "},{"kind":"crossref","label":"Is 43:14","book":"Isa","chapter":43,"verse":14,"letter":"a"},{"kind":"crossref","label":"Is 45:13","book":"Isa","chapter":45,"verse":13,"letter":"b"},{"kind":"crossref","label":"Mc 7:8","book":"Mic","chapter":7,"verse":8,"letter":"c"},{"kind":"text","text":" there the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will redeem you "},{"kind":"crossref","label":"Is 48:20","book":"Isa","chapter":48,"verse":20,"letter":"a"},{"kind":"crossref","label":"Is 52:9–12","book":"Isa","chapter":52,"verse":9,"letter":"b"},{"kind":"text","text":" from the grasp of your enemies!"}],"crossRefs":[{"label":"Mc 5:3","book":"Mic","chapter":5,"verse":3},{"label":"2Kg 20:18","book":"2Ki","chapter":20,"verse":18},{"label":"Hs 2:14","book":"Hos","chapter":2,"verse":14},{"label":"Is 43:14","book":"Isa","chapter":43,"verse":14},{"label":"Is 45:13","book":"Isa","chapter":45,"verse":13},{"label":"Mc 7:8","book":"Mic","chapter":7,"verse":8},{"label":"Is 48:20","book":"Isa","chapter":48,"verse":20},{"label":"Is 52:9–12","book":"Isa","chapte