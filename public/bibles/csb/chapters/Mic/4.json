xt","text":","},{"kind":"text","text":" their wealth for the Lord of the whole earth."}],"crossRefs":[{"label":"Is 41:15","book":"Isa","chapter":41,"verse":15},{"label":"Jr 51:20–23","book":"Jer","chapter":51,"verse":20},{"label":"Is 60:9","book":"Isa","chapter":60,"verse":9}],"footnotes":[{"marker":1,"text":"LXX, Syr, Tg; MT reads I"}]}]},"cachedAt":1783279604873}