9:8","book":"1Ki","chapter":9,"verse":8},{"label":"2Ch 36:19","book":"2Ch","chapter":36,"verse":19},{"label":"Jr 39:8","book":"Jer","chapter":39,"verse":8},{"label":"Am 2:5","book":"Amo","chapter":2,"verse":5},{"label":"Jr 17:27","book":"Jer","chapter":17,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:10","parts":[{"kind":"text","text":"The whole Chaldean army with the captain of the guards tore down the walls "},{"kind":"crossref","label":"2Kg 24:13","book":"2Ki","chapter":24,"verse":13,"letter":"a"},{"kind":"crossref","label":"Neh 1:3","book":"Neh","chapter":1,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jr 50:15","book":"Jer","chapter":50,"verse":15,"letter":"c"},{"kind":"text","text":" surrounding Jerusalem. "}],"crossRefs":[{"label":"2Kg 24:13","book":"2Ki","chapter":24,"verse":13},{"label":"Neh 1:3","book":"Neh","chapter":1,"verse":3},{"label":"Jr 50:15","book":"Jer","chapter":50,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:11","parts":[{"kind":"text","text":"Nebuzaradan, the captain of the guards, deported the rest of the people who remained in the city, the deserters who had defected to the king of Babylon, and the rest of the population. "},{"kind":"crossref","label":"2Ch 36:20","book":"2Ch","chapter":36,"verse":20,"letter":"a"},{"kind":"crossref","label":"Jr 5:19","book":"Jer","chapter":5,"verse":19,"letter":"b"},{"kind":"crossref","label":"Jr 39:1–9","book":"Jer","chapter":39,"verse":1,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Ch 36:20","book":"2Ch","chapter":36,"verse":20},{"label":"Jr 5:19","book":"Jer","chapter":5,"verse":19},{"label":"Jr 39:1–9","book":"Jer","chapter":39,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:12","parts":[{"kind":"text","text":"But the captain of the guards left some of the poorest of the land to be vinedressers and farmers. "},{"kind":"crossref","label":"2Kg 24:14","book":"2Ki","chapter":24,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jr 39:10","book":"Jer","chapter":39,"verse":10,"letter":"b"},{"kind":"crossref","label":"Jr 40:7","book":"Jer","chapter":40,"verse":7,"letter":"c"}],"crossRefs":[{"label":"2Kg 24:14","book":"2Ki","chapter":24,"verse":14},{"label":"Jr 39:10","book":"Jer","chapter":39,"verse":10},{"label":"Jr 40:7","book":"Jer","chapter":40,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:13","parts":[{"kind":"text","text":"Now "},{"kind":"crossref","label":"Jr 52:17–27","book":"Jer","chapter":52,"verse":17,"letter":"a"},{"kind":"text","text":" the Chaldeans broke into pieces the bronze pillars "},{"kind":"crossref","label":"2Kg 20:17","book":"2Ki","chapter":20,"verse":17,"letter":"b"},{"kind":"crossref","label":"2Ch 36:18","book":"2Ch","chapter":36,"verse":18,"letter":"c"},{"kind":"crossref","label":"Jr 52:17","book":"Jer","chapter":52,"verse":17,"letter":"d"},{"kind":"text","text":" of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s temple, the water carts, and the bronze basin, "},{"kind":"footnote","marker":1,"text":"Lit sea"},{"kind":"crossref","label":"1Kg 7:23","book":"1Ki","chapter":7,"verse":23,"letter":"e"},{"kind":"crossref","label":"2Ch 4:2–4","book":"2Ch","chapter":4,"verse":2,"letter":"f"},{"kind":"text","text":" which were in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s temple, and carried the bronze to Babylon. "},{"kind":"crossref","label":"Jr 27:19–22","book":"Jer","chapter":27,"verse":19,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 52:17–27","book":"Jer","chapter":52,"verse":17},{"label":"2Kg 20:17","book":"2Ki","chapter":20,"verse":17},{"label":"2Ch 36:18","book":"2Ch","chapter":36,"verse":18},{"label":"Jr 52:17","book":"Jer","chapter":52,"verse":17},{"label":"1Kg 7:23","book":"1Ki","chapter":7,"verse":23},{"label":"2Ch 4:2–4","book":"2Ch","chapter":4,"verse":2},{"label":"Jr 27:19–22","book":"Jer","chapter":27,"verse":19}],"footnotes":[{"marker":1,"text":"Lit sea"}]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:14","parts":[{"kind":"text","text":"They also took the pots, shovels, wick trimmers, dishes, and all the bronze articles used in the priests’ service. "},{"kind":"crossref","label":"Ex 27:3","book":"Exo","chapter":27,"verse":3,"letter":"a"},{"kind":"crossref","label":"1Kg 7:47","book":"1Ki","chapter":7,"verse":47,"letter":"b"},{"kind":"crossref","label":"2Ch 4:16","book":"2Ch","chapter":4,"verse":16,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 27:3","book":"Exo","chapter":27,"verse":3},{"label":"1Kg 7:47","book":"1Ki","chapter":7,"verse":47},{"label":"2Ch 4:16","book":"2Ch","chapter":4,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:15","parts":[{"kind":"text","text":"The captain of the guards took away the firepans and sprinkling basins —whatever was gold or silver. "},{"kind":"crossref","label":"2Kg 24:13","book":"2Ki","chapter":24,"verse":13,"letter":"a"},{"kind":"crossref","label":"Jr 15:13","book":"Jer","chapter":15,"verse":13,"letter":"b"},{"kind":"crossref","label":"Jr 20:5","book":"Jer","chapter":20,"verse":5,"letter":"c"}],"crossRefs":[{"label":"2Kg 24:13","book":"2Ki","chapter":24,"verse":13},{"label":"Jr 15:13","book":"Jer","chapter":15,"verse":13},{"label":"Jr 20:5","book":"Jer","chapter":20,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:16","parts":[{"kind":"text","text":"As for the two pillars, the one basin, and the water carts that Solomon had made for the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s temple, the weight of the bronze of all these articles was beyond measure. "},{"kind":"crossref","label":"1Kg 7:47","book":"1Ki","chapter":7,"verse":47,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Kg 7:47","book":"1Ki","chapter":7,"verse":47}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:17","parts":[{"kind":"text","text":"One pillar was twenty-seven feet "},{"kind":"footnote","marker":1,"text":"Lit 18 cubits"},{"kind":"text","text":" tall and had a bronze capital on top of it. The capital, encircled by a grating and pomegranates of bronze, stood five feet "},{"kind":"footnote","marker":2,"text":"Lit three cubits"},{"kind":"text","text":" high. The second pillar was the same, with its own grating. "},{"kind":"crossref","label":"1Kg 7:15","book":"1Ki","chapter":7,"verse":15,"letter":"a"}],"crossRefs":[{"label":"1Kg 7:15","book":"1Ki","chapter":7,"verse":15}],"footnotes":[{"marker":1,"text":"Lit 18 cubits"},{"marker":2,"text":"Lit three cubits"}]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:18","parts":[{"kind":"text","text":"The captain of the guards "},{"kind":"crossref","label":"Jr 39:9–13","book":"Jer","chapter":39,"verse":9,"letter":"a"},{"kind":"crossref","label":"Jr 52:12–16","book":"Jer","chapter":52,"verse":12,"letter":"b"},{"kind":"crossref","label":"Jr 52:24","book":"Jer","chapter":52,"verse":24,"letter":"c"},{"kind":"text","text":" also took away Seraiah "},{"kind":"crossref","label":"1Ch 6:14","book":"1Ch","chapter":6,"verse":14,"letter":"d"},{"kind":"crossref","label":"Ezr 7:1","book":"Ezr","chapter":7,"verse":1,"letter":"e"},{"kind":"text","text":" the chief priest, Zephaniah "},{"kind":"crossref","label":"Jr 21:1","book":"Jer","chapter":21,"verse":1,"letter":"f"},{"kind":"crossref","label":"Jr 29:25","book":"Jer","chapter":29,"verse":25,"letter":"g"},{"kind":"crossref","label":"Jr 29:29","book":"Jer","chapter":29,"verse":29,"letter":"h"},{"kind":"text","text":" the priest of the second rank, and the three doorkeepers. "}],"crossRefs":[{"label":"Jr 39:9–13","book":"Jer","chapter":39,"verse":9},{"label":"Jr 52:12–16","book":"Jer","chapter":52,"verse":12},{"label":"Jr 52:24","book":"Jer","chapter":52,"verse":24},{"label":"1Ch 6:14","book":"1Ch","chapter":6,"verse":14},{"label":"Ezr 7:1","book":"Ezr","chapter":7,"verse":1},{"label":"Jr 21:1","book":"Jer","chapter":21,"verse":1},{"label":"Jr 29:25","book":"Jer","chapter":29,"verse":25},{"label":"Jr 29:29","book":"Jer","chapter":29,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:19","parts":[{"kind":"text","text":"From the city he took a court official "},{"kind":"footnote","marker":1,"text":"Or eunuch"},{"kind":"text","text":" who had been appointed over the warriors; five trusted royal aides "},{"kind":"footnote","marker":2,"text":"Lit five men who look on the king’s face"},{"kind":"crossref","label":"Jr 52:25","book":"Jer","chapter":52,"verse":25,"letter":"a"},{"kind":"text","text":" found in the city; the secretary of the commander of the army, who enlisted the people of the land for military duty; and sixty men from the common people "},{"kind":"footnote","marker":3,"text":"Lit the people of the land"},{"kind":"text","text":" who were found within the city. "}],"crossRefs":[{"label":"Jr 52:25","book":"Jer","chapter":52,"verse":25}],"footnotes":[{"marker":1,"text":"Or eunuch"},{"marker":2,"text":"Lit five men who look on the king’s face"},{"marker":3,"text":"Lit the people of the land"}]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:20","parts":[{"kind":"text","text":"Nebuzaradan, the captain of the guards, took them and brought them to the king of Babylon at Riblah. "},{"kind":"crossref","label":"2Kg 23:33","book":"2Ki","chapter":23,"verse":33,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Kg 23:33","book":"2Ki","chapter":23,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:21","parts":[{"kind":"text","text":"The king of Babylon put them to death at Riblah in the land of Hamath. So Judah went into exile from its land. "},{"kind":"crossref","label":"Dt 28:63","book":"Deu","chapter":28,"verse":63,"letter":"a"},{"kind":"crossref","label":"2Kg 23:27","book":"2Ki","chapter":23,"verse":27,"letter":"b"}],"crossRefs":[{"label":"Dt 28:63","book":"Deu","chapter":28,"verse":63},{"label":"2Kg 23:27","book":"2Ki","chapter":23,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:22","parts":[{"kind":"text","text":"King Nebuchadnezzar of Babylon appointed Gedaliah "},{"kind":"crossref","label":"Jr 39:14","book":"Jer","chapter":39,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jr 40:7–9","book":"Jer","chapter":40,"verse":7,"letter":"b"},{"kind":"text","text":" son of Ahikam, son of Shaphan, over the rest of the people he left in the land of Judah. "},{"kind":"crossref","label":"Is 1:9","book":"Isa","chapter":1,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jr 40:5","book":"Jer","chapter":40,"verse":5,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 39:14","book":"Jer","chapter":39,"verse":14},{"label":"Jr 40:7–9","book":"Jer","chapter":40,"verse":7},{"label":"Is 1:9","book":"Isa","chapter":1,"verse":9},{"label":"Jr 40:5","book":"Jer","chapter":40,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:23","parts":[{"kind":"text","text":"When all the commanders of the armies —they and their men —heard that the king of Babylon had appointed Gedaliah, they came to Gedaliah at Mizpah. "},{"kind":"crossref","label":"Jos 18:26","book":"Jos","chapter":18,"verse":26,"letter":"a"},{"kind":"text","text":" The commanders included Ishmael son of Nethaniah, Johanan son of Kareah, Seraiah son of Tanhumeth the Netophathite, and Jaazaniah son of the Maacathite —they and their men. "},{"kind":"crossref","label":"Jr 40:7–8","book":"Jer","chapter":40,"verse":7,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jos 18:26","book":"Jos","chapter":18,"verse":26},{"label":"Jr 40:7–8","book":"Jer","chapter":40,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:24","parts":[{"kind":"text","text":"Gedaliah swore an oath to them and their men, assuring them, “Don’t be afraid of the servants of the Chaldeans. Live in the land and serve the king of Babylon, and it will go well for you.” "},{"kind":"crossref","label":"Jr 40:9","book":"Jer","chapter":40,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Jr 40:9","book":"Jer","chapter":40,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:25","parts":[{"kind":"text","text":"In the seventh month, however, Ishmael son of Nethaniah, son of Elishama, of the royal family, came with ten men and struck down Gedaliah, and he died. Also, they killed the Judeans and the Chaldeans who were with him at Mizpah. "},{"kind":"crossref","label":"Jr 41:1–2","book":"Jer","chapter":41,"verse":1,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 41:1–2","book":"Jer","chapter":41,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:26","parts":[{"kind":"text","text":"Then all the people, from the youngest to the oldest, and the commanders of the army, left and went to Egypt, for they were afraid of the Chaldeans. "},{"kind":"crossref","label":"Is 30:2","book":"Isa","chapter":30,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jr 43:4–7","book":"Jer","chapter":43,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Is 30:2","book":"Isa","chapter":30,"verse":2},{"label":"Jr 43:4–7","book":"Jer","chapter":43,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:27","parts":[{"kind":"text","text":"On "},{"kind":"crossref","label":"Jr 52:31–34","book":"Jer","chapter":52,"verse":31,"letter":"a"},{"kind":"text","text":" the twenty-seventh day of the twelfth month of the thirty-seventh year of the exile of Judah’s King Jehoiachin, in the year Evil-merodach became king of Babylon, he pardoned King Jehoiachin "},{"kind":"crossref","label":"2Kg 24:12","book":"2Ki","chapter":24,"verse":12,"letter":"b"},{"kind":"text","text":" of Judah and released him "},{"kind":"footnote","marker":1,"text":"and released him supplied for clarity"},{"kind":"text","text":" from prison. "},{"kind":"crossref","label":"Gn 40:13","book":"Gen","chapter":40,"verse":13,"letter":"c"},{"kind":"crossref","label":"Gn 40:20","book":"Gen","chapter":40,"verse":20,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 52:31–34","book":"Jer","chapter":52,"verse":31},{"label":"2Kg 24:12","book":"2Ki","chapter":24,"verse":12},{"label":"Gn 40:13","book":"Gen","chapter":40,"verse":13},{"label":"Gn 40:20","book":"Gen","chapter":40,"verse":20}],"footnotes":[{"marker":1,"text":"and released him supplied for clarity"}]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:28","parts":[{"kind":"text","text":"He spoke kindly "},{"kind":"crossref","label":"1Kg 8:50","book":"1Ki","chapter":8,"verse":50,"letter":"a"},{"kind":"text","text":" to him and set his throne over the thrones of the kings who were with him in Babylon. "},{"kind":"crossref","label":"Ezr 5:5","book":"Ezr","chapter":5,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ezr 7:6","book":"Ezr","chapter":7,"verse":6,"letter":"c"},{"kind":"crossref","label":"Ezr 7:28","book":"Ezr","chapter":7,"verse":28,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Kg 8:50","book":"1Ki","chapter":8,"verse":50},{"label":"Ezr 5:5","book":"Ezr","chapter":5,"verse":5},{"label":"Ezr 7:6","book":"Ezr","chapter":7,"verse":6},{"label":"Ezr 7:28","book":"Ezr","chapter":7,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:29","parts":[{"kind":"text","text":"So Jehoiachin changed his prison clothes, and he dined regularly in the presence of the king of Babylon for the rest of his life. "},{"kind":"crossref","label":"2Sm 9:7","book":"2Sa","chapter":9,"verse":7,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Sm 9:7","book":"2Sa","chapter":9,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Ki:25:30","parts":[{"kind":"text","text":"As for his allowance, a regular allowance "},{"kind":"crossref","label":"Gn 43:34","book":"Gen","chapter":43,"verse":34,"letter":"a"},{"kind":"crossref","label":"Neh 12:47","book":"Neh","chapter":12,"verse":47,"letter":"b"},{"kind":"text","text":" was given to him by the king, a portion for each day, for the rest of his life."}],"crossRefs":[{"label":"Gn 43:34","book":"Gen","chapter":43,"verse":34},{"label":"Neh 12:47","book":"Neh","chapter":12,"verse":47}],"footnotes":[]}]},"cachedAt":1783279425844}