ossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:9","parts":[{"kind":"text","text":"Rejoice greatly, Daughter Zion!"},{"kind":"text","text":" Shout in triumph, Daughter Jerusalem!"},{"kind":"text","text":" Look, your King is coming to you;"},{"kind":"text","text":" he is righteous and victorious, "},{"kind":"footnote","marker":1,"text":"Or and has salvation"},{"kind":"text","text":" humble and riding on a donkey,"},{"kind":"text","text":" on a colt, the foal of a donkey. "},{"kind":"crossref","label":"Is 62:11","book":"Isa","chapter":62,"verse":11,"letter":"a"},{"kind":"crossref","label":"Mt 21:5","book":"Mat","chapter":21,"verse":5,"letter":"b"},{"kind":"crossref","label":"Jn 12:15","book":"Jhn","chapter":12,"verse":15,"letter":"c"}],"crossRefs":[{"label":"Is 62:11","book":"Isa","chapter":62,"verse":11},{"label":"Mt 21:5","book":"Mat","chapter":21,"verse":5},{"label":"Jn 12:15","book":"Jhn","chapter":12,"verse":15}],"footnotes":[{"marker":1,"text":"Or and has salvation"}]},{"verseId":"a556c5305ee15c3f-01:Zec:9:10","parts":[{"kind":"text","text":"I will cut off the chariot from Ephraim"},{"kind":"text","text":" and the horse from Jerusalem."},{"kind":"text","text":" The bow of war will be removed,"},{"kind":"text","text":" and he will proclaim peace to the nations."},{"kind":"text","text":" His dominion will extend from sea to sea,"},{"kind":"text","text":" from the Euphrates River"},{"kind":"text","text":" to the ends of the earth. "},{"kind":"crossref","label":"Ps 72:8","book":"Psa","chapter":72,"verse":8,"letter":"a"},{"kind":"crossref","label":"Mc 7:12","book":"Mic","chapter":7,"verse":12,"letter":"b"}],"crossRefs":[{"label":"Ps 72:8","book":"Psa","chapter":72,"verse":8},{"label":"Mc 7:12","book":"Mic","chapter":7,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:11","parts":[{"kind":"text","text":"As for you,"},{"kind":"text","text":" because of the blood of your covenant, "},{"kind":"crossref","label":"Heb 10:29","book":"Heb","chapter":10,"verse":29,"letter":"a"},{"kind":"crossref","label":"Heb 13:20","book":"Heb","chapter":13,"verse":20,"letter":"b"},{"kind":"text","text":" I will release your prisoners"},{"kind":"text","text":" from the waterless cistern. "},{"kind":"crossref","label":"Gn 37:24","book":"Gen","chapter":37,"verse":24,"letter":"a"},{"kind":"crossref","label":"Jr 38:6","book":"Jer","chapter":38,"verse":6,"letter":"b"}],"crossRefs":[{"label":"Heb 10:29","book":"Heb","chapter":10,"verse":29},{"label":"Heb 13:20","book":"Heb","chapter":13,"verse":20},{"label":"Gn 37:24","book":"Gen","chapter":37,"verse":24},{"label":"Jr 38:6","book":"Jer","chapter":38,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:12","parts":[{"kind":"text","text":"Return to a stronghold,"},{"kind":"text","text":" you prisoners who have hope;"},{"kind":"text","text":" today I declare that I will restore double to you. "},{"kind":"crossref","label":"Jb 42:10","book":"Job","chapter":42,"verse":10,"letter":"a"},{"kind":"crossref","label":"Is 61:7","book":"Isa","chapter":61,"verse":7,"letter":"b"},{"kind":"crossref","label":"Jr 16:18","book":"Jer","chapter":16,"verse":18,"letter":"c"}],"crossRefs":[{"label":"Jb 42:10","book":"Job","chapter":42,"verse":10},{"label":"Is 61:7","book":"Isa","chapter":61,"verse":7},{"label":"Jr 16:18","book":"Jer","chapter":16,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:13","parts":[{"kind":"text","text":"For I will bend Judah as my bow;"},{"kind":"text","text":" I will fill that bow with Ephraim."},{"kind":"text","text":" I will rouse your sons, Zion,"},{"kind":"text","text":" against your sons, Greece. "},{"kind":"footnote","marker":1,"text":"Lit Javan"},{"kind":"crossref","label":"Dn 8:21","book":"Dan","chapter":8,"verse":21,"letter":"a"},{"kind":"crossref","label":"Dn 10:20","book":"Dan","chapter":10,"verse":20,"letter":"b"},{"kind":"text","text":" I will make you like a warrior’s sword."}],"crossRefs":[{"label":"Dn 8:21","book":"Dan","chapter":8,"verse":21},{"label":"Dn 10:20","book":"Dan","chapter":10,"verse":20}],"footnotes":[{"marker":1,"text":"Lit Javan"}]},{"verseId":"a556c5305ee15c3f-01:Zec:9:14","parts":[{"kind":"text","text":"Then the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" will appear over them,"},{"kind":"text","text":" and his arrow will fly like lightning."},{"kind":"text","text":" The Lord "},{"kind":"text","text":"God","style":"divine"},{"kind":"text","text":" will sound the ram’s horn"},{"kind":"text","text":" and advance with the southern storms. "},{"kind":"crossref","label":"Ps 83:15","book":"Psa","chapter":83,"verse":15,"letter":"a"}],"crossRefs":[{"label":"Ps 83:15","book":"Psa","chapter":83,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:15","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" of Armies will defend them."},{"kind":"text","text":" They will consume and conquer with slingstones;"},{"kind":"text","text":" they will drink and be rowdy as if with wine. "},{"kind":"crossref","label":"Nm 23:24","book":"Num","chapter":23,"verse":24,"letter":"a"},{"kind":"text","text":" They will be as full as the sprinkling basin, "},{"kind":"crossref","label":"Ex 27:3","book":"Exo","chapter":27,"verse":3,"letter":"a"},{"kind":"text","text":" like those at the corners of the altar. "},{"kind":"crossref","label":"Lv 1:5","book":"Lev","chapter":1,"verse":5,"letter":"a"},{"kind":"crossref","label":"Lv 1:11","book":"Lev","chapter":1,"verse":11,"letter":"b"},{"kind":"crossref","label":"Lv 3:2","book":"Lev","chapter":3,"verse":2,"letter":"c"}],"crossRefs":[{"label":"Nm 23:24","book":"Num","chapter":23,"verse":24},{"label":"Ex 27:3","book":"Exo","chapter":27,"verse":3},{"label":"Lv 1:5","book":"Lev","chapter":1,"verse":5},{"label":"Lv 1:11","book":"Lev","chapter":1,"verse":11},{"label":"Lv 3:2","book":"Lev","chapter":3,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:16","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" their God will save them on that day"},{"kind":"text","text":" as the flock of his people; "},{"kind":"crossref","label":"Ezk 36:38","book":"Ezk","chapter":36,"verse":38,"letter":"a"},{"kind":"text","text":" for they are like jewels in a crown, "},{"kind":"crossref","label":"Lv 8:9","book":"Lev","chapter":8,"verse":9,"letter":"a"},{"kind":"text","text":" sparkling over his land."}],"crossRefs":[{"label":"Ezk 36:38","book":"Ezk","chapter":36,"verse":38},{"label":"Lv 8:9","book":"Lev","chapter":8,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zec:9:17","parts":[{"kind":"text","text":"How lovely and beautiful!"},{"kind":"text","text":" Grain will make the young men flourish,"},{"kind":"text","text":" and new wine, the young women."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279611822}