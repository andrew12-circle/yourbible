k":"Act","chapter":10,"verse":14,"letter":"e"},{"kind":"crossref","label":"1Tm 4:3","book":"1Ti","chapter":4,"verse":3,"letter":"f"}],"crossRefs":[{"label":"Mt 15:18","book":"Mat","chapter":15,"verse":18},{"label":"Mk 7:15","book":"Mrk","chapter":7,"verse":15},{"label":"Ac 21:28","book":"Act","chapter":21,"verse":28},{"label":"Heb 9:13","book":"Heb","chapter":9,"verse":13},{"label":"Ac 10:14–15","book":"Act","chapter":10,"verse":14},{"label":"1Tm 4:3","book":"1Ti","chapter":4,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:15:12","parts":[{"kind":"text","text":"Then the disciples came up and told him, “Do you know that the Pharisees took offense when they heard what you said?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:15:13","parts":[{"kind":"text","text":"He replied, “Every plant that my heavenly Father didn’t plant will be uprooted."},{"kind":"crossref","label":"Is 60:21","book":"Isa","chapter":60,"verse":21,"letter":"a"},{"kind":"crossref","label":"Is 61:3","book":"Isa","chapter":61,"verse":3,"letter":"b"},{"kind":"crossref","label":"Jn 15:2","book":"Jhn","chapter":15,"verse":2,"letter":"c"},{"kind":"crossref","label":"1Co 3:9","book":"1Co","chapter":3,"verse":9,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Is 60:21","book":"Isa","chapter":60,"verse":21},{"label":"Is 61:3","book":"Isa","chapter":61,"verse":3},{"label":"Jn 15:2","book":"Jhn","chapter":15,"verse":2},{"label":"1Co 3:9","book":"1Co","chapter":3,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:15:14","parts":[{"kind":"text","text":"Leave them alone! They are blind guides."},{"kind":"footnote","marker":1,"text":"Other mss add for the blind"},{"kind":"text","text":" And if the blind guide the blind, both will fall into a pit.”"},{"kind":"crossref","label":"Mal 2:8","book":"Mal","chapter":2,"verse":8,"letter":"a"},{"kind":"crossref","label":"Mt 23:16","book":"Mat","chapter":23,"verse":16,"letter":"b"},{"kind":"crossref","label"