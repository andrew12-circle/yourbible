b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 12:34","book":"Mat","chapter":12,"verse":34},{"label":"Jms 3:6","book":"Jas","chapter":3,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:15:19","parts":[{"kind":"text","text":"For from the heart come evil thoughts, murders, adulteries, sexual immoralities, thefts, false testimonies,"},{"kind":"crossref","label":"Eph 4:31","book":"Eph","chapter":4,"verse":31,"letter":"a"},{"kind":"crossref","label":"Col 3:8","book":"Col","chapter":3,"verse":8,"letter":"b"},{"kind":"crossref","label":"1Tm 6:4","book":"1Ti","chapter":6,"verse":4,"letter":"c"},{"kind":"text","text":" slander."},{"kind":"crossref","label":"Ex 20:13–16","book":"Exo","chapter":20,"verse":13,"letter":"d"},{"kind":"crossref","label":"Gl 5:19–21","book":"Gal","chapter":5,"verse":19,"letter":"e"},{"kind":"crossref","label":"Jms 2:4","book":"Jas","chapter":2,"verse":4,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Eph 4:31","book":"Eph","chapter":4,"verse":31},{"label":"Col 3:8","book":"Col","chapter":3,"verse":8},{"label":"1Tm 6:4","book":"1Ti","chapter":6,"verse":4},{"label":"Ex 20:13–16","book":"Exo","chapter":20,"verse":13},{"label":"Gl 5:19–21","book":"Gal","chapter":5,"verse":19},{"label":"Jms 2:4","book":"Jas","chapter":2,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:15:20","parts":[{"kind":"text","text":"These are the things that defile a person; but eating with unwashed hands does not defile a person.”"},{"kind":"crossref","label":"Mt 11:18","book":"Mat","chapter":11,"verse":18,"letter":"a"},{"kind":"crossref","label":"Mk 7:2","book":"Mrk","chapter":7,"verse":2,"letter":"b"},{"kind":"crossref","label":"Mk 7:5","book":"Mrk","chapter":7,"verse":5,"letter":"c"},{"kind":"crossref","label":"1Co 6:9–10","book":"1Co","chapter":6,"verse":9,"letter":"d"}],"crossRefs":[{"label":"Mt 11:18","book":"Mat","chapter":11,"verse":18},{"label":"Mk 7:2","book":"Mrk","chapter":7,"verse":2},{"label":"Mk 7:5","book":