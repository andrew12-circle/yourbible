k","chapter":3,"verse":18},{"label":"Lk 6:15","book":"Luk","chapter":6,"verse":15},{"label":"Ac 1:13","book":"Act","chapter":1,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:10","parts":[{"kind":"text","text":"While he was reclining at the table in the house, many tax collectors and sinners came to eat with Jesus and his disciples. "},{"kind":"crossref","label":"Mt 10:42","book":"Mat","chapter":10,"verse":42,"letter":"a"},{"kind":"crossref","label":"Mt 28:19","book":"Mat","chapter":28,"verse":19,"letter":"b"},{"kind":"crossref","label":"Lk 14:26","book":"Luk","chapter":14,"verse":26,"letter":"c"},{"kind":"crossref","label":"Jn 8:31","book":"Jhn","chapter":8,"verse":31,"letter":"d"},{"kind":"crossref","label":"Jn 13:35","book":"Jhn","chapter":13,"verse":35,"letter":"e"},{"kind":"crossref","label":"Jn 15:8","book":"Jhn","chapter":15,"verse":8,"letter":"f"},{"kind":"crossref","label":"Ac 6:1","book":"Act","chapter":6,"verse":1,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 10:42","book":"Mat","chapter":10,"verse":42},{"label":"Mt 28:19","book":"Mat","chapter":28,"verse":19},{"label":"Lk 14:26","book":"Luk","chapter":14,"verse":26},{"label":"Jn 8:31","book":"Jhn","chapter":8,"verse":31},{"label":"Jn 13:35","book":"Jhn","chapter":13,"verse":35},{"label":"Jn 15:8","book":"Jhn","chapter":15,"verse":8},{"label":"Ac 6:1","book":"Act","chapter":6,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:11","parts":[{"kind":"text","text":"When the Pharisees saw this, they asked his disciples, “Why does your teacher eat with tax collectors and sinners?” "},{"kind":"crossref","label":"Mt 11:19","book":"Mat","chapter":11,"verse":19,"letter":"a"},{"kind":"crossref","label":"Lk 5:30","book":"Luk","chapter":5,"verse":30,"letter":"b"},{"kind":"crossref","label":"Lk 15:2","book":"Luk","chapter":15,"verse":2,"letter":"c"},{"kind":"crossref","label":"Gl 2:15","book":"Gal","chapter":2,"verse":15,"letter":"d"}],"crossRefs":[{"label":"Mt 11:19","book":"Mat","chapter":11,"verse":19},{"label":"Lk 5:30","book":"Luk","chapter":5,"verse":30},{"label":"Lk 15:2","book":"Luk","chapter":15,"verse":2},{"label":"Gl 2:15","book":"Gal","chapter":2,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:12","parts":[{"kind":"text","text":"Now when he heard this, he said, “It is not those who are well who need a doctor, but those who are sick."},{"kind":"crossref","label":"Mk 2:17","book":"Mrk","chapter":2,"verse":17,"letter":"a"},{"kind":"crossref","label":"Lk 5:31","book":"Luk","chapter":5,"verse":31,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 2:17","book":"Mrk","chapter":2,"verse":17},{"label":"Lk 5:31","book":"Luk","chapter":5,"verse":31}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:13","parts":[{"kind":"text","text":"Go and learn what this means: I desire mercy and not sacrifice."},{"kind":"crossref","label":"Hs 6:6","book":"Hos","chapter":6,"verse":6,"letter":"a"},{"kind":"crossref","label":"Hs 6:6","book":"Hos","chapter":6,"verse":6,"letter":"b"},{"kind":"crossref","label":"Mc 6:6","book":"Mic","chapter":6,"verse":6,"letter":"c"},{"kind":"crossref","label":"Mt 12:7","book":"Mat","chapter":12,"verse":7,"letter":"d"},{"kind":"text","text":" For I didn’t come to call the righteous, but sinners.”"},{"kind":"footnote","marker":1,"text":"Other mss add to repentance"}],"crossRefs":[{"label":"Hs 6:6","book":"Hos","chapter":6,"verse":6},{"label":"Hs 6:6","book":"Hos","chapter":6,"verse":6},{"label":"Mc 6:6","book":"Mic","chapter":6,"verse":6},{"label":"Mt 12:7","book":"Mat","chapter":12,"verse":7}],"footnotes":[{"marker":1,"text":"Other mss add to repentance"}]},{"verseId":"a556c5305ee15c3f-01:Mat:9:14","parts":[{"kind":"text","text":"Then John’s disciples came to him, saying, “Why do we and the Pharisees fast often, but your disciples do not fast?” "},{"kind":"crossref","label":"Mt 11:2","book":"Mat","chapter":11,"verse":2,"letter":"a"},{"kind":"crossref","label":"Mt 14:12","book":"Mat","chapter":14,"verse":12,"letter":"b"},{"kind":"crossref","label":"Mt 15:2","book":"Mat","chapter":15,"verse":2,"letter":"c"},{"kind":"crossref","label":"Lk 11:1","book":"Luk","chapter":11,"verse":1,"letter":"d"},{"kind":"crossref","label":"Lk 18:12","book":"Luk","chapter":18,"verse":12,"letter":"e"}],"crossRefs":[{"label":"Mt 11:2","book":"Mat","chapter":11,"verse":2},{"label":"Mt 14:12","book":"Mat","chapter":14,"verse":12},{"label":"Mt 15:2","book":"Mat","chapter":15,"verse":2},{"label":"Lk 11:1","book":"Luk","chapter":11,"verse":1},{"label":"Lk 18:12","book":"Luk","chapter":18,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:15","parts":[{"kind":"text","text":"Jesus said to them, “Can the wedding guests"},{"kind":"footnote","marker":1,"text":"Lit the sons of the bridal chamber"},{"kind":"text","text":" be sad while the groom is with them? The time"},{"kind":"footnote","marker":2,"text":"Lit days"},{"kind":"text","text":" will come when the groom will be taken away from them, and then they will fast. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit the sons of the bridal chamber"},{"marker":2,"text":"Lit days"}]},{"verseId":"a556c5305ee15c3f-01:Mat:9:16","parts":[{"kind":"text","text":"No one patches an old garment with unshrunk cloth, because the patch pulls away from the garment and makes the tear worse. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:17","parts":[{"kind":"text","text":"And no one puts"},{"kind":"footnote","marker":3,"text":"Lit And they do not put"},{"kind":"text","text":" new wine into old wineskins. Otherwise, the skins burst, the wine spills out, and the skins are ruined. No, they put new wine into fresh wineskins, and both are preserved.”"}],"crossRefs":[],"footnotes":[{"marker":3,"text":"Lit And they do not put"}]},{"verseId":"a556c5305ee15c3f-01:Mat:9:18","parts":[{"kind":"text","text":"As he was telling them these things, "},{"kind":"crossref","label":"Mk 5:22–43","book":"Mrk","chapter":5,"verse":22,"letter":"a"},{"kind":"crossref","label":"Lk 8:41–56","book":"Luk","chapter":8,"verse":41,"letter":"b"},{"kind":"text","text":" suddenly one of the leaders came and knelt down before him, saying, “My daughter just died, "},{"kind":"footnote","marker":1,"text":"Lit daughter has now come to the end"},{"kind":"text","text":" but come and lay your hand on her, and she will live.” "},{"kind":"crossref","label":"Mt 8:2–3","book":"Mat","chapter":8,"verse":2,"letter":"c"},{"kind":"crossref","label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 5:22–43","book":"Mrk","chapter":5,"verse":22},{"label":"Lk 8:41–56","book":"Luk","chapter":8,"verse":41},{"label":"Mt 8:2–3","book":"Mat","chapter":8,"verse":2},{"label":"Mk 5:23","book":"Mrk","chapter":5,"verse":23}],"footnotes":[{"marker":1,"text":"Lit daughter has now come to the end"}]},{"verseId":"a556c5305ee15c3f-01:Mat:9:19","parts":[{"kind":"text","text":"So Jesus and his disciples got up and followed "},{"kind":"crossref","label":"Lk 5:11","book":"Luk","chapter":5,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12,"letter":"b"},{"kind":"text","text":" him."}],"crossRefs":[{"label":"Lk 5:11","book":"Luk","chapter":5,"verse":11},{"label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:20","parts":[{"kind":"text","text":"Just then, a woman who had suffered from bleeding for twelve years approached from behind and touched the end of his robe, "},{"kind":"crossref","label":"Lv 15:25","book":"Lev","chapter":15,"verse":25,"letter":"a"},{"kind":"crossref","label":"Nm 15:38","book":"Num","chapter":15,"verse":38,"letter":"b"},{"kind":"crossref","label":"Dt 22:12","book":"Deu","chapter":22,"verse":12,"letter":"c"},{"kind":"crossref","label":"Mt 14:36","book":"Mat","chapter":14,"verse":36,"letter":"d"},{"kind":"crossref","label":"Mt 23:5","book"