chapter":10,"verse":36}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:4","parts":[{"kind":"text","text":"Perceiving their thoughts, "},{"kind":"crossref","label":"Mt 12:25","book":"Mat","chapter":12,"verse":25,"letter":"a"},{"kind":"crossref","label":"Lk 6:8","book":"Luk","chapter":6,"verse":8,"letter":"b"},{"kind":"crossref","label":"Lk 9:47","book":"Luk","chapter":9,"verse":47,"letter":"c"},{"kind":"crossref","label":"Lk 11:17","book":"Luk","chapter":11,"verse":17,"letter":"d"},{"kind":"text","text":" Jesus said, “Why are you thinking evil things in your hearts?"},{"kind":"footnote","marker":1,"text":"Or minds"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 12:25","book":"Mat","chapter":12,"verse":25},{"label":"Lk 6:8","book":"Luk","chapter":6,"verse":8},{"label":"Lk 9:47","book":"Luk","chapter":9,"verse":47},{"label":"Lk 11:17","book":"Luk","chapter":11,"verse":17}],"footnotes":[{"marker":1,"text":"Or minds"}]},{"verseId":"a556c5305ee15c3f-01:Mat:9:5","parts":[{"kind":"text","text":"For which is easier: to say, ‘Your sins are forgiven,’ or to say, ‘Get up and walk’? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:6","parts":[{"kind":"text","text":"But so that you may know that the Son of Man has authority on earth to forgive sins” —then he told the paralytic, “Get up, take your stretcher, and go home.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:7","parts":[{"kind":"text","text":"So he got up and went home. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:8","parts":[{"kind":"text","text":"When the crowds saw this, they were awestruck "},{"kind":"footnote","marker":2,"text":"Other mss read amazed"},{"kind":"footnote","marker":3,"text":"Lit afraid"},{"kind":"text","text":" and gave glory "},{"kind":"crossref","label":"Mt 5:16","book":"Mat","chapter":5,"verse":16,"letter":"a"},{"kind":"crossref","label":"Mt 15:31","book":"Mat","chapter":15,"verse":31,"letter":"b"},{"kind"