":14},{"label":"Mt 15:32","book":"Mat","chapter":15,"verse":32},{"label":"Mk 6:34","book":"Mrk","chapter":6,"verse":34},{"label":"Mk 8:2","book":"Mrk","chapter":8,"verse":2},{"label":"Nm 27:17","book":"Num","chapter":27,"verse":17},{"label":"1Kg 22:17","book":"1Ki","chapter":22,"verse":17},{"label":"Ezk 34:5","book":"Ezk","chapter":34,"verse":5},{"label":"Zch 10:2","book":"Zec","chapter":10,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:37","parts":[{"kind":"text","text":"Then he said to his disciples, "},{"kind":"crossref","label":"Mt 10:1","book":"Mat","chapter":10,"verse":1,"letter":"a"},{"kind":"crossref","label":"Mt 26:56","book":"Mat","chapter":26,"verse":56,"letter":"b"},{"kind":"crossref","label":"Mk 3:7","book":"Mrk","chapter":3,"verse":7,"letter":"c"},{"kind":"crossref","label":"Mk 16:20","book":"Mrk","chapter":16,"verse":20,"letter":"d"},{"kind":"crossref","label":"Lk 6:13","book":"Luk","chapter":6,"verse":13,"letter":"e"},{"kind":"crossref","label":"Jn 12:16","book":"Jhn","chapter":12,"verse":16,"letter":"f"},{"kind":"text","text":" “The harvest is abundant, but the workers are few. "}],"crossRefs":[{"label":"Mt 10:1","book":"Mat","chapter":10,"verse":1},{"label":"Mt 26:56","book":"Mat","chapter":26,"verse":56},{"label":"Mk 3:7","book":"Mrk","chapter":3,"verse":7},{"label":"Mk 16:20","book":"Mrk","chapter":16,"verse":20},{"label":"Lk 6:13","book":"Luk","chapter":6,"verse":13},{"label":"Jn 12:16","book":"Jhn","chapter":12,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:9:38","parts":[{"kind":"text","text":"Therefore, pray to the Lord of the harvest to send out workers into his harvest.”"}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783279617148}