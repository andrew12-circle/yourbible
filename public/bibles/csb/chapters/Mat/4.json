apter":5,"verse":3},{"label":"Mt 5:10","book":"Mat","chapter":5,"verse":10},{"label":"Mt 5:19","book":"Mat","chapter":5,"verse":19},{"label":"Mt 7:21","book":"Mat","chapter":7,"verse":21},{"label":"Mt 8:11","book":"Mat","chapter":8,"verse":11},{"label":"Mk 1:14","book":"Mrk","chapter":1,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:18","parts":[{"kind":"text","text":"As "},{"kind":"crossref","label":"Mk 1:16–20","book":"Mrk","chapter":1,"verse":16,"letter":"a"},{"kind":"crossref","label":"Lk 5:2–11","book":"Luk","chapter":5,"verse":2,"letter":"b"},{"kind":"crossref","label":"Jn 1:40–42","book":"Jhn","chapter":1,"verse":40,"letter":"c"},{"kind":"text","text":" he was walking along the Sea of Galilee, "},{"kind":"crossref","label":"Mt 15:29","book":"Mat","chapter":15,"verse":29,"letter":"d"},{"kind":"crossref","label":"Mk 7:31","book":"Mrk","chapter":7,"verse":31,"letter":"e"},{"kind":"crossref","label":"Lk 5:1","book":"Luk","chapter":5,"verse":1,"letter":"f"},{"kind":"crossref","label":"Jn 6:1","book":"Jhn","chapter":6,"verse":1,"letter":"g"},{"kind":"text","text":" he saw two brothers, Simon (who is called Peter), and his brother Andrew. They were casting a net into the sea —for they were fishermen. "}],"crossRefs":[{"label":"Mk 1:16–20","book":"Mrk","chapter":1,"verse":16},{"label":"Lk 5:2–11","book":"Luk","chapter":5,"verse":2},{"label":"Jn 1:40–42","book":"Jhn","chapter":1,"verse":40},{"label":"Mt 15:29","book":"Mat","chapter":15,"verse":29},{"label":"Mk 7:31","book":"Mrk","chapter":7,"verse":31},{"label":"Lk 5:1","book":"Luk","chapter":5,"verse":1},{"label":"Jn 6:1","book":"Jhn","chapter":6,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:19","parts":[{"kind":"text","text":"“Follow me,” he told them, “and I will make you fish for"},{"kind":"footnote","marker":1,"text":"Or you fishers of"},{"kind":"text","text":" people.” "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or you fishers of"}]},{"verseId":"a556c5305ee15c3f-01:Mat:4:20","parts":[{"kind":"text","text":"Immediately they left their nets and followed him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:21","parts":[{"kind":"text","text":"Going on from there, he saw two other brothers, James the son of Zebedee, and his brother John. They were in a boat with Zebedee their father, preparing their nets, and he called them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:22","parts":[{"kind":"text","text":"Immediately they left the boat and their father and followed him."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:23","parts":[{"kind":"text","text":"Now Jesus began to go all over Galilee, "},{"kind":"crossref","label":"Mk 1:35–39","book":"Mrk","chapter":1,"verse":35,"letter":"a"},{"kind":"crossref","label":"Lk 4:42–44","book":"Luk","chapter":4,"verse":42,"letter":"b"},{"kind":"text","text":" teaching in their synagogues, preaching the good news of the kingdom, and healing every "},{"kind":"footnote","marker":1,"text":"Or every kind of"},{"kind":"text","text":" disease and sickness "},{"kind":"footnote","marker":2,"text":"Or physical ailment"},{"kind":"text","text":" among the people. "},{"kind":"crossref","label":"Mt 13:54","book":"Mat","chapter":13,"verse":54,"letter":"c"},{"kind":"crossref","label":"Mt 24:14","book":"Mat","chapter":24,"verse":14,"letter":"d"},{"kind":"crossref","label":"Ac 10:38","book":"Act","chapter":10,"verse":38,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 1:35–39","book":"Mrk","chapter":1,"verse":35},{"label":"Lk 4:42–44","book":"Luk","chapter":4,"verse":42},{"label":"Mt 13:54","book":"Mat","chapter":13,"verse":54},{"label":"Mt 24:14","book":"Mat","chapter":24,"verse":14},{"label":"Ac 10:38","book":"Act","chapter":10,"verse":38}],"footnotes":[{"marker":1,"text":"Or every kind of"},{"marker":2,"text":"Or physical ailment"}]},{"verseId":"a556c5305ee15c3f-01:Mat:4:24","parts":[{"kind":"text","text":"Then the news about him spread throughout Syria. "},{"kind":"crossref","label":"Lk 2:2","book":"Luk","chapter":2,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ac 15:23","book":"Act","chapter":15,"verse":23,"letter":"b"},{"kind":"crossref","label":"Gl 1:21","book":"Gal","chapter":1,"verse":21,"letter":"c"},{"kind":"text","text":" So they brought to him all those who were afflicted, those suffering from various diseases and intense pains, the demon-possessed, the epileptics, and the paralytics. "},{"kind":"crossref","label":"Mt 8:16","book":"Mat","chapter":8,"verse":16,"letter":"d"},{"kind":"crossref","label":"Mt 9:32","book":"Mat","chapter":9,"verse":32,"letter":"e"},{"kind":"crossref","label":"Mk 5:15","book":"Mrk","chapter":5,"verse":15,"letter":"f"},{"kind":"crossref","label":"Jn 10:21","book":"Jhn","chapter":10,"verse":21,"letter":"g"},{"kind":"text","text":" And he healed them. "}],"crossRefs":[{"label":"Lk 2:2","book":"Luk","chapter":2,"verse":2},{"label":"Ac 15:23","book":"Act","chapter":15,"verse":23},{"label":"Gl 1:21","book":"Gal","chapter":1,"verse":21},{"label":"Mt 8:16","book":"Mat","chapter":8,"verse":16},{"label":"Mt 9:32","book":"Mat","chapter":9,"verse":32},{"label":"Mk 5:15","book":"Mrk","chapter":5,"verse":15},{"label":"Jn 10:21","book":"Jhn","chapter":10,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:4:25","parts":[{"kind":"text","text":"Large crowds followed him from Galilee, the Decapolis, Jerusalem, Judea, and beyond the Jordan. "},{"kind":"crossref","label":"Mk 3:7","book":"Mrk","chapter":3,"verse":7,"letter":"a"},{"kind":"crossref","label":"Mk 5:20","book":"Mrk","chapter":5,"verse":20,"letter":"b"},{"kind":"crossref","label":"Lk 6:17","book":"Luk","chapter":6,"verse":17,"letter":"c"}],"crossRefs":[{"label":"Mk 3:7","book":"Mrk","chapter":3,"verse":7},{"label":"Mk 5:20","book":"Mrk","chapter":5,"verse":20},{"label":"Lk 6:17","book":"Luk","chapter":6,"verse":17}],"footnotes":[]}]},"cachedAt":1783099495343}