"crossref","label":"Jn 6:48","book":"Jhn","chapter":6,"verse":48,"letter":"c"},{"kind":"crossref","label":"Jn 7:37","book":"Jhn","chapter":7,"verse":37,"letter":"d"}],"crossRefs":[{"label":"Is 55:1–2","book":"Isa","chapter":55,"verse":1},{"label":"Jn 4:14","book":"Jhn","chapter":4,"verse":14},{"label":"Jn 6:48","book":"Jhn","chapter":6,"verse":48},{"label":"Jn 7:37","book":"Jhn","chapter":7,"verse":37}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:7","parts":[{"kind":"text","text":"Blessed are the merciful,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:8","parts":[{"kind":"text","text":"Blessed are the pure in heart,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:9","parts":[{"kind":"text","text":"Blessed are the peacemakers,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:10","parts":[{"kind":"text","text":"Blessed are those who are persecuted because of righteousness,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:11","parts":[{"kind":"text","text":"“You are blessed when they insult you and persecute you and falsely say every kind of evil against you because of me. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:12","parts":[{"kind":"text","text":"Be glad and rejoice, because your reward is great in heaven. For that is how they persecuted"},{"kind":"crossref","label":"Mt 2:23","book":"Mat","chapter":2,"verse":23,"letter":"a"},{"kind":"crossref","label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12,"letter":"b"},{"kind":"text","text":" the prophets who were before you."},{"kind":"crossref","label":"Mt 23:37","book":"Mat","chapter":23,"verse":37,"letter":"c"},{"kind":"crossref","label":"Ac 7:52","book":"Act","chapter":7,"verse":52,"letter":"d"},{"kind":"crossref","label":"1Th 2:15","book":"1Th","chapter":2,"verse":15,"letter":"e"}],"crossRefs":[{"label":"Mt 2:23","book":"Mat","chapter":2,"verse":23},{"label":"2Tm 3:12","book":"2Ti","chapter":3,"verse":12},{"label":"Mt 23:37","book":"Mat","chapter":23,"verse":37},{"label":"Ac 7:52","book":"Act","chapter":7,"verse":52},{"label":"1Th 2:15","book":"1Th","chapter":2,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:13","parts":[{"kind":"text","text":"“You are the salt of the earth. But if the salt should lose its taste, how can it be made salty?"},{"kind":"footnote","marker":1,"text":"Or how can the earth be salted?"},{"kind":"text","text":" It’s no longer good for anything but to be thrown out and trampled under people’s feet."},{"kind":"crossref","label":"Mk 9:50","book":"Mrk","chapter":9,"verse":50,"letter":"a"},{"kind":"crossref","label":"Lk 14:34","book":"Luk","chapter":14,"verse":34,"letter":"b"}],"crossRefs":[{"label":"Mk 9:50","book":"Mrk","chapter":9,"verse":50},{"label":"Lk 14:34","book":"Luk","chapter":14,"verse":34}],"footnotes":[{"marker":1,"text":"Or how can the earth be salted?"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:14","parts":[{"kind":"text","text":"“You are the light of the world. A city situated on a hill cannot be hidden."},{"kind":"crossref","label":"Pr 4:18","book":"Pro","chapter":4,"verse":18,"letter":"a"},{"kind":"crossref","label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12,"letter":"b"},{"kind":"crossref","label":"Php 2:15","book":"Php","chapter":2,"verse":15,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Pr 4:18","book":"Pro","chapter":4,"verse":18},{"label":"Jn 8:12","book":"Jhn","chapter":8,"verse":12},{"label":"Php 2:15","book":"Php","chapter":2,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:15","parts":[{"kind":"text","text":"No one lights a lamp"},{"kind":"crossref","label":"Jn 5:35","book":"Jhn","chapter":5,"verse":35,"letter":"a"},{"kind":"crossref","label":"Rv 21:23","book":"Rev","chapter":21,"verse":23,"letter":"b"},{"kind":"text","text":" and puts it under a basket, but rather on a lampstand, and it gives light for all who are in the house."},{"kind":"crossref","label":"Mk 4:21","book":"Mrk","chapter":4,"verse":21,"letter":"c"},{"kind":"crossref","label":"Lk 8:16","book":"Luk","chapter":8,"verse":16,"letter":"d"},{"kind":"crossref","label":"Lk 11:33","book":"Luk","chapter":11,"verse":33,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 5:35","book":"Jhn","chapter":5,"verse":35},{"label":"Rv 21:23","book":"Rev","chapter":21,"verse":23},{"label":"Mk 4:21","book":"Mrk","chapter":4,"verse":21},{"label":"Lk 8:16","book":"Luk","chapter":8,"verse":16},{"label":"Lk 11:33","book":"Luk","chapter":11,"verse":33}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:16","parts":[{"kind":"text","text":"In the same way, let your light shine before others, so that they may see your good works and give glory to your Father in heaven."},{"kind":"crossref","label":"Mt 9:8","book":"Mat","chapter":9,"verse":8,"letter":"a"},{"kind":"crossref","label":"Jn 15:8","book":"Jhn","chapter":15,"verse":8,"letter":"b"},{"kind":"crossref","label":"1Pt 2:12","book":"1Pe","chapter":2,"verse":12,"letter":"c"}],"crossRefs":[{"label":"Mt 9:8","book":"Mat","chapter":9,"verse":8},{"label":"Jn 15:8","book":"Jhn","chapter":15,"verse":8},{"label":"1Pt 2:12","book":"1Pe","chapter":2,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:17","parts":[{"kind":"text","text":"“Don’t think that I came to abolish the Law or the Prophets. I did not come to abolish but to fulfill."},{"kind":"crossref","label":"Mt 7:12","book":"Mat","chapter":7,"verse":12,"letter":"a"},{"kind":"crossref","label":"Rm 3:31","book":"Rom","chapter":3,"verse":31,"letter":"b"},{"kind":"crossref","label":"Rm 10:4","book":"Rom","chapter":10,"verse":4,"letter":"c"},{"kind":"crossref","label":"Rm 13:8","book":"Rom","chapter":13,"verse":8,"letter":"d"},{"kind":"crossref","label":"Gl 3:24","book":"Gal","chapter":3,"verse":24,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 7:12","book":"Mat","chapter":7,"verse":12},{"label":"Rm 3:31","book":"Rom","chapter":3,"verse":31},{"label":"Rm 10:4","book":"Rom","chapter":10,"verse":4},{"label":"Rm 13:8","book":"Rom","chapter":13,"verse":8},{"label":"Gl 3:24","book":"Gal","chapter":3,"verse":24}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:18","parts":[{"kind":"text","text":"For truly I tell you, until heaven and earth pass away, not the smallest letter"},{"kind":"footnote","marker":1,"text":"Or not one iota; iota is the smallest letter of the Gk alphabet."},{"kind":"text","text":" or one stroke of a letter will pass away from the law until all things are accomplished. "}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or not one iota; iota is the smallest letter of the Gk alphabet."}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:19","parts":[{"kind":"text","text":"Therefore, whoever breaks one of the least of these commands and teaches others to do the same will be called least in the kingdom of heaven. But whoever does and teaches these commands will be called great in the kingdom of heaven."},{"kind":"crossref","label":"Mt 11:11","book":"Mat","chapter":11,"verse":11,"letter":"a"},{"kind":"crossref","label":"Mt 24:35","book":"Mat","chapter":24,"verse":35,"letter":"b"},{"kind":"crossref","label":"Lk 16:17","book":"Luk","chapter":16,"verse":17,"letter":"c"},{"kind":"crossref","label":"Jms 2:10","book":"Jas","chapter":2,"verse":10,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 11:11","book":"Mat","chapter":11,"verse":11},{"label":"Mt 24:35","book":"Mat","chapter":24,"verse":35},{"label":"Lk 16:17","book":"Luk","chapter":16,"verse":17},{"label":"Jms 2:10","book":"Jas","chapter":2,"verse":10}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:20","parts":[{"kind":"text","text":"For I tell you, unless your righteousness surpasses that of the scribes and Pharisees, you will never get into the kingdom of heaven."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:21","parts":[{"kind":"text","text":"“You have heard that it was said to our ancestors, Do not murder,"},{"kind":"crossref","label":"Ex 20:13","book":"Exo","chapter":20,"verse":13,"letter":"a"},{"kind":"crossref","label":"Dt 5:17","book":"Deu","chapter":5,"verse":17,"letter":"b"},{"kind":"crossref","label":"Ex 20:13","book":"Exo","chapter":20,"verse":13,"letter":"c"},{"kind":"crossref","label":"Dt 5:17","book":"Deu","chapter":5,"verse":17,"letter":"d"},{"kind":"text","text":" and whoever murders will be subject to judgment."},{"kind":"crossref","label":"Mt 19:18","book":"Mat","chapter":19,"verse":18,"letter":"e"},{"kind":"crossref","label":"Mt 23:31","book":"Mat","chapter":23,"verse":31,"letter":"f"},{"kind":"crossref","label":"Mt 23:35","book":"Mat","chapter":23,"verse":35,"letter":"g"},{"kind":"crossref","label":"Mk 10:19","book":"Mrk","chapter":10,"verse":19,"letter":"h"},{"kind":"crossref","label":"Lk 18:20","book":"Luk","chapter":18,"verse":20,"letter":"i"},{"kind":"crossref","label":"Rm 13:9","book":"Rom","chapter":13,"verse":9,"letter":"j"},{"kind":"crossref","label":"Jms 2:11","book":"Jas","chapter":2,"verse":11,"letter":"k"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 20:13","book":"Exo","chapter":20,"verse":13},{"label":"Dt 5:17","book":"Deu","chapter":5,"verse":17},{"label":"Ex 20:13","book":"Exo","chapter":20,"verse":13},{"label":"Dt 5:17","book":"Deu","chapter":5,"verse":17},{"label":"Mt 19:18","book":"Mat","chapter":19,"verse":18},{"label":"Mt 23:31","book":"Mat","chapter":23,"verse":31},{"label":"Mt 23:35","book":"Mat","chapter":23,"verse":35},{"label":"Mk 10:19","book":"Mrk","chapter":10,"verse":19},{"label":"Lk 18:20","book":"Luk","chapter":18,"verse":20},{"label":"Rm 13:9","book":"Rom","chapter":13,"verse":9},{"label":"Jms 2:11","book":"Jas","chapter":2,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:22","parts":[{"kind":"text","text":"But I tell you, everyone who is angry with his brother or sister"},{"kind":"footnote","marker":1,"text":"Other mss add without a cause"},{"kind":"text","text":" will be subject to judgment. Whoever insults"},{"kind":"footnote","marker":2,"text":"Lit Whoever says ‘Raca’; an Aramaic term of abuse that puts someone down, insulting one’s intelligence"},{"kind":"text","text":" his brother or sister will be subject to the court."},{"kind":"footnote","marker":3,"text":"Lit Sanhedrin"},{"kind":"text","text":" Whoever says, ‘You fool!’ will be subject to hellfire."},{"kind":"footnote","marker":4,"text":"Lit the gehenna of fire"},{"kind":"crossref","label":"Mt 18:9","book":"Mat","chapter":18,"verse":9,"letter":"a"},{"kind":"crossref","label":"Mk 9:43","book":"Mrk","chapter":9,"verse":43,"letter":"b"},{"kind":"crossref","label":"Jms 3:6","book":"Jas","chapter":3,"verse":6,"letter":"c"},{"kind":"crossref","label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 18:9","book":"Mat","chapter":18,"verse":9},{"label":"Mk 9:43","book":"Mrk","chapter":9,"verse":43},{"label":"Jms 3:6","book":"Jas","chapter":3,"verse":6},{"label":"1Jn 3:15","book":"1Jn","chapter":3,"verse":15}],"footnotes":[{"marker":1,"text":"Other mss add without a cause"},{"marker":2,"text":"Lit Whoever says ‘Raca’; an Aramaic term of abuse that puts someone down, insulting one’s intelligence"},{"marker":3,"text":"Lit Sanhedrin"},{"marker":4,"text":"Lit the gehenna of fire"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:23","parts":[{"kind":"text","text":"So if you are offering your gift on the altar, and there you remember that your brother or sister has something against you, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:24","parts":[{"kind":"text","text":"leave your gift there in front of the altar. First go and be reconciled with your brother or sister, and then come and offer your gift. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:25","parts":[{"kind":"text","text":"Reach a settlement quickly with your adversary while you’re on the way with him to the court, or your adversary will hand you over to the judge, and the judge to"},{"kind":"footnote","marker":5,"text":"Other mss read judge will hand you over to"},{"kind":"text","text":" the officer, and you will be thrown into prison."},{"kind":"crossref","label":"Pr 25:8","book":"Pro","chapter":25,"verse":8,"letter":"a"},{"kind":"crossref","label":"Lk 12:58","book":"Luk","chapter":12,"verse":58,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Pr 25:8","book":"Pro","chapter":25,"verse":8},{"label":"Lk 12:58","book":"Luk","chapter":12,"verse":58}],"footnotes":[{"marker":5,"text":"Other mss read judge will hand you over to"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:26","parts":[{"kind":"text","text":"Truly I tell you, you will never get out of there until you have paid the last penny."},{"kind":"footnote","marker":6,"text":"Lit quadrans, the smallest and least valuable Roman coin, worth 1/64 of a daily wage"}],"crossRefs":[],"footnotes":[{"marker":6,"text":"Lit quadrans, the smallest and least valuable Roman coin, worth 1/64 of a daily wage"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:27","parts":[{"kind":"text","text":"“You have heard that it was said, Do not commit adultery."},{"kind":"crossref","label":"Ex 20:14","book":"Exo","chapter":20,"verse":14,"letter":"a"},{"kind":"crossref","label":"Dt 5:18","book":"Deu","chapter":5,"verse":18,"letter":"b"},{"kind":"crossref","label":"Ex 20:14","book":"Exo","chapter":20,"verse":14,"letter":"c"},{"kind":"crossref","label":"Dt 5:18","book":"Deu","chapter":5,"verse":18,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 20:14","book":"Exo","chapter":20,"verse":14},{"label":"Dt 5:18","book":"Deu","chapter":5,"verse":18},{"label":"Ex 20:14","book":"Exo","chapter":20,"verse":14},{"label":"Dt 5:18","book":"Deu","chapter":5,"verse":18}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:28","parts":[{"kind":"text","text":"But I tell you, everyone who looks at a woman lustfully has already committed adultery with her in his heart."},{"kind":"crossref","label":"2Sm 11:2","book":"2Sa","chapter":11,"verse":2,"letter":"a"},{"kind":"crossref","label":"Jb 31:1","book":"Job","chapter":31,"verse":1,"letter":"b"},{"kind":"crossref","label":"Pr 6:25","book":"Pro","chapter":6,"verse":25,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Sm 11:2","book":"2Sa","chapter":11,"verse":2},{"label":"Jb 31:1","book":"Job","chapter":31,"verse":1},{"label":"Pr 6:25","book":"Pro","chapter":6,"verse":25}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:29","parts":[{"kind":"text","text":"If your right eye causes you to sin,"},{"kind":"crossref","label":"Mt 18:9","book":"Mat","chapter":18,"verse":9,"letter":"a"},{"kind":"crossref","label":"Mk 9:47","book":"Mrk","chapter":9,"verse":47,"letter":"b"},{"kind":"text","text":" gouge it out and throw it away. For it is better that you lose one of the parts of your body than for your whole body to be thrown into hell."},{"kind":"crossref","label":"Mt 10:28","book":"Mat","chapter":10,"verse":28,"letter":"c"},{"kind":"crossref","label":"Mt 23:15","book":"Mat","chapter":23,"verse":15,"letter":"d"},{"kind":"crossref","label":"Mt 23:33","book":"Mat","chapter":23,"verse":33,"letter":"e"},{"kind":"crossref","label":"Lk 12:5","book":"Luk","chapter":12,"verse":5,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 18:9","book":"Mat","chapter":18,"verse":9},{"label":"Mk 9:47","book":"Mrk","chapter":9,"verse":47},{"label":"Mt 10:28","book":"Mat","chapter":10,"verse":28},{"label":"Mt 23:15","book":"Mat","chapter":23,"verse":15},{"label":"Mt 23:33","book":"Mat","chapter":23,"verse":33},{"label":"Lk 12:5","book":"Luk","chapter":12,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:30","parts":[{"kind":"text","text":"And if your right hand causes you to sin, cut it off and throw it away. For it is better that you lose one of the parts of your body than for your whole body to go into hell."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:31","parts":[{"kind":"text","text":"“It was also said, Whoever divorces"},{"kind":"crossref","label":"Jr 3:1","book":"Jer","chapter":3,"verse":1,"letter":"a"},{"kind":"crossref","label":"Mt 19:7","book":"Mat","chapter":19,"verse":7,"letter":"b"},{"kind":"crossref","label":"Mk 10:4","book":"Mrk","chapter":10,"verse":4,"letter":"c"},{"kind":"text","text":" his wife must give her a written notice of divorce."},{"kind":"crossref","label":"Dt 24:1","book":"Deu","chapter":24,"verse":1,"letter":"d"},{"kind":"crossref","label":"Dt 24:1","book":"Deu","chapter":24,"verse":1,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jr 3:1","book":"Jer","chapter":3,"verse":1},{"label":"Mt 19:7","book":"Mat","chapter":19,"verse":7},{"label":"Mk 10:4","book":"Mrk","chapter":10,"verse":4},{"label":"Dt 24:1","book":"Deu","chapter":24,"verse":1},{"label":"Dt 24:1","book":"Deu","chapter":24,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:32","parts":[{"kind":"text","text":"But I tell you, everyone who divorces his wife, except in a case of sexual immorality, causes her to commit adultery. And whoever marries a divorced woman commits adultery."},{"kind":"crossref","label":"Mt 19:9","book":"Mat","chapter":19,"verse":9,"letter":"a"},{"kind":"crossref","label":"Mk 10:11","book":"Mrk","chapter":10,"verse":11,"letter":"b"},{"kind":"crossref","label":"Lk 16:18","book":"Luk","chapter":16,"verse":18,"letter":"c"},{"kind":"crossref","label":"Rm 7:3","book":"Rom","chapter":7,"verse":3,"letter":"d"},{"kind":"crossref","label":"1Co 7:11","book":"1Co","chapter":7,"verse":11,"letter":"e"}],"crossRefs":[{"label":"Mt 19:9","book":"Mat","chapter":19,"verse":9},{"label":"Mk 10:11","book":"Mrk","chapter":10,"verse":11},{"label":"Lk 16:18","book":"Luk","chapter":16,"verse":18},{"label":"Rm 7:3","book":"Rom","chapter":7,"verse":3},{"label":"1Co 7:11","book":"1Co","chapter":7,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:33","parts":[{"kind":"text","text":"“Again, you have heard that it was said to our ancestors, You must not break your oath, but you must keep your oaths to the Lord."},{"kind":"crossref","label":"Lv 19:12","book":"Lev","chapter":19,"verse":12,"letter":"a"},{"kind":"crossref","label":"Nm 30:2","book":"Num","chapter":30,"verse":2,"letter":"b"},{"kind":"crossref","label":"Dt 23:21","book":"Deu","chapter":23,"verse":21,"letter":"c"},{"kind":"crossref","label":"Lv 19:12","book":"Lev","chapter":19,"verse":12,"letter":"d"},{"kind":"crossref","label":"Nm 30:2","book":"Num","chapter":30,"verse":2,"letter":"e"},{"kind":"crossref","label":"Dt 23:21","book":"Deu","chapter":23,"verse":21,"letter":"f"},{"kind":"crossref","label":"Mt 23:16","book":"Mat","chapter":23,"verse":16,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lv 19:12","book":"Lev","chapter":19,"verse":12},{"label":"Nm 30:2","book":"Num","chapter":30,"verse":2},{"label":"Dt 23:21","book":"Deu","chapter":23,"verse":21},{"label":"Lv 19:12","book":"Lev","chapter":19,"verse":12},{"label":"Nm 30:2","book":"Num","chapter":30,"verse":2},{"label":"Dt 23:21","book":"Deu","chapter":23,"verse":21},{"label":"Mt 23:16","book":"Mat","chapter":23,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:34","parts":[{"kind":"text","text":"But I tell you, don’t take an oath at all: either by heaven, because it is God’s throne; "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:35","parts":[{"kind":"text","text":"or by the earth, because it is his footstool; or by Jerusalem, because it is the city of the great King."},{"kind":"crossref","label":"Ps 48:2","book":"Psa","chapter":48,"verse":2,"letter":"a"},{"kind":"crossref","label":"Is 66:1","book":"Isa","chapter":66,"verse":1,"letter":"b"},{"kind":"crossref","label":"Mt 23:22","book":"Mat","chapter":23,"verse":22,"letter":"c"},{"kind":"crossref","label":"Ac 7:49","book":"Act","chapter":7,"verse":49,"letter":"d"},{"kind":"crossref","label":"Jms 5:12","book":"Jas","chapter":5,"verse":12,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 48:2","book":"Psa","chapter":48,"verse":2},{"label":"Is 66:1","book":"Isa","chapter":66,"verse":1},{"label":"Mt 23:22","book":"Mat","chapter":23,"verse":22},{"label":"Ac 7:49","book":"Act","chapter":7,"verse":49},{"label":"Jms 5:12","book":"Jas","chapter":5,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:36","parts":[{"kind":"text","text":"Do not swear by your head, because you cannot make a single hair white or black. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:37","parts":[{"kind":"text","text":"But let your ‘yes’ mean ‘yes,’ and your ‘no’ mean ‘no.’ Anything more than this is from the evil one."},{"kind":"crossref","label":"Mt 6:13","book":"Mat","chapter":6,"verse":13,"letter":"a"},{"kind":"crossref","label":"Mt 13:19","book":"Mat","chapter":13,"verse":19,"letter":"b"},{"kind":"crossref","label":"Mt 13:38","book":"Mat","chapter":13,"verse":38,"letter":"c"},{"kind":"crossref","label":"Jn 17:15","book":"Jhn","chapter":17,"verse":15,"letter":"d"},{"kind":"crossref","label":"2Th 3:3","book":"2Th","chapter":3,"verse":3,"letter":"e"}],"crossRefs":[{"label":"Mt 6:13","book":"Mat","chapter":6,"verse":13},{"label":"Mt 13:19","book":"Mat","chapter":13,"verse":19},{"label":"Mt 13:38","book":"Mat","chapter":13,"verse":38},{"label":"Jn 17:15","book":"Jhn","chapter":17,"verse":15},{"label":"2Th 3:3","book":"2Th","chapter":3,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:38","parts":[{"kind":"text","text":"“You have heard that it was said, An eye for an eye and a tooth for a tooth."},{"kind":"crossref","label":"Ex 21:24","book":"Exo","chapter":21,"verse":24,"letter":"a"},{"kind":"crossref","label":"Lv 24:20","book":"Lev","chapter":24,"verse":20,"letter":"b"},{"kind":"crossref","label":"Dt 19:21","book":"Deu","chapter":19,"verse":21,"letter":"c"},{"kind":"crossref","label":"Ex 21:24","book":"Exo","chapter":21,"verse":24,"letter":"d"},{"kind":"crossref","label":"Lv 24:20","book":"Lev","chapter":24,"verse":20,"letter":"e"},{"kind":"crossref","label":"Dt 19:21","book":"Deu","chapter":19,"verse":21,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ex 21:24","book":"Exo","chapter":21,"verse":24},{"label":"Lv 24:20","book":"Lev","chapter":24,"verse":20},{"label":"Dt 19:21","book":"Deu","chapter":19,"verse":21},{"label":"Ex 21:24","book":"Exo","chapter":21,"verse":24},{"label":"Lv 24:20","book":"Lev","chapter":24,"verse":20},{"label":"Dt 19:21","book":"Deu","chapter":19,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:39","parts":[{"kind":"text","text":"But I tell you, don’t resist"},{"kind":"footnote","marker":1,"text":"Or don’t set yourself against, or don’t retaliate against"},{"kind":"text","text":" an evildoer. On the contrary, if anyone slaps you on your right cheek, turn the other to him also."},{"kind":"crossref","label":"Lk 6:29–30","book":"Luk","chapter":6,"verse":29,"letter":"a"},{"kind":"crossref","label":"Rm 12:17","book":"Rom","chapter":12,"verse":17,"letter":"b"},{"kind":"crossref","label":"1Co 6:7","book":"1Co","chapter":6,"verse":7,"letter":"c"},{"kind":"crossref","label":"1Pt 3:9","book":"1Pe","chapter":3,"verse":9,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 6:29–30","book":"Luk","chapter":6,"verse":29},{"label":"Rm 12:17","book":"Rom","chapter":12,"verse":17},{"label":"1Co 6:7","book":"1Co","chapter":6,"verse":7},{"label":"1Pt 3:9","book":"1Pe","chapter":3,"verse":9}],"footnotes":[{"marker":1,"text":"Or don’t set yourself against, or don’t retaliate against"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:40","parts":[{"kind":"text","text":"As for the one who wants to sue you and take away your shirt, let him have your coat as well. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:41","parts":[{"kind":"text","text":"And if anyone forces you to go one mile, go with him two. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:42","parts":[{"kind":"text","text":"Give to the one who asks you, and don’t turn away from the one who wants to borrow from you."},{"kind":"crossref","label":"Dt 15:8","book":"Deu","chapter":15,"verse":8,"letter":"a"},{"kind":"crossref","label":"Lk 6:34","book":"Luk","chapter":6,"verse":34,"letter":"b"}],"crossRefs":[{"label":"Dt 15:8","book":"Deu","chapter":15,"verse":8},{"label":"Lk 6:34","book":"Luk","chapter":6,"verse":34}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:43","parts":[{"kind":"text","text":"“You have heard that it was said, Love your neighbor"},{"kind":"crossref","label":"Lv 19:18","book":"Lev","chapter":19,"verse":18,"letter":"a"},{"kind":"crossref","label":"Lv 19:18","book":"Lev","chapter":19,"verse":18,"letter":"b"},{"kind":"crossref","label":"Dt 23:6","book":"Deu","chapter":23,"verse":6,"letter":"c"},{"kind":"crossref","label":"Lk 10:29","book":"Luk","chapter":10,"verse":29,"letter":"d"},{"kind":"text","text":" and hate your enemy. "}],"crossRefs":[{"label":"Lv 19:18","book":"Lev","chapter":19,"verse":18},{"label":"Lv 19:18","book":"Lev","chapter":19,"verse":18},{"label":"Dt 23:6","book":"Deu","chapter":23,"verse":6},{"label":"Lk 10:29","book":"Luk","chapter":10,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:44","parts":[{"kind":"text","text":"But I tell you, love your enemies"},{"kind":"footnote","marker":1,"text":"Other mss add bless those who curse you, do good to those who hate you,"},{"kind":"text","text":" and pray for those who"},{"kind":"footnote","marker":2,"text":"Other mss add mistreat you and"},{"kind":"text","text":" persecute you,"},{"kind":"crossref","label":"Lk 6:27","book":"Luk","chapter":6,"verse":27,"letter":"a"},{"kind":"crossref","label":"Lk 23:34","book":"Luk","chapter":23,"verse":34,"letter":"b"},{"kind":"crossref","label":"Ac 7:60","book":"Act","chapter":7,"verse":60,"letter":"c"},{"kind":"crossref","label":"Rm 12:20","book":"Rom","chapter":12,"verse":20,"letter":"d"},{"kind":"crossref","label":"1Co 4:12","book":"1Co","chapter":4,"verse":12,"letter":"e"},{"kind":"crossref","label":"1Pt 2:23","book":"1Pe","chapter":2,"verse":23,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 6:27","book":"Luk","chapter":6,"verse":27},{"label":"Lk 23:34","book":"Luk","chapter":23,"verse":34},{"label":"Ac 7:60","book":"Act","chapter":7,"verse":60},{"label":"Rm 12:20","book":"Rom","chapter":12,"verse":20},{"label":"1Co 4:12","book":"1Co","chapter":4,"verse":12},{"label":"1Pt 2:23","book":"1Pe","chapter":2,"verse":23}],"footnotes":[{"marker":1,"text":"Other mss add bless those who curse you, do good to those who hate you,"},{"marker":2,"text":"Other mss add mistreat you and"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:45","parts":[{"kind":"text","text":"so that you may be"},{"kind":"footnote","marker":3,"text":"Or may become, or may show yourselves to be"},{"kind":"text","text":" children of your Father in heaven. For he causes his sun to rise on the evil and the good, and sends rain on the righteous and the unrighteous."},{"kind":"crossref","label":"Jb 25:3","book":"Job","chapter":25,"verse":3,"letter":"a"},{"kind":"crossref","label":"Mt 5:9","book":"Mat","chapter":5,"verse":9,"letter":"b"},{"kind":"crossref","label":"Lk 6:35","book":"Luk","chapter":6,"verse":35,"letter":"c"},{"kind":"crossref","label":"Ac 14:17","book":"Act","chapter":14,"verse":17,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jb 25:3","book":"Job","chapter":25,"verse":3},{"label":"Mt 5:9","book":"Mat","chapter":5,"verse":9},{"label":"Lk 6:35","book":"Luk","chapter":6,"verse":35},{"label":"Ac 14:17","book":"Act","chapter":14,"verse":17}],"footnotes":[{"marker":3,"text":"Or may become, or may show yourselves to be"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:46","parts":[{"kind":"text","text":"For if you love those who love you, what reward will you have? Don’t even the tax collectors do the same? "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:5:47","parts":[{"kind":"text","text":"And if you greet only your brothers and sisters, what are you doing out of the ordinary?"},{"kind":"footnote","marker":4,"text":"Or doing that is superior; lit doing more"},{"kind":"crossref","label":"Mt 5:37","book":"Mat","chapter":5,"verse":37,"letter":"a"},{"kind":"crossref","label":"Mk 6:51","book":"Mrk","chapter":6,"verse":51,"letter":"b"},{"kind":"crossref","label":"Jn 10:10","book":"Jhn","chapter":10,"verse":10,"letter":"c"},{"kind":"crossref","label":"Rm 3:1","book":"Rom","chapter":3,"verse":1,"letter":"d"},{"kind":"crossref","label":"2Co 9:1","book":"2Co","chapter":9,"verse":1,"letter":"e"},{"kind":"text","text":" Don’t even the Gentiles"},{"kind":"footnote","marker":5,"text":"Other mss read tax collectors"},{"kind":"text","text":" do the same? "}],"crossRefs":[{"label":"Mt 5:37","book":"Mat","chapter":5,"verse":37},{"label":"Mk 6:51","book":"Mrk","chapter":6,"verse":51},{"label":"Jn 10:10","book":"Jhn","chapter":10,"verse":10},{"label":"Rm 3:1","book":"Rom","chapter":3,"verse":1},{"label":"2Co 9:1","book":"2Co","chapter":9,"verse":1}],"footnotes":[{"marker":4,"text":"Or doing that is superior; lit doing more"},{"marker":5,"text":"Other mss read tax collectors"}]},{"verseId":"a556c5305ee15c3f-01:Mat:5:48","parts":[{"kind":"text","text":"Be perfect,"},{"kind":"crossref","label":"Gn 17:1","book":"Gen","chapter":17,"verse":1,"letter":"a"},{"kind":"crossref","label":"Lv 19:2","book":"Lev","chapter":19,"verse":2,"letter":"b"},{"kind":"crossref","label":"Php 3:15","book":"Php","chapter":3,"verse":15,"letter":"c"},{"kind":"crossref","label":"Col 4:12","book":"Col","chapter":4,"verse":12,"letter":"d"},{"kind":"crossref","label":"Jms 1:4","book":"Jas","chapter":1,"verse":4,"letter":"e"},{"kind":"crossref","label":"1Pt 1:15","book":"1Pe","chapter":1,"verse":15,"letter":"f"},{"kind":"text","text":" therefore, as your heavenly Father is perfect."}],"crossRefs":[{"label":"Gn 17:1","book":"Gen","chapter":17,"verse":1},{"label":"Lv 19:2","book":"Lev","chapter":19,"verse":2},{"label":"Php 3:15","book":"Php","chapter":3,"verse":15},{"label":"Col 4:12","book":"Col","chapter":4,"verse":12},{"label":"Jms 1:4","book":"Jas","chapter":1,"verse":4},{"label":"1Pt 1:15","book":"1Pe","chapter":1,"verse":15}],"footnotes":[]}]},"cachedAt":1783280290041}