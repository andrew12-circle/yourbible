","chapter":1,"verse":29},{"label":"Lk 4:38–41","book":"Luk","chapter":4,"verse":38}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:8:15","parts":[{"kind":"text","text":"So he touched her hand, and the fever left her. Then she got up and began to serve him. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:8:16","parts":[{"kind":"text","text":"When evening came, they brought to him many who were demon-possessed. He drove out the spirits "},{"kind":"crossref","label":"Mk 3:15","book":"Mrk","chapter":3,"verse":15,"letter":"a"},{"kind":"crossref","label":"1Tm 4:1","book":"1Ti","chapter":4,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Jn 4:1","book":"1Jn","chapter":4,"verse":1,"letter":"c"},{"kind":"text","text":" with a word and healed all who were sick, "},{"kind":"crossref","label":"Mt 4:24","book":"Mat","chapter":4,"verse":24,"letter":"d"},{"kind":"crossref","label":"Mt 8:33","book":"Mat","chapter":8,"verse":33,"letter":"e"},{"kind":"crossref","label":"Ac 19:12","book":"Act","chapter":19,"verse":12,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 3:15","book":"Mrk","chapter":3,"verse":15},{"label":"1Tm 4:1","book":"1Ti","chapter":4,"verse":1},{"label":"1Jn 4:1","book":"1Jn","chapter":4,"verse":1},{"label":"Mt 4:24","book":"Mat","chapter":4,"verse":24},{"label":"Mt 8:33","book":"Mat","chapter":8,"verse":33},{"label":"Ac 19:12","book":"Act","chapter":19,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:8:17","parts":[{"kind":"text","text":"so that what was spoken through the prophet Isaiah might be fulfilled:"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:8:18","parts":[{"kind":"text","text":"When Jesus saw a large crowd "},{"kind":"footnote","marker":1,"text":"Other mss read saw large crowds"},{"kind":"crossref","label":"Mt 14:22","book":"Mat","chapter":14,"verse":22,"letter":"a"},{"kind":"crossref","label":"Mk 4:35","book":"Mrk","chapter":4,"verse":35,"letter":"b"},{"kind":"cr