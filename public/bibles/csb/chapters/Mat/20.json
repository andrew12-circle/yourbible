se":7,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 16:21","book":"Mat","chapter":16,"verse":21},{"label":"Mt 26:66","book":"Mat","chapter":26,"verse":66},{"label":"Jn 19:7","book":"Jhn","chapter":19,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:19","parts":[{"kind":"text","text":"They will hand him over to the Gentiles"},{"kind":"crossref","label":"Mt 27:2","book":"Mat","chapter":27,"verse":2,"letter":"a"},{"kind":"crossref","label":"Ac 2:23","book":"Act","chapter":2,"verse":23,"letter":"b"},{"kind":"crossref","label":"Ac 3:13","book":"Act","chapter":3,"verse":13,"letter":"c"},{"kind":"crossref","label":"Ac 4:27","book":"Act","chapter":4,"verse":27,"letter":"d"},{"kind":"crossref","label":"Ac 21:11","book":"Act","chapter":21,"verse":11,"letter":"e"},{"kind":"text","text":" to be mocked, flogged,"},{"kind":"footnote","marker":1,"text":"Or scourged"},{"kind":"text","text":" and crucified, and on the third day he will be raised.”"},{"kind":"footnote","marker":2,"text":"Other mss read will rise again"}],"crossRefs":[{"label":"Mt 27:2","book":"Mat","chapter":27,"verse":2},{"label":"Ac 2:23","book":"Act","chapter":2,"verse":23},{"label":"Ac 3:13","book":"Act","chapter":3,"verse":13},{"label":"Ac 4:27","book":"Act","chapter":4,"verse":27},{"label":"Ac 21:11","book":"Act","chapter":21,"verse":11}],"footnotes":[{"marker":1,"text":"Or scourged"},{"marker":2,"text":"Other mss read will rise again"}]},{"verseId":"a556c5305ee15c3f-01:Mat:20:20","parts":[{"kind":"text","text":"Then the mother of Zebedee’s sons approached him with her sons. "},{"kind":"crossref","label":"Mk 10:35–45","book":"Mrk","chapter":10,"verse":35,"letter":"a"},{"kind":"crossref","label":"Lk 22:24–27","book":"Luk","chapter":22,"verse":24,"letter":"b"},{"kind":"text","text":" She knelt down to ask him for something. "},{"kind":"crossref","label":"Mt 4:21","book":"Mat","chapter":4,"verse":21,"letter":"c"},{"kind":"crossref","label":"Mt 8:2","book":"Mat","chapter":8,"verse":2,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 10:35–45","book":"Mrk","chapter":10,"verse":35},{"label":"Lk 22:24–27","book":"Luk","chapter":22,"verse":24},{"label":"Mt 4:21","book":"Mat","chapter":4,"verse":21},{"label":"Mt 8:2","book":"Mat","chapter":8,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:21","parts":[{"kind":"text","text":"“What do you want?” he asked her."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:22","parts":[{"kind":"text","text":"Jesus answered, “You don’t know what you’re asking. Are you able to drink the cup that I am about to drink?”"},{"kind":"footnote","marker":1,"text":"Other mss add and (or) to be baptized with the baptism which I am baptized?”"},{"kind":"crossref","label":"Is 51:22","book":"Isa","chapter":51,"verse":22,"letter":"a"},{"kind":"crossref","label":"Jr 49:12","book":"Jer","chapter":49,"verse":12,"letter":"b"},{"kind":"crossref","label":"Mk 14:36","book":"Mrk","chapter":14,"verse":36,"letter":"c"}],"crossRefs":[{"label":"Is 51:22","book":"Isa","chapter":51,"verse":22},{"label":"Jr 49:12","book":"Jer","chapter":49,"verse":12},{"label":"Mk 14:36","book":"Mrk","chapter":14,"verse":36}],"footnotes":[{"marker":1,"text":"Other mss add and (or) to be baptized with the baptism which I am baptized?”"}]},{"verseId":"a556c5305ee15c3f-01:Mat:20:23","parts":[{"kind":"text","text":"He told them, “You will indeed drink my cup,"},{"kind":"footnote","marker":1,"text":"Other mss add and be baptized with the baptism with which I am baptized."},{"kind":"text","text":" but to sit at my right and left is not mine to give; instead, it is for those for whom it has been prepared by my Father.”"},{"kind":"crossref","label":"Ac 12:2","book":"Act","chapter":12,"verse":2,"letter":"a"},{"kind":"crossref","label":"Rv 1:9","book":"Rev","chapter":1,"verse":9,"letter":"b"}],"crossRefs":[{"label":"Ac 12:2","book":"Act","chapter":12,"verse":2},{"label":"Rv 1:9","book":"Rev","chapter":1,"verse":9}],"footnotes":[{"marker":1,"text":"Other mss add and be baptized with the baptism with which I am baptized."}]},{"verseId":"a556c5305ee15c3f-01:Mat:20:24","parts":[{"kind":"text","text":"When the ten disciples heard this, they became indignant with the two brothers. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:25","parts":[{"kind":"text","text":"Jesus called them over and said, “You know that the rulers of the Gentiles lord it over them, and those in high positions act as tyrants over them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:26","parts":[{"kind":"text","text":"It must not be like that among you. On the contrary, whoever wants to become great among you must be your servant,"},{"kind":"crossref","label":"Mt 23:11","book":"Mat","chapter":23,"verse":11,"letter":"a"},{"kind":"crossref","label":"Mk 9:35","book":"Mrk","chapter":9,"verse":35,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mt 23:11","book":"Mat","chapter":23,"verse":11},{"label":"Mk 9:35","book":"Mrk","chapter":9,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:27","parts":[{"kind":"text","text":"and whoever wants to be first among you must be your slave; "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:28","parts":[{"kind":"text","text":"just as the Son of Man did not come to be served, but to serve,"},{"kind":"crossref","label":"Lk 22:27","book":"Luk","chapter":22,"verse":27,"letter":"a"},{"kind":"crossref","label":"Jn 13:13–15","book":"Jhn","chapter":13,"verse":13,"letter":"b"},{"kind":"crossref","label":"2Co 8:9","book":"2Co","chapter":8,"verse":9,"letter":"c"},{"kind":"crossref","label":"Php 2:7","book":"Php","chapter":2,"verse":7,"letter":"d"},{"kind":"text","text":" and to give his life as a ransom for many.”"},{"kind":"crossref","label":"Mt 26:28","book":"Mat","chapter":26,"verse":28,"letter":"e"},{"kind":"crossref","label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6,"letter":"f"},{"kind":"crossref","label":"Ti 2:14","book":"Tit","chapter":2,"verse":14,"letter":"g"},{"kind":"crossref","label":"Heb 9:28","book":"Heb","chapter":9,"verse":28,"letter":"h"}],"crossRefs":[{"label":"Lk 22:27","book":"Luk","chapter":22,"verse":27},{"label":"Jn 13:13–15","book":"Jhn","chapter":13,"verse":13},{"label":"2Co 8:9","book":"2Co","chapter":8,"verse":9},{"label":"Php 2:7","book":"Php","chapter":2,"verse":7},{"label":"Mt 26:28","book":"Mat","chapter":26,"verse":28},{"label":"1Tm 2:6","book":"1Ti","chapter":2,"verse":6},{"label":"Ti 2:14","book":"Tit","chapter":2,"verse":14},{"label":"Heb 9:28","book":"Heb","chapter":9,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:29","parts":[{"kind":"text","text":"As they were leaving Jericho, a large crowd followed him. "},{"kind":"crossref","label":"Mk 10:46–52","book":"Mrk","chapter":10,"verse":46,"letter":"a"},{"kind":"crossref","label":"Lk 18:35–43","book":"Luk","chapter":18,"verse":35,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Mk 10:46–52","book":"Mrk","chapter":10,"verse":46},{"label":"Lk 18:35–43","book":"Luk","chapter":18,"verse":35}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:30","parts":[{"kind":"text","text":"There were two blind men sitting by the road. When they heard that Jesus was passing by, they cried out, “Lord, have mercy on us, Son of David!” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:31","parts":[{"kind":"text","text":"The crowd demanded that they keep quiet, but they cried out all the more, “Lord, have mercy on us, Son of David!” "},{"kind":"crossref","label":"Mt 9:27","book":"Mat","chapter":9,"verse":27,"letter":"a"},{"kind":"crossref","label":"Mt 21:9","book":"Mat","chapter":21,"verse":9,"letter":"b"},{"kind":"crossref","label":"Mt 22:42","book":"Mat","chapter":22,"verse":42,"letter":"c"}],"crossRefs":[{"label":"Mt 9:27","book":"Mat","chapter":9,"verse":27},{"label":"Mt 21:9","book":"Mat","chapter":21,"verse":9},{"label":"Mt 22:42","book":"Mat","chapter":22,"verse":42}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:32","parts":[{"kind":"text","text":"Jesus stopped, called them, and said, “What do you want me to do for you?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:33","parts":[{"kind":"text","text":"“Lord,” they said to him, “open our eyes.” "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Mat:20:34","parts":[{"kind":"text","text":"Moved with compassion, Jesus touched their eyes. Immediately they could see, and they followed him."}],"crossRefs":[],"footnotes":[]}]},"cachedAt":1783099500576}