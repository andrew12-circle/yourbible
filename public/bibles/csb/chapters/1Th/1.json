{"key":"a556c5305ee15c3f-01|1Th|1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","chapter":1,"textRevision":"api-bible-csb-2024","parserRevision":"v11","verses":[{"verseId":"a556c5305ee15c3f-01:1Th:1:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":1,"text":"Paul, Silvanus, and Timothy: To the church of the Thessalonians in God the Father and the Lord Jesus Christ. Grace to you and peace.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":2,"text":"We always thank God for all of you, making mention of you constantly in our prayers.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":3,"text":"We recall, in the presence of our God and Father, your work produced by faith, your labor motivated by love, and your endurance inspired by hope in our Lord Jesus Christ.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":4,"text":"For we know, brothers and sisters loved by God, that he has chosen you,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":5,"text":"because our gospel did not come to you in word only, but also in power, in the Holy Spirit, and with full assurance. You know how we lived among you for your benefit,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":6,"text":"and you yourselves became imitators of us and of the Lord when, in spite of severe persecution, you welcomed the message with joy from the Holy Spirit.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":7,"text":"As a result, you became an example to all the believers in Macedonia and Achaia.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":8,"text":"For the word of the Lord rang out from you, not only in Macedonia and Achaia, but in every place that your faith in God has gone out. Therefore, we don’t need to say anything,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":9,"text":"for they themselves report what kind of reception we had from you: how you turned to God from idols to serve the living and true God","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:1Th:1:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","bookOrder":51,"chapter":1,"verse":10,"text":"and to wait for his Son from heaven, whom he raised from the dead —Jesus, who rescues us from the coming wrath.","textRevision":"api-bible-csb-2024"}],"layout":{"bibleId":"a556c5305ee15c3f-01","bookAbbr":"1Th","chapter":1,"paragraphStarts":[1,2],"headings":[{"beforeVerse":1,"text":"Greeting"},{"beforeVerse":2,"text":"Thanksgiving"}],"poetryBlocks":[],"studyByVerse":[{"verseId":"a556c5305ee15c3f-01:1Th:1:1","parts":[{"kind":"text","text":"Paul, Silvanus, "},{"kind":"footnote","marker":1,"text":"Or Silas; Ac 15:22–32; 16:19–40; 17:1–16"},{"kind":"crossref","label":"Ac 15:22","book":"Act","chapter":15,"verse":22,"letter":"a"},{"kind":"crossref","label":"2Co 1:19","book":"2Co","chapter":1,"verse":19,"letter":"b"},{"kind":"crossref","label":"2Th 1:1","book":"2Th","chapter":1,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Pt 5:12","book":"1Pe","chapter":5,"verse":12,"letter":"d"},{"kind":"text","text":" and Timothy: "},{"kind":"crossref","label":"Ac 16:1","book":"Act","chapter":16,"verse":1,"letter":"e"},{"kind":"crossref","label":"1Tm 1:2","book":"1Ti","chapter":1,"verse":2,"letter":"f"},{"kind":"text","text":" To the church of the Thessalonians "},{"kind":"crossref","label":"Ac 17:1","book":"Act","chapter":17,"verse":1,"letter":"a"},{"kind":"text","text":" in God the Father and the Lord Jesus Christ."},{"kind":"text","text":" Grace to you and peace. "},{"kind":"footnote","marker":1,"text":"Other mss add from God our Father and the Lord Jesus Christ"}],"crossRefs":[{"label":"Ac 15:22","book":"Act","chapter":15,"verse":22},{"label":"2Co 1:19","book":"2Co","chapter":1,"verse":19},{"label":"2Th 1:1","book":"2Th","chapter":1,"verse":1},{"label":"1Pt 5:12","book":"1Pe","chapter":5,"verse":12},{"label":"Ac 16:1","book":"Act","chapter":16,"verse":1},{"label":"1Tm 1:2","book":"1Ti","chapter":1,"verse":2},{"label":"Ac 17:1","book":"Act","chapter":17,"verse":1}],"footnotes":[{"marker":1,"text":"Or Silas; Ac 15:22–32; 16:19–40; 17:1–16"},{"marker":1,"text":"Other mss add from God our Father and the Lord Jesus Christ"}]},{"verseId":"a556c5305ee15c3f-01:1Th:1:2","parts":[{"kind":"text","text":"We always thank God for all of you, making mention of you constantly in our prayers. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Th:1:3","parts":[{"kind":"text","text":"We recall, in the presence of our God and Father, "},{"kind":"crossref","label":"Php 4:20","book":"Php","chapter":4,"verse":20,"letter":"a"},{"kind":"text","text":" your work produced by faith, "},{"kind":"crossref","label":"Rm 3:28","book":"Rom","chapter":3,"verse":28,"letter":"b"},{"kind":"crossref","label":"Rm 9:32","book":"Rom","chapter":9,"verse":32,"letter":"c"},{"kind":"crossref","label":"Gl 2:16","book":"Gal","chapter":2,"verse":16,"letter":"d"},{"kind":"crossref","label":"Gl 5:6","book":"Gal","chapter":5,"verse":6,"letter":"e"},{"kind":"crossref","label":"2Th 1:11","book":"2Th","chapter":1,"verse":11,"letter":"f"},{"kind":"crossref","label":"