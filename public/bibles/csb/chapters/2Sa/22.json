,"verse":8,"letter":"a"},{"kind":"crossref","label":"Ps 118:5","book":"Psa","chapter":118,"verse":5,"letter":"b"}],"crossRefs":[{"label":"Ps 31:8","book":"Psa","chapter":31,"verse":8},{"label":"Ps 118:5","book":"Psa","chapter":118,"verse":5}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:21","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" rewarded me"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:22","parts":[{"kind":"text","text":"For I have kept the ways of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"crossref","label":"Pr 8:32","book":"Pro","chapter":8,"verse":32,"letter":"a"}],"crossRefs":[{"label":"Pr 8:32","book":"Pro","chapter":8,"verse":32}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:23","parts":[{"kind":"text","text":"Indeed, I let all his ordinances "},{"kind":"crossref","label":"Ps 119:30","book":"Psa","chapter":119,"verse":30,"letter":"a"},{"kind":"crossref","label":"Ps 119:102","book":"Psa","chapter":119,"verse":102,"letter":"b"},{"kind":"text","text":" guide me "},{"kind":"footnote","marker":1,"text":"Lit Indeed, all his ordinances have been in front of me"}],"crossRefs":[{"label":"Ps 119:30","book":"Psa","chapter":119,"verse":30},{"label":"Ps 119:102","book":"Psa","chapter":119,"verse":102}],"footnotes":[{"marker":1,"text":"Lit Indeed, all his ordinances have been in front of me"}]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:24","parts":[{"kind":"text","text":"I was blameless before him"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:25","parts":[{"kind":"text","text":"So the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" repaid me"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:26","parts":[{"kind":"text","text":"With the faithful"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:27","parts":[{"kind":"text","text":"with the pure"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:28","parts":[{"kind":"text","text":"You rescue an oppressed people, "},{"kind":"crossref","label":"Ps 72:12–13","book":"Psa","chapter":72,"verse":12,"letter":"a"}],"crossRefs":[{"label":"Ps 72:12–13","book":"Psa","chapter":72,"verse":12}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:29","parts":[{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", you are my lamp;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:30","parts":[{"kind":"text","text":"With you I can attack a barricade, "},{"kind":"footnote","marker":1,"text":"Or a ridge, or raiders"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Or a ridge, or raiders"}]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:31","parts":[{"kind":"text","text":"God —his way is perfect; "},{"kind":"crossref","label":"Dt 32:4","book":"Deu","chapter":32,"verse":4,"letter":"a"}],"crossRefs":[{"label":"Dt 32:4","book":"Deu","chapter":32,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:32","parts":[{"kind":"text","text":"For who is God besides the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"?"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:33","parts":[{"kind":"text","text":"God is my strong refuge; "},{"kind":"footnote","marker":1,"text":"DSS, some LXX mss, Syr, Vg read God clothes me with strength; Ps 18:32"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"DSS, some LXX mss, Syr, Vg read God clothes me with strength; Ps 18:32"}]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:34","parts":[{"kind":"text","text":"He makes my feet like the feet of a deer"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:35","parts":[{"kind":"text","text":"He trains my hands for war; "},{"kind":"crossref","label":"Ps 144:1","book":"Psa","chapter":144,"verse":1,"letter":"a"}],"crossRefs":[{"label":"Ps 144:1","book":"Psa","chapter":144,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:36","parts":[{"kind":"text","text":"You have given me the shield of your salvation; "},{"kind":"crossref","label":"Eph 6:16–17","book":"Eph","chapter":6,"verse":16,"letter":"a"}],"crossRefs":[{"label":"Eph 6:16–17","book":"Eph","chapter":6,"verse":16}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:37","parts":[{"kind":"text","text":"You make a spacious place beneath me for my steps,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:38","parts":[{"kind":"text","text":"I pursue my enemies and destroy them;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:39","parts":[{"kind":"text","text":"I wipe them out and crush them,"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:40","parts":[{"kind":"text","text":"You have clothed me with strength for battle;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:41","parts":[{"kind":"text","text":"You have made my enemies retreat before me; "},{"kind":"footnote","marker":1,"text":"Lit you gave me the neck of my enemies"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit you gave me the neck of my enemies"}]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:42","parts":[{"kind":"text","text":"They look, but there is no one to save them —"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:43","parts":[{"kind":"text","text":"I pulverize them like dust of the earth;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:44","parts":[{"kind":"text","text":"You have freed me from the feuds among my people; "},{"kind":"crossref","label":"2Sm 2:8","book":"2Sa","chapter":2,"verse":8,"letter":"a"},{"kind":"crossref","label":"2Sm 15:1–6","book":"2Sa","chapter":15,"verse":1,"letter":"b"},{"kind":"crossref","label":"2Sm 20:1–2","book":"2Sa","chapter":20,"verse":1,"letter":"c"}],"crossRefs":[{"label":"2Sm 2:8","book":"2Sa","chapter":2,"verse":8},{"label":"2Sm 15:1–6","book":"2Sa","chapter":15,"verse":1},{"label":"2Sm 20:1–2","book":"2Sa","chapter":20,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:45","parts":[{"kind":"text","text":"Foreigners submit to me cringing;"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:46","parts":[{"kind":"text","text":"Foreigners lose heart"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:47","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" lives —blessed be my rock!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:48","parts":[{"kind":"text","text":"God —he grants me vengeance"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:49","parts":[{"kind":"text","text":"He frees me from my enemies."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:50","parts":[{"kind":"text","text":"Therefore I will give thanks to you among the nations, "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":";"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:2Sa:22:51","parts":[{"kind":"text","text":"He is a tower of salvation for "},{"kind":"footnote","marker":1,"text":"DSS read he gives great victory to"},{"kind":"text","text":" his king;"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"DSS read he gives great victory to"}]}]},"cachedAt":1783099301692}