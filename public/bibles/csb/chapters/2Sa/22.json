{"key":"a556c5305ee15c3f-01|2Sa|22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","chapter":22,"textRevision":"api-bible-csb-2024","parserRevision":"v10","verses":[{"verseId":"a556c5305ee15c3f-01:2Sa:22:1","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":1,"text":"David spoke the words of this song to the Lord on the day the Lord rescued him from the grasp of all his enemies and from the grasp of Saul.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:2","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":2,"text":"He said:","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:3","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":3,"text":"my God, my rock where I seek refuge.","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:4","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":4,"text":"I called to the Lord, who is worthy of praise,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:5","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":5,"text":"For the waves of death engulfed me;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:6","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":6,"text":"The ropes of Sheol entangled me;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:7","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":7,"text":"I called to the Lord in my distress;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:8","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":8,"text":"Then the earth shook and quaked;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:9","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":9,"text":"Smoke rose from his nostrils,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:10","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":10,"text":"He bent the heavens and came down,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:11","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":11,"text":"He rode on a cherub and flew,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:12","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":12,"text":"He made darkness a canopy around him,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:13","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":13,"text":"From the radiance of his presence,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:14","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":14,"text":"The Lord thundered from heaven;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:15","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":15,"text":"He shot arrows and scattered them;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:16","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":16,"text":"The depths of the sea became visible,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:17","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":17,"text":"He reached down from on high","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:18","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":18,"text":"He rescued me from my powerful enemy","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:19","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":19,"text":"They confronted me in the day of my calamity,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:20","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":20,"text":"He brought me out to a spacious place;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:21","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":21,"text":"The Lord rewarded me","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:22","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":22,"text":"For I have kept the ways of the Lord","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:23","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":23,"text":"Indeed, I let all his ordinances guide me","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:24","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":24,"text":"I was blameless before him","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:25","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":25,"text":"So the Lord repaid me","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:26","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":26,"text":"With the faithful","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:27","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":27,"text":"with the pure","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:28","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":28,"text":"You rescue an oppressed people,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:29","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":29,"text":"Lord, you are my lamp;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:30","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":30,"text":"With you I can attack a barricade,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:31","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":31,"text":"God —his way is perfect;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:32","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":32,"text":"For who is God besides the Lord?","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:33","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":33,"text":"God is my strong refuge;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:34","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":34,"text":"He makes my feet like the feet of a deer","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:35","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":35,"text":"He trains my hands for war;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:36","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":36,"text":"You have given me the shield of your salvation;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:37","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":37,"text":"You make a spacious place beneath me for my steps,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:38","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":38,"text":"I pursue my enemies and destroy them;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:39","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":39,"text":"I wipe them out and crush them,","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:40","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":40,"text":"You have clothed me with strength for battle;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:41","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":41,"text":"You have made my enemies retreat before me;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:42","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":42,"text":"They look, but there is no one to save them —","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:43","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":43,"text":"I pulverize them like dust of the earth;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:44","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":44,"text":"You have freed me from the feuds among my people;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:45","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":45,"text":"Foreigners submit to me cringing;","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:46","bibleId":"a556c5305ee15c3f-01","bookAbbr":"2Sa","bookOrder":9,"chapter":22,"verse":46,"text":"Foreigners lose heart","textRevision":"api-bible-csb-2024"},{"verseId":"a556c5305ee15c3f-01:2Sa:22:47","bibleId":"a556c5305ee15c3f-01","bookAbb