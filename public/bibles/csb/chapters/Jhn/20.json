el":"Jn 11:16","book":"Jhn","chapter":11,"verse":16,"letter":"b"},{"kind":"text","text":" (called “Twin” "},{"kind":"footnote","marker":1,"text":"Gk Didymus"},{"kind":"text","text":"), one of the Twelve, was not with them when Jesus came. "}],"crossRefs":[{"label":"Mk 3:18","book":"Mrk","chapter":3,"verse":18},{"label":"Jn 11:16","book":"Jhn","chapter":11,"verse":16}],"footnotes":[{"marker":1,"text":"Gk Didymus"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:25","parts":[{"kind":"text","text":"So the other disciples were telling him, “We’ve seen the Lord!”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:26","parts":[{"kind":"text","text":"A week later his disciples were indoors again, and Thomas was with them. Even though the doors were locked, Jesus came and stood among them and said, “Peace be with you.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:27","parts":[{"kind":"text","text":"Then he said to Thomas, “Put your finger here and look at my hands. Reach out your hand and put it into my side. Don’t be faithless, but believe.”"},{"kind":"crossref","label":"Nm 12:7","book":"Num","chapter":12,"verse":7,"letter":"a"}],"crossRefs":[{"label":"Nm 12:7","book":"Num","chapter":12,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:28","parts":[{"kind":"text","text":"Thomas responded to him, “My Lord and my God!”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:29","parts":[{"kind":"text","text":"Jesus said, “Because you have seen me, you have believed."},{"kind":"footnote","marker":1,"text":"Or have you believed?"},{"kind":"text","text":" Blessed are those who have not seen and yet believe.”"},{"kind":"crossref","label":"2Co 5:7","book":"2Co","chapter":5,"verse":7,"letter":"a"},{"kind":"crossref","label":"1Pt 1:8","book":"1Pe","chapter":1,"verse":8,"letter":"b"}],"crossRefs":[{"label":"2Co 5:7","book":"2Co","chapter":5,"verse":7},{"label":"1Pt 1:8","book":"1Pe","chapter":1,"verse":8}],"footnotes":[{"marker":1,"text":"Or have you believed?"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:30","parts":[{"kind":"text","text":"Jesus performed many other signs "},{"kind":"crossref","label":"Jn 2:11","book":"Jhn","chapter":2,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 21:25","book":"Jhn","chapter":21,"verse":25,"letter":"b"},{"kind":"text","text":" in the presence of his disciples that are not written "},{"kind":"crossref","label":"1Jn 1:4","book":"1Jn","chapter":1,"verse":4,"letter":"c"},{"kind":"text","text":" in this book. "},{"kind":"crossref","label":"2Tm 4:13","book":"2Ti","chapter":4,"verse":13,"letter":"d"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 2:11","book":"Jhn","chapter":2,"verse":11},{"label":"Jn 21:25","book":"Jhn","chapter":21,"verse":25},{"label":"1Jn 1:4","book":"1Jn","chapter":1,"verse":4},{"label":"2Tm 4:13","book":"2Ti","chapter":4,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:31","parts":[{"kind":"text","text":"But these are written so that you may believe that Jesus is the Messiah, "},{"kind":"crossref","label":"Mt 1:17","book":"Mat","chapter":1,"verse":17,"letter":"a"},{"kind":"crossref","label":"Ac 18:5","book":"Act","chapter":18,"verse":5,"letter":"b"},{"kind":"crossref","label":"1Jn 2:22","book":"1Jn","chapter":2,"verse":22,"letter":"c"},{"kind":"crossref","label":"1Jn 5:1","book":"1Jn","chapter":5,"verse":1,"letter":"d"},{"kind":"text","text":" the Son "},{"kind":"crossref","label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19,"letter":"e"},{"kind":"text","text":" of God, "},{"kind":"footnote","marker":1,"text":"Or that the Messiah, the Son of God, is Jesus"},{"kind":"crossref","label":"Heb 1:2","book":"Heb","chapter":1,"verse":2,"letter":"f"},{"kind":"text","text":" and that by believing you may have life in his name. "},{"kind":"crossref","label":"Jn 10:27","book":"Jhn","chapter":10,"verse":27,"letter":"g"},{"kind":"crossref","label":"1Jn 3:23","book":"1Jn","chapter":3,"verse":23,"le