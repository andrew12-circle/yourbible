hapter":16,"verse":7},{"label":"Mt 13:49","book":"Mat","chapter":13,"verse":49},{"label":"Ac 5:19","book":"Act","chapter":5,"verse":19},{"label":"Rv 14:6","book":"Rev","chapter":14,"verse":6},{"label":"Lk 12:4","book":"Luk","chapter":12,"verse":4},{"label":"Jn 2:21","book":"Jhn","chapter":2,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:13","parts":[{"kind":"text","text":"They said to her, “Woman, why are you crying?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:14","parts":[{"kind":"text","text":"Having said this, she turned around and saw Jesus standing there, but she did not know it was Jesus. "},{"kind":"crossref","label":"Jn 21:4","book":"Jhn","chapter":21,"verse":4,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 21:4","book":"Jhn","chapter":21,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:15","parts":[{"kind":"text","text":"“Woman,” Jesus said to her, “why are you crying? Who is it that you’re seeking?”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:16","parts":[{"kind":"text","text":"Jesus said to her, “Mary.”"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:17","parts":[{"kind":"text","text":"“Don’t cling to me,” Jesus told her, “since I have not yet ascended"},{"kind":"crossref","label":"Lk 24:51","book":"Luk","chapter":24,"verse":51,"letter":"a"},{"kind":"crossref","label":"Jn 3:13","book":"Jhn","chapter":3,"verse":13,"letter":"b"},{"kind":"crossref","label":"Jn 6:62","book":"Jhn","chapter":6,"verse":62,"letter":"c"},{"kind":"crossref","label":"Ac 1:9–11","book":"Act","chapter":1,"verse":9,"letter":"d"},{"kind":"crossref","label":"Ac 2:33–34","book":"Act","chapter":2,"verse":33,"letter":"e"},{"kind":"crossref","label":"Rm 10:6","book":"Rom","chapter":10,"verse":6,"letter":"f"},{"kind":"crossref","label":"Eph 1:20–21","book":"Eph","chapter":1,"verse":20,"letter":"g"},{"kind":"crossref","label":"Eph 4:8","book":"Eph","chapter":4,"verse":8,"letter":"h"},{"kind":"crossref","label":"1Pt 3:22","book":"1Pe","chapter":3,"verse":22,"letter":"i"},{"kind":"text","text":" to the Father."},{"kind":"crossref","label":"Mt 5:16","book":"Mat","chapter":5,"verse":16,"letter":"j"},{"kind":"crossref","label":"Mt 11:27","book":"Mat","chapter":11,"verse":27,"letter":"k"},{"kind":"crossref","label":"Jn 8:42","book":"Jhn","chapter":8,"verse":42,"letter":"l"},{"kind":"text","text":" But go to my brothers"},{"kind":"crossref","label":"Ac 9:30","book":"Act","chapter":9,"verse":30,"letter":"m"},{"kind":"text","text":" and tell them that I am ascending to my Father"},{"kind":"crossref","label":"Jn 14:12","book":"Jhn","chapter":14,"verse":12,"letter":"n"},{"kind":"text","text":" and your Father, to my God"},{"kind":"crossref","label":"Mt 27:46","book":"Mat","chapter":27,"verse":46,"letter":"o"},{"kind":"text","text":" and your God.”"}],"crossRefs":[{"label":"Lk 24:51","book":"Luk","chapter":24,"verse":51},{"label":"Jn 3:13","book":"Jhn","chapter":3,"verse":13},{"label":"Jn 6:62","book":"Jhn","chapter":6,"verse":62},{"label":"Ac 1:9–11","book":"Act","chapter":1,"verse":9},{"label":"Ac 2:33–34","book":"Act","chapter":2,"verse":33},{"label":"Rm 10:6","book":"Rom","chapter":10,"verse":6},{"label":"Eph 1:20–21","book":"Eph","chapter":1,"verse":20},{"label":"Eph 4:8","book":"Eph","chapter":4,"verse":8},{"label":"1Pt 3:22","book":"1Pe","chapter":3,"verse":22},{"label":"Mt 5:16","book":"Mat","chapter":5,"verse":16},{"label":"Mt 11:27","book":"Mat","chapter":11,"verse":27},{"label":"Jn 8:42","book":"Jhn","chapter":8,"verse":42},{"label":"Ac 9:30","book":"Act","chapter":9,"verse":30},{"label":"Jn 14:12","book":"Jhn","chapter":14,"verse":12},{"label":"Mt 27:46","book":"Mat","chapter":27,"verse":46}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:20:18","parts":[{"kind":"text","text":"Mary Magdalene went and announced to the disciples, “I have seen the Lord!” "},{"kind":"crossref","label":"Mk 16:10","book":"Mrk","ch