text","text":" No one will snatch"},{"kind":"crossref","label":"1Th 4:17","book":"1Th","chapter":4,"verse":17,"letter":"n"},{"kind":"text","text":" them out of my hand. "}],"crossRefs":[{"label":"Jn 12:25","book":"Jhn","chapter":12,"verse":25},{"label":"Ac 13:48","book":"Act","chapter":13,"verse":48},{"label":"1Jn 2:25","book":"1Jn","chapter":2,"verse":25},{"label":"Mt 10:42","book":"Mat","chapter":10,"verse":42},{"label":"Mk 9:41","book":"Mrk","chapter":9,"verse":41},{"label":"Lk 21:18","book":"Luk","chapter":21,"verse":18},{"label":"Jn 3:16","book":"Jhn","chapter":3,"verse":16},{"label":"Jn 6:27","book":"Jhn","chapter":6,"verse":27},{"label":"Jn 6:39","book":"Jhn","chapter":6,"verse":39},{"label":"Jn 17:12","book":"Jhn","chapter":17,"verse":12},{"label":"Jn 18:9","book":"Jhn","chapter":18,"verse":9},{"label":"2Co 4:9","book":"2Co","chapter":4,"verse":9},{"label":"2Jn 8","book":"2Jn","chapter":1,"verse":8},{"label":"1Th 4:17","book":"1Th","chapter":4,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:10:29","parts":[{"kind":"text","text":"My Father,"},{"kind":"crossref","label":"Mt 11:27","book":"Mat","chapter":11,"verse":27,"letter":"a"},{"kind":"text","text":" who has given them to me, is greater than all. No one is able to snatch them out of the Father’s hand. "}],"crossRefs":[{"label":"Mt 11:27","book":"Mat","chapter":11,"verse":27}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:10:30","parts":[{"kind":"text","text":"I and the Father are one.”"},{"kind":"crossref","label":"Jn 1:15","book":"Jhn","chapter":1,"verse":15,"letter":"a"},{"kind":"crossref","label":"Jn 14:10","book":"Jhn","chapter":14,"verse":10,"letter":"b"},{"kind":"crossref","label":"Jn 17:11","book":"Jhn","chapter":17,"verse":11,"letter":"c"},{"kind":"crossref","label":"1Jn 2:24","book":"1Jn","chapter":2,"verse":24,"letter":"d"}],"crossRefs":[{"label":"Jn 1:15","book":"Jhn","chapter":1,"verse":15},{"label":"Jn 14:10","book":"Jhn","chapter":14,"verse":10},{"label":"Jn 17:11","boo