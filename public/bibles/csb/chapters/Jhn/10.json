:"Jesus answered them, “Isn’t it written in your law,"},{"kind":"footnote","marker":1,"text":"Other mss read in the scripture"},{"kind":"text","text":" I said, you are gods?"},{"kind":"crossref","label":"Ps 82:6","book":"Psa","chapter":82,"verse":6,"letter":"a"},{"kind":"crossref","label":"Ps 82:6","book":"Psa","chapter":82,"verse":6,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 82:6","book":"Psa","chapter":82,"verse":6},{"label":"Ps 82:6","book":"Psa","chapter":82,"verse":6}],"footnotes":[{"marker":1,"text":"Other mss read in the scripture"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:10:35","parts":[{"kind":"text","text":"If he called those to whom the word"},{"kind":"crossref","label":"Lk 8:21","book":"Luk","chapter":8,"verse":21,"letter":"a"},{"kind":"crossref","label":"Jn 2:22","book":"Jhn","chapter":2,"verse":22,"letter":"b"},{"kind":"crossref","label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32,"letter":"c"},{"kind":"text","text":" of God came ‘gods’ —and the Scripture"},{"kind":"crossref","label":"Mt 26:54","book":"Mat","chapter":26,"verse":54,"letter":"d"},{"kind":"text","text":" cannot be broken — "}],"crossRefs":[{"label":"Lk 8:21","book":"Luk","chapter":8,"verse":21},{"label":"Jn 2:22","book":"Jhn","chapter":2,"verse":22},{"label":"Jn 18:32","book":"Jhn","chapter":18,"verse":32},{"label":"Mt 26:54","book":"Mat","chapter":26,"verse":54}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:10:36","parts":[{"kind":"text","text":"do you say, ‘You are blaspheming’ to the one the Father set apart and sent into the world, because I said: I am the Son of God?"},{"kind":"crossref","label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19,"letter":"a"},{"kind":"crossref","label":"Heb 1:2","book":"Heb","chapter":1,"verse":2,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19},{"label":"Heb 1:2","book":"Heb","chapter":1,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:10:37","pa