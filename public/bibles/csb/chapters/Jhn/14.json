:"Jhn","chapter":7,"verse":16,"letter":"b"},{"kind":"crossref","label":"Jn 8:28","book":"Jhn","chapter":8,"verse":28,"letter":"c"},{"kind":"crossref","label":"Jn 12:49–50","book":"Jhn","chapter":12,"verse":49,"letter":"d"}],"crossRefs":[{"label":"Jn 5:19","book":"Jhn","chapter":5,"verse":19},{"label":"Jn 7:16","book":"Jhn","chapter":7,"verse":16},{"label":"Jn 8:28","book":"Jhn","chapter":8,"verse":28},{"label":"Jn 12:49–50","book":"Jhn","chapter":12,"verse":49}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:25","parts":[{"kind":"text","text":"“I have spoken these things to you while I remain with you. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:26","parts":[{"kind":"text","text":"But the Counselor, the Holy Spirit,"},{"kind":"crossref","label":"Ps 51:11","book":"Psa","chapter":51,"verse":11,"letter":"a"},{"kind":"crossref","label":"Jn 1:33","book":"Jhn","chapter":1,"verse":33,"letter":"b"},{"kind":"crossref","label":"Ac 2:4","book":"Act","chapter":2,"verse":4,"letter":"c"},{"kind":"crossref","label":"Rm 8:9","book":"Rom","chapter":8,"verse":9,"letter":"d"},{"kind":"crossref","label":"Gl 5:25","book":"Gal","chapter":5,"verse":25,"letter":"e"},{"kind":"crossref","label":"Ti 3:5","book":"Tit","chapter":3,"verse":5,"letter":"f"},{"kind":"crossref","label":"Rv 3:22","book":"Rev","chapter":3,"verse":22,"letter":"g"},{"kind":"text","text":" whom the Father will send"},{"kind":"crossref","label":"Lk 24:49","book":"Luk","chapter":24,"verse":49,"letter":"h"},{"kind":"crossref","label":"Jn 14:16","book":"Jhn","chapter":14,"verse":16,"letter":"i"},{"kind":"crossref","label":"Jn 15:26","book":"Jhn","chapter":15,"verse":26,"letter":"j"},{"kind":"crossref","label":"Jn 16:7","book":"Jhn","chapter":16,"verse":7,"letter":"k"},{"kind":"crossref","label":"Ac 2:33","book":"Act","chapter":2,"verse":33,"letter":"l"},{"kind":"text","text":" in my name, will teach you all things"},{"kind":"crossref","label":"Jn 16:13","book":"Jhn","chapter":16,"verse":13,"letter":"m"},{"kind":"crossref","label":"1Co 2:10","book":"1Co","chapter":2,"verse":10,"letter":"n"},{"kind":"crossref","label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27,"letter":"o"},{"kind":"text","text":" and remind you of everything I have told you."},{"kind":"crossref","label":"Jn 2:22","book":"Jhn","chapter":2,"verse":22,"letter":"p"},{"kind":"crossref","label":"2Pt 1:21","book":"2Pe","chapter":1,"verse":21,"letter":"q"}],"crossRefs":[{"label":"Ps 51:11","book":"Psa","chapter":51,"verse":11},{"label":"Jn 1:33","book":"Jhn","chapter":1,"verse":33},{"label":"Ac 2:4","book":"Act","chapter":2,"verse":4},{"label":"Rm 8:9","book":"Rom","chapter":8,"verse":9},{"label":"Gl 5:25","book":"Gal","chapter":5,"verse":25},{"label":"Ti 3:5","book":"Tit","chapter":3,"verse":5},{"label":"Rv 3:22","book":"Rev","chapter":3,"verse":22},{"label":"Lk 24:49","book":"Luk","chapter":24,"verse":49},{"label":"Jn 14:16","book":"Jhn","chapter":14,"verse":16},{"label":"Jn 15:26","book":"Jhn","chapter":15,"verse":26},{"label":"Jn 16:7","book":"Jhn","chapter":16,"verse":7},{"label":"Ac 2:33","book":"Act","chapter":2,"verse":33},{"label":"Jn 16:13","book":"Jhn","chapter":16,"verse":13},{"label":"1Co 2:10","book":"1Co","chapter":2,"verse":10},{"label":"1Jn 2:27","book":"1Jn","chapter":2,"verse":27},{"label":"Jn 2:22","book":"Jhn","chapter":2,"verse":22},{"label":"2Pt 1:21","book":"2Pe","chapter":1,"verse":21}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:27","parts":[{"kind":"text","text":"“Peace I leave with you. My peace I give to you. I do not give to you as the world gives. Don’t let your heart be troubled or fearful."},{"kind":"crossref","label":"2Tm 1:7","book":"2Ti","chapter":1,"verse":7,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Tm 1:7","book":"2Ti","chapter":1,"verse":7}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:28","parts":[{"kind":"text","text":"You have heard me tell you, ‘I am going away"},{"kind":"crossref","label":"Jn 16:5","book":"Jhn","chapter":16,"verse":5,"letter":"a"},{"kind":"text","text":" and I am coming to you.’ If you loved me, you would rejoice that I am going to the Father,"},{"kind":"crossref","label":"Jn 16:10","book":"Jhn","chapter":16,"verse":10,"letter":"b"},{"kind":"text","text":" because the Father is greater than I."},{"kind":"crossref","label":"Jn 10:29","book":"Jhn","chapter":10,"verse":29,"letter":"c"},{"kind":"crossref","label":"1Jn 3:20","book":"1Jn","chapter":3,"verse":20,"letter":"d"},{"kind":"crossref","label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 16:5","book":"Jhn","chapter":16,"verse":5},{"label":"Jn 16:10","book":"Jhn","chapter":16,"verse":10},{"label":"Jn 10:29","book":"Jhn","chapter":10,"verse":29},{"label":"1Jn 3:20","book":"1Jn","chapter":3,"verse":20},{"label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:29","parts":[{"kind":"text","text":"I have told you now before it happens"},{"kind":"crossref","label":"Jn 13:19","book":"Jhn","chapter":13,"verse":19,"letter":"a"},{"kind":"crossref","label":"Jn 16:4","book":"Jhn","chapter":16,"verse":4,"letter":"b"},{"kind":"text","text":" so that when it does happen you may believe. "}],"crossRefs":[{"label":"Jn 13:19","book":"Jhn","chapter":13,"verse":19},{"label":"Jn 16:4","book":"Jhn","chapter":16,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:14:30","parts":[{"kind":"text","text":"I will not talk with you much longer, because the ruler of the world"},{"kind":"crossref","label":"Mt 4:1","book":"Mat","chapter":4,"verse":1,"letter":"a"},{"kind":"crossref","label":"Jn 12:31","book":"Jhn","chapter":12,"verse":31,"letter":"b"},{"kind":"text","text":" is coming. He has no power over me."},{"kind":"footnote","marker":1,"text":"Lit He has nothing in me"},{"kind":"crossref","label":"Lk 4:6","book":"Luk","chapter":4,"verse":6,"letter":"c"},{"kind":"text","text":" "}],"crossR