","chapter":5,"verse":44,"letter":"a"},{"kind":"crossref","label":"Rm 16:27","book":"Rom","chapter":16,"verse":27,"letter":"b"},{"kind":"text","text":" true"},{"kind":"crossref","label":"Jn 4:23","book":"Jhn","chapter":4,"verse":23,"letter":"c"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"d"},{"kind":"text","text":" God, and the one you have sent"},{"kind":"crossref","label":"Mk 9:37","book":"Mrk","chapter":9,"verse":37,"letter":"e"},{"kind":"crossref","label":"Jn 1:6","book":"Jhn","chapter":1,"verse":6,"letter":"f"},{"kind":"text","text":" —Jesus Christ."},{"kind":"crossref","label":"Jn 5:38","book":"Jhn","chapter":5,"verse":38,"letter":"g"},{"kind":"crossref","label":"Jn 6:29","book":"Jhn","chapter":6,"verse":29,"letter":"h"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 5:44","book":"Jhn","chapter":5,"verse":44},{"label":"Rm 16:27","book":"Rom","chapter":16,"verse":27},{"label":"Jn 4:23","book":"Jhn","chapter":4,"verse":23},{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20},{"label":"Mk 9:37","book":"Mrk","chapter":9,"verse":37},{"label":"Jn 1:6","book":"Jhn","chapter":1,"verse":6},{"label":"Jn 5:38","book":"Jhn","chapter":5,"verse":38},{"label":"Jn 6:29","book":"Jhn","chapter":6,"verse":29}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:4","parts":[{"kind":"text","text":"I have glorified you on the earth by completing the work you gave me to do. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:5","parts":[{"kind":"text","text":"Now, Father,"},{"kind":"crossref","label":"Mt 11:27","book":"Mat","chapter":11,"verse":27,"letter":"a"},{"kind":"text","text":" glorify me in your presence with that glory"},{"kind":"crossref","label":"Mk 10:37","book":"Mrk","chapter":10,"verse":37,"letter":"b"},{"kind":"crossref","label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1,"letter":"d"},{"kind":"text","te