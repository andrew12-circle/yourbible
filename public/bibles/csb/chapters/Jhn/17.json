nd":"crossref","label":"1Jn 4:5","book":"1Jn","chapter":4,"verse":5,"letter":"m"},{"kind":"text","text":" They were yours, you gave them to me,"},{"kind":"crossref","label":"Jn 18:9","book":"Jhn","chapter":18,"verse":9,"letter":"n"},{"kind":"text","text":" and they have kept your word."},{"kind":"crossref","label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51,"letter":"o"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 10:25","book":"Jhn","chapter":10,"verse":25},{"label":"Ac 15:14","book":"Act","chapter":15,"verse":14},{"label":"Rv 14:1","book":"Rev","chapter":14,"verse":1},{"label":"Mt 24:22","book":"Mat","chapter":24,"verse":22},{"label":"Jn 6:37","book":"Jhn","chapter":6,"verse":37},{"label":"Jn 8:23","book":"Jhn","chapter":8,"verse":23},{"label":"Jn 13:1","book":"Jhn","chapter":13,"verse":1},{"label":"Jn 15:19","book":"Jhn","chapter":15,"verse":19},{"label":"Jn 17:14–16","book":"Jhn","chapter":17,"verse":14},{"label":"Jn 18:36","book":"Jhn","chapter":18,"verse":36},{"label":"1Co 5:10","book":"1Co","chapter":5,"verse":10},{"label":"1Jn 2:16","book":"1Jn","chapter":2,"verse":16},{"label":"1Jn 4:5","book":"1Jn","chapter":4,"verse":5},{"label":"Jn 18:9","book":"Jhn","chapter":18,"verse":9},{"label":"Jn 8:51","book":"Jhn","chapter":8,"verse":51}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:7","parts":[{"kind":"text","text":"Now they know that everything you have given me is from you, "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:8","parts":[{"kind":"text","text":"because I have given them the words you gave me."},{"kind":"crossref","label":"Jn 14:24","book":"Jhn","chapter":14,"verse":24,"letter":"a"},{"kind":"text","text":" They have received them and have known for certain that I came from you."},{"kind":"crossref","label":"Jn 5:43","book":"Jhn","chapter":5,"verse":43,"letter":"b"},{"kind":"crossref","label":"Jn 13:3","book":"Jhn","chapter":13,"verse":3,"letter":"c"},{"kind":"text","text":" They have believed that you sent me."}],"crossRefs":[{"label":"Jn 14:24","book":"Jhn","chapter":14,"verse":24},{"label":"Jn 5:43","book":"Jhn","chapter":5,"verse":43},{"label":"Jn 13:3","book":"Jhn","chapter":13,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:9","parts":[{"kind":"text","text":"“I pray"},{"kind":"footnote","marker":1,"text":"Lit ask (throughout this passage)"},{"kind":"text","text":" for them. I am not praying for the world but for those you have given me,"},{"kind":"crossref","label":"Rm 9:11","book":"Rom","chapter":9,"verse":11,"letter":"a"},{"kind":"text","text":" because they are yours. "}],"crossRefs":[{"label":"Rm 9:11","book":"Rom","chapter":9,"verse":11}],"footnotes":[{"marker":1,"text":"Lit ask (throughout this passage)"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:10","parts":[{"kind":"text","text":"Everything I have is yours, and everything you have is mine,"},{"kind":"crossref","label":"Jn 16:15","book":"Jhn","chapter":16,"verse":15,"letter":"a"},{"kind":"text","text":" and I am glorified in them. "}],"crossRefs":[{"label":"Jn 16:15","book":"Jhn","chapter":16,"verse":15}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:11","parts":[{"kind":"text","text":"I am no longer in the world, but they are in the world, and I am coming to you."},{"kind":"crossref","label":"Jn 13:3","book":"Jhn","chapter":13,"verse":3,"letter":"a"},{"kind":"crossref","label":"Jn 14:12","book":"Jhn","chapter":14,"verse":12,"letter":"b"},{"kind":"text","text":" Holy"},{"kind":"crossref","label":"Ps 20:6","book":"Psa","chapter":20,"verse":6,"letter":"c"},{"kind":"crossref","label":"1Co 7:14","book":"1Co","chapter":7,"verse":14,"letter":"d"},{"kind":"text","text":" Father, protect"},{"kind":"footnote","marker":2,"text":"Lit keep (throughout this passage)"},{"kind":"text","text":" them by your name"},{"kind":"crossref","label":"Pr 18:10","book":"Pro","chapter":18,"verse":10,"letter":"e"},{"kind":"text","text":" that you have given me, so that they may be one"},{"kind":"crossref","label":"Jn 11:52","book":"Jhn","chapter":11,"verse":52,"letter":"f"},{"kind":"text","text":" as we are"},{"kind":"crossref","label":"Jn 10:16","book":"Jhn","chapter":10,"verse":16,"letter":"g"},{"kind":"crossref","label":"Jn 10:30","book":"Jhn","chapter":10,"verse":30,"letter":"h"},{"kind":"crossref","label":"Jn 17:22","book":"Jhn","chapter":17,"verse":22,"letter":"i"},{"kind":"crossref","label":"Gl 3:28","book":"Gal","chapter":3,"verse":28,"letter":"j"},{"kind":"text","text":" one. "}],"crossRefs":[{"label":"Jn 13:3","book":"Jhn","chapter":13,"verse":3},{"label":"Jn 14:12","book":"Jhn","chapter":14,"verse":12},{"label":"Ps 20:6","book":"Psa","chapter":20,"verse":6},{"label":"1Co 7:14","book":"1Co","chapter":7,"verse":14},{"label":"Pr 18:10","book":"Pro","chapter":18,"verse":10},{"label":"Jn 11:52","book":"Jhn","chapter":11,"verse":52},{"label":"Jn 10:16","book":"Jhn","chapter":10,"verse":16},{"label":"Jn 10:30","book":"Jhn","chapter":10,"verse":30},{"label":"Jn 17:22","book":"Jhn","chapter":17,"verse":22},{"label":"Gl 3:28","book":"Gal","chapter":3,"verse":28}],"footnotes":[{"marker":2,"text":"Lit keep (throughout this passage)"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:12","parts":[{"kind":"text","text":"While I was with them, I was protecting them by your name that you have given me. I guarded"},{"kind":"crossref","label":"2Tm 1:14","book":"2Ti","chapter":1,"verse":14,"letter":"a"},{"kind":"text","text":" them and not one of them is lost, except the son of destruction,"},{"kind":"footnote","marker":3,"text":"The one destined for destruction, loss, or perdition"},{"kind":"text","text":" so that the Scripture"},{"kind":"crossref","label":"Mt 26:54","book":"Mat","chapter":26,"verse":54,"letter":"b"},{"kind":"text","text":" may be fulfilled."},{"kind":"crossref","label":"Ps 41:9","book":"Psa","chapter":41,"verse":9,"letter":"c"},{"kind":"crossref","label":"Jn 13:18","book":"Jhn","chapter":13,"verse":18,"letter":"d"},{"kind":"crossref","label":"Jn 15:25","book":"Jhn","chapter":15,"verse":25,"letter":"e"},{"kind":"crossref","label":"Jn 19:24","book":"Jhn","chapter":19,"verse":24,"letter":"f"},{"kind":"crossref","label":"Jn 19:36","book":"Jhn","chapter":19,"verse":36,"letter":"g"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Tm 1:14","book":"2Ti","chapter":1,"verse":14},{"label":"Mt 26:54","book":"Mat","chapter":26,"verse":54},{"label":"Ps 41:9","book":"Psa","chapter":41,"verse":9},{"label":"Jn 13:18","book":"Jhn","chapter":13,"verse":18},{"label":"Jn 15:25","book":"Jhn","chapter":15,"verse":25},{"label":"Jn 19:24","book":"Jhn","chapter":19,"verse":24},{"label":"Jn 19:36","book":"Jhn","chapter":19,"verse":36}],"footnotes":[{"marker":3,"text":"The one destined for destruction, loss, or perdition"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:13","parts":[{"kind":"text","text":"Now I am coming to you, and I speak these things in the world so that they may have my joy completed in them. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:14","parts":[{"kind":"text","text":"I have given them your word. The world hated"},{"kind":"crossref","label":"Lk 6:22","book":"Luk","chapter":6,"verse":22,"letter":"a"},{"kind":"crossref","label":"Lk 6:27","book":"Luk","chapter":6,"verse":27,"letter":"b"},{"kind":"crossref","label":"Lk 19:14","book":"Luk","chapter":19,"verse":14,"letter":"c"},{"kind":"text","text":" them because they are not of the world,"},{"kind":"crossref","label":"Jn 15:19","book":"Jhn","chapter":15,"verse":19,"letter":"d"},{"kind":"text","text":" just as I am not of the world."},{"kind":"crossref","label":"Jn 8:23","book":"Jhn","chapter":8,"verse":23,"letter":"e"},{"kind":"crossref","label":"Jn 18:36","book":"Jhn","chapter":18,"verse":36,"letter":"f"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Lk 6:22","book":"Luk","chapter":6,"verse":22},{"label":"Lk 6:27","book":"Luk","chapter":6,"verse":27},{"label":"Lk 19:14","book":"Luk","chapter":19,"verse":14},{"label":"Jn 15:19","book":"Jhn","chapter":15,"verse":19},{"label":"Jn 8:23","book":"Jhn","chapter":8,"verse":23},{"label":"Jn 18:36","book":"Jhn","chapter":18,"verse":36}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:15","parts":[{"kind":"text","text":"I am not praying that you take them out of the world but that you protect them from the evil one."},{"kind":"crossref","label":"2Th 3:3","book":"2Th","chapter":3,"verse":3,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"2Th 3:3","book":"2Th","chapter":3,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:16","parts":[{"kind":"text","text":"They are not of the world, just as I am not of the world."},{"kind":"crossref","label":"Jn 18:36","book":"Jhn","chapter":18,"verse":36,"letter":"a"},{"kind":"crossref","label":"1Jn 4:17","book":"1Jn","chapter":4,"verse":17,"letter":"b"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Jn 18:36","book":"Jhn","chapter":18,"verse":36},{"label":"1Jn 4:17","book":"1Jn","chapter":4,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:17","parts":[{"kind":"text","text":"Sanctify"},{"kind":"crossref","label":"Lk 11:2","book":"Luk","chapter":11,"verse":2,"letter":"a"},{"kind":"text","text":" them by the truth;"},{"kind":"crossref","label":"Ps 119:142","book":"Psa","chapter":119,"verse":142,"letter":"b"},{"kind":"crossref","label":"2Th 2:10","book":"2Th","chapter":2,"verse":10,"letter":"c"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"d"},{"kind":"text","text":" your word is truth. "}],"crossRefs":[{"label":"Lk 11:2","book":"Luk","chapter":11,"verse":2},{"label":"Ps 119:142","book":"Psa","chapter":119,"verse":142},{"label":"2Th 2:10","book":"2Th","chapter":2,"verse":10},{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:18","parts":[{"kind":"text","text":"As you sent me into the world,"},{"kind":"crossref","label":"1Jn 4:17","book":"1Jn","chapter":4,"verse":17,"letter":"a"},{"kind":"text","text":" I also have sent them into the world. "}],"crossRefs":[{"label":"1Jn 4:17","book":"1Jn","chapter":4,"verse":17}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:19","parts":[{"kind":"text","text":"I sanctify myself for them, so that they also may be sanctified by the truth."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:20","parts":[{"kind":"text","text":"“I pray not only for these, but also for those who believe in me through their word. "}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:21","parts":[{"kind":"text","text":"May they all be one,"},{"kind":"crossref","label":"Jn 11:52","book":"Jhn","chapter":11,"verse":52,"letter":"a"},{"kind":"crossref","label":"Jn 17:11","book":"Jhn","chapter":17,"verse":11,"letter":"b"},{"kind":"text","text":" as you, Father, are in me and I am in you."},{"kind":"crossref","label":"1Jn 2:24","book":"1Jn","chapter":2,"verse":24,"letter":"c"},{"kind":"crossref","label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20,"letter":"d"},{"kind":"text","text":" May they also be"},{"kind":"footnote","marker":1,"text":"Other mss add one"},{"kind":"text","text":" in us, so that the world may believe you sent me. "}],"crossRefs":[{"label":"Jn 11:52","book":"Jhn","chapter":11,"verse":52},{"label":"Jn 17:11","book":"Jhn","chapter":17,"verse":11},{"label":"1Jn 2:24","book":"1Jn","chapter":2,"verse":24},{"label":"1Jn 5:20","book":"1Jn","chapter":5,"verse":20}],"footnotes":[{"marker":1,"text":"Other mss add one"}]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:22","parts":[{"kind":"text","text":"I have given them the glory"},{"kind":"crossref","label":"Mk 10:37","book":"Mrk","chapter":10,"verse":37,"letter":"a"},{"kind":"crossref","label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24,"letter":"b"},{"kind":"crossref","label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1,"letter":"c"},{"kind":"crossref","label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4,"letter":"d"},{"kind":"text","text":" you have given me, so that they may be one as we are one. "}],"crossRefs":[{"label":"Mk 10:37","book":"Mrk","chapter":10,"verse":37},{"label":"Jn 17:24","book":"Jhn","chapter":17,"verse":24},{"label":"1Pt 5:1","book":"1Pe","chapter":5,"verse":1},{"label":"1Pt 5:4","book":"1Pe","chapter":5,"verse":4}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:23","parts":[{"kind":"text","text":"I am in them and you are in me,"},{"kind":"crossref","label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4,"letter":"a"},{"kind":"text","text":" so that they may be made completely one, that the world may know you have sent me and have loved"},{"kind":"crossref","label":"Jn 3:16","book":"Jhn","chapter":3,"verse":16,"letter":"b"},{"kind":"crossref","label":"Jn 12:43","book":"Jhn","chapter":12,"verse":43,"letter":"c"},{"kind":"crossref","label":"1Co 13:1","book":"1Co","chapter":13,"verse":1,"letter":"d"},{"kind":"crossref","label":"2Th 2:13","book":"2Th","chapter":2,"verse":13,"letter":"e"},{"kind":"text","text":" them as you have loved me."},{"kind":"crossref","label":"Jn 15:9","book":"Jhn","chapter":15,"verse":9,"letter":"f"}],"crossRefs":[{"label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4},{"label":"Jn 3:16","book":"Jhn","chapter":3,"verse":16},{"label":"Jn 12:43","book":"Jhn","chapter":12,"verse":43},{"label":"1Co 13:1","book":"1Co","chapter":13,"verse":1},{"label":"2Th 2:13","book":"2Th","chapter":2,"verse":13},{"label":"Jn 15:9","book":"Jhn","chapter":15,"verse":9}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:24","parts":[{"kind":"text","text":"“Father, I want those you have given me to be with me where I am,"},{"kind":"crossref","label":"Jn 12:26","book":"Jhn","chapter":12,"verse":26,"letter":"a"},{"kind":"text","text":" so that they will see my glory, which you have given me because you loved me before the world’s foundation. "}],"crossRefs":[{"label":"Jn 12:26","book":"Jhn","chapter":12,"verse":26}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:25","parts":[{"kind":"text","text":"Righteous Father, the world has not known you. However, I have known you,"},{"kind":"crossref","label":"Mt 11:27","book":"Mat","chapter":11,"verse":27,"letter":"a"},{"kind":"crossref","label":"Lk 10:22","book":"Luk","chapter":10,"verse":22,"letter":"b"},{"kind":"text","text":" and they have known that you sent me. "}],"crossRefs":[{"label":"Mt 11:27","book":"Mat","chapter":11,"verse":27},{"label":"Lk 10:22","book":"Luk","chapter":10,"verse":22}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Jhn:17:26","parts":[{"kind":"text","text":"I made your name"},{"kind":"crossref","label":"Jn 10:25","book":"Jhn","chapter":10,"verse":25,"letter":"a"},{"kind":"text","text":" known to them and will continue to make it known, so that the love you have loved me with may be in them and I may be in them.”"},{"kind":"crossref","label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4,"letter":"b"}],"crossRefs":[{"label":"Jn 10:25","book":"Jhn","chapter":10,"verse":25},{"label":"1Jn 4:4","book":"1Jn","chapter":4,"verse":4}],"footnotes":[]}]},"cachedAt":1783099521230}