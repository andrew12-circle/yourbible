 Vg reads up forever"},{"kind":"text","text":" For my decision is to gather nations,"},{"kind":"text","text":" to assemble kingdoms,"},{"kind":"text","text":" in order to pour out my indignation "},{"kind":"crossref","label":"Ps 69:24","book":"Psa","chapter":69,"verse":24,"letter":"a"},{"kind":"crossref","label":"Ezk 21:31","book":"Ezk","chapter":21,"verse":31,"letter":"b"},{"kind":"crossref","label":"Ezk 22:31","book":"Ezk","chapter":22,"verse":31,"letter":"c"},{"kind":"crossref","label":"Nah 1:6","book":"Nam","chapter":1,"verse":6,"letter":"d"},{"kind":"text","text":" on them,"},{"kind":"text","text":" all my burning anger;"},{"kind":"text","text":" for the whole earth will be consumed"},{"kind":"text","text":" by the fire of my jealousy. "},{"kind":"crossref","label":"Dt 29:20","book":"Deu","chapter":29,"verse":20,"letter":"a"},{"kind":"crossref","label":"Ps 79:5","book":"Psa","chapter":79,"verse":5,"letter":"b"},{"kind":"crossref","label":"Zch 1:14","book":"Zec","chapter":1,"verse":14,"letter":"c"},{"kind":"crossref","label":"Zch 8:2","book":"Zec","chapter":8,"verse":2,"letter":"d"}],"crossRefs":[{"label":"Jb 3:21","book":"Job","chapter":3,"verse":21},{"label":"Ps 33:20","book":"Psa","chapter":33,"verse":20},{"label":"Is 8:17","book":"Isa","chapter":8,"verse":17},{"label":"Is 30:18","book":"Isa","chapter":30,"verse":18},{"label":"Is 64:4","book":"Isa","chapter":64,"verse":4},{"label":"Ps 69:24","book":"Psa","chapter":69,"verse":24},{"label":"Ezk 21:31","book":"Ezk","chapter":21,"verse":31},{"label":"Ezk 22:31","book":"Ezk","chapter":22,"verse":31},{"label":"Nah 1:6","book":"Nam","chapter":1,"verse":6},{"label":"Dt 29:20","book":"Deu","chapter":29,"verse":20},{"label":"Ps 79:5","book":"Psa","chapter":79,"verse":5},{"label":"Zch 1:14","book":"Zec","chapter":1,"verse":14},{"label":"Zch 8:2","book":"Zec","chapter":8,"verse":2}],"footnotes":[{"marker":1,"text":"LXX, Syr read for a witness; Vg reads up forever"}]},{"verseId":"a556c5305ee15c3f-01:Zep:3:9","parts":[{"kind":"text","text":"For I will then restore"},{"kind":"text","text":" pure "},{"kind":"crossref","label":"Dn 12:10","book":"Dan","chapter":12,"verse":10,"letter":"a"},{"kind":"text","text":" speech to the peoples"},{"kind":"text","text":" so that all of them may call"},{"kind":"text","text":" on the name of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" and serve him with a single purpose. "},{"kind":"footnote","marker":1,"text":"Lit with one shoulder"}],"crossRefs":[{"label":"Dn 12:10","book":"Dan","chapter":12,"verse":10}],"footnotes":[{"marker":1,"text":"Lit with one shoulder"}]},{"verseId":"a556c5305ee15c3f-01:Zep:3:10","parts":[{"kind":"text","text":"From beyond the rivers of Cush "},{"kind":"crossref","label":"Is 18:1–3","book":"Isa","chapter":18,"verse":1,"letter":"a"},{"kind":"text","text":" my supplicants, my dispersed people,"},{"kind":"text","text":" will bring an offering to me."}],"crossRefs":[{"label":"Is 18:1–3","book":"Isa","chapter":18,"verse":1}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:11","parts":[{"kind":"text","text":"On that day you "},{"kind":"footnote","marker":1,"text":"= Israel"},{"kind":"text","text":" will not be put to shame "},{"kind":"crossref","label":"Gn 2:25","book":"Gen","chapter":2,"verse":25,"letter":"a"},{"kind":"crossref","label":"2Sm 19:5","book":"2Sa","chapter":19,"verse":5,"letter":"b"},{"kind":"crossref","label":"Ps 25:3","book":"Psa","chapter":25,"verse":3,"letter":"c"},{"kind":"text","text":" because of everything you have done"},{"kind":"text","text":" in rebelling "},{"kind":"crossref","label":"Is 1:2","book":"Isa","chapter":1,"verse":2,"letter":"a"},{"kind":"text","text":" against me."},{"kind":"text","text":" For then I will remove"},{"kind":"text","text":" from among you your jubilant, "},{"kind":"crossref","label":"Jr 48:29","book":"Jer","chapter":48,"verse":29,"letter":"a"},{"kind":"text","text":" arrogant people,"},{"kind":"text","text":" and you will never again be haughty"},{"kind":"text","text":" on my holy mountain. "},{"kind":"crossref","label":"Is 11:9","book":"Isa","chapter":11,"verse":9,"letter":"a"}],"crossRefs":[{"label":"Gn 2:25","book":"Gen","chapter":2,"verse":25},{"label":"2Sm 19:5","book":"2Sa","chapter":19,"verse":5},{"label":"Ps 25:3","book":"Psa","chapter":25,"verse":3},{"label":"Is 1:2","book":"Isa","chapter":1,"verse":2},{"label":"Jr 48:29","book":"Jer","chapter":48,"verse":29},{"label":"Is 11:9","book":"Isa","chapter":11,"verse":9}],"footnotes":[{"marker":1,"text":"= Israel"}]},{"verseId":"a556c5305ee15c3f-01:Zep:3:12","parts":[{"kind":"text","text":"I will leave"},{"kind":"text","text":" a meek and humble people "},{"kind":"crossref","label":"Is 66:2","book":"Isa","chapter":66,"verse":2,"letter":"a"},{"kind":"text","text":" among you,"},{"kind":"text","text":" and they will take refuge in the name of the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"."}],"crossRefs":[{"label":"Is 66:2","book":"Isa","chapter":66,"verse":2}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:13","parts":[{"kind":"text","text":"The remnant "},{"kind":"crossref","label":"Gn 45:7","book":"Gen","chapter":45,"verse":7,"letter":"a"},{"kind":"crossref","label":"2Kg 19:31","book":"2Ki","chapter":19,"verse":31,"letter":"b"},{"kind":"crossref","label":"Jr 23:3","book":"Jer","chapter":23,"verse":3,"letter":"c"},{"kind":"text","text":" of Israel will no longer"},{"kind":"text","text":" do wrong or tell lies;"},{"kind":"text","text":" a deceitful tongue will not be found"},{"kind":"text","text":" in their mouths."},{"kind":"text","text":" They will pasture and lie down,"},{"kind":"text","text":" with nothing to make them afraid. "},{"kind":"crossref","label":"Gn 42:28","book":"Gen","chapter":42,"verse":28,"letter":"a"},{"kind":"crossref","label":"Jr 50:19","book":"Jer","chapter":50,"verse":19,"letter":"b"},{"kind":"crossref","label":"Ezk 34:14","book":"Ezk","chapter":34,"verse":14,"letter":"c"},{"kind":"crossref","label":"Mc 4:4","book":"Mic","chapter":4,"verse":4,"letter":"d"},{"kind":"crossref","label":"Mc 7:14","book":"Mic","chapter":7,"verse":14,"letter":"e"}],"crossRefs":[{"label":"Gn 45:7","book":"Gen","chapter":45,"verse":7},{"label":"2Kg 19:31","book":"2Ki","chapter":19,"verse":31},{"label":"Jr 23:3","book":"Jer","chapter":23,"verse":3},{"label":"Gn 42:28","book":"Gen","chapter":42,"verse":28},{"label":"Jr 50:19","book":"Jer","chapter":50,"verse":19},{"label":"Ezk 34:14","book":"Ezk","chapter":34,"verse":14},{"label":"Mc 4:4","book":"Mic","chapter":4,"verse":4},{"label":"Mc 7:14","book":"Mic","chapter":7,"verse":14}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:14","parts":[{"kind":"text","text":"Sing for joy, Daughter Zion;"},{"kind":"text","text":" shout loudly, Israel!"},{"kind":"text","text":" Be glad and celebrate with all your heart,"},{"kind":"text","text":" Daughter Jerusalem!"}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:15","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" has removed your punishment;"},{"kind":"text","text":" he has turned back your enemy."},{"kind":"text","text":" The King of Israel, the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", is among you;"},{"kind":"text","text":" you need no longer fear harm."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:16","parts":[{"kind":"text","text":"On that day it will be said to Jerusalem:"},{"kind":"text","text":" “Do not fear;"},{"kind":"text","text":" Zion, do not let your hands grow weak. "},{"kind":"crossref","label":"Jr 6:24","book":"Jer","chapter":6,"verse":24,"letter":"a"},{"kind":"crossref","label":"Jr 50:43","book":"Jer","chapter":50,"verse":43,"letter":"b"}],"crossRefs":[{"label":"Jr 6:24","book":"Jer","chapter":6,"verse":24},{"label":"Jr 50:43","book":"Jer","chapter":50,"verse":43}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:Zep:3:17","parts":[{"kind":"text","text":"The "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" your God is among you,"},{"kind":"text","text":" a warrior "},{"kind":"crossref","label":"Jos 1:14","book":"Jos","chapter":1,"verse":14,"letter":"a"},{"kind":"crossref","label":"Jb 16:14","book":"Job","chapter":16,"verse":14,"letter":"b"},{"kind":"crossref","label":"Ps 78:65","book":"Psa","chapter":78,"verse":65,"letter":"c"},{"kind":"text","text":" who saves."},{"kind":"text","text":" He will rejoice over you "},{"kind":"crossref","label":"Dt 28:63","book":"Deu","chapter":28,"verse":63,"letter":"a"},{"kind":"crossref","label":"Dt 30:9","book":"Deu","chapter":30,"verse":9,"letter":"b"},{"kind":"text","text":" with gladness."},{"kind":"text","text":" He will be quiet "},{"kind":"footnote","marker":1,"text":"LXX, Syr read He will renew you"},{"kind":"text","text":" in his love."},{"kind":"text","text":" He will delight in you with singing.” "},{"kind":"crossref","label":"Ps 30:5","book":"Psa","chapter":30,"verse":5,"letter":"a"}],"crossRefs":[{"label":"Jos 1:14","book":"Jos","chapter":1,"verse":14},{"label":"Jb 16:14","book":"Job","chapter":16,"verse":14},{"label":"Ps 78:65","book":"Psa","chapter":78,"verse":65},{"label":"Dt 28:63","book":"Deu","chapter":28,"verse":63},{"label":"Dt 30:9","book":"Deu","chapter":30,"verse":9},{"label":"Ps 30:5","book":"Psa","chapter":30,"verse":5}],"footnotes":[{"marker":1,"text":"LXX, Syr read He will renew you"}]},{"verseId":"a556c5305ee15c3f-01:Zep:3:18","parts":[{"kind":"text","text":"I will gather those who have been driven "},{"kind":"crossref","label":"Lm 1:4","book":"Lam","chapter":1,"verse":4,"letter":"a"},{"kind":"crossref","label":"Lm 3:33","book":"Lam","chapter":3,"verse":33,"letter":"b"},{"kind":"text","text":" from the appointed festivals;"},{"kind":"text","text":" they will be a tribute from you "},{"kind":"footnote","marker":1,"text":"= Jerusalem"},{"kind":"text","text":" and a reproach on her. "},{"kind":"footnote",