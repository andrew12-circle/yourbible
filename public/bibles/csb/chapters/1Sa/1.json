:13","book":"Act","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:15","parts":[{"kind":"text","text":"“No, my lord,” Hannah replied. “I am a woman with a broken heart. I haven’t had any wine or beer; I’ve been pouring out my heart before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "},{"kind":"crossref","label":"Ps 62:8","book":"Psa","chapter":62,"verse":8,"letter":"a"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Ps 62:8","book":"Psa","chapter":62,"verse":8}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:16","parts":[{"kind":"text","text":"Don’t think of me as a wicked woman; "},{"kind":"crossref","label":"1Sm 2:12","book":"1Sa","chapter":2,"verse":12,"letter":"a"},{"kind":"text","text":" I’ve been praying from the depth of my anguish and resentment.” "},{"kind":"crossref","label":"Lk 6:45","book":"Luk","chapter":6,"verse":45,"letter":"b"}],"crossRefs":[{"label":"1Sm 2:12","book":"1Sa","chapter":2,"verse":12},{"label":"Lk 6:45","book":"Luk","chapter":6,"verse":45}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:17","parts":[{"kind":"text","text":"Eli responded, “Go in peace, "},{"kind":"crossref","label":"1Sm 25:35","book":"1Sa","chapter":25,"verse":35,"letter":"a"},{"kind":"crossref","label":"2Kg 5:19","book":"2Ki","chapter":5,"verse":19,"letter":"b"},{"kind":"crossref","label":"Mk 5:34","book":"Mrk","chapter":5,"verse":34,"letter":"c"},{"kind":"text","text":" and may the God of Israel grant the request you’ve made of him.” "},{"kind":"crossref","label":"Ru 2:13","book":"Rut","chapter":2,"verse":13,"letter":"d"}],"crossRefs":[{"label":"1Sm 25:35","book":"1Sa","chapter":25,"verse":35},{"label":"2Kg 5:19","book":"2Ki","chapter":5,"verse":19},{"label":"Mk 5:34","book":"Mrk","chapter":5,"verse":34},{"label":"Ru 2:13","book":"Rut","chapter":2,"verse":13}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:18","parts":[{"kind":"text","text":"“May your servant find favor with you,” "},{"kind":"crossref","label":"Ru 2:13","book":"Rut","chapter":2,"verse":13,"letter":"a"},{"kind":"text","text":" she replied. Then Hannah went on her way; she ate and no longer looked despondent. "},{"kind":"footnote","marker":1,"text":"Lit and her face was not to her again"},{"kind":"crossref","label":"Rm 15:13","book":"Rom","chapter":15,"verse":13,"letter":"b"}],"crossRefs":[{"label":"Ru 2:13","book":"Rut","chapter":2,"verse":13},{"label":"Rm 15:13","book":"Rom","chapter":15,"verse":13}],"footnotes":[{"marker":1,"text":"Lit and her face was not to her again"}]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:19","parts":[{"kind":"text","text":"The next morning Elkanah and Hannah got up early to worship before the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". Afterward, they returned home to Ramah. "},{"kind":"crossref","label":"1Sm 1:1","book":"1Sa","chapter":1,"verse":1,"letter":"a"},{"kind":"crossref","label":"1Sm 2:11","book":"1Sa","chapter":2,"verse":11,"letter":"b"},{"kind":"text","text":" Then Elkanah was intimate with his wife Hannah, and the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" remembered her. "},{"kind":"crossref","label":"Gn 8:1","book":"Gen","chapter":8,"verse":1,"letter":"c"},{"kind":"crossref","label":"Gn 30:22","book":"Gen","chapter":30,"verse":22,"letter":"d"},{"kind":"crossref","label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11,"letter":"e"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Sm 1:1","book":"1Sa","chapter":1,"verse":1},{"label":"1Sm 2:11","book":"1Sa","chapter":2,"verse":11},{"label":"Gn 8:1","book":"Gen","chapter":8,"verse":1},{"label":"Gn 30:22","book":"Gen","chapter":30,"verse":22},{"label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:20","parts":[{"kind":"text","text":"After some time, "},{"kind":"footnote","marker":1,"text":"Lit In the turning of the days"},{"kind":"text","text":" Hannah conceived and gave birth to a son. She named him Samuel, "},{"kind":"footnote","marker":2,"text":"In Hb, the name Samuel sounds like the phrase “requested from God.”"},{"kind":"text","text":" because she said, “I requested him from the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":".”"}],"crossRefs":[],"footnotes":[{"marker":1,"text":"Lit In the turning of the days"},{"marker":2,"text":"In Hb, the name Samuel sounds like the phrase “requested from God.”"}]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:21","parts":[{"kind":"text","text":"When Elkanah and all his household went up to make the annual sacrifice "},{"kind":"crossref","label":"Dt 12:11","book":"Deu","chapter":12,"verse":11,"letter":"a"},{"kind":"crossref","label":"1Sm 1:3","book":"1Sa","chapter":1,"verse":3,"letter":"b"},{"kind":"text","text":" and his vow offering to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":", "}],"crossRefs":[{"label":"Dt 12:11","book":"Deu","chapter":12,"verse":11},{"label":"1Sm 1:3","book":"1Sa","chapter":1,"verse":3}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:22","parts":[{"kind":"text","text":"Hannah did not go and explained to her husband, “After the child is weaned, I’ll take him to appear in the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s presence "},{"kind":"crossref","label":"Lk 2:22","book":"Luk","chapter":2,"verse":22,"letter":"a"},{"kind":"text","text":" and to stay there permanently.” "},{"kind":"crossref","label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11,"letter":"b"},{"kind":"crossref","label":"1Sm 1:28","book":"1Sa","chapter":1,"verse":28,"letter":"c"}],"crossRefs":[{"label":"Lk 2:22","book":"Luk","chapter":2,"verse":22},{"label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11},{"label":"1Sm 1:28","book":"1Sa","chapter":1,"verse":28}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:23","parts":[{"kind":"text","text":"Her husband, Elkanah, replied, “Do what you think is best, "},{"kind":"crossref","label":"Nm 30:10","book":"Num","chapter":30,"verse":10,"letter":"a"},{"kind":"text","text":" and stay here until you’ve weaned him. May the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" confirm your "},{"kind":"footnote","marker":1,"text":"DSS, LXX, Syr; MT reads his"},{"kind":"text","text":" word.” "},{"kind":"crossref","label":"Nm 30:13","book":"Num","chapter":30,"verse":13,"letter":"b"},{"kind":"text","text":" So Hannah stayed there and nursed her son until she weaned him. "}],"crossRefs":[{"label":"Nm 30:10","book":"Num","chapter":30,"verse":10},{"label":"Nm 30:13","book":"Num","chapter":30,"verse":13}],"footnotes":[{"marker":1,"text":"DSS, LXX, Syr; MT reads his"}]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:24","parts":[{"kind":"text","text":"When she had weaned him, she took him with her to Shiloh, as well as a three-year-old bull, "},{"kind":"footnote","marker":2,"text":"DSS, LXX, Syr; MT reads Shiloh with three bulls"},{"kind":"text","text":" half a bushel "},{"kind":"footnote","marker":3,"text":"Lit bull and an ephah"},{"kind":"text","text":" of flour, and a clay jar of wine. "},{"kind":"crossref","label":"Nm 15:9","book":"Num","chapter":15,"verse":9,"letter":"a"},{"kind":"text","text":" Though the boy was still young, "},{"kind":"footnote","marker":4,"text":"Lit And the youth was a youth"},{"kind":"text","text":" she took him to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":"’s house at Shiloh. "},{"kind":"crossref","label":"Jos 18:1","book":"Jos","chapter":18,"verse":1,"letter":"b"},{"kind":"crossref","label":"1Sm 4:3","book":"1Sa","chapter":4,"verse":3,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"Nm 15:9","book":"Num","chapter":15,"verse":9},{"label":"Jos 18:1","book":"Jos","chapter":18,"verse":1},{"label":"1Sm 4:3","book":"1Sa","chapter":4,"verse":3}],"footnotes":[{"marker":2,"text":"DSS, LXX, Syr; MT reads Shiloh with three bulls"},{"marker":3,"text":"Lit bull and an ephah"},{"marker":4,"text":"Lit And the youth was a youth"}]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:25","parts":[{"kind":"text","text":"Then they slaughtered the bull and brought the boy to Eli."}],"crossRefs":[],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:26","parts":[{"kind":"text","text":"“Please, my lord,” she said, “as surely as you live, "},{"kind":"crossref","label":"2Kg 2:2","book":"2Ki","chapter":2,"verse":2,"letter":"a"},{"kind":"crossref","label":"2Kg 2:4","book":"2Ki","chapter":2,"verse":4,"letter":"b"},{"kind":"crossref","label":"2Kg 2:6","book":"2Ki","chapter":2,"verse":6,"letter":"c"},{"kind":"text","text":" my lord, I am the woman who stood here beside you praying to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". "}],"crossRefs":[{"label":"2Kg 2:2","book":"2Ki","chapter":2,"verse":2},{"label":"2Kg 2:4","book":"2Ki","chapter":2,"verse":4},{"label":"2Kg 2:6","book":"2Ki","chapter":2,"verse":6}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:27","parts":[{"kind":"text","text":"I prayed for this boy, "},{"kind":"crossref","label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11,"letter":"a"},{"kind":"text","text":" and since the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" gave me what I asked him for, "},{"kind":"crossref","label":"1Sm 1:17","book":"1Sa","chapter":1,"verse":17,"letter":"b"},{"kind":"crossref","label":"1Sm 1:20","book":"1Sa","chapter":1,"verse":20,"letter":"c"},{"kind":"text","text":" "}],"crossRefs":[{"label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11},{"label":"1Sm 1:17","book":"1Sa","chapter":1,"verse":17},{"label":"1Sm 1:20","book":"1Sa","chapter":1,"verse":20}],"footnotes":[]},{"verseId":"a556c5305ee15c3f-01:1Sa:1:28","parts":[{"kind":"text","text":"I now give the boy to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":". For as long as he lives, he is given to the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":".” "},{"kind":"crossref","label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11,"letter":"a"},{"kind":"text","text":" Then he "},{"kind":"footnote","marker":1,"text":"DSS read she; some Hb mss, Syr, Vg read they"},{"kind":"text","text":" worshiped the "},{"kind":"text","text":"Lord","style":"divine"},{"kind":"text","text":" there. "},{"kind":"footnote","marker":2,"text":"LXX reads Then she left him there before the Lord"}],"crossRefs":[{"label":"1Sm 1:11","book":"1Sa","chapter":1,"verse":11}],"footnotes":[{"marker":1,"text":"DSS read she; some Hb mss, Syr, Vg read they"},{"marker":2,"text":"LXX reads Then she left him there before the Lord"}]}]},"cachedAt":1783099285033}