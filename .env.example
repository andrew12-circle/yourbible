VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Optional (Supabase Edge secrets for `claim-research-pack`): override default English Bible from `bible-passage` list.
# CLAIM_RESEARCH_DEFAULT_BIBLE_ID=

# Optional web search for claim research when the client sends claim_research.use_web=true.
# WEB_SEARCH_PROVIDER=   # leave unset to skip; set to "brave" or "serpapi" when keys are configured
# BRAVE_SEARCH_API_KEY= # or BRAVE_API_KEY=
# SERPAPI_API_KEY=

# Optional: set as Supabase Edge Function secret (not Vite). When set, chapter discovery uses YouTube Data API v3 `videos.list` snippet.description before HTML fallback.
# YOUTUBE_DATA_API_KEY=

# Optional: client calls this OpenAI-compatible endpoint for AI writing assist polish instead of Supabase `ai-text-polish`.
# VITE_AI_POLISH_URL=https://api.openai.com/v1/chat/completions
# VITE_AI_POLISH_KEY=
# VITE_AI_POLISH_MODEL=gpt-4o-mini

# Optional: Supabase Edge secret overrides for `framework-analyze` (claim volume / timed chunk pass).
# FRAMEWORK_ANALYZE_MAX_CLAIMS=120
# FRAMEWORK_ANALYZE_CHUNK_SPACING_SEC=540
# FRAMEWORK_ANALYZE_MIN_DURATION_CHUNK_PASS_SEC=1500
