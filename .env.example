# Edge secrets should also be set via `npx supabase secrets set` for deployed functions; .env is for local reference/CLI script use.

# --- Vite / Supabase client ---
# Project ref (Dashboard URL): https://supabase.com/dashboard/project/<VITE_SUPABASE_PROJECT_ID>
VITE_SUPABASE_PROJECT_ID=
# Must match the project ref above:
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Client key — use ONE of these (Dashboard → Settings → API Keys):
#   • Publishable key (recommended): sb_publishable_…  (copy the full string; watch 0 vs O, l vs 1)
#   • Legacy anon JWT: eyJ…  (tab "Legacy anon, service_role API keys") — same env var, or use VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional alias if you prefer the legacy name:
# VITE_SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=

# --- Edge function secrets (required) ---
# Gemini: framework chat, analysis, journal polish, My AI / journal chat (default provider), embed-row, etc.
GEMINI_API_KEY=
# OpenAI: optional for my-ai-chat when AI_PROVIDER=openai (falls back to Gemini on 401 / missing key)
OPENAI_API_KEY=
# Chat model for my-ai-chat when using OpenAI (default gpt-5.5). Examples: gpt-5.5, gpt-4.1, gpt-4o
OPENAI_CHAT_MODEL=gpt-5.5
# AI_PROVIDER: gemini | openai — defaults to gemini when unset; my-ai-chat falls back to Gemini on OpenAI auth errors
AI_PROVIDER=gemini
# API.Bible: bible-passage edge function
API_BIBLE_KEY=
# ElevenLabs: sleep-tts (Rest in the Word), journal-voice-to-text, framework-transcribe-audio
# Local .env is NOT used by deployed edge functions — set the secret in Supabase:
#   npx supabase secrets set ELEVENLABS_API_KEY=sk_... --project-ref YOUR_REF
#   npx supabase functions deploy sleep-tts --project-ref YOUR_REF
ELEVENLABS_API_KEY=
# Optional sleep narration model (edge secret): eleven_multilingual_v2 | eleven_turbo_v2_5
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# --- Edge function secrets (optional) ---
# YouTube Data API v3: framework-fetch-transcript, framework-sync-youtube-chapters
YOUTUBE_DATA_API_KEY=
# Web search for claim-research-pack multi-source validation (Brave or SerpAPI)
BRAVE_SEARCH_API_KEY=
BRAVE_API_KEY=
SERPAPI_API_KEY=
# "brave" or "serpapi"; leave empty to skip live web search (validation still runs on training data)
WEB_SEARCH_PROVIDER=
# claim-research-pack also requires GEMINI_API_KEY (validation + standard packs)
# Default English Bible id for claim-research-pack when not specified by client
CLAIM_RESEARCH_DEFAULT_BIBLE_ID=
# framework-analyze tuning (defaults: 120, 540, 1500)
FRAMEWORK_ANALYZE_MAX_CLAIMS=
FRAMEWORK_ANALYZE_CHUNK_SPACING_SEC=
FRAMEWORK_ANALYZE_MIN_DURATION_CHUNK_PASS_SEC=
